upported by the following objects: application, document."></direct-parameter></command><command name="remove event listener" code="K2  eREL" description="Removes the event listener."><direct-parameter type="specifier" description="Supported by the following objects: place gun, idle task, script arg, application, background task, document, window, layout window, story window, content placer object."></direct-parameter><parameter name="event type" code="pEvT" type="text" description="The registered event type."></parameter><parameter name="handler" code="pHnd" type="any" description="The registered event handler. Can accept: alias or string or JavaScript Function."></parameter><parameter name="captures" code="pCps" type="boolean" optional="yes" description="This parameter is obsolete. Can accept: boolean (Default: FALSE)."></parameter><result type="boolean" description="Returns true if the handler was previously registered for this event."></result></command><command name="reset all buttons" code="K2  rstB" description="Resets all the buttons to their Normal state."><direct-parameter type="document"></direct-parameter></command><command name="reset all multi state objects" code="K2  rstM" description="Resets all the multi-state objects to their first state."><direct-parameter type="document"></direct-parameter></command><command name="restore" code="K2  rstr" description="Restores all script arguments."><direct-parameter type="specifier" description="Supported by the following objects: script arg, window, layout window, story window."></direct-parameter></command><command name="revert" code="K2  bREV" description="Reverts the document to its state at the last save operation. "><direct-parameter type="document"></direct-parameter><result type="boolean" description="If true, the revert succeeded."></result></command><command name="revert to project" code="K2  rprj" description="Reverts to the version of the document in Version Cue."><direct-parameter type="document"></