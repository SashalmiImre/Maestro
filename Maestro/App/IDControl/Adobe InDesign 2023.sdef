n" description="Emit CSS"></property><property name="enable anchored object options" code="obao" type="boolean" description="If true, the object style will apply an anchored object setting."></property><property name="enable export tagging" code="obet" type="boolean" description="If true, the object style will apply an epub tag and class."></property><property name="enable fill" code="obfc" type="boolean" description="If true, the object style will apply a fill."></property><property name="enable frame fitting options" code="obff" type="boolean" description="If true, the object style will apply frame fitting options."></property><property name="enable object export alt text options" code="osea" type="boolean" description="If true, the object style will apply alt text export options."></property><property name="enable object export epub options" code="osee" type="boolean" description="If true, the object style will apply epub export options."></property><property name="enable object export tagged pdf options" code="osep" type="boolean" description="If true, the object style will apply tagged pdf export options."></property><property name="enable paragraph style" code="obpc" type="boolean" description="If true, the object style will apply a paragraph style."></property><property name="enable story options" code="oboc" type="boolean" description="If true, the object style will apply story options."></property><property name="enable stroke" code="obsc" type="boolean" description="If true, the object style will apply a stroke."></property><property name="enable stroke and corner options" code="obCc" type="boolean" description="If true, the object style will apply stroke options and corner options."></property><property name="enable text frame auto sizing options" code="obas" type="boolean" description="If true, the object style will apply auto-sizing text frame options."></property><property name="enable text frame baseline options" code="obbc" type="boolean" description