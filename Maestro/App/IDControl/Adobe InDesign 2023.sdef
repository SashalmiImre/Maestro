n of the button."></property><property name="end cap" code="endc" type="ecap" description="The end shape of an open path."></property><property name="end join" code="endj" type="ejon" description="The corner join applied to the button."></property><property name="fill color" code="flcl" type="swatch" description="The swatch (color, gradient, tint, or mixed ink) applied to the fill of the button. . Can also accept: string."></property><property name="fill tint" code="filt" type="real" description="The percent of tint to use in the button's fill color. (To specify a tint percent, use a number in the range of 0 to 100; to use the inherited or overridden value, use -1.)"></property><property name="fill transparency settings" code="xpSF" type="fill transparency setting" access="r" description="Transparency settings for the fill applied to the button."></property><property name="flip" code="RpFp" type="EnFp" description="The direction in which to flip the printed image."></property><property name="gap color" code="gapC" type="swatch" description="The swatch (color, gradient, tint, or mixed ink) applied to the gap of a dashed, dotted, or striped stroke. For information, see stroke type."></property><property name="gap tint" code="gapT" type="real" description="The tint as a percentage of the gap color. (To specify a tint percent, use a number in the range of 0 to 100; to use the inherited or overridden value, use -1.)"></property><property name="geometric bounds" code="gbnd" description="The bounds of the button excluding the stroke width, in the format [y1, x1, y2, x2], which give the coordinates of the top-left and bottom-right corners of the bounding box."><type type="number"></type><type type="text"></type></property><property name="gradient fill angle" code="pgfa" type="real" description="The angle of a linear gradient applied to the fill of the button. (Range: -180 to 180)"></property><property name="gradient fill length" code="pgfl" description="The length (for a linear gradient) or radius (for a radial gradient) applied to the fill of the button."><type type="number"></type><type type="text"></type></property><property name="gradient fill start" code="pgst" description="The starting point (in page coordinates) of a gradient applied to the fill of the button, in the format [x, y]."><type type="number" list="yes"></type><type type="text" list="yes"></type></property><property name="gradient stroke angle" code="pgsa" type="real" description="The angle of a linear gradient applied to the stroke of the button. (Range: -180 to 180)"></property><property name="gradient stroke length" code="pgsl" description="The length (for a linear gradient) or radius (for a radial gradient) applied to the stroke of the button."><type type="number"></type><type type="text"></type></property><property name="gradient stroke start" code="pgss" description="The starting point (in page coordinates) of a gradient applied to the stroke of the button, in the format [x, y]."><type type="number" list="yes"></type><type type="text" list="yes"></type></property><property name="hidden until triggered" code="HiTr" type="boolean" description="If true, the form field/push button is hidden until triggered in the exported PDF."></property><property name="horizontal layout constraints" code="HoCo" description="The left margin, width, and right margin constraints this item is subject to when using the object-based layout rule."><type type="LPdc" list="yes"></type></property><property name="horizontal scale" code="phzs" type="real" description="The horizontal scaling applied to the button."></property><property name="id" code="ID  " type="integer" access="r" description="The unique ID of the button."></property><property name="index" code="pidx" type="integer" access="r" description="The index of the button within its containing object."></property><property name="item layer" code="pilr" type="layer" description="The layer that the button is on."></property><property n