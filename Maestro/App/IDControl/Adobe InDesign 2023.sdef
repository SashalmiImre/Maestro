ype="preflight profile rule" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="preflight profile" access="r" description="The parent of the preflight profile rule (a preflight profile)."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property></class><class name="preflight rule" code="PFNR" description="A preflight rule" plural="preflight rules"><element type="event"></element><element type="event listener"></element><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="description" code="pdes" type="text" access="r" description="The description of the preflight rule."></property><property name="full feature" code="ruFF" type="boolean" description="If true, the preflight rule is fully supported."></property><property name="id" code="ID  " type="text" access="r" description="The rule ID for this rule."></property><property name="index" code="pidx" type="integer" access="r" description="The index of the preflight rule within its containing object."></property><property name="name" code="pnam" type="text" access="r" description="The name of the preflight rule."></property><property name="object reference" code="posp" type="preflight rule" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the preflight rule (a application)."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property></class><class name="preflight rule instance" code="PFRI" description="A preflight rule instance." inherits="preflight profile rule" plural="preflight rule instances"><element type="event"></element><element type="event listener"></element><ele