object reference" code="posp" type="index section" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="index" access="r" description="The parent of the index section (a index)."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property></class><class name="page reference" code="PgRf" description="The page reference for an index topic." plural="page references"><element type="event"></element><element type="event listener"></element><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="id" code="ID  " type="integer" access="r" description="The unique ID of the page reference."></property><property name="index" code="pidx" type="integer" access="r" description="The index of the page reference within its containing object."></property><property name="label" code="ptag" type="text" description="A property that can be set to any string."></property><property name="name" code="pnam" type="text" description="The name of the page reference; this is an alias to the page reference's label property."></property><property name="object reference" code="posp" type="page reference" access="r" description="An object reference for the object."></property><property name="page number style override" code="StOv" type="character style" description="The character style applied to page numbers. "></property><property name="page reference limit" code="PrLm" type="any" description="The paragraph style or number of paragraphs or pages that defines the last page in a page range. Note: Valid only when page reference type specifies the next use of a paragraph style or a number of paragraphs or pages. . Can return: paragraph style or integer."></property><property name="page reference type" code="PrTp" type="PgTp" description="Options for index page references."></property><property name="parent" code="pare" type="topic" access="r" description="The parent of the page reference (a topic)."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="source text" code="hsTx" type="text.ctxt" access="r" description="The hyperlinked text or insertion point."></property></class><class name="topic" code="cTpc" description="An index topic." plural="topics"><element type="cross reference"></element><element type="event"></element><element type="event listener"></element><element type="page reference"></element><element type="topic"></element><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="index" code="pidx" type="integer" access="r" description="The index of the topic within its containing object."></property><property name="name" code="pnam" type="text" description="The name of the topic."></property><property name="object reference" code="posp" type="topic" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the topic (a index section, topic or index). Can return: index section, topic or index."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="sort order" code="SOdr" type="text" description="The string by which the topic is sorted instead of the topic name is not used. Note: The actual topic text, rather than the sort order text, appears in the index."></property></class><enumeration name="PgTp" code="PgTp"><enumerator name="current page" code="crpg" description="The page on which the index entry is located."></enumerator><enumerator name="to next style change" code="tnsc" description="The range of pages from the page containing the index entry to the page containing the next paragraph style change."></enumerator><enumerator name="to next use of style" code="tnus" description="The range of pages from the page containing the index entry to the page that contains the next occurrance of the specified paragraph style. If no paragraph style is specified, the paragraph style of the index entry paragraph is used."></enumerator><enumerator name="to end of story" code="eost" description="The last page in the story containing the index entry."></enumerator><enumerator name="to end of document" code="eodc" description="The last page in the document."></enumerator><enumerator name="to end of section" code="eosc" description="The last page in the numbered section containing the index entry."></enumerator><enumerator name="for next n paragraphs" code="fnpr" description="The range of pages from the page containing the index entry to the page containing the nth full paragraph from the paragraph containing the index entry (where n is the number of paragraphs to include)."></enumerator><enumerator name="for next n pages" code="fnpg" description="The range of pages from the page containing the inedex entry to the nth page after that page (where n is the number of pages to include)."></enumerator><enumerator name="suppress page numbers" code="nprg" description="Turns off page numbers for the index topic."></enumerator></enumeration><enumeration name="IdFt" code="IdFt"><enumerator name="runin format" code="RiIf" description="Places nested topics on the same line as their parent topic, separated by the specified separator."></enumerator><enumerator name="nested format" code="NtIf" description="Places nested topics on the line below and indented from the parent topic."></enumerator></enumeration><enumeration name="CrfT" code="CrfT"><enumerator name="see or also bracket" code="SoAl" description="Inserts 'See also' in front of the referenced topic if the topic has an associated page reference; inserts 'See' if the topic does not have a page reference."></enumerator><enumerator name="see" code="enSe" description="Inserts 'See' in front of the referenced topic."></enumerator><enumerator name="see also" code="SeAl" description="Inserts 'See also' in front of the referenced topic."></enumerator><enumerator name="see herein" code="SHrn" description="Inserts 'See herein' in front of the referenced topic."></enumerator><enumerator name="see also herein" code="SaHr" description="Inserts 'See also herein' in front of the referenced topic."></enumerator><enumerator name="custom cross reference" code="CstC" description="Inserts the specified string in front of the referenced topic."></enumerator><enumerator name="custom cross reference before" code="Cstb" description="Inserts the specified string and the specified before cross reference separator in front of the referenced topic. If no before cross reference separator is specified, inserts a space."></enumerator><enumerator name="custom cross reference after" code="Csta" description="Inserts the specified following topic separator and the specified string after the referenced topic. If no following topic separator is specified, inserts a space."></enumerator></enumeration><enumeration name="IxCo" code="IxCo"><enumerator name="selected entry" code="STpe" description="Capitalizes the specified topic but does not capitalize its nested topics. Valid only as parameter of the topic capitalize method; cannot be used as a parameter of the index capitalize method. Note: Must occur after the specified topic and its nested topics are created."></enumerator><enumerator name="include subentries" code="iSbE" description="Capitalizes the specified topic and its nested topics. Valid only as parameter of the topic capitalize method; cannot be used as a parameter of the index capitalize method. Note: Must occur after the selected topic and its nested subtopics are created."></enumerator><enumerator name="all level 1 entries" code="ALEt" description="Capitalizes all level 1 entries. Note: Capitalizes only topics created before the capitalization statement appears in the script. "></enumerator><enumerator name="all entries" code="AllE" description="Capitalizes all index entries. Note: Capitalizes only topics created before the capitalization statement appears in the script."></enumerator></enumeration></suite><suite name="interactive elements suite" code="InES" description="Interactive elements."><command name="add event listener" code="InESeAEL" description="Adds an event listener."><direct-parameter type="specifier" description="Supported by the following objects: form field, button, state, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, navigation point, sound, behavior, goto first page behavior, goto last page behavior, goto next page behavior, goto previous page behavior, goto next view behavior, goto previous view behavior, goto URL behavior, movie behavior, show hide fields behavior, animation behavior, open file behavior, goto next state behavior, goto previous state behavior, goto state behavior, view zoom behavior, sound behavior, goto anchor behavior, goto page behavior, clear form behavior, print form behavior, submit form behavior, timing setting, timing list, timing group, timing target."></direct-parameter><parameter name="event type" code="pEvT" type="text" description="The event type."></parameter><parameter name="handler" code="pHnd" type="any" description="The event handler. Can accept: alias or string or JavaScript Function."></parameter><parameter name="captures" code="pCps" type="boolean" optional="yes" description="This parameter is obsolete. Can accept: boolean (Default: FALSE)."></parameter><result type="event listener" description="The new event listener."></result></command><command name="add items as state" code="InESaias" description="Adds items to a specific appearance state of this object."><direct-parameter type="multi state object"></direct-parameter><parameter name="pageitems" code="pGpI" type="page item" description="One or more page items to add as a state."></parameter></command><command name="add items to state" code="InESaits" description="Adds page items to this state."><direct-parameter type="state"></direct-parameter><parameter name="pageitems" code="pGpI" type="page item" description="One or more page items to add to this state."></parameter></command><command name="apply object style" code="InESAOsy" description="Applies the specified object style."><direct-parameter type="specifier" description="Supported by the following objects: form field, button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter><parameter name="using" code="usng" type="object style" description="The object style to apply."></parameter><parameter name="clearing overrides" code="clov" type="boolean" optional="yes" description="If true, clears the object's existing attributes before applying the style. Can accept: boolean (Default: TRUE)."></parameter><parameter name="clearing overrides through root object style" code="cotr" type="boolean" optional="yes" description="If true, clears attributes and formatting applied to the object that are not defined in the object style. Can accept: boolean (Default: FALSE)."></parameter></command><command name="asynchronous export file" code="InESexAs" description="asynchronously exports the object(s) to a file."><direct-parameter type="specifier" description="Supported by the following objects: form field, button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter><parameter name="format" code="exft" type="any" description="The export format, specified as an enumeration value or as an extension that appears in the Save as type or Format menu in the Export dialog. Can accept: tagged text/PDF type/EPS type/RTF/text type/XML/JPG/HTML/EPUB/fixed layout EPUB/HTMLFXL/InDesign snippet/InDesign markup/InCopy markup/PNG format/interactive PDF or string."></parameter><parameter name="to" code="kfil" description="The path to the export file."><type type="file"></type><type type="text"></type></parameter><parameter name="showing options" code="imot" type="boolean" optional="yes" description="If true, displays the export options dialog. Can accept: boolean (Default: FALSE)."></parameter><parameter name="using" code="usng" type="PDF export preset" optional="yes" description="The export style."></parameter><parameter name="version comments" code="vcmt" type="text" optional="yes" description="The comment for this version."></parameter><parameter name="force save" code="vclb" type="boolean" optional="yes" description="If true, forcibly saves a version. Can accept: boolean (Default: FALSE)."></parameter><result type="background task" description="object representing the asynchronous export"></result></command><command name="auto tag" code="InESXste" description="Tag the object or the parent story using default tags defined in XML preference."><direct-parameter type="specifier" description="Supported by the following objects: form field, button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter></command><command name="bring forward" code="InESbrfr" description="Brings the object forward one level in its layer."><direct-parameter type="specifier" description="Supported by the following objects: button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter></command><command name="bring to front" code="InESbtfr" description="Brings the object to the front of its layer or in front of a particular item."><direct-parameter type="specifier" description="Supported by the following objects: button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter></command><command name="change object" code="InESFCOt" description="Finds objects that match the find what value and replace the objects with the change to value."><direct-parameter type="specifier" description="Supported by the following objects: form field, button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter><parameter name="reverse order" code="Rrvr" type="boolean" optional="yes" description="If true, returns the results in reverse order."></parameter><result type="page item" description="The replaced object(s)."></result></command><command name="clear object style overrides" code="InESosco" description="Clear overrides for object style"><direct-parameter type="specifier" description="Supported by the following objects: form field, button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter></command><command name="clear transformations" code="InEScxfm" description="Clears transformations from the object. Transformations include rotation, scaling, flipping, fitting, and shearing."><direct-parameter type="specifier" description="Supported by the following objects: form field, button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter></command><command name="content place" code="InEScopl" description="Duplicate an object and place it into the target page item."><direct-parameter type="specifier" description="Supported by the following objects: form field, button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter><parameter name="page items" code="pits" type="page item" description="One or more page items to place or load"></parameter><parameter name="link page items" code="pLOO" type="boolean" optional="yes" description="Whether to link pageItems in content placer (if true it will override link stories value). Can accept: boolean (Default: FALSE)."></parameter><parameter name="link stories" code="pLSO" type="boolean" optional="yes" description="Whether to link stories in content placer (only applicable for single story, pageItem links will also be created in case of more than one item). Can accept: boolean (Default: FALSE)."></parameter><parameter name="map styles" code="pMSO" type="boolean" optional="yes" description="Whether to map styles in content placer. Can accept: boolean (Default: FALSE)."></parameter><parameter name="showing options" code="imot" type="boolean" optional="yes" description="Whether to display the link options dialog. Can accept: boolean (Default: FALSE)."></parameter><result type="specifier" description="The placed content. Can return: list of page items, graphics, stories or texts."></result></command><command name="convert shape" code="InESCOSH" description="Converts the object to a different shape."><direct-parameter type="specifier" description="Supported by the following objects: form field, button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter><parameter name="given" code="givn" type="CSOP" description="The object's new shape."></parameter><parameter name="number of sides" code="nsid" type="integer" optional="yes" description="The number of sides for the resulting polygon. (Range: 3 to 100). Can accept: integer (3 - 100)."></parameter><parameter name="inset percentage" code="istp" type="integer" optional="yes" description="The star inset percentage for the resulting polygon. (Range: 0.0 to 100.0) . Can accept: integer (0 - 100)."></parameter><parameter name="corner radius" code="pcrd" optional="yes" description="The corner radius of the resulting rectangle. Can accept: number or string (0 - 800 points)."><type type="number"></type><type type="text"></type></parameter></command><command name="convert to object" code="InESbToO" description="Converts the button object to the page item currently in the active state. Page items from other states will be lost."><direct-parameter type="specifier" description="Supported by the following objects: button, check box, combo box, list box, radio button, text box, signature field."></direct-parameter></command><command name="Create Email QR Code" code="InESQrem" description="Create Email QR Code on the page item or document"><direct-parameter type="specifier" description="Supported by the following objects: form field, button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter><parameter name="email address" code="QETo" type="text" optional="yes" description="QR code Email Address"></parameter><parameter name="subject" code="QRSu" type="text" optional="yes" description="QR code Email Subject"></parameter><parameter name="body" code="GNbo" type="text" optional="yes" description="QR code Email Body Message"></parameter><parameter name="qr code swatch" code="QRsw" type="any" optional="yes" description="Swatch to be applied on generated QR Code Graphic . Can accept: swatch or string."></parameter><parameter name="with properties" code="prdt" type="text" optional="yes" description="Initial values for properties of the new object. Above parameters can also be passed as properties"></parameter></command><command name="Create Hyperlink QR Code" code="InESQurl" description="Create Hyperlink QR Code on the page item or document"><direct-parameter type="specifier" description="Supported by the following objects: form field, button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter><parameter name="url link" code="QrUr" type="text" optional="yes" description="QR code Hyperlink URL "></parameter><parameter name="qr code swatch" code="QRsw" type="any" optional="yes" description="Swatch to be applied on generated QR Code Graphic . Can accept: swatch or string."></parameter><parameter name="with properties" code="prdt" type="text" optional="yes" description="Initial values for properties of the new object. Above parameters can also be passed as properties"></parameter></command><command name="Create Plain Text QR Code" code="InESQrPt" description="Create Plain Text QR Code on the page item"><direct-parameter type="specifier" description="Supported by the following objects: form field, button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter><parameter name="plain text" code="TYPt" type="text" optional="yes" description="QR code Plain Text "></parameter><parameter name="qr code swatch" code="QRsw" type="any" optional="yes" description="Swatch to be applied on generated QR Code Graphic . Can accept: swatch or string."></parameter><parameter name="with properties" code="prdt" type="text" optional="yes" description="Initial values for properties of the new object. Above parameters can also be passed as properties"></parameter></command><command name="Create Text Msg QR Code" code="InESQrSm" description="Create Text Msg QR Code on the page item or document"><direct-parameter type="specifier" description="Supported by the following objects: form field, button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter><parameter name="cell number" code="QPhN" type="text" optional="yes" description="QR code Text Phone Number"></parameter><parameter name="text message" code="QRtM" type="text" optional="yes" description="QR code Text Message"></parameter><parameter name="qr code swatch" code="QRsw" type="any" optional="yes" description="Swatch to be applied on generated QR Code Graphic . Can accept: swatch or string."></parameter><parameter name="with properties" code="prdt" type="text" optional="yes" description="Initial values for properties of the new object. Above parameters can also be passed as properties"></parameter></command><command name="Create vCard QR Code" code="InESQrVc" description="Create Business Card QR Code on the page item or load on document's placegun"><direct-parameter type="specifier" description="Supported by the following objects: form field, button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter><parameter name="first name" code="QRFN" type="text" optional="yes" description="QR code Business Card First Name"></parameter><parameter name="last name" code="QRLN" type="text" optional="yes" description="QR code Business Card Last Name"></parameter><parameter name="job title" code="QRTl" type="text" optional="yes" description="QR code Business Card Title"></parameter><parameter name="cell phone" code="QRCP" type="text" optional="yes" description="QR code Business Card Cell Phone Number"></parameter><parameter name="phone" code="QRPh" type="text" optional="yes" description="QR code Business Card Phone Number"></parameter><parameter name="email" code="QREm" type="text" optional="yes" description="QR code Business Card Email Address"></parameter><parameter name="organisation" code="QROg" type="text" optional="yes" description="QR code Business Card Organisation"></parameter><parameter name="street Address" code="QRAd" type="text" optional="yes" description="QR code Business Card Street Address"></parameter><parameter name="city" code="QRCi" type="text" optional="yes" description="QR code Business Card City"></parameter><parameter name="adr state" code="QRSt" type="text" optional="yes" description="QR code Business Card State"></parameter><parameter name="country" code="QRCn" type="text" optional="yes" description="QR code Business Card Country"></parameter><parameter name="postal code" code="QRPC" type="text" optional="yes" description="QR code Business Card Postal Code"></parameter><parameter name="website" code="QRUr" type="text" optional="yes" description="QR code Business Card URL"></parameter><parameter name="qr code swatch" code="QRsw" type="any" optional="yes" description="Swatch to be applied on generated QR Code Graphic . Can accept: swatch or string."></parameter><parameter name="with properties" code="prdt" type="text" optional="yes" description="Initial values for properties of the new object. Above parameters can also be passed as properties"></parameter></command><command name="detach" code="InESdtch" description="Detaches an overridden master page item from the master page."><direct-parameter type="specifier" description="Supported by the following objects: form field, button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter></command><command name="export" code="InESexpt" description="Exports the object(s) to a file."><direct-parameter type="specifier" description="Supported by the following objects: form field, button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter><parameter name="format" code="exft" type="any" description="The export format, specified as an enumeration value or as an extension that appears in the Save as type or Format menu in the Export dialog. Can accept: tagged text/PDF type/EPS type/RTF/text type/XML/JPG/HTML/EPUB/fixed layout EPUB/HTMLFXL/InDesign snippet/InDesign markup/InCopy markup/PNG format/interactive PDF or string."></parameter><parameter name="to" code="kfil" description="The path to the export file."><type type="file"></type><type type="text"></type></parameter><parameter name="showing options" code="imot" type="boolean" optional="yes" description="If true, displays the export options dialog. Can accept: boolean (Default: FALSE)."></parameter><parameter name="using" code="usng" type="PDF export preset" optional="yes" description="The export style."></parameter><parameter name="version comments" code="vcmt" type="text" optional="yes" description="The comment for this version."></parameter><parameter name="force save" code="vclb" type="boolean" optional="yes" description="If true, forcibly saves a version. Can accept: boolean (Default: FALSE)."></parameter></command><command name="extract labels" code="InESexLs" description="Gets the label value associated with the specified key. If key string is null, then a list of key-value pairs associated with the item is returned."><direct-parameter type="specifier" description="Supported by the following objects: form field, button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter><parameter name="key" code="with" type="text" optional="yes" description="The key."></parameter><result type="any" description="The label. Can return: string or list of lists of 2 strings."></result></command><command name="find object" code="InESFOjt" description="Finds objects that match the find what value."><direct-parameter type="specifier" description="Supported by the following objects: form field, button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter><parameter name="reverse order" code="Rrvr" type="boolean" optional="yes" description="If true, returns the results in reverse order."></parameter><result type="page item" description="The found object(s)."></result></command><command name="fit" code="InESfitc" description="Applies the specified fit option to content in a frame."><direct-parameter type="specifier" description="Supported by the following objects: form field, button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter><parameter name="given" code="givn" type="fito" description="The fit option to use."></parameter></command><command name="flip item" code="InESflip" description="Flips the object."><direct-parameter type="specifier" description="Supported by the following objects: form field, button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter><parameter name="given" code="givn" type="EnFp" description="The axis around which to flip the object."></parameter><parameter name="around" code="arnd" type="any" optional="yes" description="The point around which to flip the object. Can accept: list of 2 numbers or strings or top left anchor/top center anchor/top right anchor/left center anchor/center anchor/right center anchor/bottom left anchor/bottom center anchor/bottom right anchor."></parameter></command><command name="markup" code="InESXmku" description="Associates the page item with the specified XML element while preserving existing content."><direct-parameter type="specifier" description="Supported by the following objects: form field, button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter><parameter name="using" code="usng" type="XML element" description="The XML element."></parameter></command><command name="override" code="InESovrr" description="Overrides a master page item and places the item on the document page as a new object."><direct-parameter type="specifier" description="Supported by the following objects: form field, button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter><parameter name="destination page" code="dPge" type="page" description="The document page that contains the master page item to override."></parameter><result type="specifier" description="The new object. Can return: page item, guide, graphic, movie or sound."></result></command><command name="place" code="InESplac" description="Places the file."><direct-parameter description="The file to place. Supported by the following objects: movie, sound."><type type="file"></type><type type="text"></type></direct-parameter><parameter name="on" code="insh" type="specifier" optional="yes" description="Where to place the file. Can accept: spread, page, master spread, page item or graphic."></parameter><parameter name="place point" code="insw" optional="yes" description="The point at which to place (only applicable if you are telling a page or spread to place)"><type type="number"></type><type type="text"></type></parameter><parameter name="destination layer" code="pdlr" type="layer" optional="yes" description="The layer on which to place (only applicable if you are telling a page or spread to place)"></parameter><parameter name="showing options" code="imot" type="boolean" optional="yes" description="Whether to display the import options dialog. Can accept: boolean (Default: FALSE)."></parameter><parameter name="autoflowing" code="aflw" type="boolean" optional="yes" description="Whether to autoflow placed text. Can accept: boolean (Default: FALSE)."></parameter><parameter name="with properties" code="prdt" type="record" optional="yes" description="Initial values for properties of the placed object(s)"></parameter><result type="specifier" description="The placed file. Can return: list of page items, graphics, movies, sounds, stories or texts."></result></command><command name="place XML" code="InESXplc" description="Places XML content into the specified object. Note: Replaces any existing content."><direct-parameter type="specifier" description="Supported by the following objects: form field, button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter><parameter name="using" code="usng" type="XML element" description="The XML element whose content you want to place."></parameter><parameter name="place point" code="insw" optional="yes" description="The point at which to place the object, specified in the format [x, y].  Only applicable for page and spread."><type type="number"></type><type type="text"></type></parameter><parameter name="autoflowing" code="aflw" type="boolean" optional="yes" description="If true, autoflows placed text.  Only applicable for page and spread. Can accept: boolean (Default: FALSE)."></parameter></command><command name="redefine scaling" code="InESpshs" description="Apply an item's scaling to its content if possible."><direct-parameter type="specifier" description="Supported by the following objects: form field, button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter><parameter name="to" code="to  " type="real" optional="yes" description="The scale factors to be left on the item.  The default is {1.0, 1.0}."></parameter></command><command name="reframe" code="InEStlbr" description="Move the bounding box of the page item"><direct-parameter type="specifier" description="Supported by the following objects: form field, button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter><parameter name="in" code="in  " type="any" description="The bounding box to resize. Can accept: pasteboard coordinates/parent coordinates/inner coordinates/page coordinates/spread coordinates or Ordered list containing coordinate space:pasteboard coordinates/parent coordinates/inner coordinates/page coordinates/spread coordinates, bounds kind:outer stroke bounds/geometric path bounds."></parameter><parameter name="opposing corners" code="BoxC" type="real" description="Opposing corners of new bounding box in the given coordinate space"></parameter></command><command name="release as object" code="InESSrls" description="Releases this state's appearance as a page item, removing the state from its parent object."><direct-parameter type="state"></direct-parameter></command><command name="release as objects" code="InESSrss" description="Releases all the states associated with this object and then destroys the parent object."><direct-parameter type="multi state object"></direct-parameter></command><command name="remove event listener" code="InESeREL" description="Removes the event listener."><direct-parameter type="specifier" description="Supported by the following objects: form field, button, state, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, navigation point, sound, behavior, goto first page behavior, goto last page behavior, goto next page behavior, goto previous page behavior, goto next view behavior, goto previous view behavior, goto URL behavior, movie behavior, show hide fields behavior, animation behavior, open file behavior, goto next state behavior, goto previous state behavior, goto state behavior, view zoom behavior, sound behavior, goto anchor behavior, goto page behavior, clear form behavior, print form behavior, submit form behavior, timing setting, timing list, timing group, timing target."></direct-parameter><parameter name="event type" code="pEvT" type="text" description="The registered event type."></parameter><parameter name="handler" code="pHnd" type="any" description="The registered event handler. Can accept: alias or string or JavaScript Function."></parameter><parameter name="captures" code="pCps" type="boolean" optional="yes" description="This parameter is obsolete. Can accept: boolean (Default: FALSE)."></parameter><result type="boolean" description="Returns true if the handler was previously registered for this event."></result></command><command name="remove override" code="InESrmov" description="Removes the override from a previously overridden master page item."><direct-parameter type="specifier" description="Supported by the following objects: form field, button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter></command><command name="reset overlay defaults" code="InESrodf" description="Reset overlay to its default values and/or clear overlay type."><direct-parameter type="specifier" description="Supported by the following objects: form field, button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter><parameter name="overlay type" code="dpol" type="text" description="The overlay type to reset"></parameter><parameter name="clear asset" code="coas" type="boolean" optional="yes" description="The flag to clear overlay asset"></parameter><parameter name="clear overlay" code="cotp" type="boolean" optional="yes" description="The flag to clear overlay"></parameter></command><command name="resize" code="InESscal" description="Resize the page item."><direct-parameter type="specifier" description="Supported by the following objects: form field, button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter><parameter name="in" code="in  " type="any" description="The bounding box to resize. Can accept: pasteboard coordinates/parent coordinates/inner coordinates/page coordinates/spread coordinates, outer stroke bounds/geometric path bounds or Ordered list containing coordinate space:pasteboard coordinates/parent coordinates/inner coordinates/page coordinates/spread coordinates, bounds kind:outer stroke bounds/geometric path bounds."></parameter><parameter name="from" code="zpnt" type="any" description="The transform origin. Legal specifications: relative to bounding box: anchor | {anchor | {x,y}, bounds kind [, coordinate space]}; relative to coordinate space: {x,y} | {{x,y}[, coordinate space]}; relative to layout window ruler: {{x,y}, page index | bounds kind}. Can accept: list of 2 fixed, top left anchor/top center anchor/top right anchor/left center anchor/center anchor/right center anchor/bottom left anchor/bottom center anchor/bottom right anchor or list of lists of 2 fixed, pasteboard coordinates/parent coordinates/inner coordinates/page coordinates/spread coordinates, top left anchor/top center anchor/top right anchor/left center anchor/center anchor/right center anchor/bottom left anchor/bottom center anchor/bottom right anchor, outer stroke bounds/geometric path bounds or integers."></parameter><parameter name="by" code="by  " type="rMet" description="How the current dimensions are affected by the given values"></parameter><parameter name="values" code="BoxD" type="any" description="The width and height values. Legal dimensions specifications: {x, y [, coordinate space]}, {x, resize constraint [, coordinate space]}, or {resize constraint, y [, coordinate space]}; where x and y are real numbers and coordinate space is used to determine _only_ the unit of length for x and y; coordinate space is ignored for the 'current dimensions times' resize method). Can accept: list of fixed, keep current value/keep current proportions/tall proportions/wide proportions/inverse proportions or pasteboard coordinates/parent coordinates/inner coordinates/page coordinates/spread coordinates."></parameter><parameter name="resize individually" code="rPer" type="boolean" optional="yes" description="If false and multiple page items are targeted, the new dimensions are attained only by moving the individual items rather than resizing them. Can accept: boolean (Default: TRUE)."></parameter><parameter name="considering ruler units" code="seeR" type="boolean" optional="yes" description="If true then a ruler location is interpreted using ruler units rather than points. The default value is false. This parameter has no effect unless the reference point is specified relative to a page. Can accept: boolean (Default: FALSE)."></parameter></command><command name="resolve" code="InESwher" description="Get the coordinates of the given location in the specified coordinate system."><direct-parameter type="specifier" description="Supported by the following objects: form field, button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter><parameter name="location" code="corn" type="any" description="The location requested. Can accept: list of 2 fixed, top left anchor/top center anchor/top right anchor/left center anchor/center anchor/right center anchor/bottom left anchor/bottom center anchor/bottom right anchor or list of lists of 2 fixed, pasteboard coordinates/parent coordinates/inner coordinates/page coordinates/spread coordinates, top left anchor/top center anchor/top right anchor/left center anchor/center anchor/right center anchor/bottom left anchor/bottom center anchor/bottom right anchor, outer stroke bounds/geometric path bounds or integers."></parameter><parameter name="in" code="in  " type="xyxy" description="The coordinate space to use."></parameter><parameter name="considering ruler units" code="seeR" type="boolean" optional="yes" description="If true then a ruler location is interpreted using ruler units rather than points. The default value is false. This parameter has no effect unless the reference point is specified relative to a page. Can accept: boolean (Default: FALSE)."></parameter><result type="any" description="The resolved location for each of the targeted page items. Can return: list of 2 fixed or list of lists of 2 fixed."></result></command><command name="select" code="InESselt" description="Selects the object."><direct-parameter type="specifier" description="Supported by the following objects: form field, button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter><parameter name="existing selection" code="exts" type="enSl" optional="yes" description="The selection status of the object in relation to previously selected objects. Can accept: add to/remove from/replace with/set key (Default: replace with)."></parameter></command><command name="send backward" code="InESsnbw" description="Sends the object back one level in its layer."><direct-parameter type="specifier" description="Supported by the following objects: button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter></command><command name="send to back" code="InESsnbk" description="Sends the object to the back of its layer or behind a particular item (must have same parent)."><direct-parameter type="specifier" description="Supported by the following objects: button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter></command><command name="store" code="InESstor" description="Stores the object in the specified library."><direct-parameter type="specifier" description="Supported by the following objects: form field, button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter><parameter name="using" code="usng" type="library" description="The library in which to store the object."></parameter><parameter name="with properties" code="prdt" type="record" optional="yes" description="Initial values for properties of the new object"></parameter><result type="asset" description="The new library asset(s)."></result></command><command name="transform" code="InESxfrm" description="Transform the page item."><direct-parameter type="specifier" description="Supported by the following objects: form field, button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter><parameter name="in" code="in  " type="xyxy" description="The coordinate space to use"></parameter><parameter name="from" code="zpnt" type="any" description="The temporary origin during the transformation. Can accept: list of 2 fixed, top left anchor/top center anchor/top right anchor/left center anchor/center anchor/right center anchor/bottom left anchor/bottom center anchor/bottom right anchor or list of lists of 2 fixed, pasteboard coordinates/parent coordinates/inner coordinates/page coordinates/spread coordinates, top left anchor/top center anchor/top right anchor/left center anchor/center anchor/right center anchor/bottom left anchor/bottom center anchor/bottom right anchor, outer stroke bounds/geometric path bounds or integers."></parameter><parameter name="with matrix" code="1xfm" type="any" description="Transform matrix. Can accept: list of 6 fixed or transformation matrix."></parameter><parameter name="replacing current" code="mxto" type="any" optional="yes" description="Transform components to consider; providing this optional parameter causes the target's existing transform components to be replaced with new values.  Without this parameter, the given matrix is concatenated onto the target's existing transform combining the effect of the two. Can accept: scale values/shear value/rotation value/translation values, list of scale values/shear value/rotation value/translation values or integer."></parameter><parameter name="considering ruler units" code="seeR" type="boolean" optional="yes" description="If true then a ruler based origin is interpreted using ruler units rather than points. The default value is false. This parameter has no effect unless the reference point is specified relative to a page. Can accept: boolean (Default: FALSE)."></parameter></command><command name="transform again" code="InESTrAg" description="Transforms the object using the last transformation performed on any object. Transformations include moving, rotating, shearing, scaling, and flipping. "><direct-parameter type="specifier" description="Supported by the following objects: form field, button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter><result type="text" description="Playback errors."></result></command><command name="transform again individually" code="InESTrAI" description="Transforms the object using the last transformation performed on any object. Transformations include moving, rotating, shearing, scaling, and flipping. "><direct-parameter type="specifier" description="Supported by the following objects: form field, button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter><result type="text" description="Playback errors"></result></command><command name="transform sequence again" code="InESTrSA" description="Transforms the object using the last sequence of transform operations performed on any single object or performed at the same time on any group of objects. Transformations include moving, rotating, shearing, scaling, and flipping."><direct-parameter type="specifier" description="Supported by the following objects: form field, button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter><result type="text" description="Playback errors"></result></command><command name="transform sequence again individually" code="InESTrSI" description="Transforms the object using the last sequence of transformations performed on any single object or performed at the same time on any group of objects. Transformations include moving, rotating, shearing, scaling, and flipping."><direct-parameter type="specifier" description="Supported by the following objects: form field, button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter><result type="text" description="Playback errors"></result></command><command name="transform values of" code="InESxfva" description="Get the transformation values of the page item."><direct-parameter type="specifier" description="Supported by the following objects: form field, button, multi state object, check box, combo box, list box, radio button, text box, signature field, movie, sound."></direct-parameter><parameter name="in" code="in  " type="xyxy" description="The coordinate space to use"></parameter><result type="transformation matrix" description="A list of the transformation matrices"></result></command><command name="unlink" code="InESunlk" description="Unlink all targets in the group into separate groups in this timing list."><direct-parameter type="specifier" description="Supported by the following objects: timing group, timing target."></direct-parameter></command><command name="verify URL" code="InESSepo" description="Verifies that the specified URL is valid and contains the specified movie file. Valid only when the movie file is specified by a URL rather than a file path."><direct-parameter type="movie"></direct-parameter><result type="boolean" description="Returns true if the URL is a valid URL that contains the specified movie file."></result></command><class name="animation behavior" code="aniB" description="A animation behavior." inherits="behavior" plural="animation behaviors"><element type="event"></element><element type="event listener"></element><property name="animated page item" code="anim" type="page item" description="The animation page item."></property><property name="auto reverse on roll off" code="aurv" type="boolean" description="If true, will automatically play the animation in reverse on roll off of the rollover event."></property><property name="behavior event" code="Bevt" type="bhev" description="The event which triggers the behavior."></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="enable behavior" code="enbh" type="boolean" description="If true, the behavior is enabled."></property><property name="id" code="ID  " type="integer" access="r" description="