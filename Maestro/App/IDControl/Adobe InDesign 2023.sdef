rty><property name="warichu line spacing" code="jwls" type="real" description="The gap between lines of warichu characters."></property><property name="warichu lines" code="jwli" type="integer" description="The number of lines of warichu within a single normal line."></property><property name="warichu size" code="jwas" type="real" description="The amount (as a percentage) to scale parent text size to determine warichu size."></property><property name="x offset diacritic" code="diax" type="real" description="The x (horizontal) offset for diacritic adjustment."></property><property name="y offset diacritic" code="diay" type="real" description="The y (vertical) offset for diacritic adjustment."></property></class><enumeration name="TVmt" code="TVmt"><enumerator name="custom text type" code="TVct" description="Custom text variable."></enumerator><enumerator name="file name type" code="TVfn" description="File name variable."></enumerator><enumerator name="last page number type" code="TVtp" description="Last page number variable."></enumerator><enumerator name="chapter number type" code="cntp" description="Chapter number variable."></enumerator><enumerator name="output date type" code="TVod" description="Output date variable."></enumerator><enumerator name="creation date type" code="TVcd" description="Creation date variable."></enumerator><enumerator name="modification date type" code="TVmd" description="Modification date variable."></enumerator><enumerator name="match character style type" code="TVcS" description="Running header (character style) variable."></enumerator><enumerator name="match paragraph style type" code="TVpS" description="Running header (paragraph style) variable."></enumerator><enumerator name="live caption type" code="TVcm" description="Live Caption variable."></enumerator><enumerator name="xref page number type" code="TVxr" description="Private cross reference page number variable."></enumerator><enumerator name="xref chapter number type" code="TVcn" description="Private cross reference chapter number variable."></enumerator></enumeration><enumeration name="taal" code="taal"><enumerator name="ascender text alignment" code="taas" description="Aligns the ascender to the path (not the path's stroke)."></enumerator><enumerator name="descender text alignment" code="tads" description="Aligns descender to the path (not the path's stroke). "></enumerator><enumerator name="center text alignment" code="tact" description="Aligns the midpoint between the ascender and the descender to the path (not the path's stroke)."></enumerator><enumerator name="baseline text alignment" code="tabl" description="The text baseline is aligned to the path (not the path's stroke)."></enumerator><enumerator name="above right em box text alignment" code="tare" description="The top-edge or right-edge baseline of the em box is aligned to the path. "></enumerator><enumerator name="below left em box text alignment" code="tble" description="The bottom-edge or left-edge baseline of the em box is aligned to the path."></enumerator><enumerator name="above right icf box text alignment" code="tari" description="The ideographic character face box top-edge or right-edge baseline is aligned to the path."></enumerator><enumerator name="below left icf box text alignment" code="tbli" description="The ideographic character face box bottom-edge or left-edge baseline is aligned to the path."></enumerator></enumeration><enumeration name="__pe" code="__pe"><enumerator name="rainbow path effect" code="_pfr" description="The center of each character's baseline is parallel to the path's tangent. This is the default effect."></enumerator><enumerator name="skew path effect" code="_pfs" description="The text characters' vertical edges are perfectly vertical regardless of the path shape."></enumerator><enumerator name="ribbon path effect" code="_pf3" description="The text characters' horizontal edges are perfectly horizontal regardless of the path shape."></enumerator><enumerator name="stair step path effect" code="_pss" description="The left edge of each character's baseline is on the path and no characters are rotated."></enumerator><enumerator name="gravity path effect" code="_pfg" description="The center of each character's baseline is on the path while each vertical edge is in line with the path's center point."></enumerator></enumeration><enumeration name="paal" code="paal"><enumerator name="top path alignment" code="pat_" description="The text is aligned to the top of the path stroke."></enumerator><enumerator name="bottom path alignment" code="pab_" description="The text is aligned to the bottom of the path stroke."></enumerator><enumerator name="center path alignment" code="pac_" description="The text is aligned to the center of the path stroke."></enumerator></enumeration><enumeration name="flvl" code="flvl"><enumerator name="not flipped" code="nflp" description="No flip effect applied."></enumerator><enumerator name="flipped" code="yflp" description="Flips the text across the path."></enumerator><enumerator name="undefined flip value" code="uflp" description="Undefined flip effect."></enumerator></enumeration><enumeration name="tsae" code="tsae"><enumerator name="left align" code="left" description="Left."></enumerator><enumerator name="center align" code="cent" description="Center."></enumerator><enumerator name="right align" code="rght" description="Right."></enumerator><enumerator name="character align" code="tbac" description="Aligns the specified character with the tab stop."></enumerator></enumeration><enumeration name="estt" code="estt"><enumerator name="regular story" code="rgst" description="The story is a regular text story."></enumerator><enumerator name="toc story" code="tost" description="The story is a table of contents."></enumerator><enumerator name="indexing story" code="idst" description="The story is an index."></enumerator><enumerator name="endnote story" code="enst" description="The story is an endnote story"></enumerator></enumeration><enumeration name="BRls" code="BRls"><enumerator name="none" code="none" description="No lock state."></enumerator><enumerator name="unmanaged story" code="BRum" description="The story is unmanaged."></enumerator><enumerator name="checked in story" code="BRci" description="The story has been checked in."></enumerator><enumerator name="checked out story" code="BRco" description="The story has been checked out."></enumerator><enumerator name="locked story" code="BRlk" description="The story is locked."></enumerator><enumerator name="embedded story" code="BRem" description="The story is embedded."></enumerator><enumerator name="missing lock state" code="BRms" description="The story file is missing."></enumerator><enumerator name="mixed lock state" code="BRmx" description="The stories have a mixed lock state."></enumerator></enumeration><enumeration name="enrp" code="enrp"><enumerator name="any previous level" code="enap" description="Restart numbering after any previous (higher) numbering level."></enumerator><enumerator name="after specific level" code="ensl" description="Restart numbering after a specific numbering level."></enumerator><enumerator name="range of levels" code="enrl" description="Restart numbering after any of a range of numbering levels."></enumerator></enumeration><enumeration name="RIde" code="RIde"><enumerator name="sentence" code="RIds" description="Uses the first sentence or sentences in the paragraph as the nested style delimiter. The first sentence is considered all text preceding the first period, question mark, or exclamation mark in the paragraph."></enumerator><enumerator name="any word" code="RIdw" description="Uses the first word or words in the paragraph as the nested style delimiter. The first word is considered all characters preceding the first space or white space character in the paragraph."></enumerator><enumerator name="any character" code="RIdc" description="Uses the first character or characters other than zero-width markers as the nested style delimiter. Zero-width markers include anchors, index markers, XML tags, and so on."></enumerator><enumerator name="letters" code="RIdl" description="Uses the first alpha character or characters as the nested style delimiter. Note: To specify the number of letters, see repetition."></enumerator><enumerator name="digits" code="RIdd" description="Uses the first numeric character or characters as the nested style delimiter. Note: To specify the number of digits, see repetition."></enumerator><enumerator name="tabs" code="RIdt" description="Uses the first tab character as the nested style delimiter. Note: Does not use the first tab stop. If no actual tab character has been inserted in the paragraph, the nested style is applied through the end of the paragraph. "></enumerator><enumerator name="inline graphic" code="RIdi" description="Uses the first inline graphic as the nested style delimiter."></enumerator><enumerator name="dropcap" code="RIdC" description="Uses the dropcap as the nested style delimiter."></enumerator><enumerator name="forced line break" code="SFlb" description="Uses the first forced line break as the nested style delimiter."></enumerator><enumerator name="end nested style" code="SBRS" description="Uses the inserted end nested style here character as the nested style delimiter."></enumerator><enumerator name="indent here tab" code="SIht" description="Uses the first indent-to-here tab character as the nested style delimiter. Note: Does not use the first indent-to-here tab stop. If no actual indent-to-here tab character has been inserted in the paragraph, the nested style is applied through the end of the paragraph. "></enumerator><enumerator name="Em space" code="SEmS" description="Uses the first em space as the nested style delimiter."></enumerator><enumerator name="En space" code="SEnS" description="Uses the first en space as the nested style delimiter."></enumerator><enumerator name="nonbreaking space" code="SNbS" description="Uses the first nonbreaking space as the nested style delimiter."></enumerator><enumerator name="auto page number" code="SApn" description="Uses the first automatic page number as the nested style delimiter."></enumerator><enumerator name="section marker" code="SsnM" description="Uses the first section name marker as the nested style delimiter."></enumerator><enumerator name="repeat" code="RIrl" description="Repeat"></enumerator></enumeration><enumeration name="soHT" code="soHT"><enumerator name="basic latin" code="HTBL" description="Basic Latin"></enumerator><enumerator name="finnish swedish" code="HTSF" description="Finnish/Swedish"></enumerator><enumerator name="danish norwegian" code="HTDN" description="Danish/Norwegian"></enumerator><enumerator name="spanish" code="HTSp" description="Spanish"></enumerator><enumerator name="croatian" code="HTCr" description="Croatian"></enumerator><enumerator name="czech" code="HTCz" description="Czech"></enumerator><enumerator name="estonian" code="HTEs" description="Estonian"></enumerator><enumerator name="hungarian" code="HTHu" description="Hungarian"></enumerator><enumerator name="latvian" code="HTLa" description="Latvian"></enumerator><enumerator name="lithuanian" code="HTLi" description="Lithuanian"></enumerator><enumerator name="polish" code="HTPo" description="Polish"></enumerator><enumerator name="romanian" code="HTRo" description="Romanian"></enumerator><enumerator name="slovak" code="HTSk" description="Slovak"></enumerator><enumerator name="slovenian" code="HTSn" description="Slovenian"></enumerator><enumerator name="turkish" code="HTTu" description="Turkish"></enumerator><enumerator name="belarusian" code="HTBe" description="Belarusian"></enumerator><enumerator name="bulgarian" code="HTBu" description="Bulgarian"></enumerator><enumerator name="russian" code="HTRu" description="Russian"></enumerator><enumerator name="ukrainian" code="HTUk" description="Ukrainian"></enumerator><enumerator na