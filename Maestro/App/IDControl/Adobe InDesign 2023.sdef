ing/line end all one half em enum/one em indent line end uke one half em enum/one or one half em indent line end uke one half em enum/one or one half em indent line end all one em enum/one em indent line end all one em enum/one em indent line end all no float enum/one em indent line end uke no float enum/one or one half em indent line end uke no float enum/one em indent line end all one half em enum/line end all one em enum/line end uke no float enum/one or one half em indent line end period one em enum/one em indent line end period one em enum/line end period one em enum/trad chinese default/simp chinese default."></property><property name="name" code="pnam" type="text" description="The name of the xml story; this is an alias to the xml story's label property."></property><property name="no break" code="nobk" type="boolean" description="If true, keeps the text on the same line. "></property><property name="numbering alignment" code="bnna" type="bueA" description="The alignment of the number."></property><property name="numbering apply restart policy" code="bnar" type="boolean" description="If true, apply the numbering restart policy."></property><property name="numbering character style" code="bnnc" type="any" description="The character style to be used for the number string. Can return: character style or string."></property><property name="numbering continue" code="bncp" type="boolean" description="Continue the numbering at this level."></property><property name="numbering expression" code="bnne" type="text" description="The number string expression for numbering."></property><property name="numbering format" code="DHnm" type="any" description="Numbering format options. Can return: upper roman/lower roman/upper letters/lower letters/arabic/kanji/katakana modern/katakana traditional/format none/single leading zeros/arabic alif ba tah/arabic abjad/hebrew biblical/hebrew non standard/double leading zeros/triple leading zeros or string."></property><property name="numbering level" code="bnle" type="integer" description="The level of the paragraph."></property><property name="numbering restart policies" code="bnbr" type="numbering restart policy" access="r" description="Numbering restart policies."></property><property name="numbering start at" code="bnst" type="integer" description="Determines starting number in a numbered list."></property><property name="object reference" code="posp" type="xml story" access="r" description="An object reference for the object."></property><property name="OpenType features" code="jofl" description="OpenType features. Can return: list of list of 2 strings or integers."><type type="any" list="yes"></type></property><property name="OTF contextual alternate" code="OTca" type="boolean" description="If true, uses contextual alternate forms in OpenType fonts."></property><property name="OTF discretionary ligature" code="OTdl" type="boolean" description="If true, uses discretionary ligatures in OpenType fonts."></property><property name="OTF figure style" code="Ofst" type="OTfs" description="The figure style in OpenType fonts."></property><property name="OTF fraction" code="OTfr" type="boolean" description="If true, uses fractions in OpenType fonts."></property><property name="OTF historical" code="OThi" type="boolean" description="If true, use historical forms in OpenType fonts."></property><property name="OTF HV kana" code="hkna" type="boolean" description="If true, switches hiragana fonts, which have different glyphs for horizontal and vertical. "></property><property name="OTF justification alternate" code="OTja" type="boolean" description="If true, use alternate justification forms in OpenType fonts"></property><property name="OTF locale" code="OTlc" type="boolean" description="If true, uses localized forms in OpenType fonts."></property><property name="OTF mark" code="OTmk" type="boolean" description="If true, uses mark positioning in OpenType fonts."></property><property name="OTF ordinal" code=