d" description="A property that allows setting of several properties at the same time."></property></class><class name="library" code="Libr" description="An object library." plural="libraries"><element type="asset"></element><element type="event"></element><element type="event listener"></element><property name="associated panel" code="pAsP" type="panel" access="r" description="The associated panel."></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="file path" code="path" access="r" description="The full path to the file."><type type="file"></type><type type="text"></type></property><property name="full name" code="fnam" access="r" description="The full path to the library, including the name of the library."><type type="file"></type><type type="text"></type></property><property name="index" code="pidx" type="integer" access="r" description="The index of the library within its containing object."></property><property name="name" code="pnam" type="text" access="r" description="The name of the library."></property><property name="object reference" code="posp" type="library" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the library (a application)."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property></class><enumeration name="aste" code="aste"><enumerator name="image type" code="t_im" description="The asset is cataloged as an image asset."></enumerator><enumerator name="EPS type" code="t_EP" description="The asset is cataloged as an EPS asset."></enumerator><enumerator name="PDF type" code="t_PD" description="The asset is cataloged as a PDF asset."></enumerator><enumerator name="geometry type" code="t_ge" description="The asset is cataloged as a geometric page item asset."></enumerator><enumerator name="page type" code="t_pa" description="The asset is cataloged as a page asset."></enumerator><enumerator name="text type" code="t_te" description="The asset is cataloged as a text asset."></enumerator><enumerator name="structure type" code="t_st" description="Structure asset"></enumerator><enumerator name="InDesign file type" code="t_id" description="InDesign file asset"></enumerator></enumeration><enumeration name="enSl" code="enSl"><enumerator name="add to" code="add2" description="Adds the object to the existing selection; if no object was previously selected, makes the object the only selected object."></enumerator><enumerator name="remove from" code="remF" description="Deselects the object."></enumerator><enumerator name="replace with" code="repW" description="Selects the object and deselects any previously selected objects."></enumerator><enumerator name="set key" code="setk" description="Sets the key object. At least 2 objects must be selected, and the key object specified must be one of them."></enumerator></enumeration></suite><suite name="links suite" code="K2LK" description="Scripting support for links."><command name="add event listener" code="K2LKeAEL" description="Adds an event listener."><direct-parameter type="specifier" description="Supported by the following objects: link, http link connection manager object, link metadata."></direct-parameter><parameter name="event type" code="pEvT" type="text" description="The event type."></parameter><parameter name="handler" code="pHnd" type="any" description="The event handler. Can accept: alias or string or JavaScript Function."></parameter><parameter name="captures" code="pCps" type="boolean" optional="yes" description="This parameter is obsolete. Can accept: boolean (Default: FALSE)."></parameter><result type="event listener" description="The new event listener."></result></command><command name="check in" code="K2LKbSUB" description="Check in to Version Cue."><direct-parameter type="link"></direct-parameter><parameter name="version comments" code="vcmt" type="text" optional="yes" description="The comment for this version"></parameter><parameter name="force save" code="vclb" type="boolean" optional="yes" description="Forcibly save a version. Can accept: boolean (Default: FALSE)."></parameter></command><command name="copy link" code="K2LKcplk" description="Copies the link file to the specified location."><direct-parameter type="link"></direct-parameter><parameter name="to" code="to  " description="The file or folder to which to copy the file."><type type="file"></type><type type="text"></type></parameter><parameter name="version comments" code="vcmt" type="text" optional="yes" description="The comment for this version."></parameter><parameter name="force save" code="vclb" type="boolean" optional="yes" description="If true, forcibly saves a version. Can accept: boolean (Default: FALSE)."></parameter></command><command name="count container" code="K2LKMdcc" description="Counts the number of items in the container."><direct-parameter type="link metadata"></direct-parameter><parameter name="namespace" code="Mdns" type="text" description="The namespace of the container."></parameter><parameter name="path" code="Mdpt" type="text" description="The path to the container."></parameter><result type="integer" description="The number of items in the container."></result></command><command name="edit original" code="K2LKedto" description="Opens the source file of the link in the default editor for the source file type."><direct-parameter type="link"></direct-parameter></command><command name="get property" code="K2LKgXMP" description="Gets the XMP property value associated with the specified path."><direct-parameter type="link metadata"></direct-parameter><parameter name="namespace" code="Mdns" type="text" description="The namespace of the property."></parameter><parameter name="path" code="Mdpt" type="text" description="The specified path."></parameter><result type="text" description="The associated property value."></result></command><command name="go to source" code="K2LKgosr" description="Opens the source file of the link in InDesign for SharedContent links."><direct-parameter type="link"></direct-parameter></command><command name="http connect" code="K2LKhcon" description="Experimental: Create a url connection for the given server address"><direct-parameter type="http link connection manager object"></direct-parameter><parameter name="serverURL" code="surl" type="text" description="Server URL to connect"></parameter><parameter name="json data" code="jsnd" type="text" description="JSON data"></parameter></command><command name="is connected" code="K2LKiscn" description="Experimental: Checks if the given server URL is connected or not."><direct-parameter type="http link connection manager object"></direct-parameter><parameter name="serverURL" code="surl" type="text" description="Server URL to check"></parameter><result type="boolean" description="Returns true if connected else return false."></result></command><command name="logout" code="K2LKlogt" description="Experimental: Logout from the given URL"><direct-parameter type="http link connection manager object"></direct-parameter><parameter name="serverURL" code="surl" type="text" description="Server URL to logout from"></parameter></command><command name="reinit link" code="K2LKrinl" description="Experimental: Reinitialize the link to a new uri"><direct-parameter type="link"></direct-parameter><parameter name="link resource URI" code="lURI" type="text" description="Resource URI to relink."></parameter></command><command name="relink" code="K2LKrlnk" description="Points the link to a new source file. "><direct-parameter type="link"></direct-parameter><parameter name="to" code="to  " type="any" description="The full path name of the new source file. Can accept: alias or string or string."></parameter></command><command name="relink text fragment link" code="K2LKrtfl" description="Experimental: Relink the text fragment link to a new uri"><direct-parameter type="link"></direct-parameter><parameter name="link resource URI" code="lURI" type="text" description="Resource URI to relink to."></parameter><parameter name="name" code="pnam" type="text" optional="yes" description="The tag name for the key."></parameter></command><command name="remove event listener" code="K2LKeREL" description="Removes the event listener."><direct-parameter type="specifier" description="Supported by the following objects: link, http link connection manager object, link metadata."></direct-parameter><parameter name="event type" code="pEvT" type="text" description="The registered event type."></parameter><parameter name="handler" code="pHnd" type="any" description="The registered event handler. Can accept: alias or string or JavaScript Function."></parameter><parameter name="captures" code="pCps" type="boolean" optional="yes" description="This parameter is obsolete. Can accept: boolean (Default: FALSE)."></parameter><result type="boolean" description="Returns true if the handler was previously registered for this event."></result></command><command name="replace with original" code="K2LKReOr" description="Experimental: Download the original asset and replace FPO with it. "><direct-parameter type="link"></direct-parameter></command><command name="reveal in Bridge" code="K2LKrvlB" description="Opens Adobe Bridge and selects the source file of the link."><direct-parameter type="link"></direct-parameter></command><command name="reveal in system" code="K2LKrvlO" description="Opens the file system to the folder that contains the source file of the link, and selects the file."><direct-parameter type="link"></direct-parameter></command><command name="show" code="K2LKshow" description="Selects the link."><direct-parameter type="link"></direct-parameter></command><command name="unembed" code="K2LKuneb" description="Unembeds the source file. If no folder is specified, creates a link to the original source file; if a folder is specified, copies the file to the folder and creates a link to the copied file."><direct-parameter type="link"></direct-parameter><parameter name="to" code="to  " optional="yes" description="The folder to which to copy the unembedded file."><type type="file"></type><type type="text"></type></parameter><parameter name="version comments" code="vcmt" type="text" optional="yes" description="The comment for this version."></parameter><parameter name="force save" code="vclb" type="boolean" optional="yes" description="If true, forcibly saves a version. Can accept: boolean (Default: FALSE)."></parameter></command><command name="unlink" code="K2LKunlk" description="Embeds the source file in the document."><direct-parameter type="link"></direct-parameter></command><command name="update" code="K2LKupdt" description="Updates the link if the source file has been changed. "><direct-parameter type="link"></direct-parameter><result type="link" description="The updated link."></result></command><class name="http link connection manager object" code="cmgr" description="Experimental: An http link connection manager."><element type="event"></element><element type="event listener"></element><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="index" code="pidx" type="integer" access="r" description="The index of the http link connection manager object within its containing object."></property><property name="object reference" code="posp" type="http link connection manager object" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the http link connection manager object (a application)."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property></class><class name="link" code="clnk" description="A link to a placed file." plural="links"><element type="event"></element><element type="event listener"></element><element type="link"></element><element type="preference"></element><property name="asset ID" code="laID" type="text" access="r" description="The asset ID of the linked object."></property><property name="asset URL" code="lURL" type="text" access="r" description="The asset URL of the linked object."></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="date" code="sdte" type="date" access="r" description="The date and time the link was created."></property><property name="edited" code="lked" type="boolean" access="r" description="If true, indicates the linked object has been edited in the current document but the source file has not been updated."></property><property name="editing state" code="qedt" type="vcES" access="r" description="The Version Cue editing state of the file."></property><property name="file path" code="path" type="text" access="r" description="The file path (colon delimited on the Mac OS). Can also accept: alias or string."></property><property name="id" code="ID  " type="integer" access="r" description="The unique ID of the link."></property><property name="index" code="pidx" type="integer" access="r" description="The index of the link in the links collection."></property><property name="label" code="ptag" type="text" description="A property that can be set to any string."></property><property name="link resource URI" code="lURI" type="text" access="r" description="The URI of the linked resource."></property><property name="link type" code="lnkt" type="text" access="r" description="The file type of the linked object. "></property><property name="link xmp" code="lXMP" type="link metadata" access="r" description="XMP data for the link source file."></property><property name="name" code="pnam" type="text" access="r" description="The name of the link."></property><property name="needed" code="lknd" type="boolean" access="r" description="If true, indicates a link to a full-resolution version of the source file is needed. If false, indicates the object is embedded."></property><property name="object reference" code="posp" type="link" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="specifier" access="r" description="The linked object. Can return: story, graphic, movie or sound."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="rendition data" code="lRen" type="LrRT" access="r" description="The rendition data of the link resource."></property><property name="size" code="dsiz" type="integer" access="r" description="The size of the link file."></property><property name="status" code="stts" type="stte" access="r" description="The status of the link."></property><property name="version state" code="qver" type="vcVS" access="r" description="The Version Cue version state of the file."></property><property name="after attribute changed" code="AfAC" type="text" description="Dispatched when the value of a property changes on this link. This event bubbles. This event is not cancelable."></property><property name="after delete" code="AfDl" type="text" description="Dispatched after a link is deleted. This event bubbles. This event is not cancelable."></property><property name="after embed" code="AfEm" type="text" description="Dispatched after a link is embedded. This event bubbles. This event is not cancelable."></property><property name="after move" code="AfMv" type="text" description="Dispatched after a link is relocated from one object to another. This event bubbles. This event is not cancelable."></property><property name="after new" code="afNw" type="text" description="Dispatched after a link is created. This event bubbles. This event is not cancelable."></property><property name="after unembed" code="AfUE" type="text" description="Dispatched after a link is unembedded. This event bubbles. This event is not cancelable."></property><property name="after update" code="AfUp" type="text" description="Dispatched after a link is updated. This event bubbles. This event is not cancelable."></property><property name="before delete" code="BfDl" type="text" description="Dispatched before a link is deleted. This event bubbles. This event is cancelable."></property><property name="before embed" code="BfEm" type="text" description="Dispatched before a link is embedded. This event bubbles. This event is cancelable."></property><property name="before move" code="BfMv" type="text" description="Dispatched before a link is relocated from one object to another. This event bubbles. This event is cancelable."></property><property name="before unembed" code="BfUE" type="text" description="Dispatched before a link is unembedded. This event bubbles. This event is cancelable."></property><property name="before update" code="BfUp" type="text" description="Dispatched before a link is updated. This event bubbles. This event is cancelable."></property></class><class name="link metadata" code="clxm" description="MetaData properties for the link source file."><element type="event"></element><element type="event listener"></element><property name="author" code="Mdau" type="text" access="r" description="The author of the document."></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="copyright info URL" code="Mdou" type="text" access="r" description="The URL of the file that contains the linked copyright statement."></property><property name="copyright notice" code="Mdcn" type="text" access="r" description="The text to use as a copyright notice."></property><property name="copyright status" code="Mdcr" type="mdcT" access="r" description="The copyright status of the document."></property><property name="creation date" code="ascd" type="date" access="r" description="The creation date of the document."></property><property name="creator" code="Mdct" type="text" access="r" description="The name of the application used to create the document."></property><property name="description" code="pdes" type="text" access="r" description="The description of the link metadata."></property><property name="document title" code="Mdtn" type="text" access="r" description="The title of the document."></property><property name="format" code="Mdft" type="text" access="r" description="The format of the document."></property><property name="job name" code="Mdjn" type="text" access="r" description="The job name."></property><property name="keywords" code="Mdkw" access="r" description="The list of keywords associated with the document."><type type="text" list="yes"></type></property><property name="modification date" code="asmo" type="date" access="r" description="The most recent modification date of the document."></property><property name="object reference" code="posp" type="link metadata" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="link" access="r" description="The parent of the link metadata (a link)."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="server URL" code="Mdsu" type="text" access="r" description="The location of the document on the asset management server."></property></class><enumeration name="mdcT" code="mdcT"><enumerator name="unknown" code="Unkn" description="The copyright status is unknown."></enumerator><enumerator name="yes" code="yes " description="The document is copyrighted."></enumerator><enumerator name="no" code="no  " description="The document is in the public domain."></enumerator></enumeration><enumeration name="vcVS" code="vcVS"><enumerator name="version unknown" code="vcVU" description="The version is not known."></enumerator><enumerator name="project file newer" code="vcVP" description="The project has a newer file."></enumerator><enumerator name="local project match" code="vcVM" description="The version is identical to the project."></enumerator><enumerator name="local newer" code="vcVL" description="The version has modifications that make it newer than the project."></enumerator><enumerator name="version conflict" code="vcVC" description="The version contains local edits but the project file is newer."></enumerator><enumerator name="no resource" code="vcVN" description="No resource and no local file."></enumerator></enumeration><enumeration name="stte" code="stte"><enumerator name="normal" code="norm" description="The link is a normal link."></enumerator><enumerator name="link out of date" code="lood" description="A more recent version of the file exists on the disk."></enumerator><enumerator name="link missing" code="lmis" description="The linked file has been moved, renamed, or deleted."></enumerator><enumerator name="link embedded" code="Lmbd" description="The file is embedded in the document."></enumerator><enumerator name="link inaccessible" code="lina" description="The url link is inaccessible."></enumerator></enumeration><enumeration name="LrRT" code="LrRT"><enumerator name="FPO" code="Lfpo" description="The link resource has FPO rendition."></enumerator><enumerator name="Actual" code="Lori" description="The link resource has original rendition."></enumerator></enumeration><enumeration name="vcES" code="vcES"><enumerator name="editing unknown" code="vcEU" description="The editing status is not known."></enumerator><enumerator name="editing nowhere" code="vcEN" description="The file is not currently in use and is not locked."></enumerator><enumerator name="editing remotely" code="vcER" descript