ration name="enX5" code="enX5"><enumerator name="none" code="none" description="Disables shape following and uses the rectangular bounds of the object."></enumerator><enumerator name="leading edge" code="en5a" description="Feathers only the leading edge facing the specified angle."></enumerator><enumerator name="all edges" code="en5b" description="Feathers all edges that face the specified angle."></enumerator></enumeration><enumeration name="cmpu" code="cmpu"><enumerator name="use user dictionary" code="Usrd" description="Uses the list stored in the external user dictionary."></enumerator><enumerator name="use document" code="uDoc" description="Uses the list stored in the document."></enumerator><enumerator name="both" code="both" description="Uses the lists stored in both the document and the user dictionary."></enumerator></enumeration><enumeration name="dmRp" code="dmRp"><enumerator name="single record" code="dmSr" description="Places each record on a new page."></enumerator><enumerator name="multiple record" code="dmMr" description="Places as many records as fit on a page."></enumerator></enumeration><enumeration name="dmRs" code="dmRs"><enumerator name="all records" code="dmAr" description="Merges all records."></enumerator><enumerator name="one record" code="dmOr" description="Merges the specified record. "></enumerator><enumerator name="range" code="dmRr" description="Merges all records in the specified range. "></enumerator></enumeration><enumeration name="dmAb" code="dmAb"><enumerator name="rows first" code="dmRf" description="Arranges records by row."></enumerator><enumerator name="columns first" code="dmCf" description="Arranges records by column."></enumerator></enumeration><enumeration name="dmFi" code="dmFi"><enumerator name="proportional" code="dmPr" description="Resizes content to fit the frame while preserving content proportions. If the content and frame have different proportions, some empty space occurs in the frame."></enumerator><enumerator name="fit content to frame" code="dmFc" description="Resizes content to fit the frame. Note: Content that is a different size than the frame appears stretched or squeezed."></enumerator><enumerator name="fit frame to content" code="dmFf" description="Resizes the frame to fit the content."></enumerator><enumerator name="preserve sizes" code="dmPs" description="Preserves the original sizes of the frame and the content. Note: Content that is larger than the frame is obscured around the edges."></enumerator><enumerator name="fill proportional" code="dmFp" description="Resizes content to fill the frame while preserving content proportions. If the content and frame have different proportions, some content is obscured by the bounding box of the frame."></enumerator><enumerator name="content aware fitting" code="dmCA" description="Selects best crop region of the content for the frame based on Adobe Sensei. Note: Preserves frame size but might scale the content size. If this fitting is set, centerImage property is turned-off."></enumerator><enumerator name="honour existing style" code="dmHS" description="Apply the frame fitting based on existing setting applied on the orginal frame."></enumerator></enumeration><enumeration name="nSPc" code="nSPc"><enumerator name="auto page number" code="SApn" description="Inserts an automatic page number."></enumerator><enumerator name="next page number" code="SNpn" description="Inserts the next page number."></enumerator><enumerator name="previous page number" code="SPpn" description="Inserts the previous page number."></enumerator><enumerator name="section marker" code="SsnM" description="Inserts a section marker."></enumerator><enumerator name="bullet character" code="SBlt" description="Inserts a bullet character."></enumerator><enumerator name="copyright symbol" code="SCrt" description="Inserts a copyright symbol."></enumerator><enumerator name="degree symbol" code="SDgr" description="Inserts a degree symbol."></enumerator><enumerator name="ellipsis character" code="SLps" description="Inserts an ellipsis character."></enumerator><enumerator name="forced line break" code="SFlb" description="Inserts a forced line break."></enumerator><enumerator name="paragraph symbol" code="SPar" description="Inserts a paragraph symbol."></enumerator><enumerator name="registered trademark" code="SRTm" description="Inserts a registered trademark."></enumerator><enumerator name="section symbol" code="SsnS" description="Inserts a section symbol."></enumerator><enumerator name="trademark symbol" code="STmk" description="Inserts a trademark symbol."></enumerator><enumerator name="right indent tab" code="SRit" description="Inserts a right indent tab."></enumerator><enumerator name="indent here tab" code="SIht" description="Inserts an indent to here character."></enumerator><enumerator name="Em dash" code="SEmD" description="Inserts an em dash."></enumerator><enumerator name="En dash" code="SEnD" description="Inserts an en dash."></enumerator><enumerator name="discretionary hyphen" code="SDHp" description="Inserts a discretionary hyphen."></enumerator><enumerator name="nonbreaking hyphen" code="SNbh" description="Inserts a nonbreaking hyphen."></enumerator><enumerator name="end nested style" code="SBRS" description="Inserts an end nested style here character."></enumerator><enumerator name="double left quote" code="SDLq" description="Inserts a double left quote."></enumerator><enumerator name="double right quote" code="SDRq" description="Inserts a double right quote."></enumerator><enumerator name="single left quote" code="SSLq" description="Inserts a single left quote."></enumerator><enumerator name="single right quote" code="SSRq" description="Inserts a single right quote."></enumerator><enumerator name="Em space" code="SEmS" description="Inserts an em space."></enumerator><enumerator name="En space" code="SEnS" description="Inserts an en space."></enumerator><enumerator name="flush space" code="SFlS" description="Inserts