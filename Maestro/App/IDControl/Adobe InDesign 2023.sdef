e="jatc" type="integer" description="The number of half-width characters at or below which the characters automatically run horizontally in vertical text."></property><property name="auto tcy include roman" code="jatr" type="boolean" description="If true, auto tcy includes Roman characters."></property><property name="balance ragged lines" code="bala" type="any" description="If true or set to an enumeration value, balances ragged lines. Note: Not valid with a single-line text composer. Can return: boolean or no balancing/vee shape/fully balanced/pyramid shape."></property><property name="baseline shift" code="bshf" description="The baseline shift applied to the text."><type type="number"></type><type type="text"></type></property><property name="bullet char" code="bnbc" type="bullet" access="r" description="Bullet character."></property><property name="bullets alignment" code="bnba" type="bueA" description="The alignment of the bullet character."></property><property name="bullets and numbering list type" code="bnlt" type="enLT" description="List type for bullets and numbering."></property><property name="bullets character style" code="bnbs" type="any" description="The character style to be used for the text after string. Can return: character style or string."></property><property name="bullets text after" code="bnta" type="text" description="The text after string expression for bullets."></property><property name="bunri kinshi" code="jbki" type="boolean" description="If true, adds the double period (..), ellipse (...), and double hyphen (--) to the selected kinsoku set. Note: Valid only when a kinsoku set is in effect."></property><property name="capitalization" code="capm" type="cape" description="The capitalization scheme."></property><property name="character alignment" code="jcal" type="Jaca" description="The alignment of small characters to the largest character in the line."></property><property name="character direction" code="cdir" type="chdi" description=