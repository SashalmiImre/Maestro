rty name="left line end" code="llen" type="ahed" description="The arrowhead applied to the start of the path. "></property><property name="linked Page Item options" code="lpip" type="linked Page Item option" access="r" description="Linked Page Item options"></property><property name="local display setting" code="pLDs" type="dsps" description="Display performance options for the PDF."></property><property name="locked" code="plck" type="boolean" description="If true, the PDF is locked."></property><property name="miter limit" code="mitr" type="real" description="The limit of the ratio of stroke width to miter length before a miter (pointed) join becomes a bevel (squared-off) join. Can return: fixed (1 - 500)."></property><property name="name" code="pnam" type="text" description="The name of the PDF."></property><property name="nonprinting" code="nopr" type="boolean" description="If true, the PDF does not print."></property><property name="object reference" code="posp" type="PDF" access="r" description="An object reference for the object."></property><property name="overprint fill" code="ovpr" type="boolean" description="If true, the PDF's fill color overprints any underlying objects. If false, the fill color knocks out the underlying colors."></property><property name="overprint gap" code="gapO" type="boolean" description="If true, the gap color overprints any underlying colors. If false, the gap color knocks out the underlying colors."></property><property name="overprint stroke" code="sovp" type="boolean" description="If true, the PDF's stroke color overprints any underlying objects. If false, the stroke color knocks out the  underlying colors."></property><property name="overridden" code="Ovrn" type="boolean" access="r" description="If true, the object originated on a master spread and was overridden. If false, the object either originated on a master spread and was not overridden, or the object did not originate on a master page."></property><property name="overridden master page item" code="ovrp" type="specifier" access="r" description="An object that originated on a master page and has been overridden. Can return: page item, guide, graphic, movie or sound."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the PDF (a spline item, polygon, graphic line, rectangle, oval, state, text box, signature field, combo box, list box, XML element, place gun or snippet). Can return: spline item, polygon, graphic line, rectangle, oval, state, text box, signature field, combo box, list box, XML element, place gun or snippet."></property><property name="parent page" code="PaPa" type="page" access="r" description="The page on which this page item appears."></property><property name="PDF attributes" code="DFaf" type="PDF attribute" access="r" description="PDF attribute settings."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="RGB vector policy" code="ICpr" type="Dpie" description="The color profile policy for RGB content in a placed vector."></property><property name="right arrow head scale" code="rahs" type="real" description="The scaling applied to the arrowhead at the end of the path. (Range: 1 to 1000)"></property><property name="right line end" code="rlen" type="ahed" description="The arrowhead applied to the end of the path."></property><property name="rotation angle" code="kang" type="real" description="The rotatation angle of the PDF. (Range: -360 to 360) "></property><property name="shear angle" code="pShr" type="real" description="The skewing angle applied to the PDF. (Range: -360 to 360)"></property><property name="stroke alignment" code="strA" type="stAm" description="The stroke alignment applied to the PDF."></property><property name="stroke color" code="lncl" type="swatch" description="The swatch (color, gradient, tint, or mixed ink) applied to the stroke of the PDF. Can also accept: string."></property><property name="stroke corner adjustment" code="Scaj" type="Escj" description="The corner adjustment applied to the PDF."></property><property name="stroke dash and gap" code="Sdag" description="The dash and gap measurements that define the pattern of a custom dashed line. Define up to six values (in points) in the format [dash1, gap1, dash2, gap2, dash3, gap3]."><type type="number"></type><type type="text"></type></property><property name="stroke tint" code="lint" type="real" description="The percent of tint to use in object's stroke color. (To specify a tint percent, use a number in the range of 0 to 100; to use the inherited or overridden value, use -1.)"></property><property name="stroke transparency settings" code="xpSS" type="stroke transparency setting" access="r" description="Transparency settings for the stroke."></property><property name="stroke type" code="stty" type="stroke style" description="The name of the stroke style to apply. Can also accept: string."></property><property name="stroke weight" code="lnwt" description="The weight (in points) to apply to the PDF's stroke."><type type="number"></type><type type="text"></type></property><property name="text wrap preferences" code="txwr" type="text wrap preference" access="r" description="The text wrap preference properties that define the default formatting for wrapping text around objects."></property><property name="timing settings" code="pTST" type="timing setting" access="r" description="The object timing settings."></property><property name="top left corner option" code="pcO1" type="coPt" description="The shape to be applied to the top left corner of rectangular shapes and all corners of non-rectangular shapes.Note: corner option differs from end join in which you can set a radius for a corner option, whereas the rounded or beveled effect of an end join depends on the stroke weight."></property><property name="top left corner radius" code="p