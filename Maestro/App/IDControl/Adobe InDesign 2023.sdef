on="Bullet character."></property><property name="bullets alignment" code="bnba" type="bueA" description="The alignment of the bullet character."></property><property name="bullets and numbering list type" code="bnlt" type="enLT" description="List type for bullets and numbering."></property><property name="bullets character style" code="bnbs" type="any" description="The character style to be used for the text after string. Can return: character style or string."></property><property name="bullets text after" code="bnta" type="text" description="The text after string expression for bullets."></property><property name="bunri kinshi" code="jbki" type="boolean" description="If true, adds the double period (..), ellipse (...), and double hyphen (--) to the selected kinsoku set. Note: Valid only when a kinsoku set is in effect."></property><property name="capitalization" code="capm" type="cape" description="The capitalization scheme."></property><property name="character alignment" code="jcal" type="Jaca" description="The alignment of small characters to the largest character in the line."></property><property name="character direction" code="cdir" type="chdi" description="The direction of the character."></property><property name="character rotation" code="crot" type="real" description="The rotation angle (in degrees) of individual characters. Note: The rotation is counterclockwise."></property><property name="cjk grid tracking" code="jgrt" type="boolean" description="If true, uses grid tracking to track non-Roman characters in CJK grids."></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="composer" code="ptce" type="text" description="The text composer to use to compose the text."></property><property name="contents" code="pcnt" type="any" description="The contents of the text. Can return: string or auto page number/next page number/previous page number/section marker/bullet character/