e="alternating rows" code="AlRw" description="Alternates row fills."></enumerator><enumerator name="alternating columns" code="AlCl" description="Alternates column fills."></enumerator></enumeration><enumeration name="senm" code="senm"><enumerator name="nothing" code="nada" description="Nothing"></enumerator></enumeration><enumeration name="eVJA" code="eVJA"><enumerator name="top align" code="top " description="Text is aligned at the top of the object."></enumerator><enumerator name="center align" code="cent" description="Text is center aligned vertically in the object. "></enumerator><enumerator name="bottom align" code="botm" description="Text is aligned at the bottom of the object."></enumerator><enumerator name="justify align" code="jstf" description="Lines of text are evenly distributed vertically between the top and bottom of the object."></enumerator></enumeration><enumeration name="pbbe" code="pbbe"><enumerator name="anywhere" code="nbrk" description="Starts in the next available space."></enumerator><enumerator name="next column" code="cbrk" description="Starts at the top of the next column."></enumerator><enumerator name="next frame" code="NFbk" description="Starts at the top of the next text frame in the thread."></enumerator><enumerator name="next page" code="pbrk" description="Starts at the top of the next page."></enumerator><enumerator name="next odd page" code="Opbk" description="Starts at the top of the next odd-numbered page."></enumerator><enumerator name="next even page" code="Epbk" description="Starts at the top of the next even-numbered page."></enumerator></enumeration><enumeration name="ERts" code="ERts"><enumerator name="body row" code="EBrw" description="Makes the row a body row."></enumerator><enumerator name="header row" code="EHrw" description="Makes the row a header row. Note: When setting row type as header row, the row must be either the top row in the table or adjacent to an existing header row."></enumerator><enumerator name="footer