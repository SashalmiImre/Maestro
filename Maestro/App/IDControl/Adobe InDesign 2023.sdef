 gutter if the paragraph splits columns"><type type="number"></type><type type="text"></type></property><property name="start paragraph" code="pbbp" type="pbbe" description="The location at which to start the paragraph."></property><property name="story preferences" code="pSTP" type="story preference" access="r" description="Story preference settings."></property><property name="story title" code="sTtl" type="text" description="Title for this InCopy story."></property><property name="story type" code="trty" type="estt" access="r" description="The type of story."></property><property name="strike through color" code="stco" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the strikethrough stroke. Can return: swatch or string."></property><property name="strike through gap color" code="stgc" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the gap of the strikethrough stroke. Can return: swatch or string."></property><property name="strike through gap overprint" code="stgo" type="boolean" description="If true, the gap color of the strikethrough stroke will overprint. Note: Valid when strike through type is not solid."></property><property name="strike through gap tint" code="stgt" type="real" description="The tint (as a percentage) of the strikethrough stroke gap color. (Range: 0 to 100) Note: Valid when strike through type is not solid."></property><property name="strike through offset" code="stos" description="The amount by which to offset the strikethrough stroke from the text baseline."><type type="number"></type><type type="text"></type></property><property name="strike through overprint" code="Stvp" type="boolean" description="If true, the strikethrough stroke will overprint."></property><property name="strike through tint" code="sttt" type="real" description="The tint (as a percentage) of the strikethrough stroke. (Range: 0 to 100)"></property><property name="strike through type" code="sttp" 