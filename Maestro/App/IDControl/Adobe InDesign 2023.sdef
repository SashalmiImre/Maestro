le" code="Askw" type="real" description="The skewing angle of the WMF relative to its containing object. (Range: -360 to 360)"></property><property name="absolute vertical scale" code="Avts" type="real" description="The vertical scale of the WMF relative to its containing object."></property><property name="all articles" code="pAts" access="r" description="The list of all articles this page item is part of"><type type="article" list="yes"></type></property><property name="all graphics" code="aGrf" access="r" description="Lists all graphics contained by the WMF."><type type="graphic" list="yes"></type></property><property name="all page items" code="aPgi" access="r" description="Lists all page items contained by the WMF."><type type="page item" list="yes"></type></property><property name="allow overrides" code="ovbl" type="boolean" description="If true, the master page item can be overridden."></property><property name="animation settings" code="pAmS" type="animation setting" access="r" description="The page item animation settings."></property><property name="applied object style" code="aobs" type="object style" description="The object style applied to the WMF."></property><property name="arrow head alignment" code="awha" type="eaha" description="The arrowhead alignment applied to the WMF."></property><property name="associated XML element" code="Xaxn" type="XML item" access="r" description="The XML element associated with the WMF."></property><property name="bottom  right corner option" code="pcO4" type="coPt" description="The shape to apply to the bottom right corner of rectangular shapes."></property><property name="bottom left corner option" code="pcO3" type="coPt" description="The shape to apply to the bottom left corner of rectangular shapes."></property><property name="bottom left corner radius" code="pcr3" description="The radius in measurement units of the corner effect applied to the bottom left corner of rectangular shapes"><type type="number"></type><typ