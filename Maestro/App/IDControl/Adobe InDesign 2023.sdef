ty><property name="span split column count" code="scct" type="any" description="The number of columns a paragraph spans or the number of split columns. Can return: small integer (1 - 40) or all."></property><property name="split column inside gutter" code="scig" description="The inside gutter if the paragraph splits columns"><type type="number"></type><type type="text"></type></property><property name="split column outside gutter" code="scog" description="The outside gutter if the paragraph splits columns"><type type="number"></type><type type="text"></type></property><property name="start paragraph" code="pbbp" type="pbbe" description="The location at which to start the paragraph."></property><property name="strike through color" code="stco" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the strikethrough stroke. Can return: swatch or string."></property><property name="strike through gap color" code="stgc" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the gap of the strikethrough stroke. Can return: swatch or string."></property><property name="strike through gap overprint" code="stgo" type="boolean" description="If true, the gap color of the strikethrough stroke will overprint. Note: Valid when strike through type is not solid."></property><property name="strike through gap tint" code="stgt" type="real" description="The tint (as a percentage) of the strikethrough stroke gap color. (Range: 0 to 100) Note: Valid when strike through type is not solid."></property><property name="strike through offset" code="stos" description="The amount by which to offset the strikethrough stroke from the text baseline."><type type="number"></type><type type="text"></type></property><property name="strike through overprint" code="Stvp" type="boolean" description="If true, the strikethrough stroke will overprint."></property><property name="strike through tint" code="sttt" type="real" description="The tint (as