erty name="ruby font size" code="jrfs" type="real" description="The size (in points) of ruby characters."></property><property name="ruby font style" code="jrft" type="any" description="The font style of ruby characters. Can return: string or nothing."></property><property name="ruby open type pro" code="jpro" type="boolean" description="If true, uses OpenType Pro fonts for ruby."></property><property name="ruby overhang" code="jrov" type="boolean" description="If true, constrains ruby overhang to the specified amount. For information on specifying an amount, see ruby parent overhang amount. "></property><property name="ruby overprint fill" code="jrof" type="Jafl" description="The method of overprinting the ruby fill."></property><property name="ruby overprint stroke" code="jros" type="Jafl" description="The method of overprinting the ruby stroke."></property><property name="ruby parent overhang amount" code="jrva" type="Jruo" description="The amount by which ruby characters can overhang the parent text."></property><property name="ruby parent scaling percent" code="jrsc" type="real" description="The amount (as a percentage) to scale the parent text size to determine the ruby text size."></property><property name="ruby parent spacing" code="jrsp" type="Jers" description="The ruby spacing relative to the parent text. "></property><property name="ruby position" code="jrpz" type="Jkps" description="The position of ruby characters relative to the parent text."></property><property name="ruby stroke" code="jrsk" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the stroke of ruby characters. Can return: swatch or string."></property><property name="ruby stroke tint" code="jrst" type="real" description="The stroke tint (as a percentage) of ruby characters."></property><property name="ruby tint" code="jrti" type="real" description="The tint (as a percentage) of the ruby fill color. (Range: 0 to 100)"></property><property name="ruby type" c