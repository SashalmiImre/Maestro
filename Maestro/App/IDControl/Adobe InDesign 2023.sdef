/element><property name="absolute flip" code="flsa" type="EnFp" description="Indicates whether the PDF has been flipped independently of its parent object and, if yes, the direction in which the PDF was flipped."></property><property name="absolute horizontal scale" code="Ahzs" type="real" description="The horizontal scale of the PDF relative to its containing object."></property><property name="absolute rotation angle" code="Aang" type="real" description="The rotation angle of the PDF relative to its containing object. (Range: -360 to 360)"></property><property name="absolute shear angle" code="Askw" type="real" description="The skewing angle of the PDF relative to its containing object. (Range: -360 to 360)"></property><property name="absolute vertical scale" code="Avts" type="real" description="The vertical scale of the PDF relative to its containing object."></property><property name="all articles" code="pAts" access="r" description="The list of all articles this page item is part of"><type type="article" list="yes"></type></property><property name="all graphics" code="aGrf" access="r" description="Lists all graphics contained by the PDF."><type type="graphic" list="yes"></type></property><property name="all page items" code="aPgi" access="r" description="Lists all page items contained by the PDF."><type type="page item" list="yes"></type></property><property name="allow overrides" code="ovbl" type="boolean" description="If true, the master page item can be overridden."></property><property name="animation settings" code="pAmS" type="animation setting" access="r" description="The page item animation settings."></property><property name="applied object style" code="aobs" type="object style" description="The object style applied to the PDF."></property><property name="arrow head alignment" code="awha" type="eaha" description="The arrowhead alignment applied to the PDF."></property><property name="associated XML element" code="Xaxn" type="XML item" access="r" description="The XML element associated with the PDF."></property><property name="bottom  right corner option" code="pcO4" type="coPt" description="The shape to apply to the bottom right corner of rectangular shapes."></property><property name="bottom left corner option" code="pcO3" type="coPt" description="The shape to apply to the bottom left corner of rectangular shapes."></property><property name="bottom left corner radius" code="pcr3" description="The radius in measurement units of the corner effect applied to the bottom left corner of rectangular shapes"><type type="number"></type><type type="text"></type></property><property name="bottom right corner radius" code="pcr4" description="The radius in measurement units of the corner effect applied to the bottom right corner of rectangular shapes"><type type="number"></type><type type="text"></type></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="clipping path" code="pcpt" type="clipping path settings" access="r" description="Clipping path settings."></property><property name="CMYK vector policy" code="ICpc" type="Dpie" description="The color profile policy for CMYK content in a placed vector."></property><property name="content transparency settings" code="xpSC" type="content transparency setting" access="r" description="Transparency settings for the content of the PDF."></property><property name="end cap" code="endc" type="ecap" description="The end shape of an open path."></property><property name="end join" code="endj" type="ejon" description="The corner join applied to the PDF."></property><property name="fill color" code="flcl" type="swatch" description="The swatch (color, gradient, tint, or mixed ink) applied to the fill of the PDF. . Can also accept: string."></property><property name="fill tint" code="filt" type="real" description="The percent of tint to use in the PDF's fill color. (To specify a tint percent, use a number in the range of 0 to 100; to use the inherited or overridden value, use -1.)"></property><property name="fill transparency settings" code="xpSF" type="fill transparency setting" access="r" description="Transparency settings for the fill applied to the PDF."></property><property name="flip" code="RpFp" type="EnFp" description="The direction in which to flip the printed image."></property><property name="gap color" code="gapC" type="swatch" description="The swatch (color, gradient, tint, or mixed ink) applied to the gap of a dashed, dotted, or striped stroke. For information, see stroke type."></property><property name="gap tint" code="gapT" type="real" description="The tint as a percentage of the gap color. (To specify a tint percent, use a number in the range of 0 to 100; to use the inherited or overridden value, use -1.)"></property><property name="geometric bounds" code="gbnd" description="The bounds of the PDF excluding the stroke width, in the format [y1, x1, y2, x2], which give the coordinates of the top-left and bottom-right corners of the bounding box."><type type="number"></type><type type="text"></type></property><property name="gradient fill angle" code="pgfa" type="real" description="The angle of a linear gradient applied to the fill of the PDF. (Range: -180 to 180)"></property><property name="gradient fill length" code="pgfl" description="The length (for a linear gradient) or radius (for a radial gradient) applied to the fill of the PDF."><type type="number"></type><type type="text"></type></property><property name="gradient fill start" code="pgst" description="The starting point (in page coordinates) of a gradient applied to the fill of the PDF, in the format [x, y]."><type type="number" list="yes"></type><type type="text" list="yes"></type></property><property name="gradient stroke angle" code="pgsa" type="real" description="The angle of a linear gradient applied to the stroke of the PDF. (Range: -180 to 180)"></property><property name="gradient stroke 