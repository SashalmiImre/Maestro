 options" code="pFFo" type="frame fitting option" description="The frame fitting option to apply to placed or pasted content. Can be applied to a frame, object style, or document or to the application."></property><property name="gap color" code="gapC" type="swatch" description="The swatch (color, gradient, tint, or mixed ink) applied to the gap of a dashed, dotted, or striped stroke. For information, see stroke type."></property><property name="gap tint" code="gapT" type="real" description="The tint as a percentage of the gap color. (To specify a tint percent, use a number in the range of 0 to 100; to use the inherited or overridden value, use -1.)"></property><property name="gradient fill angle" code="pgfa" type="real" description="The angle of a linear gradient applied to the fill of the object style. (Range: -180 to 180)"></property><property name="gradient stroke angle" code="pgsa" type="real" description="The angle of a linear gradient applied to the stroke of the object style. (Range: -180 to 180)"></property><property name="id" code="ID  " type="integer" access="r" description="The unique ID of the object style."></property><property name="include class" code="exrj" type="boolean" description="If true, class attribute will be generated for the style"></property><property name="index" code="pidx" type="integer" access="r" description="The index of the object style within its containing object."></property><property name="label" code="ptag" type="text" description="A property that can be set to any string."></property><property name="left arrow head scale" code="lahs" type="real" description="The scaling applied to the arrowhead at the start of the path. (Range: 1 to 1000)"></property><property name="left line end" code="llen" type="ahed" description="The arrowhead applied to the start of the path. "></property><property name="miter limit" code="mitr" type="real" description="The limit of the ratio of stroke width to miter length before a miter (pointed) join becomes a bevel (squared-off) join. Can return: fixed (1 - 500)."></property><property name="name" code="pnam" type="text" description="The name of the object style."></property><property name="nonprinting" code="nopr" type="boolean" description="If true, the object style does not print."></property><property name="object effects enabling settings" code="osps" type="object style object effects category settings" access="r" description="The object effects enabling settings."></property><property name="object export options" code="oExP" type="object export option" access="r" description="Export options for the object"></property><property name="object reference" code="posp" type="object style" access="r" description="An object reference for the object."></property><property name="overprint fill" code="ovpr" type="boolean" description="If true, the object style's fill color overprints any underlying objects. If false, the fill color knocks out the underlying colors."></property><property name="overprint gap" code="gapO" type="boolean" description="If true, the gap color overprints any underlying colors. If false, the gap color knocks out the underlying colors."></property><property name="overprint stroke" code="sovp" type="boolean" description="If true, the object style's stroke color overprints any underlying objects. If false, the stroke color knocks out the  underlying colors."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the object style (a document, application or object style group). Can return: document, application or object style group."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="right arrow head scale" code="rahs" type="real" description="The scaling applied to the arrowhead at the end of the path. (Range: 1 to 1000)"></property><property name="right line end" code="rlen"