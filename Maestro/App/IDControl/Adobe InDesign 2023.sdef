olor, gradient, tint, or mixed ink)." plural="swatches"><element type="event"></element><element type="event listener"></element><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="id" code="ID  " type="integer" access="r" description="The unique ID of the swatch."></property><property name="index" code="pidx" type="integer" access="r" description="The index of the swatch within its containing object."></property><property name="label" code="ptag" type="text" description="A property that can be set to any string."></property><property name="name" code="pnam" type="text" description="The name of the swatch."></property><property name="object reference" code="posp" type="swatch" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the swatch (a application or document). Can return: application or document."></property><property name="parent color group" code="pPcg" type="color group" access="r" description="The color group that a swatch belongs to"></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property></class><class name="tint" code="tint" description="A tint swatch." inherits="color" plural="tints"><element type="event"></element><element type="event listener"></element><property name="base color" code="clbs" type="color" access="r" description="The color that the tint is based on."></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="color value" code="clvl" access="r" description="The ink values that create the color, specified as a percentage for each ink. Note: The number of values required and the range depends on the color space. For RGB, specify three values, with each value in the range 0 to 255; for CMYK, specify four values representing C, M, Y, and K, with each value in the range 0 to 100; for LAB, specify three values representing L (Range: 0 to 100), A (Range: -128 to 127), and B (Range: -128 to 127); for mixed ink, specify values for each ink in the ink list, with each value in the range 0 to 100."><type type="real" list="yes"></type></property><property name="id" code="ID  " type="integer" access="r" description="The unique ID of the tint."></property><property name="index" code="pidx" type="integer" access="r" description="The index of the tint within its containing object."></property><property name="label" code="ptag" type="text" description="A property that can be set to any string."></property><property name="model" code="clmd" type="clme" access="r" description="The color model."></property><property name="name" code="pnam" type="text" access="r" description="The name of the tint."></property><property name="object reference" code="posp" type="tint" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the tint (a application or document). Can return: application or document."></property><property name="parent color group" code="pPcg" type="color group" access="r" description="The color group that a swatch belongs to"></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="space" code="clsp" type="clte" access="r" description="The color space."></property><property name="tint value" code="tntv" type="real" description="The percent of the base color. (Range: 0 to 100). Can return: fixed (0 - 100)."></property></class><class name="trap preset" code="trSt" description="A trap preset." plural="trap presets"><element type="event"></element><element type="event listener"></element><property name="black color threshold" code="tpBT" type="real" description="The minimum amount (as a percentage) of black ink required before the black width setting is applied. (Range: 0 to 100). Can return: fixed (0 - 100)."></property><property name="black density" code="tpBD" type="real" description="The neutral density value at or above which an ink is considered black. (Range: .001 to 10). Can return: fixed (0 - 10)."></property><property name="black width" code="tpBW" description="The black width. (Range depends on unit. For points: 0.0 to 8.0; picas: 0p0 to 0p8; inches: 0 to 0.1111; mm: 0 to 2.822; cm: 0 to .2822; ciceros: 0c0 to 0c7.507). Can return: number or string (0 - 8 points)."><type type="number"></type><type type="text"></type></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="color reduction" code="tpRD" type="real" description="The degree (as a percentage) to which components from abutting colors are used to reduce the trap color. (Range: 0 to 100) Note: 0% makes a trap whose neutral density is equal to the neutral density of the darker color. Can return: fixed (0 - 100)."></property><property name="default trap width" code="tpDW" description="The default width for trapping all colors except those involving solid black. (Range depends on unit. For points: 0.0 to 8.0; picas: 0p0 to 0p8; inches: 0 to 0.1111; mm: 0 to 2.822; cm: 0 to .2822; ciceros: 0c0 to 0c7.507). Can return: number or string (0 - 8 points)."><type type="number"></type><type type="text"></type></property><property name="id" code="ID  " type="integer" access="r" description="The unique ID of the trap preset."></property><property name="image placement" code="tpIP" type="tpip" description="The trap placement between vector objects and bitmap images."></property><property name="images to images" code="tpII" type="boolean" description="If true, turns on trapping along the boundary of overlapping or abutting bitmap images."></property><property name="index" code="pidx" type="integer" access="r" description="The index of the trap preset within its containing object."></property><property name="internal images" code="tpIM" type="boolean" description="If true, turns on trapping among colors within individual bitmap images."></property><property name="label" code="ptag" type="text" description="A property that can be set to any string."></property><property name="name" code="pnam" type="text" description="The name of the trap preset."></property><property name="object reference" code="posp" type="trap preset" access="r" description="An object reference for the object."></property><property name="objects to images" code="tpOI" type="boolean" description="If true, ensures that vector objects overlap bitmap images."></property><property name="one bit images" code="tpOB" type="boolean" description="If true, ensures that one-bit images trap to abutting objects."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the trap preset (a application or document). Can return: application or document."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="sliding trap threshold" code="tpSL" type="real" description="The difference (as a percentage) between the neutral densities of abutting colors at which the trap is moved from the darker side of a color edge toward the centerline. (Range: 0 to 100). Can return: fixed (0 - 100)."></property><property name="step threshold" code="tpST" type="real" description="The amount (as a percentage) that components of abutting colors must vary before a trap is created. (Range: 1 to 100). Can return: fixed (1 - 100)."></property><property name="trap end" code="tpES" type="tpen" description="The shape to use at the intersection of three-way traps."></property><property name="trap join" code="tpJS" type="ejon" description="The join type of the trap preset."></property></class><enumeration name="ejon" code="ejon"><enumerator name="miter end join" code="mjon" description="Miter end join."></enumerator><enumerator name="round end join" code="rjon" description="Rounded end join."></enumerator><enumerator name="bevel end join" code="bjon" description="Beveled end join."></enumerator></enumeration><enumeration name="tpen" code="tpen"><enumerator name="miter trap ends" code="tpme" description="Shapes the end of the trap to keep it away from the intersecting object."></enumerator><enumerator name="overlap trap ends" code="tpol" description="Reshapes the trap generated by the lightest neutral density object so that it wraps around the point where the three objects intersect."></enumerator></enumeration><enumeration name="tpip" code="tpip"><enumerator name="center edges" code="tpcn" description="Creates a trap that straddles the edge between vector objects and bitmap images."></enumerator><enumerator name="choke" code="tpch" description="Causes vector objects to overlap abutting images."></enumerator><enumerator name="image neutral density" code="tpnd" description="Applies the same trapping rules as used elsewhere in the document. Note: When used to trap an object to a photograph, can result in noticeably uneven edges as the trap moves from one side of the edge to another."></enumerator><enumerator name="images over spread" code="tpsp" description="Causes bitmap images to overlap the abutting objects."></enumerator></enumeration><enumeration name="enIT" code="enIT"><enumerator name="normal" code="norm" description="Uses traditional process inks and most spot inks."></enumerator><enumerator name="opaque" code="itOp" description="Uses heavy, nontransparent inks to prevent trapping of underlying colors but allow for trapping along the edges of the ink. Best for metallic inks."></enumerator><enumerator name="transparent" code="itTr" description="Uses clear inks to ensure that underlying items trap. Best for varnishes and dieline inks."></enumerator><enumerator name="opaque ignore" code="itIg" description="Uses heavy, nontransparent inks to prevent trapping of underlying colors but allow for trapping along the edges of the ink. Best for inks that have undesirable interactions with other inks."></enumerator></enumeration><enumeration name="gtyp" code="gtyp"><enumerator name="linear" code="axlg" description="A linear gradient."></enumerator><enumerator name="radial" code="radg" description="A radial gradient."></enumerator></enumeration><enumeration name="clte" code="clte"><enumerator name="RGB" code="cRGB" description="RGB."></enumerator><enumerator name="CMYK" code="CMYK" description="CMYK."></enumerator><enumerator name="LAB" code="cLAB" description="LAB."></enumerator><enumerator name="MixedInk" code="cMIX" description="Mixed ink."></enumerator><enumerator name="HSB" code="cHSB" description="HSB."></enumerator></enumeration><enumeration name="clme" code="clme"><enumerator name="spot" code="spot" description="Spot color."></enumerator><enumerator name="process" code="prss" description="Process color."></enumerator><enumerator name="registration" code="regs" description="Registration color."></enumerator><enumerator name="mixedinkmodel" code="inmx" description="Mixed ink color."></enumerator></enumeration></suite><suite name="datamerge suite" code="dmSu" description="Scripting support for the dataMerge feature."><command name="add event listener" code="dmSueAEL" description="Adds an event listener."><direct-parameter type="specifier" description="Supported by the following objects: data merge text placeholder, data merge image placeholder, data merge field, data merge qrcode placeholder."></direct-parameter><parameter name="event type" code="pEvT" type="text" description="The event type."></parameter><parameter name="handler" code="pHnd" type="any" description="The event handler. Can accept: alias or string or JavaScript Function."></parameter><parame