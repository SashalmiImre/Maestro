(1 - 999999)."></property><property name="top" code="mart" description="The top edge of the document preset."><type type="number"></type><type type="text"></type></property></class><class name="drop shadow setting" code="xpQf" description="Drop shadow settings."><element type="event"></element><element type="event listener"></element><property name="angle" code="inAn" type="real" description="The angle at which the shadow is thrown. Can return: fixed (-180 - 180)."></property><property name="blend mode" code="xpBm" type="enXM" description="The blending mode for the drop shadow effect."></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="distance" code="e0D8" description="The distance between the item and its shadow. Can return: number or string (0 - 1000 points)."><type type="number"></type><type type="text"></type></property><property name="effect color" code="xpUt" type="swatch" description="The color applied to the drop shadow, specified as a swatch (color, gradient, tint, or mixed ink), or as an array of color values. The color mode dictates the array values: for RGB, specify three values, each in the range 0 to 255, in the format [R,G,B]; for CMYK, specify four values, each as a percentage and each in the range 0 to 100, in the format [C,M,Y,K]; for LAB, specify three values in the format [L,A,B], with L in the range 0 to 100 and A and B in the range -128 to 127."></property><property name="honor other effects" code="xpU7" type="boolean" description="If true, the drop shadow will take into account other non-shadow effects."></property><property name="knocked out" code="xpUr" type="boolean" description="If true, the layer will knock out the drop shadow."></property><property name="mode" code="xpUp" type="enXS" description="The shadow mode."></property><property name="noise" code="e0D5" type="real" description="The amount (as a percentage) of noise applied to the shadow. (Range: 0 to 100). Can return: fixed (0 - 100)."></property><property name="object reference" code="posp" type="drop shadow setting" access="r" description="An object reference for the object."></property><property name="opacity" code="xpBo" type="real" description="The opacity of the drop shadow (as a percentage). (Range: 0 to 100). Can return: fixed (0 - 100)."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the drop shadow setting (a transparency setting, stroke transparency setting, fill transparency setting or content transparency setting). Can return: transparency setting, stroke transparency setting, fill transparency setting or content transparency setting."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="size" code="dsiz" description="The radius (in pixels) of the blur applied to the drop shadow. (Range depends on the unit type. For points: 0 to 144; for picas: 0p0 to 12p0; for inches: 0 to 2; for mm: 0 to 50.08; for cm: 0 to 5.08; for ciceros: 0c0 to 11c3.128.). Can return: number or string (0 - 144 points)."><type type="number"></type><type type="text"></type></property><property name="spread" code="sprd" type="real" description="The amount (as a percentage of the blur width) to spread the footprint of the drop shadow and reduce the radius of the blur. (Range: 0 to 100). Can return: fixed (0 - 100)."></property><property name="use global light" code="xpUs" type="boolean" description="If true, uses the global light angle."></property><property name="x offset" code="xpUj" description="The horizontal offset of the drop shadow. Range depends on the unit type. For points: -1000 to 1000; for picas: -83p4 to 83p4; for inches: -13.8889 to 13.8889; for mm: -352.778 to 352.778; for cm: -35.277 to 35.277; for ciceros: -78c2.389 to 78c2.389. Can return: number or string (-1000 - 1000 points)."><type type="number"></type><type type="text"></type></property><property name="y offset" code="xpUk" description="The vertical offset of the drop shadow. (Range depends on the unit type. For points: -1000 to 1000; for picas: -83p4 to 83p4; for inches: -13.8889 to 13.8889; for mm: -352.778 to 352.778; for cm: -35.277 to 35.277; for ciceros: -78c2.389 to 78c2.389). Can return: number or string (-1000 - 1000 points)."><type type="number"></type><type type="text"></type></property></class><class name="endnote option" code="Enop" description="Options for specifying default endnote formatting."><element type="event"></element><element type="event listener"></element><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="endnote marker positioning" code="ENmp" type="any" description="The position of endnote reference numbers in the main text. Can return: normal marker/superscript marker/subscript marker/ruby marker or string."></property><property name="endnote marker style" code="ENmc" type="character style" description="The character style to apply to endnote reference numbers in the main text. "></property><property name="endnote numbering style" code="ENns" type="any" description="The endnote numbering style. Can return: upper roman/lower roman/upper letters/lower letters/arabic/symbols/kanji/full width arabic/single leading zeros/double leading zeros/asterisks/arabic alif ba tah/arabic abjad/hebrew biblical/hebrew non standard or string."></property><property name="endnote prefix" code="ENpr" type="text" description="The prefix text of the endnote. (Limit: 0 to 100 characters)"></property><property name="endnote separator text" code="ENsp" type="text" description="The text to insert between the endnote marker number and the endnote text. (Range: 0 to 100 characters)"></property><property name="endnote suffix" code="ENsu" type="text" description="The suffix text of the endnote. (Limit: 0 to 100 characters)"></property><property name="endnote text style" code="ENap" type="paragraph style" description="The paragraph style to apply to endnote text."></property><property name="endnote title" code="ENti" type="text" description="Title of the endnotes. (Limit: 0 to 100 characters)"></property><property name="endnote title style" code="ENtp" type="paragraph style" description="The paragraph style to apply to endnote title."></property><property name="frame create option" code="ENfc" type="any" description="Frame creation of the endnotes. Can return: load endnote place gun/new page or string."></property><property name="object reference" code="posp" type="endnote option" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the endnote option (a application or document). Can return: application or document."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="restart endnote numbering" code="ENrn" type="any" description="The point at which to restart endnote numbering. Can return: continuous/story restart or string."></property><property name="scope value" code="ENsv" type="any" description="Scope value of the endnotes. Can return: story scope/endnote document scope or string."></property><property name="show endnote prefix suffix" code="ENps" type="any" description="The position of the endnote prefix and/or suffix. Can return: no prefix suffix/prefix suffix reference/prefix suffix marker/prefix suffix both or string."></property><property name="start endnote number at" code="ENsa" type="integer" description="The number at which to start endnote numbering. Can return: integer (1 - 100000)."></property></class><class name="EPS export preference" code="cEEP" description="EPS export preferences."><element type="event"></element><element type=