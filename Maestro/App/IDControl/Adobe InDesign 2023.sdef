e type="text"></type></property><property name="text wrap preferences" code="txwr" type="text wrap preference" access="r" description="The text wrap preference properties that define the default formatting for wrapping text around objects."></property><property name="timing settings" code="pTST" type="timing setting" access="r" description="The object timing settings."></property><property name="top left corner option" code="pcO1" type="coPt" description="The shape to be applied to the top left corner of rectangular shapes and all corners of non-rectangular shapes.Note: corner option differs from end join in which you can set a radius for a corner option, whereas the rounded or beveled effect of an end join depends on the stroke weight."></property><property name="top left corner radius" code="pcr1" description="The radius in measurement units of the corner effect applied to the top left corner of rectangular shapes and all corners of non-rectangular shapes"><type type="number"></type><type type="text"></type></property><property name="top right corner option" code="pcO2" type="coPt" description="The shape to apply to the top right corner of rectangular shapes"></property><property name="top right corner radius" code="pcr2" description="The radius in measurement units of the corner effect applied to the top right corner of rectangular shapes"><type type="number"></type><type type="text"></type></property><property name="transparency settings" code="xpSP" type="transparency setting" access="r" description="Transparency settings."></property><property name="vertical layout constraints" code="VeCo" description="The top margin, height, and bottom margin constraints this item is subject to when using the object-based layout rule."><type type="LPdc" list="yes"></type></property><property name="vertical scale" code="pvts" type="real" description="The vertical scaling applied to the oval."></property><property name="visible" code="pvis" type="boolean" description="If true, 