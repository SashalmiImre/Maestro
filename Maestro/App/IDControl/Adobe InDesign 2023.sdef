ription="The bounds of the text box excluding the stroke width, in the format [y1, x1, y2, x2], which give the coordinates of the top-left and bottom-right corners of the bounding box."><type type="number"></type><type type="text"></type></property><property name="gradient fill angle" code="pgfa" type="real" description="The angle of a linear gradient applied to the fill of the text box. (Range: -180 to 180)"></property><property name="gradient fill length" code="pgfl" description="The length (for a linear gradient) or radius (for a radial gradient) applied to the fill of the text box."><type type="number"></type><type type="text"></type></property><property name="gradient fill start" code="pgst" description="The starting point (in page coordinates) of a gradient applied to the fill of the text box, in the format [x, y]."><type type="number" list="yes"></type><type type="text" list="yes"></type></property><property name="gradient stroke angle" code="pgsa" type="real" description="The angle of a linear gradient applied to the stroke of the text box. (Range: -180 to 180)"></property><property name="gradient stroke length" code="pgsl" description="The length (for a linear gradient) or radius (for a radial gradient) applied to the stroke of the text box."><type type="number"></type><type type="text"></type></property><property name="gradient stroke start" code="pgss" description="The starting point (in page coordinates) of a gradient applied to the stroke of the text box, in the format [x, y]."><type type="number" list="yes"></type><type type="text" list="yes"></type></property><property name="hidden until triggered" code="HiTr" type="boolean" description="If true, the form field/push button is hidden until triggered in the exported PDF."></property><property name="horizontal layout constraints" code="HoCo" description="The left margin, width, and right margin constraints this item is subject to when using the object-based layout rule."><type type="LPdc" list="yes"></type></property><property name="horizontal scale" code="phzs" type="real" description="The horizontal scaling applied to the text box."></property><property name="id" code="ID  " type="integer" access="r" description="The unique ID of the text box."></property><property name="index" code="pidx" type="integer" access="r" description="The index of the text box within its containing object."></property><property name="item layer" code="pilr" type="layer" description="The layer that the text box is on."></property><property name="label" code="ptag" type="text" description="A property that can be set to any string."></property><property name="left arrow head scale" code="lahs" type="real" description="The scaling applied to the arrowhead at the start of the path. (Range: 1 to 1000)"></property><property name="left line end" code="llen" type="ahed" description="The arrowhead applied to the start of the path. "></property><property name="linked Page Item options" code="lpip" type="linked Page Item option" access="r" description="Linked Page Item options"></property><property name="local display setting" code="pLDs" type="dsps" description="Display performance options for the text box."></property><property name="locked" code="plck" type="boolean" description="If true, the text box is locked."></property><property name="miter limit" code="mitr" type="real" description="The limit of the ratio of stroke width to miter length before a miter (pointed) join becomes a bevel (squared-off) join. Can return: fixed (1 - 500)."></property><property name="multiline" code="Txml" type="boolean" description="If true, the text field is multiline in the exported PDF."></property><property name="name" code="pnam" type="text" description="The name of the text box."></property><property name="nonprinting" code="nopr" type="boolean" description="If true, the text box does not print."></property><property name="object reference" code="posp" type="text box" access="r" description="An object reference for the object."></property><property name="overprint fill" code="ovpr" type="boolean" description="If true, the text box's fill color overprints any underlying objects. If false, the fill color knocks out the underlying colors."></property><property name="overprint gap" code="gapO" type="boolean" description="If true, the gap color overprints any underlying colors. If false, the gap color knocks out the underlying colors."></property><property name="overprint stroke" code="sovp" type="boolean" description="If true, the text box's stroke color overprints any underlying objects. If false, the stroke color knocks out the  underlying colors."></property><property name="overridden" code="Ovrn" type="boolean" access="r" description="If true, the object originated on a master spread and was overridden. If false, the object either originated on a master spread and was not overridden, or the object did not originate on a master page."></property><property name="overridden master page item" code="ovrp" type="specifier" access="r" description="An object that originated on a master page and has been overridden. Can return: page item, guide, graphic, movie or sound."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the text box (a character, spread, master spread, spline item, polygon, graphic line, rectangle, oval, group, place gun or snippet). Can return: character, spread, master spread, spline item, polygon, graphic line, rectangle, oval, group, place gun or snippet."></property><property name="parent page" code="PaPa" type="page" access="r" description="The page on which this page item appears."></property><property name="password" code="iSpw" type="boolean" description="If true, the text field is a password field in the exported PDF."></property><property name="printable in pdf" code="PPDF" type="boolean" description="If true, the form field/push button is printable in the exported PDF."></property><property name="pr