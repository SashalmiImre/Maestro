scription="Align or distribute to the bounds of the spread."></enumerator><enumerator name="key object" code="eKey" description="Align or distribute to a key object."></enumerator></enumeration><enumeration name="aOEn" code="aOEn"><enumerator name="left edges" code="LfEd" description="Align the left edges of the objects."></enumerator><enumerator name="top edges" code="TpEd" description="Align the top edges of the objects."></enumerator><enumerator name="right edges" code="RtEd" description="Align the right edges of the objects."></enumerator><enumerator name="bottom edges" code="BtEd" description="Align the bottom edges of the objects."></enumerator><enumerator name="horizontal centers" code="HoZc" description="Align the horizontal centers of the objects."></enumerator><enumerator name="vertical centers" code="VeTc" description="Align the vertical centers of the objects."></enumerator></enumeration></suite><suite name="book suite" code="InBK" description="Scripting support for the book feature."><command name="add event listener" code="InBKeAEL" description="Adds an event listener."><direct-parameter type="specifier" description="Supported by the following objects: book, book content."></direct-parameter><parameter name="event type" code="pEvT" type="text" description="The event type."></parameter><parameter name="handler" code="pHnd" type="any" description="The event handler. Can accept: alias or string or JavaScript Function."></parameter><parameter name="captures" code="pCps" type="boolean" optional="yes" description="This parameter is obsolete. Can accept: boolean (Default: FALSE)."></parameter><result type="event listener" description="The new event listener."></result></command><command name="export" code="InBKexpt" description="Exports the book to a file."><direct-parameter type="book"></direct-parameter><parameter name="format" code="exft" type="any" description="The export format, specified as an enumeration value or as an extension that appears in the Save as type or Format menu in the Export dialog. Can accept: tagged text/PDF type/EPS type/RTF/text type/XML/JPG/HTML/EPUB/fixed layout EPUB/HTMLFXL/InDesign snippet/InDesign markup/InCopy markup/PNG format/interactive PDF or string."></parameter><parameter name="to" code="kfil" optional="yes" description="The file to which to export the book."><type type="file"></type><type type="text"></type></parameter><parameter name="showing options" code="imot" type="boolean" optional="yes" description="Used to specify if the PDF Export Options Dialog needs to be shown or not. Can accept: boolean (Default: FALSE)."></parameter><parameter name="using" code="usng" type="PDF export preset" optional="yes" description="Used to specify the presets for the export which can be the object of the preset type, enumeration for existing presets or user defined presets, or a string naming the preset to be used, but in case Showing Options is true, the preset specified in the Export Dialog will over ride this parameter"></parameter><parameter name="which documents" code="bewd" type="book content" optional="yes" description="Used to specify a list of book content references, from the current book, where the list may contain duplicate entries and if the list is not specified then the entire book contents shall be exported"></parameter><parameter name="version comments" code="vcmt" type="text" optional="yes" description="The comment for this version."></parameter><parameter name="force save" code="vclb" type="boolean" optional="yes" description="If true, forcibly saves a version. Can accept: boolean (Default: FALSE)."></parameter></command><command name="package" code="InBKPAS4" description="Packages the document."><direct-parameter type="book"></direct-parameter><parameter name="to" code="rLOC" description="The folder, alias, or path in which to place the packaged files."><type type="file"></type><type type="text"></type></parameter><parameter name="copying fonts" code="rFON" type="boolean" description="If true, copies fonts used in the document to the package folder."></parameter><parameter name="copying linked graphics" code="rLIN" type="boolean" description="If true, copies linked graphics files to the package folder."></parameter><parameter name="copying profiles" code="rPRO" type="boolean" description="If true, copies color profiles to the package folder."></parameter><parameter name="updating graphics" code="rUGR" type="boolean" description="If true, updates graphics links to the package folder. "></parameter><parameter name="including hidden layers" code="rHIL" type="boolean" description="If true, copies fonts and links from hidden layers to the package."></parameter><parameter name="ignore preflight errors" code="rIPE" type="boolean" description="If true, ignores preflight errors and proceeds with the packaging. If false, cancels the packaging when errors exist."></parameter><parameter name="creating report" code="rREP" type="boolean" description="If true, creates a package report that includes printing instructions, print settings, lists of fonts, links and required inks, and other information."></parameter><parameter name="include idml" code="rIDM" type="boolean" optional="yes" description="If true, generates and includes IDML in the package folder."></parameter><parameter name="include pdf" code="rPDF" type="boolean" optional="yes" description="If true, generates and includes PDF in the package folder."></parameter><parameter name="pdf style" code="rSty" type="text" optional="yes" description="If specified and PDF is to be included, use this style for PDF export if it is valid, otherwise use the last used PDF preset."></parameter><parameter name="use document hyphenation exceptions only" code="rUHE" type="boolean" optional="yes" description="If this option is selected, InDesign flags this document so that it does not reflow when someone else opens or edits it on a computer that has different hyphenation and dictionary settings."></parameter><parameter name="version comments" code="vcmt" type="text" optional="yes" description="The comments for the version."></parameter><parameter name="force save" code="vclb" type="boolean" optional="yes" description="If true, forcibly saves a version. Can accept: boolean (Default: FALSE)."></parameter><result type="boolean" description="True if the packaging was successful."></result></command><command name="preflight" code="InBKPRS4" description="Preflight a book and optionally save the resulting report."><direct-parameter type="specifier" description="Supported by the following objects: book, book content."></direct-parameter><parameter name="to" code="kfil" optional="yes" description="The preflight report to save to."><type type="file"></type><type type="text"></type></parameter><parameter name="auto open" code="rAop" type="boolean" optional="yes" description="If true, automatically open the report after creation. Can accept: boolean (Default: FALSE)."></parameter></command><command name="remove event listener" code="InBKeREL" description="Removes the event listener."><direct-parameter type="specifier" description="Supported by the following objects: book, book content."></direct-parameter><parameter name="event type" code="pEvT" type="text" description="The registered event type."></parameter><parameter name="handler" code="pHnd" type="any" description="The registered event handler. Can accept: alias or string or JavaScript Function."></parameter><parameter name="captures" code="pCps" type="boolean" optional="yes" description="This parameter is obsolete. Can accept: boolean (Default: FALSE)."></parameter><result type="boolean" description="Returns true if the handler was previously registered for this event."></result></command><command name="repaginate" code="InBKrpan" description="Repaginates the book."><direct-parameter type="book"></direct-parameter></command><command name="replace" code="InBKerpl" description="Replaces a book content object with a new file. Note: If the new file replaces the current style source document, the new file becomes the style source document. "><direct-parameter type="book content"></direct-parameter><parameter name="using" code="usng" description="The full path name of the new book content object."><type type="file"></type><type type="text"></type></parameter><result type="book content" description="The new book content object."></result></command><command name="synchronize" code="InBKsync" description="Synchronizes the entire book to the style source document."><direct-parameter type="specifier" description="Supported by the following objects: book, book content."></direct-parameter></command><command name="update all cross references" code="InBKuxrb" description="Updates the cross references in the entire book."><direct-parameter type="book"></direct-parameter></command><command name="update all numbers" code="InBKuanb" description="Update all numbers (e.g. Page numbers, chapter numbers and paragraph numbers) throughout the book."><direct-parameter type="book"></direct-parameter></command><command name="update chapter and paragraph numbers" code="InBKunib" description="Updates chapter numbers and paragraph numbers throughout the book."><direct-parameter type="book"></direct-parameter></command><class name="book" code="Book" description="A book." plural="books"><element type="book content"></element><element type="event"></element><element type="event listener"></element><element type="preference"></element><property name="automatic document conversion" code="atcv" type="boolean" description="If true, automatically converts the book content object during repagination and synchronization."></property><property name="automatic pagination" code="atpg" type="boolean" description="If true, automatically updates page numbers when pages in book content files are added, deleted, or rearranged."></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."><