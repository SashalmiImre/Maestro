meration name="rKVP" code="rKVP"><enumerator name="keep current value" code="KepV" description="Keep current value"></enumerator><enumerator name="keep current proportions" code="KepP" description="Keep current proportions"></enumerator><enumerator name="tall proportions" code="TalP" description="Tall proportions"></enumerator><enumerator name="wide proportions" code="WidP" description="Wide proportions"></enumerator><enumerator name="inverse proportions" code="InvP" description="Inverse proportions"></enumerator></enumeration><enumeration name="rMet" code="rMet"><enumerator name="adding current dimensions to" code="HowP" description="Add additional width and height to current values"></enumerator><enumerator name="multiplying current dimensions by" code="HowM" description="Multiply current width and height by the given factors"></enumerator><enumerator name="replacing current dimensions with" code="HowE" description="Change width and height overriding current values"></enumerator><enumerator name="reshaping area to ratio" code="HowA" description="Change width to height ratio keeping the current area"></enumerator><enumerator name="reshaping border to ratio" code="HowS" description="Change width to height ratio keeping the current perimeter"></enumerator></enumeration><enumeration name="edge" code="edge"><enumerator name="outer stroke bounds" code="ink1" description="Outer stroke bounds"></enumerator><enumerator name="geometric path bounds" code="ink0" description="Geometric path bounds"></enumerator></enumeration><enumeration name="xyxy" code="xyxy"><enumerator name="pasteboard coordinates" code="xypb" description="Pasteboard coordinates"></enumerator><enumerator name="parent coordinates" code="xypa" description="Parent coordinates"></enumerator><enumerator name="inner coordinates" code="xyin" description="Inner coordinates"></enumerator><enumerator name="page coordinates" code="xypg" description="Page coordinates."></enumerator><enumerator name="spread coordinates" code="xysp" description="Spread coordinates."></enumerator></enumeration><enumeration name="eAnc" code="eAnc"><enumerator name="top left anchor" code="ANtl" description="The top left corner."></enumerator><enumerator name="top center anchor" code="ANtc" description="The center point on the top of the bounding box."></enumerator><enumerator name="top right anchor" code="ANtr" description="The top right corner."></enumerator><enumerator name="left center anchor" code="ANlc" description="The center point on the left side of the bounding box."></enumerator><enumerator name="center anchor" code="ANct" description="The center point in the bounding box."></enumerator><enumerator name="right center anchor" code="ANrc" description="The center point on the right side of the bounding box."></enumerator><enumerator name="bottom left anchor" code="ANbl" description="The bottom left corner."></enumerator><enumerator name="bottom center anchor" code="ANbc" description="The center point on the bottom of the bounding box."></enumerator><enumerator name="bottom right anchor" code="ANbr" description="The bottom right corner."></enumerator></enumeration><enumeration name="EnFp" code="EnFp"><enumerator name="none" code="none" description="The printed image is not flipped."></enumerator><enumerator name="horizontal" code="horz" description="Flips the printed image horizontally."></enumerator><enumerator name="vertical" code="vert" description="Flips the printed image vertically."></enumerator><enumerator name="horizontal and vertical" code="HzVl" description="Flips the printed image horizontally and vertically (same as rotate 180)."></enumerator><enumerator name="both" code="both" description="Horizontal and vertical flip (same as rotate 180)"></enumerator></enumeration><enumeration name="fito" code="fito"><enumerator name="content to frame" code="ctof" description="Resizes content to fit the frame. Note: Content that is a different size than the frame appears stretched or squeezed."></enumerator><enumerator name="center content" code="cenc" description="Centers content in the frame; preserves the frame size as well as content size and proportions. Note: If the content is larger than the frame, content around the edges is obscured."></enumerator><enumerator name="proportionally" code="conp" description="Resizes content to fit the frame while preserving content proportions. If the content and frame have different proportions, some empty space appears in the frame."></enumerator><enumerator name="content aware fit" code="cafi" description="Selects best crop region of the content for the frame based on Adobe Sensei. Note: Preserves frame size but might scale the content size."></enumerator><enumerator name="frame to content" code="ftoc" description="Resizes the frame so it fits the content."></enumerator><enumerator name="fill proportionally" code="filp" description="Resizes content to fill the frame while perserving the proportions of the content. If the content and frame have different proportions, some of the content is obscured by the bounding box of the frame."></enumerator><enumerator name="apply frame fitting options" code="affo" description="Applies the current frame fitting options to the frame and content. Before using this, do confirm that the expected Frame Fitting Options are applied on the frame. For example, the act of placing an image in a frame set to 'Fit Content Proportionally' can change the crop settings in the Frame Fitting Options, which would then get applied for any subsequent image placement when this API is called."></enumerator></enumeration><enumeration name="hrso" code="hrso"><enumerator name="no sort" code="nost" description="Do not sort the ranges."></enumerator><enumerator name="ascending sort" code="asds" description="Sort the ranges in ascending order."></enumerator><enumerator name="descending sort" code="dsst" description="Sort the ranges in descending order."></enumerator></enumeration><enumeration name="CSOP" code="CSOP"><enumerator name="convert to rectangle" code="CSRE" description="Converts the object to a rectangle."></enumerator><enumerator name="convert to rounded rectangle" code="CSRR" description="Converts the object to a rectangle with rounded corners."></enumerator><enumerator name="convert to beveled rectangle" code="CSBR" description="Converts the object to a rectangle with beveled corners."></enumerator><enumerator name="convert to inverse rounded rectangle" code="CSIR" description="Converts the object to a rectangle with inverse rounded corners."></enumerator><enumerator name="convert to oval" code="CSOV" description="Converts the object to an ellipse."></enumerator><enumerator name="convert to triangle" code="CSTR" description="Converts the object to a triangle."></enumerator><enumerator name="convert to polygon" code="CSPO" description="Converts the object to a polygon."></enumerator><enumerator name="convert to line" code="CSLI" description="Converts the object to a line that connects the upper left and lower right corners of the object's bounding box."></enumerator><enumerator name="convert to straight line" code="CSSL" description="Converts the object to straight line. If the object is a square, circle, or its bounding box is wider than it is tall, the line is horizontal and connects the center points on the vertical sides of the bounding box. If the object's bounding box is taller than it is wide, the line connects the center points of the horizontal sides of the bounding box."></enumerator><enumerator name="convert to open path" code="CSOp" description="Converts the object to an open path."></enumerator><enumerator name="convert to closed path" code="CSCp" description="Converts the object to a closed path."></enumerator></enumeration><enumeration name="OvTp" code="OvTp"><enumerator name="all" code="all " description="Clears all types of override."></enumerator><enumerator name="character only" code="chro" description="Clears only character style overrides."></enumerator><enumerator name="paragraph only" code="paro" description="Clears only paragraph style overrides."></enumerator></enumeration><enumeration name="OTFf" code="OTFf"><enumerator name="low" code="enLw" description="Low."></enumerator><enumerator name="discretionary ligatures feature" code="OTdL" description="Allows the use of optional discretionary ligatures."></enumerator><enumerator name="fractions feature" code="OTfR" description="Reformats numbers separated by a slash, such as 1/2, as fractions. Note: In some fonts, the fractions feature reformats only standard fractions. For information on reformatting non-standard fractions such as 4/13, see denominator feature and numerator feature."></enumerator><enumerator name="ordinal feature" code="OToR" description="Superscripts the alpha characters in ordinal numbers."></enumerator><enumerator name="swash feature" code="OTsW" description="Provides regular and contextual swashes, which may include alternate caps and end-of-word alternatives."></enumerator><enumerator name="titling feature" code="OTtI" description="Activates alternative characters used for uppercase titles."></enumerator><enumerator name="contextual alternates feature" code="OTcA" description="Activates contextual ligatures and connecting alternates."></enumerator><enumerator name="all small caps feature" code="c2sC" description="Provides authentic small caps rather than scaled-down versions of the font's regular caps."></enumerator><enumerator name="superscript feature" code="pOTS" description="Sizes raised glyphs correctly relative to the surrounding characters."></enumerator><enumerator name="subscript feature" code="pOTB" description="Sizes lowered glyphs correctly relative to the surrounding characters."></enumerator><enumerator name="numerator feature" code="pOTN" description="In a series of two numbers separated by a slash that form a non-standard fraction, such as 4/13, reformats the first number as a numerator."></enumerator><enumerator name="denominator feature" code="pOTD" description="In a series of two numbers separated by a slash that form a non-standard fraction, such as 4/13, reformats the second number as a denominator."></enumerator><enumerator name="tabular lining feature" code="OTfT" description="Gives full-height figures fixed, equal width."></enumerator><enumerator name="proportional oldstyle feature" code="OToS" description="Gives varying-height figures varying widths."></enumerator><enumerator name="proportional lining feature" code="OTlP" description="Gives full-height figures varying widths."></enumerator><enumerator name="tabular oldstyle feature" code="OToT" description="Gives varying-height figures fixed, equal widths."></enumerator><enumerator name="default figure style feature" code="OTfD" description="Applies the default figure style of the current font to figure glyphs."></enumerator><enumerator name="overlap swash" code="OToV" description="Overlap swash"></enumerator><enumerator name="stylistic alternate" code="OTsT" description="Stylistic alternate"></enumerator><enumerator name="justification alternate" code="OTjU" description="Justification alternate"></enumerator><enumerator name="stretched alternate" code="OTsR" description="Stretched alternate"></enumerator></enumeration><enumeration name="ccmd" code="ccmd"><enumerator name="uppercase" code="ccuc" description="Makes all letters uppercase."></enumerator><enumerator name="lowercase" code="cclc" description="Makes all letters lowercase."></enumerator><enumerator name="titlecase" code="cctc" description="Makes the first letter of each word uppercase."></enumerator><enumerator name="sentencecase" code="ccsc" description="Makes the first letter of each sentence uppercase."></enumerator></enumeration><enumeration name="eXft" code="eXft"><enumerator name="tagged text" code="Tgtx" description="Exports to a tagged text file with a TXT extension. "></enumerator><enumerator name="PDF type" code="t_PD" description="Exports to PDF format."></enumerator><enumerator name="EPS type" code="t_EP" description="Exports to EPS format."></enumerator><enumerator name="RTF" code="RTF " description="Exports to rich text format (RTF). "></enumerator><enumerator name="text type" code="t_te" description="Exports to text (TXT) format."></enumerator><enumerator name="XML" code="XML " description="Exports the document's tagged content to XML."></enumerator><enumerator name="JPG" code="JPG " description="Exports to JPEG format."></enumerator><enumerator name="HTML" code="HTML" description="Exports to XHTML format."></enumerator><enumerator name="EPUB" code="epub" description="Exports to EPub format."></enumerator><enumerator name="fixed layout EPUB" code="epfx" description="Exports to fixed layout EPub format."></enumerator><enumerator name="HTMLFXL" code="HTfx" description="Exports to XHTML FXL format."></enumerator><enumerator name="InDesign snippet" code="snpt" description="Exports to InDesign snippet (IDMS) format."></enumerator><enumerator name="InDesign markup" code="idml" description="Exports to InDesign markup (IDML) format."></enumerator><enumerator name="InCopy markup" code="icml" description="Exports to InCopy markup (ICML) format."></enumerator><enumerator name="PNG format" code="ePNG" description="Exports to PNG format."></enumerator><enumerator name="interactive PDF" code="t_iP" description="Exports to Interactive PDF format."></enumerator></enumeration></suite><suite name="UI suite" code="UIUI" description="Scripting support for user interface elements."><command name="add event listener" code="UIUIeAEL" description="Adds an event listener."><direct-parameter type="specifier" description="Supported by the following objects: pages panel, library panel, menu action, script menu action, menu, menu element, submenu, menu item, menu separator, panel, dialog, widget, text editbox, static text, dropdown, checkbox control, dialog column, radiobutton group, radiobutton control, integer editbox, in