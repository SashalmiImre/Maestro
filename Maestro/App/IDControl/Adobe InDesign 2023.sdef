nt handler. Can accept: alias or string or JavaScript Function."></parameter><parameter name="captures" code="pCps" type="boolean" optional="yes" description="This parameter is obsolete. Can accept: boolean (Default: FALSE)."></parameter><result type="boolean" description="Returns true if the handler was previously registered for this event."></result></command><command name="select" code="UIUIselt" description="Selects the specified object(s)."><direct-parameter type="any" description="The objects to select. Supported by the following objects: library panel, menu item."></direct-parameter><parameter name="existing selection" code="exts" type="enSl" optional="yes" description="The selection status of the object in relation to previously selected objects. Can accept: add to/remove from/replace with/set key (Default: replace with)."></parameter></command><command name="show" code="UIUIshow" description="Displays the dialog."><direct-parameter type="dialog"></direct-parameter><result type="boolean" description="True if the OK button was used to dismiss dialog; false if the Cancel button was used."></result></command><command name="show all" code="UIUIeSAl" description="Show all assets"><direct-parameter type="library panel"></direct-parameter></command><class name="angle combobox" code="uCAn" description="A degree entry control featuring both a pop-up menu and and entry field." inherits="widget" plural="angle comboboxes"><element type="event"></element><element type="event listener"></element><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="edit contents" code="uiEC" type="text" description="The default value in an editbox control. Note: Do not specify both edit contents and edit value. If both are specified, the one that occurs later in the script is used. "></property><property name="edit value" code="uEdV" type="real" description="The real number default value of the editbox or combobox. No