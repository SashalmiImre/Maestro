td" code="K2  Xldt" description="Imports a DTD to use for validation."><direct-parameter type="document"></direct-parameter><parameter name="from" code="from" description="The path to the DTD file."><type type="file"></type><type type="text"></type></parameter></command><command name="import formats" code="K2  imXF" description="Imports the cross reference formats from specified file."><direct-parameter type="document"></direct-parameter><parameter name="from" code="from" description="The file whose formats to import."><type type="file"></type><type type="text"></type></parameter></command><command name="import pdf comments" code="K2  PDim" description="Import Commemnts from PDF"><direct-parameter type="document"></direct-parameter><parameter name="from" code="from" description="The PDF File from which you want to import comments."><type type="file"></type><type type="text"></type></parameter><parameter name="with properties" code="prdt" type="record" optional="yes" description="Initial values for properties of the new object"></parameter></command><command name="import styles" code="K2  imST" description="Imports the specified styles."><direct-parameter type="specifier" description="Supported by the following objects: application, document."></direct-parameter><parameter name="format" code="exft" type="iXst" description="The types of styles to import."></parameter><parameter name="from" code="from" description="The file containing the styles you want to import."><type type="file"></type><type type="text"></type></parameter><parameter name="global strategy" code="scrs" type="ClRS" optional="yes" description="The resolution strategy to employ for imported styles that have the same names as existing styles. Can accept: load all with overwrite/load all with rename/do not load the style (Default: load all with overwrite)."></parameter></command><command name="import XML" code="K2  XMLi" description="Imports the specified XML file into an InDesign document."><direct-parameter type="document"></direct-parameter><parameter name="from" code="from" description="The XML file."><type type="file"></type><type type="text"></type></parameter></command><command name="insert label" code="K2  inLb" description="Sets the label to the value associated with the specified key."><direct-parameter type="specifier" description="Supported by the following objects: event listener, idle task, application, document."></direct-parameter><parameter name="key" code="with" type="text" description="The key."></parameter><parameter name="value" code="to  " type="text" description="The value."></parameter></command><command name="is defined" code="K2  Dfsp" description="Verifies whether the script argument is defined."><direct-parameter type="script arg"></direct-parameter><parameter name="name" code="pnam" type="text" description="The name of the script argument."></parameter><result type="boolean" description="If true, the script arg is defined."></result></command><command name="load" code="K2  LCDr" description="Load the Content Placer with one or more objects."><direct-parameter type="content placer object"></direct-parameter><parameter name="page items" code="pits" type="page item" description="One or more page items to place or load"></parameter><parameter name="link page items" code="pLOO" type="boolean" optional="yes" description="Whether to link pageItems in content placer (if true it will override link stories value). Can accept: boolean (Default: FALSE)."></parameter><parameter name="link stories" code="pLSO" type="boolean" optional="yes" description="Whether to link stories in content placer (only applicable for single story, pageItem links will also be created in case of more than one item). Can accept: boolean (Default: FALSE)."></parameter><parameter name="map styles" code="pMSO" type="boolean" optional="yes" description="Whether to map styles in content placer. Can accept: boolean (Default: FALSE)."></parameter><parameter name="showing options" code="imot" type="boolean" optional="yes" description="Whether to display the link options dialog. Can accept: boolean (Default: FALSE)."></parameter></command><command name="load conditions" code="K2  ldCt" description="Load conditions from the specified file."><direct-parameter type="specifier" description="Supported by the following objects: application, document."></direct-parameter><parameter name="from" code="from" description="The path to the file that contains the conditions."><type type="file"></type><type type="text"></type></parameter><parameter name="load condition sets" code="plCs" type="boolean" optional="yes" description="If true, load the condition sets as well."></parameter></command><command name="load find change query" code="K2  FCLq" description="Loads the specified find/change query."><parameter name="query name" code="fcqn" type="text" description="The query to load."></parameter><parameter name="search mode" code="Fsmd" type="Fscm" description="The search mode."></parameter></command><command name="load masters" code="K2  LdMP" description="Load masterpages from an InDesign file."><direct-parameter type="document"></direct-parameter><parameter name="from" code="from" description="The InDesign file to load the masters from."><type type="file"></type><type type="text"></type></parameter><parameter name="global strategy for master page" code="Mpcr" type="MPCL" optional="yes" description="the global clash resolution strategy for load master page. Can accept: load all with overwrite/load all with rename (Default: load all with overwrite)."></parameter></command><command name="load motion preset" code="K2  imMP" description="Load motion preset from the specified file."><parameter name="from" code="kfil" description="The Flash motion preset file."><type type="file"></type><type type="text"></type></parameter><result type="Motion Preset" description="The motion preset that is imported."></result></command><command name="load place gun" code="K2  LPGn" description="Load the place gun with one or more files."><direct-parameter type="any" description="One or more files to place. "></direct-parameter><parameter name="showing options" code="imot" type="boolean" optional="yes" description="Whether to display the import options dialog. Can accept: boolean (Default: FALSE)."></parameter><parameter name="with properties" code="prdt" type="record" optional="yes" description="Initial values for properties of the placed object(s)"></parameter></command><command name="load preflight profile" code="K2  ldPP" description="Load preflight profile from the specified file."><parameter name="from" code="kfil" description="The InDesign preflight profile file or InDesign document."><type type="file"></type><type type="text"></type></parameter><result type="preflight profile" description="The preflight profile that is loaded."></result></command><command name="load swatches" code="K2  LdSw" description="Load swatches from the specified file."><direct-parameter type="specifier" description="Supported by the following objects: application, document."></direct-parameter><parameter name="from" code="kfil" description="The swatch file or InDesign document."><type type="file"></type><type type="text"></type></parameter></command><command name="load XML tags" code="K2  Xltg" description="Loads a set of XML markup tags from the specified file."><direct-parameter type="specifier" description="Supported by the following objects: application, document."></direct-parameter><parameter name="from" code="from" description="The path to the file that contains the tags."><type type="file"></type><type type="text"></type></parameter></command><command name="map styles to XML tags" code="K2  Xmst" description="Auto tag the document based on the style to tag mappings"><direct-parameter type="document"></direct-parameter></command><command name="map XML tags to styles" code="K2  Xmts" description="Auto style the document based on the tag to style mappings"><direct-parameter type="document"></direct-parameter></command><command name="maximize" code="K2  maxi" description="Maximizes the window."><direct-parameter type="specifier" description="Supported by the following objects: window, layout window, story window."></direct-parameter></command><command name="memory statistics" code="K2  SMSt" description="Gets the memory statistics from the server."><result type="integer" description="The memory statistics, specified as an array: [(core allocation count), (core memory size), (private bytes), (virtual memory size), (resident memory size), (handle count), (gdi object count), ]."></result></command><command name="minimize" code="K2  mini" description="Minimizes the window."><direct-parameter type="specifier" description="Supported by the following objects: window, layout window, story window."></direct-parameter></command><command name="mount project" code="K2  mtpj" description="Mount a Version Cue project."><parameter name="server URL" code="vurl" type="text" description="The URL of the Version Cue server containing the project"></parameter><parameter name="project name" code="pjnm" type="text" description="The name of the Version Cue project to mount"></parameter></command><command name="open cloud document" code="K2  eOCD" description="Open cloud document for a given reference."><parameter name="asset reference" code="pCAR" type="text" description=" The reference to asset"></parameter><parameter name="showing window" code="psiw" type="boolean" optional="yes" description="If true, opens the document in a window. If false, the document is opened but is not displayed in a window. Can accept: boolean (Default: TRUE)."></parameter><result type="document" description="The opened document"></result></command><command name="package" code="K2  PAS4" description="Packages the document."><direct-parameter type="document"></direct-parameter><parameter name="to" code="rLOC" description="The folder, alias, or path in which to place the packaged files."><type type="file"></type><type type="text"></type></parameter><parameter name="copying fonts" code="rFON" type="boolean" description="If true, copies fonts used in the document to the package folder."></parameter><parameter name="copying linked graphics" code="rLIN" type="boolean" description="If true, copies linked graphics files to the package folder."></parameter><parameter name="copying profiles" code="rPRO" type="boolean" description="If true, copies color profiles to the package folder."></parameter><parameter name="updating graphics" code="rUGR" type="boolean" description="If true, updates graphics links to the package folder. "></parameter><parameter name="including hidden layers" code="rHIL" type="boolean" description="If true, copies fonts and links from hidden layers to the package."></parameter><parameter name="ignore preflight errors" code="rIPE" type="boolean" description="If true, ignores preflight errors and proceeds with the packaging. If false, cancels the packaging when errors exist."></parameter><parameter name="creating report" code="rREP" type="boolean" description="If true, creates a package report that includes printing instructions, print settings, lists of fonts, links and required inks, and other information."></parameter><parameter name="include idml" code="rIDM" type="boolean" optional="yes" description="If true, generates and includes IDML in the package folder."></parameter><parameter name="include pdf" code="rPDF" type="boolean" optional="yes" description="If true, generates and includes PDF in the package folder."></parameter><parameter name="pdf style" code="rSty" type="text" optional="yes" description="If specified and PDF is to be included, use this style for PDF export if it is valid, otherwise use the last used PDF preset."></parameter><parameter name="use document hyphenation exceptions only" code="rUHE" type="boolean" optional="yes" description="If this option is selected, InDesign flags this document s