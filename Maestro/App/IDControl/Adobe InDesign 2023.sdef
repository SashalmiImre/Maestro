y if splits" code="pbDf" type="boolean" description="If true, then paragraph border is also displayed at the points where the paragraph splits across frames or columns."></property><property name="paragraph border gap color" code="psGc" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the paragraph border gap. Note: Valid only when the border type is not solid. Can return: swatch or string."></property><property name="paragraph border gap overprint" code="psGo" type="boolean" description="If true, the paragraph border gap will overprint. Note: Valid only when border type is not solid."></property><property name="paragraph border gap tint" code="psGt" type="real" description="The tint (as a percentage) of the paragraph border gap. Note: Valid only when the border type is not solid. (Range: 0 to 100)"></property><property name="paragraph border left line weight" code="psWL" description="The left line weight of the border of paragraph."><type type="number"></type><type type="text"></type></property><property name="paragraph border left offset" code="pbOl" description="The distance to offset the left edge of the paragraph border."><type type="number"></type><type type="text"></type></property><property name="paragraph border on" code="psOn" type="boolean" description="If true, the paragraph border is on."></property><property name="paragraph border overprint" code="psSo" type="boolean" description="If true, the paragraph border will overprint."></property><property name="paragraph border right line weight" code="psWR" description="The right line weight of the border of paragraph."><type type="number"></type><type type="text"></type></property><property name="paragraph border right offset" code="pbOr" description="The distance to offset the right edge of the paragraph border."><type type="number"></type><type type="text"></type></property><property name="paragraph border stroke end cap" code="psEc" type="ecap" description="The end shape of an open path."></property><property name="paragraph border stroke end join" code="psEj" type="ejon" description="The corner join applied to the text."></property><property name="paragraph border tint" code="psSt" type="real" description="The tint (as a percentage) of the paragraph stroke. (Range: 0 to 100)"></property><property name="paragraph border top left corner option" code="bcO1" type="coPt" description="The shape to be applied to the top left corner of rectangular shapes and all corners of non-rectangular shapes.Note: corner option differs from end join in which you can set a radius for a corner option, whereas the rounded or beveled effect of an end join depends on the stroke weight."></property><property name="paragraph border top left corner radius" code="bcr1" description="The radius in measurement units of the corner effect applied to the top left corner of rectangular shapes and all corners of non-rectangular shapes"><type type="number"></type><type type="text"></type></property><property name="paragraph border top line weight" code="psWT" description="The top line weight of the border of paragraph."><type type="number"></type><type type="text"></type></property><property name="paragraph border top offset" code="pbOt" description="The distance to offset the top edge of the paragraph border."><type type="number"></type><type type="text"></type></property><property name="paragraph border top origin" code="pbTo" type="pbTe" description="The basis (cap height, ascent or baseline) used to calculate the top origin of the paragraph border."></property><property name="paragraph border top right corner option" code="bcO2" type="coPt" description="The shape to apply to the top right corner of rectangular shapes"></property><property name="paragraph border top right corner radius" code="bcr2" description="The radius in measurement units of the corner effect applied to the top right corner of rectangular shapes"><type type="number"></type><type type="text"></type></property><property name="paragraph border type" code="psSy" type="any" description="The type of the border for the paragraph. Can return: stroke style or string."></property><property name="paragraph border width" code="pbWi" type="pbWe" description="The basis (text width or column width) used to calculate the width of the paragraph border."></property><property name="paragraph direction" code="pdir" type="padi" description="Paragraph direction."></property><property name="paragraph gyoudori" code="jpgd" type="boolean" description="If true, the gyoudori mode applies to the entire paragraph. If false, the gyoudori mode applies to each line in the paragraph."></property><property name="paragraph justification" code="pjus" type="pjut" description="Paragraph justification."></property><property name="paragraph kashida width" code="pkas" type="real" description="Paragraph kashida width. 0 is none, 1 is short, 2 is medium, 3 is long"></property><property name="paragraph shading bottom  right corner option" code="scO4" type="coPt" description="The shape to apply to the bottom right corner of rectangular shapes."></property><property name="paragraph shading bottom left corner option" code="scO3" type="coPt" description="The shape to apply to the bottom left corner of rectangular shapes."></property><property name="paragraph shading bottom left corner radius" code="scr3" description="The radius in measurement units of the corner effect applied to the bottom left corner of rectangular shapes"><type type="number"></type><type type="text"></type></property><property name="paragraph shading bottom offset" code="psOb" description="The distance to offset the bottom edge of the paragraph."><type type="number"></type><type type="text"></type></property><property name="paragraph shading bottom origin" code="psBo" type="psBe" description="The basis (descent or baseline) used to calculate the bottom origin of the paragraph shading."></property><property name="paragraph shading bot