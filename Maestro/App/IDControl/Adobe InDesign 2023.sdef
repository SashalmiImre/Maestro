property><property name="alt metadata property" code="alMp" type="any" description="The metadata property to use as source of alternate text. Can return: Ordered list containing namespace prefix:string, property path:string."></property><property name="alt text source type" code="alSP" type="sTyp" description="The source type of alternate text"></property><property name="apply tag type" code="Aptt" type="tgTp" description="The tag type of page item"></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="custom actual text" code="acCt" type="text" description="The custom actual text entered by the user"></property><property name="custom alt text" code="alCt" type="text" description="The custom alternate text entered by the user"></property><property name="custom layout" code="CuLy" type="boolean" description="If true, custom layout is enabled for object"></property><property name="custom layout type" code="CLaT" type="CuLT" description="Custom Layout settings to be used for object"></property><property name="custom size" code="EbCu" type="text" description="Custom size applied to the object"></property><property name="epub type" code="EpTy" type="text" description="The epub type as recommended by IDPF"></property><property name="GIF options interlaced" code="Xegi" type="boolean" description="If true, generates interlaced GIFs. Note: Not valid  when image conversion is JPEG."></property><property name="GIF options palette" code="Xegp" type="plty" description="The color palette for GIF conversion. Note: Not valid when image conversion is JPEG. "></property><property name="image alignment" code="ImAl" type="ImAn" description="Alignment applied to images"></property><property name="image conversion type" code="ICvt" type="iCvt" description="Allows user to select the image format for conversion"></property><property name="image export resolution" code="ImRs" type="Imrs" description="The export resolution"></property><property name="image page break" code="ImPk" type="ImPb" description="Image page break settings to be used with objects"></property><property name="image space after" code="ImSA" type="real" description="Space After applied to images. Can return: fixed (0 - 8640)."></property><property name="image space before" code="ImSB" type="real" description="Space Before applied to images. Can return: fixed (0 - 8640)."></property><property name="JPEG options format" code="Xejf" type="jpge" description="The formatting method for converted JPEG images. Note: Not valid  when image conversion is GIF."></property><property name="JPEG options quality" code="Xejq" type="jpgq" description="The quality of converted JPEG images. Note: Not valid when image conversion is GIF. "></property><property name="object reference" code="posp" type="object export option" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the object export option (a spline item, polygon, graphic line, rectangle, oval, group, text frame, endnote text frame or object style). Can return: spline item, polygon, graphic line, rectangle, oval, group, text frame, endnote text frame or object style."></property><property name="preserve appearance from layout" code="PoLa" type="PrAp" description="Preserve Appearance from Layout"></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="size type" code="CSsT" type="CuSi" description="size settings to be used for the object"></property><property name="use image page break" code="Uipb" type="boolean" description="If true, image page break settings will be used in objects"></property></class><class name="object style content effects category settings" code="oscc" description="Object style content effects category settings."><