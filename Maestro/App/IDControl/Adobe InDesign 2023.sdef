ur type" code="pcot" type="enct" description="The contour type."></property><property name="include inside edges" code="iied" type="boolean" description="If true, creates interior clipping paths within the surrounding clipping path. Note: Valid only when clipping type is alpha channel or detect edges. "></property><property name="object reference" code="posp" type="contour option" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="text wrap preference" access="r" description="The parent of the contour option (a text wrap preference)."></property><property name="photoshop path names" code="ptns" access="r" description="A list of the clipping paths stored in the graphic."><type type="text" list="yes"></type></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property></class><class name="EPS" code="EPS " description="A placed EPS file." inherits="graphic" plural="EPSs"><element type="event"></element><element type="event listener"></element><element type="graphic"></element><element type="page item"></element><element type="preference"></element><element type="SVG"></element><property name="absolute flip" code="flsa" type="EnFp" description="Indicates whether the EPS has been flipped independently of its parent object and, if yes, the direction in which the EPS was flipped."></property><property name="absolute horizontal scale" code="Ahzs" type="real" description="The horizontal scale of the EPS relative to its containing object."></property><property name="absolute rotation angle" code="Aang" type="real" description="The rotation angle of the EPS relative to its containing object. (Range: -360 to 360)"></property><property name="absolute shear angle" code="Askw" type="real" description="The skewing angle of the EPS relative to its containing object. (Range: -360 to 360)"></property><property name="absolute 