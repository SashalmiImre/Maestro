s name="path" code="ppth" description="A path." plural="paths"><element type="event"></element><element type="event listener"></element><element type="path point"></element><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="entire path" code="plst" description="A list of the coordinates of all of the path points on the path, including anchor points and left- and right-direction points. When creating a path using this property, supply either a list of anchor point coordinates ([[x1, y1], [x2, y2], ...]) or a list of anchor point, left-direction point, and right-direction point coordinates ([[[x1, y1], [x2, y2], [x3, y3]], [[x4, y4], [x5, y5], [x6, y6]], ...]). Note: Providing only anchor points results in a path on which all of the path points are connected with straight line segments; supplying the positions of left- and right-direction points specifies curved line segments. Can return: list of lists of 2 numbers or strings."><type type="any" list="yes"></type></property><property name="index" code="pidx" type="integer" access="r" description="The index of the path within its containing object."></property><property name="object reference" code="posp" type="path" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the path (a spline item, polygon, graphic line, rectangle, oval, text frame, endnote text frame, media item, sound, movie, button, multi state object, clipping path settings or text wrap preference). Can return: spline item, polygon, graphic line, rectangle, oval, text frame, endnote text frame, media item, sound, movie, button, multi state object, clipping path settings or text wrap preference."></property><property name="path type" code="ptyp" type="paty" description="The path type."></property><property name="properties" code="qpro" type="record" description="A property 