ords added to the user dictionary."><type type="text" list="yes"></type></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="index" code="pidx" type="integer" access="r" description="The index of the user dictionary within its containing object."></property><property name="name" code="pnam" type="text" access="r" description="The name of the user dictionary."></property><property name="object reference" code="posp" type="user dictionary" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the user dictionary (a application)."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="removed words" code="notw" description="A list of words removed from the user dictionary."><type type="text" list="yes"></type></property></class><class name="word" code="cwor" description="A word." inherits="text.ctxt" plural="words"><element type="button"></element><element type="character"></element><element type="check box"></element><element type="combo box"></element><element type="endnote range"></element><element type="endnote text frame"></element><element type="EPSText"></element><element type="event"></element><element type="event listener"></element><element type="footnote"></element><element type="form field"></element><element type="graphic line"></element><element type="group"></element><element type="hidden text"></element><element type="insertion point"></element><element type="line"></element><element type="list box"></element><element type="multi state object"></element><element type="nested grep style"></element><element type="nested line style"></element><element type="nested style"></element><element type="note"></element><element type="oval"></element><elem