e type="specifier" list="yes"></type></property></class><class name="page item" code="pitm" description="An item on a page, including rectangles, ellipses, graphic lines, polygons, groups, text frames, and buttons." plural="page items"><element type="event"></element><element type="event listener"></element><element type="graphic"></element><element type="page item"></element><element type="preference"></element><element type="SVG"></element><property name="absolute flip" code="flsa" type="EnFp" description="Indicates whether the page item has been flipped independently of its parent object and, if yes, the direction in which the page item was flipped."></property><property name="absolute horizontal scale" code="Ahzs" type="real" description="The horizontal scale of the page item relative to its containing object."></property><property name="absolute rotation angle" code="Aang" type="real" description="The rotation angle of the page item relative to its containing object. (Range: -360 to 360)"></property><property name="absolute shear angle" code="Askw" type="real" description="The skewing angle of the page item relative to its containing object. (Range: -360 to 360)"></property><property name="absolute vertical scale" code="Avts" type="real" description="The vertical scale of the page item relative to its containing object."></property><property name="all articles" code="pAts" access="r" description="The list of all articles this page item is part of"><type type="article" list="yes"></type></property><property name="all graphics" code="aGrf" access="r" description="Lists all graphics contained by the page item."><type type="graphic" list="yes"></type></property><property name="all page items" code="aPgi" access="r" description="Lists all page items contained by the page item."><type type="page item" list="yes"></type></property><property name="allow overrides" code="ovbl" type="boolean" description="If true, the master page item can be overridden."></property><prop