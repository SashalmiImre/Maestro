n="The radius in measurement units of the corner effect applied to the top right corner of rectangular shapes"><type type="number"></type><type type="text"></type></property><property name="paragraph border type" code="psSy" type="any" description="The type of the border for the paragraph. Can return: stroke style or string."></property><property name="paragraph border width" code="pbWi" type="pbWe" description="The basis (text width or column width) used to calculate the width of the paragraph border."></property><property name="paragraph direction" code="pdir" type="padi" description="Paragraph direction."></property><property name="paragraph gyoudori" code="jpgd" type="boolean" description="If true, the gyoudori mode applies to the entire paragraph. If false, the gyoudori mode applies to each line in the paragraph."></property><property name="paragraph justification" code="pjus" type="pjut" description="Paragraph justification."></property><property name="paragraph kashida width" code="pkas" type="real" description="Paragraph kashida width. 0 is none, 1 is short, 2 is medium, 3 is long"></property><property name="paragraph shading bottom  right corner option" code="scO4" type="coPt" description="The shape to apply to the bottom right corner of rectangular shapes."></property><property name="paragraph shading bottom left corner option" code="scO3" type="coPt" description="The shape to apply to the bottom left corner of rectangular shapes."></property><property name="paragraph shading bottom left corner radius" code="scr3" description="The radius in measurement units of the corner effect applied to the bottom left corner of rectangular shapes"><type type="number"></type><type type="text"></type></property><property name="paragraph shading bottom offset" code="psOb" description="The distance to offset the bottom edge of the paragraph."><type type="number"></type><type type="text"></type></property><property name="paragraph shading bottom origin" code="psBo" type="ps