"></type></property><property name="paragraph border stroke end cap" code="psEc" type="ecap" description="The end shape of an open path."></property><property name="paragraph border stroke end join" code="psEj" type="ejon" description="The corner join applied to the word."></property><property name="paragraph border tint" code="psSt" type="real" description="The tint (as a percentage) of the paragraph stroke. (Range: 0 to 100)"></property><property name="paragraph border top left corner option" code="bcO1" type="coPt" description="The shape to be applied to the top left corner of rectangular shapes and all corners of non-rectangular shapes.Note: corner option differs from end join in which you can set a radius for a corner option, whereas the rounded or beveled effect of an end join depends on the stroke weight."></property><property name="paragraph border top left corner radius" code="bcr1" description="The radius in measurement units of the corner effect applied to the top left corner of rectangular shapes and all corners of non-rectangular shapes"><type type="number"></type><type type="text"></type></property><property name="paragraph border top line weight" code="psWT" description="The top line weight of the border of paragraph."><type type="number"></type><type type="text"></type></property><property name="paragraph border top offset" code="pbOt" description="The distance to offset the top edge of the paragraph border."><type type="number"></type><type type="text"></type></property><property name="paragraph border top origin" code="pbTo" type="pbTe" description="The basis (cap height, ascent or baseline) used to calculate the top origin of the paragraph border."></property><property name="paragraph border top right corner option" code="bcO2" type="coPt" description="The shape to apply to the top right corner of rectangular shapes"></property><property name="paragraph border top right corner radius" code="bcr2" description="The radius in measurement units of the corner effect applied to the top right corner of rectangular shapes"><type type="number"></type><type type="text"></type></property><property name="paragraph border type" code="psSy" type="any" description="The type of the border for the paragraph. Can return: stroke style or string."></property><property name="paragraph border width" code="pbWi" type="pbWe" description="The basis (text width or column width) used to calculate the width of the paragraph border."></property><property name="paragraph direction" code="pdir" type="padi" description="Paragraph direction."></property><property name="paragraph gyoudori" code="jpgd" type="boolean" description="If true, the gyoudori mode applies to the entire paragraph. If false, the gyoudori mode applies to each line in the paragraph."></property><property name="paragraph justification" code="pjus" type="pjut" description="Paragraph justification."></property><property name="paragraph kashida width" code="pkas" type="real" description="Paragraph kashida width. 0 is none, 1 is short, 2 is medium, 3 is long"></property><property name="paragraph shading bottom  right corner option" code="scO4" type="coPt" description="The shape to apply to the bottom right corner of rectangular shapes."></property><property name="paragraph shading bottom left corner option" code="scO3" type="coPt" description="The shape to apply to the bottom left corner of rectangular shapes."></property><property name="paragraph shading bottom left corner radius" code="scr3" description="The radius in measurement units of the corner effect applied to the bottom left corner of rectangular shapes"><type type="number"></type><type type="text"></type></property><property name="paragraph shading bottom offset" code="psOb" description="The distance to offset the bottom edge of the paragraph."><type type="number"></type><type type="text"></type></property><property name="paragraph shading bottom origin" code="psBo" type="psBe" description="The basis (descent or baseline) used to calculate the bottom origin of the paragraph shading."></property><property name="paragraph shading bottom right corner radius" code="scr4" description="The radius in measurement units of the corner effect applied to the bottom right corner of rectangular shapes"><type type="number"></type><type type="text"></type></property><property name="paragraph shading clip to frame" code="psCf" type="boolean" description="If true, forces the shading of the paragraph to be clipped with respect to frame shape."></property><property name="paragraph shading color" code="psFc" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the paragraph shading. Can return: swatch or string."></property><property name="paragraph shading left offset" code="psOl" description="The distance to offset the left edge of the paragraph."><type type="number"></type><type type="text"></type></property><property name="paragraph shading on" code="pfOn" type="boolean" description="If true, the paragraph shading is On."></property><property name="paragraph shading overprint" code="psFo" type="boolean" description="If true, the paragraph shading will overprint."></property><property name="paragraph shading right offset" code="psOr" description="The distance to offset the right edge of the paragraph."><type type="number"></type><type type="text"></type></property><property name="paragraph shading suppress printing" code="psSp" type="boolean" description="If true, suppress printing of the shading of the paragraph."></property><property name="paragraph shading tint" code="psFt" type="real" description="The tint (as a percentage) of the paragraph shading. (Range: 0 to 100)"></property><property name="paragraph shading top left corner option" code="scO1" type="coPt" description="The shape to be applied to the top left corner of rectangular shapes and all corners of non-rectangular shapes.Note: corner option differs from end join in which you can set a radius for a corner option, whereas the rounded or beveled effect of an end join depends on the stroke weight."></property><property name="paragraph shading top left corner radius" code="scr1" description="The radius in measurement units of the corner effect applied to the top left corner of rectangular shapes and all corners of non-rectangular shapes"><type type="number"></type><type type="text"></type></property><property name="paragraph shading top offset" code="psOt" description="The distance to offset the top edge of the paragraph."><type type="number"></type><type type="text"></type></property><property name="paragraph shading top origin" code="psTo" type="psTe" description="The basis (cap height, ascent or baseline) used to calculate the top origin of the paragraph shading."></property><property name="paragraph shading top right corner option" code="scO2" type="coPt" description="The shape to apply to the top right corner of rectangular shapes"></property><property name="paragraph shading top right corner radius" code="scr2" description="The radius in measurement units of the corner effect applied to the top right corner of rectangular shapes"><type type="number"></type><type type="text"></type></property><property name="paragraph shading width" code="psWi" type="psWe" description="The basis (text width or column width) used to calculate the width of the paragraph shading."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the word (a hidden text, text path, text frame, endnote text frame, text, insertion point, text style range, paragraph, text column, line, word, character, story, xml story, cell, XML element, endnote, footnote, change or note). Can return: hidden text, text path, text frame, endnote text frame, text, insertion point, text style range, paragraph, text column, line, word, character, story, xml story, cell, XML element, endnote, footnote, change or note."></property><property name="parent story" code="strp" type="story" access="r" description="The story that contains the text."></property><property name="parent text frames" code="pTxS" access="r" description="An array of the text frames that contain the text. Can return: list of text frames or text paths."><type type="specifier" list="yes"></type></property><property name="point size" code="ptsz" description="The text size."><type type="number"></type><type type="text"></type></property><property name="position" code="posm" type="pose" description="The text position relative to the baseline."></property><property name="positional form" code="OTPf" type="OTpf" description="The OpenType positional form."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="provider hyphenation style" code="phys" type="dphs" description="The hyphenation style chosen for the provider."></property><property name="rensuuji" code="jren" type="boolean" description="If true, disallows line breaks in numbers. If false, lines can break between digits in multi-digit numbers."></property><property name="right indent" code="inbr" description="The width of the right indent."><type type="number"></type><type type="text"></type></property><property name="rotate single byte characters" code="jro1" type="boolean" description="If true, rotates Roman characters in vertical text."></property><property name="ruby alignment" code="jral" type="Jrua" description="The ruby alignment."></property><property name="ruby auto align" code="jraa" type="boolean" description="If true, auto aligns ruby."></property><property name="ruby auto scaling" code="jras" type="boolean" description="If true, automatically scales ruby to the specified percent of parent text size. For information on specifying a percent, see ruby parent scaling percent. "></property><property name="ruby auto tcy auto scale" code="jrts" type="boolean" description="If true, automatically scales glyphs in auto tcy (tate-chuu-yoko) in ruby to fit one em."></property><property name="ruby auto tcy digits" code="jrtd" type="integer" description="The number of digits included in auto tcy (tate-chuu-yoko) in ruby."></property><property name="ruby auto tcy include roman" code="jrtr" type="boolean" description="If true, includes Roman characters in auto tcy (tate-chuu-yoko) in ruby."></property><property name="ruby fill" code="jrfl" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the fill of ruby characters. Can return: swatch or string."></property><property name="ruby flag" code="jrfg" type="boolean" description="If true, ruby is on. "></property><property name="ruby font" code="jrfn" type="any" description="The font applied to ruby characters. Can return: font or string."></property><property name="ruby font size" code="jrfs" type="real" description="The size (in points) of ruby characters."></property><property name="ruby font style" code="jrft" type="any" description="The font style of ruby characters. Can return: string or nothing."></property><property name="ruby open type pro" code="jpro" type="boolean" description="If true, uses OpenType Pro fonts for ruby."></property><property name="ruby overhang" code="jrov" type="boolean" description="If true, constrains ruby overhang to the specified amount. For information on specifying an amount, see ruby parent overhang amount. "></property><property name="ruby overprint fill" code="jrof" type="Jafl" description="The method of overprinting the ruby fill."></property><property name="ruby overprint stroke" code="jros" type="Jafl" description="The method of overprinting the ruby stroke."></property><property name="ruby parent overhang amount" code="jrva" type="Jruo" description="The amount by which ruby characters can overhang the parent text."></property><property name="ruby parent scaling percent" code="jrsc" type="real" description="The amount (as a percentage) to scale the parent text size to determine the ruby text size."></property><property name="ruby parent spacing" code="jrsp" type="Jers" description="The ruby spacing relative to the parent text. "></property><property name="ruby position" code="jrpz" type="Jkps" description="The position of ruby characters relative to the parent text."></property><property name="ruby string" code="jrsg" type="text" description="The ruby string contents."></property><property name="ruby stroke" code="jrsk" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the stroke of ruby characters. Can return: swatch or string."></property><property name="ruby stroke tint" code="jrst" type="real" description="The stroke tint (as a percentage) of ruby characters."></property><property name="ruby tint" code="jrti" type="real" description="The tint (as a percentage) of the ruby fill color. (Range: 0 to 100)"></property><property name="ruby type" code="jrtp" type="Jrty" description="The ruby type."></property><property name="ruby weight" code="jrwt" type="real" description="The stroke weight (in points) of ruby characters."></property><property name="ruby X offset" code="jrxo" type="real" description="The amount of horizontal space between ruby and parent characters."></property><property name="ruby X scale" code="jrwd" type="real" description="The horizontal size of ruby characters, specified as a percent of the original size."></property><property name="ruby Y offset" code="jryo" type="real" description="The amount of vertical space between ruby and parent characters."></property><property name="ruby Y scale" code="jrpt" type="real" description="The vertical size of ruby characters, specified as a percent of the original size."></property><property name="rule above" code="prar" type="boolean" description="If true, places a rule above the paragraph."></property><property name="rule above color" code="rlac" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the paragraph rule above. Can return: swatch or string."></property><property name="rule above gap color" code="ragc" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the stroke gap of the paragraph rule above. Note: Valid only when the paragraph rule above type is not solid. Can return: swatch or string."></property><property name="rule above gap overprint" code="rago" type="boolean" description="If true, the stroke gap of the paragraph rule above will overprint. Note: Valid only the rule above type is not solid."></property><property name="rule above gap tint" code="ragt" type="real" description="The tint (as a percentage) of the stroke gap color of the paragraph rule. (Range: 0 to 100) Note: Valid only when the rule above type is not solid."></property><property name="rule above left indent" code="pral" description="The distance to indent the left edge of the paragraph rule above (based on either the text width or the column width of the first line in the paragraph."><type type="number"></type><type type="text"></type></property><property name="rule above line weight" code="pras" description="The line weight of the rule above."><type type="number"></type><type type="text"></type></property><property name="rule above offset" code="paof" description="The amount to offset the paragraph rule above from the baseline of the first line the paragraph."><type type="number"></type><type type="text"></type></property><property name="rule above overprint" code="prao" type="boolean" description="If true, the paragraph rule above will overprint."></property><property name="rule above right indent" code="pair" description="The distance to indent the right edge of the paragraph rule above (based on either the text width or the column width of the first line in the paragraph."><type type="number"></type><type type="text"></type></property><property name="rule above tint" code="prat" type="real" description="The tint (as a 