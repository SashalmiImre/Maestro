r" code="rbgc" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the stroke gap of the paragraph rule below. Note: Valid only when the paragraph rule below type is not solid. Can return: swatch or string."></property><property name="rule below gap overprint" code="rbg2" type="boolean" description="If true, the gap color of the rule below will overprint."></property><property name="rule below gap tint" code="rbgt" type="real" description="The tint (as a percentage) of the stroke gap color of the paragraph rule below. (Range: 0 to 100) Note: Valid only when the paragraph rule below type is not solid."></property><property name="rule below left indent" code="prbl" description="The distance to indent the left edge of the paragraph rule below (based on either the text width or the column width of the last line in the paragraph."><type type="number"></type><type type="text"></type></property><property name="rule below line weight" code="prbs" description="The line weight of the rule below."><type type="number"></type><type type="text"></type></property><property name="rule below offset" code="pbop" description="The amount to offset the the paragraph rule below from the baseline of the last line of the paragraph."><type type="number"></type><type type="text"></type></property><property name="rule below overprint" code="prb2" type="boolean" description="If true, the rule below will overprint."></property><property name="rule below right indent" code="pbir" description="The distance to indent the right edge of the paragraph rule below (based on either the text width or the column width of the last line in the paragraph."><type type="number"></type><type type="text"></type></property><property name="rule below tint" code="prbt" type="real" description="The tint (as a percentage) of the paragraph rule below. (Range: 0 to 100)"></property><property name="rule below type" code="pbtp" type="any" description="The stroke type of the rule below the 