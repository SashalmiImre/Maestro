 on either the text width or the column width of the first line in the paragraph."><type type="number"></type><type type="text"></type></property><property name="rule above line weight" code="pras" description="The line weight of the rule above."><type type="number"></type><type type="text"></type></property><property name="rule above offset" code="paof" description="The amount to offset the paragraph rule above from the baseline of the first line the paragraph."><type type="number"></type><type type="text"></type></property><property name="rule above overprint" code="prao" type="boolean" description="If true, the paragraph rule above will overprint."></property><property name="rule above right indent" code="pair" description="The distance to indent the right edge of the paragraph rule above (based on either the text width or the column width of the first line in the paragraph."><type type="number"></type><type type="text"></type></property><property name="rule above tint" code="prat" type="real" description="The tint (as a percentage) of the paragraph rule above. (Range: 0 to 100)"></property><property name="rule above type" code="patp" type="any" description="The stroke type of the rule above the paragraph. Can return: stroke style or string."></property><property name="rule above width" code="rawd" type="rlwd" description="The basis (text width or column width) used to calculate the width of the paragraph rule above."></property><property name="rule below" code="prbr" type="boolean" description="If true, applies a paragraph rule below."></property><property name="rule below color" code="rlbc" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the paragraph rule below. Can return: swatch or string."></property><property name="rule below gap color" code="rbgc" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the stroke gap of the paragraph rule below. Note: Valid only when the paragraph rule below type is not solid. Can return: swatch or string."></property><property name="rule below gap overprint" code="rbg2" type="boolean" description="If true, the gap color of the rule below will overprint."></property><property name="rule below gap tint" code="rbgt" type="real" description="The tint (as a percentage) of the stroke gap color of the paragraph rule below. (Range: 0 to 100) Note: Valid only when the paragraph rule below type is not solid."></property><property name="rule below left indent" code="prbl" description="The distance to indent the left edge of the paragraph rule below (based on either the text width or the column width of the last line in the paragraph."><type type="number"></type><type type="text"></type></property><property name="rule below line weight" code="prbs" description="The line weight of the rule below."><type type="number"></type><type type="text"></type></property><property name="rule below offset" code="pbop" description="The amount to offset the the paragraph rule below from the baseline of the last line of the paragraph."><type type="number"></type><type type="text"></type></property><property name="rule below overprint" code="prb2" type="boolean" description="If true, the rule below will overprint."></property><property name="rule below right indent" code="pbir" description="The distance to indent the right edge of the paragraph rule below (based on either the text width or the column width of the last line in the paragraph."><type type="number"></type><type type="text"></type></property><property name="rule below tint" code="prbt" type="real" description="The tint (as a percentage) of the paragraph rule below. (Range: 0 to 100)"></property><property name="rule below type" code="pbtp" type="any" description="The stroke type of the rule below the paragraph. Can return: stroke style or string."></property><property name="rule below width" code="rbwd" type="rlwd" description="The basis (text width or column width) used to calculate the width of the paragraph rule below."></property><property name="same para style spacing" code="spsp" type="any" description="The space between paragraphs using same style. Can return: number or string or SetIgnore."></property><property name="scale affects line height" code="jslh" type="boolean" description="If true, the line changes size when characters are scaled. "></property><property name="shatai adjust rotation" code="jshr" type="boolean" description="If true, applies shatai rotation."></property><property name="shatai adjust tsume" code="jsht" type="boolean" description="If true, adjusts shatai tsume."></property><property name="shatai degree angle" code="jsha" type="real" description="The shatai lens angle (in degrees)."></property><property name="shatai magnification" code="jshp" type="real" description="The amount (as a percentage) of shatai obliquing to apply."></property><property name="single word justification" code="pals" type="sjst" description="The alignment to use for lines that contain a single word."></property><property name="skew" code="pskw" type="real" description="The skew angle of the paragraph style."></property><property name="space after" code="spaf" description="The height of the paragraph space below."><type type="number"></type><type type="text"></type></property><property name="space before" code="spbe" description="The height of the paragraph space above."><type type="number"></type><type type="text"></type></property><property name="span column min space after" code="scma" description="The minimum space after a span or a split column"><type type="number"></type><type type="text"></type></property><property name="span column min space before" code="scmb" description="The minimum space before a span or a split column"><type type="number"></type><type type="text"></type></property><property name="span column type" code="scte" type="spte" description="Whether a paragraph should be a single column, span columns or split columns"></prope