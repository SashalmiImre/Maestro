ical text."></property><property name="ruby alignment" code="jral" type="Jrua" description="The ruby alignment."></property><property name="ruby auto align" code="jraa" type="boolean" description="If true, auto aligns ruby."></property><property name="ruby auto scaling" code="jras" type="boolean" description="If true, automatically scales ruby to the specified percent of parent text size. For information on specifying a percent, see ruby parent scaling percent. "></property><property name="ruby auto tcy auto scale" code="jrts" type="boolean" description="If true, automatically scales glyphs in auto tcy (tate-chuu-yoko) in ruby to fit one em."></property><property name="ruby auto tcy digits" code="jrtd" type="integer" description="The number of digits included in auto tcy (tate-chuu-yoko) in ruby."></property><property name="ruby auto tcy include roman" code="jrtr" type="boolean" description="If true, includes Roman characters in auto tcy (tate-chuu-yoko) in ruby."></property><property name="ruby fill" code="jrfl" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the fill of ruby characters. Can return: swatch or string."></property><property name="ruby flag" code="jrfg" type="boolean" description="If true, ruby is on. "></property><property name="ruby font" code="jrfn" type="any" description="The font applied to ruby characters. Can return: font or string."></property><property name="ruby font size" code="jrfs" type="real" description="The size (in points) of ruby characters."></property><property name="ruby font style" code="jrft" type="any" description="The font style of ruby characters. Can return: string or nothing."></property><property name="ruby open type pro" code="jpro" type="boolean" description="If true, uses OpenType Pro fonts for ruby."></property><property name="ruby overhang" code="jrov" type="boolean" description="If true, constrains ruby overhang to the specified amount. For information on specifying an amount, see 