ws setting of several properties at the same time."></property><property name="text after" code="TVta" type="text" description="The text that follows the value of the variable. (Limit: 128 characters)"></property><property name="text before" code="TVtb" type="text" description="The text that precedes the value of the variable. (Limit: 128 characters)"></property></class><class name="fill transparency setting" code="xpQc" description="Transparency settings for the fill applied to the parent object."><element type="event"></element><element type="event listener"></element><element type="preference"></element><property name="bevel and emboss settings" code="xpS6" type="bevel and emboss setting" access="r" description="Settings related to the bevel and emboss effect."></property><property name="blending settings" code="xpS0" type="blending setting" access="r" description="Blending mode settings."></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="directional feather settings" code="xpS8" type="directional feather setting" access="r" description="Settings related to the directional feather effect."></property><property name="drop shadow settings" code="xpS1" type="drop shadow setting" access="r" description="Settings related to the drop shadow effect."></property><property name="feather settings" code="xpS2" type="feather setting" access="r" description="Settings related to the feather effect."></property><property name="gradient feather settings" code="xpS9" type="gradient feather setting" access="r" description="Settings related to the gradient feather effect."></property><property name="inner glow settings" code="xpS5" type="inner glow setting" access="r" description="Settings related to the inner glow effect."></property><property name="inner shadow settings" code="xpS3" type="inner shadow setting" access="r" description="Settings related to the inner shadow effect."></property><pro