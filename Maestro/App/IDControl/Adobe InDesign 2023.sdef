ype="specifier" description="Supported by the following objects: nested line style, nested grep style, text, character, word, line, text column, paragraph, text style range, insertion point, text frame, story, paragraph style, character style, tab stop, nested style, endnote, endnote range, endnote text frame, language, language with vendors, font, kinsoku table, mojikumi table, hyphenation exception, user dictionary, auto correct table, change, text path, note, footnote, text variable, text variable instance, style export tag map, paragraph style group, character style group, composite font, composite font entry, named grid, indexing sort option, bullet, numbering restart policy, numbering list, object style group, condition, hidden text, condition set."></direct-parameter><parameter name="event type" code="pEvT" type="text" description="The event type."></parameter><parameter name="handler" code="pHnd" type="any" description="The event handler. Can accept: alias or string or JavaScript Function."></parameter><parameter name="captures" code="pCps" type="boolean" optional="yes" description="This parameter is obsolete. Can accept: boolean (Default: FALSE)."></parameter><result type="event listener" description="The new event listener."></result></command><command name="add exception" code="TeXTadde" description="Adds the specified words to the hyphenation exceptions list."><direct-parameter type="hyphenation exception"></direct-parameter><parameter name="added exceptions" code="andh" type="text" description="The list of words to add."></parameter><parameter name="removed list" code="notl" type="boolean" optional="yes" description="If true, adds the words to the removed exceptions list. If false or unspecified, adds the words to the added exceptions list. Can accept: boolean (Default: FALSE)."></parameter></command><command name="add path" code="TeXTUNPH" description="Creates a new page item by combining the object with other objects. Deletes the objects if they do not intersect."><direct-parameter type="specifier" description="Supported by the following objects: text frame, endnote text frame."></direct-parameter><parameter name="with" code="with" type="page item" description="The object(s) to add."></parameter><result type="page item" description="The new page item."></result></command><command name="add word" code="TeXTaddw" description="Adds the specified words to the specified list in the dictionary."><direct-parameter type="user dictionary"></direct-parameter><parameter name="added words" code="andw" type="text" description="The words to add."></parameter><parameter name="removed list" code="notl" type="boolean" optional="yes" description="If true, adds the words to the removed words list. If false or unspecified, adds the words to the added words list. Can accept: boolean (Default: FALSE)."></parameter></command><command name="apply character style" code="TeXTXacs" description="Apply a character style."><direct-parameter type="specifier" description="Supported by the following objects: text, character, word, line, text column, paragraph, text style range, insertion point."></direct-parameter><parameter name="using" code="usng" type="character style" description="The character style to apply."></parameter></command><command name="apply conditions" code="TeXTXact" description="Apply one or more conditions."><direct-parameter type="specifier" description="Supported by the following objects: text, character, word, line, text column, paragraph, text style range, insertion point."></direct-parameter><parameter name="using" code="usng" type="condition" description="The condition(s) to apply"></parameter><parameter name="remove existing" code="rmex" type="boolean" optional="yes" description="If true, remove existing conditions. Can accept: boolean (Default: FALSE)."></parameter></command><command name="apply object style" code="TeXTAOsy" description="Applies the specified object style."><direct-parameter type="specifier" description="Supported by the following objects: text frame, endnote text frame."></direct-parameter><parameter name="using" code="usng" type="object style" description="The object style to apply."></parameter><parameter name="clearing overrides" code="clov" type="boolean" optional="yes" description="If true, clears the object's existing attributes before applying the style. Can accept: boolean (Default: TRUE)."></parameter><parameter name="clearing overrides through root object style" code="cotr" type="boolean" optional="yes" description="If true, clears attributes and formatting applied to the object that are not defined in the object style. Can accept: boolean (Default: FALSE)."></parameter></command><command name="apply paragraph style" code="TeXTXaps" description="Apply a paragraph style."><direct-parameter type="specifier" description="Supported by the following objects: text, character, word, line, text column, paragraph, text style range, insertion point."></direct-parameter><parameter name="using" code="usng" type="paragraph style" description="The paragraph style to apply."></parameter><parameter name="clearing overrides" code="clov" type="boolean" optional="yes" description="If true, clear any text attributes before applying the style. Can accept: boolean (Default: TRUE)."></parameter></command><command name="asynchronous export file" code="TeXTexAs" description="asynchronously exports the object(s) to a file."><direct-parameter type="specifier" description="Supported by the following objects: text, character, word, line, text column, paragraph, text style range, insertion point, text frame, story, endnote text frame."></direct-parameter><parameter name="format" code="exft" type="any" description="The export format, specified as an enumeration value or as an extension that appears in the Save as type or Format menu in the Export dialog. Can accept: tagged text/PDF type/EPS type/RTF/text type/XML/JPG/HTML/EPUB/fixed layout EPUB/HTMLFXL/InDesign snippet/InDesign markup/InCopy markup/PNG format/interactive PDF or string."></parameter><parameter name="to" code="kfil" description="The path to the export file."><type type="file"></type><type type="text"></type></parameter><parameter name="showing options" code="imot" type="boolean" optional="yes" description="If true, displays the export options dialog. Can accept: boolean (Default: FALSE)."></parameter><parameter name="using" code="usng" type="PDF export preset" optional="yes" description="The export style."></parameter><parameter name="version comments" code="vcmt" type="text" optional="yes" description="The comment for this version."></parameter><parameter name="force save" code="vclb" type="boolean" optional="yes" description="If true, forcibly saves a version. Can accept: boolean (Default: FALSE)."></parameter><result type="background task" description="object representing the asynchronous export"></result></command><command name="auto tag" code="TeXTXste" description="Tag the object or the parent story using default tags defined in XML preference."><direct-parameter type="specifier" description="Supported by the following objects: text, character, word, line, text column, paragraph, text style range, insertion point, text frame, story, endnote text frame."></direct-parameter></command><command name="bring forward" code="TeXTbrfr" description="Brings the object forward one level in its layer."><direct-parameter type="specifier" description="Supported by the following objects: text frame, endnote text frame."></direct-parameter></command><command name="bring to front" code="TeXTbtfr" description="Brings the object to the front of its layer or in front of a particular item."><direct-parameter type="specifier" description="Supported by the following objects: text frame, endnote text frame."></direct-parameter></command><command name="change glyph" code="TeXTFCGh" description="Finds glyphs that match the find what value and replaces the glyphs with the change to value. "><direct-parameter type="specifier" description="Supported by the following objects: text, character, word, line, text column, paragraph, text style range, insertion point, text frame, story, endnote text frame, text path."></direct-parameter><parameter name="reverse order" code="Rrvr" type="boolean" optional="yes" description="If true, returns the results in reverse order."></parameter><result type="text.ctxt" description="The replaced glyph(s)."></result></command><command name="change grep" code="TeXTFCGp" description="Finds text that matches the find what value and replaces the text with the change to value."><direct-parameter type="specifier" description="Supported by the following objects: text, character, word, line, text column, paragraph, text style range, insertion point, text frame, story, endnote text frame, text path."></direct-parameter><parameter name="reverse order" code="Rrvr" type="boolean" optional="yes" description="If true, returns the results in reverse order."></parameter><result type="text.ctxt" description="The replaced text."></result></command><command name="change object" code="TeXTFCOt" description="Finds objects that match the find what value and replace the objects with the change to value."><direct-parameter type="specifier" description="Supported by the following objects: text frame, endnote text frame."></direct-parameter><parameter name="reverse order" code="Rrvr" type="boolean" optional="yes" description="If true, returns the results in reverse order."></parameter><result type="page item" description="The replaced object(s)."></result></command><command name="change text" code="TeXTChgT" description="Finds text that matches the find what value and replaces the text with the change to value."><direct-parameter type="specifier" description="Supported by the following objects: text, character, word, line, text column, paragraph, text style range, insertion point, text frame, story, endnote text frame, text path."></direct-parameter><parameter name="reverse order" code="Rrvr" type="boolean" optional="yes" description="If true, returns the results in reverse order."></parameter><result type="text.ctxt" description="The replaced text."></result></command><command name="change transliterate" code="TeXTFCTl" description="Finds text that matches the find character type value and replaces the text with the change character type value."><direct-parameter type="specifier" description="Supported by the following objects: text, character, word, line, text column, paragraph, text style range, insertion point, text frame, story, endnote text frame, text path."></direct-parameter><parameter name="reverse order" code="Rrvr" type="boolean" optional="yes" description="If true, returns the results in reverse order."></parameter><result type="text.ctxt" description="The replaced text."></result></command><command name="changecase" code="TeXTccas" description="Sets the case of the text."><direct-parameter type="specifier" description="Supported by the following objects: text, character, word, line, text column, paragraph, text style range, insertion point, story."></direct-parameter><parameter name="using" code="usng" type="ccmd" description="The text case option."></parameter></command><command name="check in" code="TeXTbSUB" description="Checks in the story or stories."><direct-parameter type="story"></direct-parameter><parameter name="version comments" code="vcmt" type="text" optional="yes" description="The comment for this version."></parameter><parameter name="force save" code="vclb" type="boolean" optional="yes" description="If true, forcibly saves a version. Can accept: boolean (Default: FALSE)."></parameter><result type="boolean" description="True if the check in succeeded."></result></command><command name="check OpenType feature" code="TeXTCOTF" description="Checks whether the font supports the specified OpenType feature."><direct-parameter type="font"></direct-parameter><parameter name="using" code="usng" type="any" description="The OpenType feature to check for, specified either as an OpenType feature or a string. Can accept: low/discretionary ligatures feature/fractions feature/ordinal feature/swash feature/titling feature/contextual alternates feature/all small caps feature/superscript feature/subscript feature/numerator feature/denominator feature/tabular lining feature/proportional oldstyle feature/proportional lining feature/tabular oldstyle feature/default figure style feature/overlap swash/stylistic alternate/justification alternate/stretched alternate or string."></parameter><result type="boolean" description="If true, the font supports the specified feature."></result></command><command name="check out" code="TeXTbEDT" description="Checks out the story."><direct-parameter type="story"></direct-parameter><result type="boolean" description="If true, the check out succeeded."></result></command><command name="clear object style overrides" code="TeXTosco" description="Clear overrides for object style"><direct-parameter type="specifier" description="Supported by the following objects: text frame, endnote text frame."></direct-parameter></command><command name="clear overrides" code="TeXTCOvr" description="Clears the specified types of override."><direct-parameter type="specifier" description="Supported by the following objects: text, character, word, line, text column, paragraph, text style range, insertion point, story."></direct-parameter><parameter name="overrides to clear" code="ovtp" type="OvTp" optional="yes" description="The types of override to clear. Can accept: all/character only/paragraph only (Default: all)."></parameter></command><command name="clear transformations" code="TeXTcxfm" description="Clears transformations from the object. Transformations include rotation, scaling, flipping, fitting, and shearing."><direct-parameter type="specifier" description="Supported by the following objects: text frame, endnote text frame."></direct-parameter></command><command name="content place" code="TeXTcopl" description="Duplicate an object and place it into the target page item."><direct-parameter type="specifier" description="Supported by the following objects: text frame, endnote text frame."></direct-parameter><parameter name="page items" code="pits" type="page item" description="One or more page items to place or load"></parameter><parameter name="link page items" code="pLOO" type="boolean" optional="yes" description="Whether to link pageItems in content placer (if true it will override link stories value). Can accept: boolean (Default: FALSE)."></parameter><parameter name="link stories" code="pLSO" type="boolean" optional="yes" description="Whether to link stories in content placer (only applicable for single story, pageItem links will also be created in case of more than one item). Can accept: boolean (Default: FALSE)."></parameter><parameter name="map styles" code="pMSO" type="boolean" optional="yes" description="Whether to map styles in content placer. Can accept: boolean (Default: FALSE)."></parameter><parameter name="showing options" code="imot" type="boolean" optional="yes" description="Whether to display the link options dialog. Can accept: boolean (Default: FALSE)."></parameter><result type="specifier" description="The placed content. Can return: list of page items, graphics, stories or texts."></result></command><command name="convert bullets and numbering to text" code="TeXTbuCT" description="Convert bullets and numbering to text."><direct-parameter type="specifier" description="Supported by the following objects: text, character, word, line, text column, paragraph, text style range, insertion point, story, paragraph style."></direct-parameter></command><command name="convert shape" code="TeXTCOSH" description="Converts the object to a different shape."><direct-parameter type="specifier" description="Supported by the following objects: text frame, endnote text frame."></direct-parameter><parameter name="given" code="givn" type="CSOP" description="The object's new shape."></parameter><parameter name="number of sides" code="nsid" type="integer" optional="yes" description="The number of sides for the resulting polygon. (Range: 3 to 100). Can accept: integer (3 - 100)."></parameter><parameter name="inset percentage" code="istp" type="integer" optional="yes" description="The star inset percentage for the resulting polygon. (Range: 0.0 to 100.0) . Can accept: integer (0 - 100)."></parameter><parameter name="corner radius" code="pcrd" optional="yes" description="The corner radius of the resulting rectangle. Can accept: number or string (0 - 800 points)."><type type="number"></type><type type="text"></type></parameter></command><command name="convert to note" code="TeXTCvtN" description="Converts the text to a note."><direct-parameter type="specifier" description="Supported by the following objects: text, character, word, line, text column, paragraph, text style range, insertion point."></direct-parameter><result type="note" description="The new note."></result></command><command name="convert to raw text" code="TeXTCtRt" description="Convert the text frame contents to raw text"><direct-parameter type="specifier" description="Supported by the following objects: text frame, endnote text frame."></direct-parameter></command><command name="convert to table" code="TeXTToTb" description="Converts the text to a table."><direct-parameter type="specifier" description="Supported by the following objects: text, character, word, line, text column, paragraph, text style range, insertion point."></direct-parameter><parameter name="column separator" code="CSep" type="text" optional="yes" description="The character that starts a new column in the new table."></parameter><parameter name="row separator" code="RSep" type="text" optional="yes" description="The character starts a new row in the new table."></parameter><parameter name="number of columns" code="ncls" type="integer" optional="yes" description="The number of columns in the table. Note: Valid only when the column and row separator characters are the same. Can accept: integer (Default: 1)."></parameter><result type="table" description="The new table"></result></command><command name="convert to text" code="TeXTToTx" description="Converts the note to story text."><direct-parameter type="specifier" description="Supported by the following objects: note, footnote, text variable, text variable instance."></direct-parameter></command><command name="Create Email QR Code" code="TeXTQrem" description="Create Email QR Code on the page item or document"><direct-parameter type="specifier" description="Supported by the following objects: text, character, word, line, text column, paragraph, text style range, insertion point, text frame, endnote text frame."></direct-parameter><parameter name="email address" code="QETo" type="text" optional="yes" description="QR code Email Address"></parameter><parameter name="subject" code="QRSu" type="text" optional="yes" description="QR code Email Subject"></parameter><parameter name="body" code="GNbo" type="text" optional="yes" description="QR code Email Body Message"></parameter><parameter name="qr code swatch" code="QRsw" type="any" optional="yes" description="Swatch to be applied on generated QR Code Graphic . Can accept: swatch or string."></parameter><parameter name="with properties" code="prdt" type="text" optional="yes" description="Initial values for properties of the new object. Above parameters can also be passed as properties"></parameter></command><command name="create endnote" code="TeXTcren" description="Creates a new endnote. Internally it creates the endnote reference and its endnote text range."><direct-parameter type="insertion point"></direct-parameter><result type="endnote" description="The new endnote."></result></command><command name="Create Hyperlink QR Code" code="TeXTQurl" description="Create Hyperlink QR Code on the page item or document"><direct-parameter type="specifier" description="Supported by the following objects: text, character, word, line, text column, paragraph, text style range, insertion point, text frame, endnote text frame."></direct-parameter><parameter name="url link" code="QrUr" type="text" optional="yes" description="QR code Hyperlink URL "></parameter><parameter name="qr code swatch" code="QRsw" type="any" optional="yes" description="Swatch to be applied on generated QR Code Graphic . Can accept: swatch or string."></parameter><parameter name="with properties" code="prdt" type="text" optional="yes" description="Initial values for properties of the new object. Above parameters can also be passed as properties"></parameter></command><command name="create outlines" code="TeXTcout" description="Converts text to outlines. Each line of text becomes a polygon object. When the converted text is a single letter that has no internal spaces or detached parts, the polygon contains only a single path. Note: To determine whether a font allows the creation of outlines, see allow outlines."><direct-parameter type="specifier" description="Supported by the following objects: text, character, word, line, text column, paragraph, text style range, insertion point, text frame, story, endnote text frame."></direct-parameter><parameter name="delete original" code="dOrg" type="boolean" optional="yes" description="If true, deletes the original text. If false, creates the outlines as separate object(s) on top of the text. . Can accept: boolean (Default: TRUE)."></parameter><result type="page item" description="The polygon or polygons."></result></command><command name="Create Plain Text QR Code" code="TeXTQrPt" description="Create Plain Text QR Code on the page item"><direct-parameter type="specifier" description="Supported by the following objects: text, character, word, line, text column, paragraph, text style range, insertion point, text frame, endnote text frame."></direct-parameter><parameter name="plain text" code="TYPt" type="text" optional="yes" description="QR code Plain Text "></parameter><parameter name="qr code swatch" code="QRsw" type="any" optional="yes" description="Swatch to be applied on generated QR Code Graphic . Can accept: swatch or string."></parameter><parameter name="with properties" code="prdt" type="text" optional="yes" description="Initial values for properties of the new object. Above parameters can also be passed as properties"></parameter></command><command name="Create subset font" code="TeXTssFn" description="Create a copy of the font with just enough information to render the list of characters given."><direct-parameter type="font"></direct-parameter><parameter name="characters for subset" code="ssCs" type="text" description="String with all the characters used in the resulting font."></parameter><parameter name="font destination" code="ssFi" description="File location for the new font."><type type="file"></type><type type="text"></type></parameter></command><command name="create text fragment link" code="TeXTctfl" description="Experimental: Place the text fragment fetched from url onto insertion point and create a link"><direct-parameter type="insertion point"></direct-parameter><parameter name="link resource URI" code="lURI" type="text" description="Resource URI for the link."></parameter><parameter name="name" code="pnam" type="text" optional="yes" description="The tag name for the key."></parameter><result type="link" description="The created link "></result></command><command name="Create Text Msg QR Code" code="TeXTQrSm" description="Create Text Msg QR Code on the page item or document"><direct-parameter type="specifier" description="Supported by the following objects: text, character, word, line, text column, paragraph, text style range, insertion point, text frame, endnote text frame."></direct-parameter><parameter name="cell number" code="QPhN" type="text" optional="yes" description="QR code Text Phone Number"></parameter><parameter name="text message" code="QRtM" type="text" optional="yes" description="QR code Text Message"></parameter><parameter name="qr code swatch" code="QRsw" type="any" optional="yes" description="Swatch to be applied on generated QR Code Graphic . Can accept: swatch or string."></parameter><parameter name="with properties" code="prdt" type="text" optional="yes" description="Initial values for properties of the new object. Above parameters can also be passed as properties"></parameter></command><command name="Create vCard QR Code" code="TeXTQrVc" description="Create Business Card QR Code on the page item or load on document's placegun"><direct-parameter type="specifier" description="Supported by the following objects: text, character, word, line, text column, paragraph, text style range, insertion point, text frame, endnote text frame."></direct-parameter><parameter name="first name" code="QRFN" type="text" optional="yes" description="QR code Business Card First Name"></parameter><parameter name="last name" code="QRLN" type="text" optional="yes" description="QR code Business Card Last Name"></parameter><parameter name="job title" code="QRTl" type="text" optional="yes" description="QR code Business Card Title"></parameter><parameter name="cell phone" code="QRCP" type="text" optional="yes" description="QR code Business Card Cell Phone Number"></parameter><parameter name="phone" code="QRPh" type="text" optional="yes" description="QR code Business Card Phone Number"></parameter><parameter name="email" code="QREm" type="text" optional="yes" description="QR code Business Card Email Address"></parameter><parameter name="organisation" code="QROg" type="text" optional="yes" description="QR code Business Card Organisation"></parameter><parameter name="street Address" code="QRAd" type="text" optional="yes" description="QR code Business Card Street Address"></parameter><parameter name="city" code="QRCi" type="text" optional="yes" description="QR code Business Card City"></parameter><parameter name="adr state" code="QRSt" type="text" optional="yes" description="QR code Business Card State"></parameter><parameter name="country" code="QRCn" type="text" optional="yes" description="QR code Business Card Country"></parameter><parameter name="postal code" code="QRPC" type="text" optional="yes" description="QR code Business Card Postal Code"></parameter><parameter name="website" code="QRUr" type="text" optional="yes" description="QR code Business Card URL"></parameter><parameter name="qr code swatch" code="QRsw" type="any" optional="yes" description="Swatch to be applied on generated QR Code Graphic . Can accept: swatch or string."></parameter><parameter name="with properties" code="prdt" type="text" optional="yes" description="Initial values for properties of the new object. Above parameters can also be passed as properties"></parameter></command><command name="delete endnote" code="TeXTdena" description="Deletes the endnote reference and the associated endnote text range."><direct-parameter type="endnote"></direct-parameter></command><command name="delete endnote range" code="TeXTdenr" description="Deletes the endnote range and the associated endnote anchor."><direct-parameter type="endnote range"></direct-parameter></command><command name="detach" code="TeXTdtch" description="Detaches an overridden master page item from the master page."><direct-parameter type="specifier" description="Supported by the following objects: text frame, endnote text frame."></direct-parameter></command><command name="exclude overlap path" code="TeXTXOPH" description="Creates a new page item by excluding the overlapping areas of the object and other objects."><direct-parameter type="specifier" description="Supported by the following objects: text frame, endnote text frame."></direct-parameter><parameter name="with" code="with" type="page item" description="The object(s) to exclude."></parameter><result type="page item" description="The new page item."></result></command><command name="export" code="TeXTexpt" description="Exports the object(s) to a file."><direct-parameter type="specifier" description="Supported by the following objects: text, character, word, line, text column, paragraph, text style range, insertion point, text frame, story, endnote text frame."></direct-parameter><parameter name="format" code="exft" type="any" description="The export format, specified as an enumeration value or as an extension that appears in the Save as type or Format menu in the Export dialog. Can accept: tagged text/PDF type/EPS type/RTF/text type/XML/JPG/HTML/EPUB/fixed layout EPUB/HTMLFXL/InDesign snippet/InDesign markup/InCopy markup/PNG format/interactive PDF or string."></parameter><parameter name="to" code="kfil" description="The path to the export file."><type type="file"></type><type type="text"></type></parameter><parameter name="showing options" code="imot" type="boolean" optional="yes" description="If true, displays the export options dialog. Can accept: boolean (Default: FALSE)."></parameter><parameter name="using" code="usng" type="PDF export preset" optional="yes" description="The export style."></parameter><parameter name="version comments" code="vcmt" type="text" optional="yes" description="The comment for this version."></parameter><parameter name="force save" code="vclb" type="boolean" optional="yes" description="If true, forcibly saves a version. Can accept: boolean (Default: FALSE)."></parameter></command><command name="extract labels" code="TeXTexLs" description="Gets the label value associated with the specified key. If key string is null, then a list of key-value pairs associated with the item is returned."><direct-parameter type="specifier" description="Supported by the following objects: text frame, endnote text frame."></direct-parameter><parameter name="key" code="with" type="text" optional="yes" description="The key."></parameter><result type="any" description="The label. Can return: string or list of lists of 2 strings."></result></command><command name="find glyph" code="TeXTFGph" description="Finds glyphs that match the find what value."><direct-parameter type="specifier" description="Supported by the following objects: text, character, word, line, text column, paragraph, text style range, insertion point, text frame, story, endnote text frame, text path."></direct-parameter><parameter name="reverse order" code="Rrvr" type="boolean" optional="yes" description="If true, returns the results in reverse order."></parameter><result type="text.ctxt" description="The found glyph(s)."></result></command><command name="find grep" code="TeXTFGrp" description="Finds text that matches the find what value."><direct-parameter type="specifier" description="Supported by the following objects: text, character, word, line, text column, paragraph, text style range, insertion point, text frame, story, endnote text frame, text path."></direct-parameter><parameter name="reverse order" code="Rrvr" type="boolean" optional="yes" description="If true, returns the results in reverse order."></parameter><result type="text.ctxt" description="The found text."></result></command><command name="find hyperlinks" code="TeXTfdhl" description="Finds hyperlink sources that intersecting with specified text range."><direct-parameter type="specifier" description="Supported by the following objects: text, character, word, line, text column, paragraph, text style range, insertion point."></direct-parameter><parameter name="sort order" code="SOdr" type="hrso" optional="yes" description="The sort order of found ranges."></parameter><result type="hyperlink text source" description="The found hyperlinks."></result></command><command name="find object" code="TeXTFOjt" description="Finds objects that match the find what value."><direct-parameter type="specifier" description="Supported by the following objects: text frame, endnote text frame."></direct-parameter><parameter name="reverse order" code="Rrvr" type="boolean" optional="yes" description="If true, returns the results in reverse order."></parameter><result type="page item" description="The found object(s)."></result></command><command name="find text" code="TeXTFndT" description="Finds text that matches the find what value."><direct-parameter type="specifier" description="Supported by the following objects: text, character, word, line, text column, paragraph, text style range, insertion point, text frame, story, endnote text frame, text path."></direct-parameter><parameter name="reverse order" code="Rrvr" type="boolean" optional="yes" description="If true, returns the results in reverse order."></parameter><result type="text.ctxt" description="The found text."></result></command><command name="find transliterate" code="TeXTFTlt" description="Finds text that matches the find character type value."><direct-parameter type="specifier" description="Supported by the following objects: text, character, word, line, text column, paragraph, text style range, insertion point, text frame, story, endnote text frame, text path."></direct-parameter><parameter name="reverse order" code="Rrvr" type="boolean" optional="yes" description="If true, returns the results in reverse order."></parameter><result type="text.ctxt" description="The found text."></result></command><command name="fit" code="TeXTfitc" description="Applies the specified fit option to content in a frame."><direct-parameter type="specifier" description="Supported by the following objects: text frame, endnote text frame."></direct-parameter><parameter name="given" code="givn" type="fito" description="The fit option to use."></parameter></command><command name="flip item" code="TeXTflip" description="Flips the object."><direct-parameter type="specifier" description="Supported by the following objects: text frame, endnote text frame."></direct-parameter><parameter name="given" code="givn" type="EnFp" description="The axis around which to flip the object."></parameter><parameter name="around" code="arnd" type="any" optional="yes" description="The point around which to flip the object. Can accept: list of 2 numbers or strings or top left anchor/top center anchor/top right anchor/left center anchor/center anchor/right center anchor/bottom left anchor/bottom center anchor/bottom right anchor."></parameter></command><command name="insert text in endnote" code="TeXTitie" description="Insert the text in endnote text range at specified text index. Insertion position should lie within the start and end range indices excluding the markers"><direct-parameter type="endnote"></direct-parameter><parameter name="story offset" code="STof" type="insertion point" description="The location within the story, specified as an insertion point."></parameter><parameter name="contents" code="pcnt" type="text" description="The content to insert."></parameter></command><command name="intersect path" code="TeXTISPH" description="Creates a new page item by intersecting the object with other objects. Returns an error if the objects do not intersect."><direct-parameter type="specifier" description="Supported by the following objects: text frame, endnote text frame."></direct-parameter><parameter name="with" code="with" type="page item" description="The object(s) with which to intersect. "></parameter><result type="page item" description="The new page item."></result></command><command name="is nth design axis hidden" code="TeXTgndv" description="If true, Nth design axis of variable font is hidden."><direct-parameter type="specifier" description="Supported by the following objects: text, character, word, line, text column, paragraph, text style range, insertion point, story, paragraph style, character style."></direct-parameter><parameter name="nth axis index" code="nxsi" type="integer" description="Index of design axis."></parameter><result type="boolean" description="Return true if design axis of variable font is hidden."></result></command><command name="make compound path" code="TeXTMCPH" description="Creates a compound path by combining the path(s) of the object with the paths of other objects."><direct-parameter type="specifier" description="Supported by the following objects: text frame, endnote text frame."></direct-parameter><parameter name="with" code="with" type="page item" description="The other objects whose paths to include in the new compound path."></parameter><result type="page item" description="The new compound path."></result></command><command name="markup" code="TeXTXmku" description="Associates the page item with the specified XML element while preserving existing content."><direct-parameter type="specifier" description="Supported by the following objects: text, character, word, line, text column, paragraph, text style range, insertion point, text frame, story, endnote text frame."></direct-parameter><parameter name="using" code="usng" type="XML element" description="The XML element."></parameter></command><command name="minus back" code="TeXTRDPH" description="Creates a new page item by reverse subtracting the overlapping areas of the object and other objects."><direct-parameter type="specifier" description="Supported by the following objects: text frame, endnote text frame."></direct-parameter><parameter name="with" code="with" type="page item" description="The object(s) to reverse subtract."></parameter><result type="page item" description="The new page item."></result></command><command name="override" code="TeXTovrr" description="Overrides a master page item and places the item on the document page as a new object."><direct-parameter type="specifier" description="Supported by the following objects: text frame, endnote text frame."></direct-parameter><parameter name="destination page" code="dPge" type="page" description="The document page that contains the master page item to override."></parameter><result type="specifier" description="The new object. Can return: page item, guide, graphic, movie or sound."></result></command><command name="place" code="TeXTplac" description="Places the file."><direct-parameter description="The file to place. Supported by the following objects: text, character, word, line, text column, paragraph, text style range, insertion point, text frame, endnote text frame."><type type="file"></type><type type="text"></type></direct-parameter><parameter name="on" code="insh" type="specifier" optional="yes" description="Where to place the file. Can accept: spread, page, master spread, page item or graphic."></parameter><parameter name="place point" code="insw" optional="yes" description="The point at which to place (only applicable if you are telling a page or spread to place)"><type type="number"></type><type type="text"></type></parameter><parameter name="destination layer" code="pdlr" type="layer" optional="yes" description="The layer on which to place (only applicable if you are telling a page or spread to place)"></parameter><parameter name="showing options" code="imot" type="boolean" optional="yes" description="Whether to display the import options dialog. Can accept: boolean (Default: FALSE)."></parameter><parameter name="autoflowing" code="aflw" type="boolean" optional="yes" description="Whether to autoflow placed text. Can accept: boolean (Default: FALSE)."></parameter><parameter name="with properties" code="prdt" type="record" optional="yes" description="Initial values for properties of the placed object(s)"></parameter><result type="specifier" description="The placed file. Can return: list of page items, graphics, movies, sounds, stories or texts."></result></command><command name="place and link" code="TeXTplli" description="Deprecated: Use contentPlace method. Original Description: Create a linked story and place it into the target page item."><direct-parameter type="specifier" description="Supported by the following objects: text frame, endnote text frame."></direct-parameter><parameter name="parent story" code="strp" type="story" description="The story to place and link from."></parameter><parameter name="showing options" code="imot" type="boolean" optional="yes" description="Whether to display the link options dialog. Can accept: boolean (Default: FALSE)."></parameter><result type="story" description="The placed story"></result></command><command name="place XML" code="TeXTXplc" description="Places XML content into the specified object. Note: Replaces any existing content."><direct-parameter type="specifier" description="Supported by the following objects: text frame, story, endnote text frame."></direct-parameter><parameter name="using" code="usng" type="XML element" description="The XML element whose content you want to place."></parameter><parameter name="place point" code="insw" optional="yes" description="The point at which to place the object, specified in the format [x, y].  Only applicable for page and spread."><type type="number"></type><type type="text"></type></parameter><parameter name="autoflowing" code="aflw" type="boolean" optional="yes" description="If true, autoflows placed text.  Only applicable for page and spread. Can accept: boolean (Default: FALSE)."></parameter></command><command name="recompose" code="TeXTRcmp" description="Recomposes the text in the object."><direct-parameter type="specifier" description="Supported by the following objects: text, character, word, line, text column, paragraph, text style range, insertion point, text frame, story, endnote text frame."></direct-parameter></command><command name="redefine" code="TeXTplRC" description="Redefine a condition set with the currently existing conditions and visibilities."><direct-parameter type="condition set"></direct-parameter></command><command name="redefine scaling" code="TeXTpshs" description="Apply an item's scaling to its content if possible."><direct-parameter type="specifier" description="Supported by the following objects: text frame, endnote text frame."></direct-parameter><parameter name="to" code="to  " type="real" optional="yes" description="The scale factors to be left on the item.  The default is {1.0, 1.0}."></parameter></command><command name="reframe" code="TeXTtlbr" description="Move the bounding box of the page item"><direct-parameter type="specifier" description="Supported by the following objects: text frame, endnote text frame."></direct-parameter><parameter name="in" code="in  " type="any" description="The bounding box to resize. Can accept: pasteboard coordinates/parent coordinates/inner coordinates/page coordinates/spread coordinates or Ordered list containing coordinate space:pasteboard coordinates/parent coordinates/inner coordinates/page coordinates/spread coordinates, bounds kind:outer stroke bounds/geometric path bounds."></parameter><parameter name="opposing corners" code="BoxC" type="real" description="Opposing corners of new bounding box in the given coordinate space"></parameter></command><command name="reject" code="TeXTRjct" description="Rejects the tracked change. Note: Valid only when track changes is true."><direct-parameter type="change"></direct-parameter></command><command name="release compound path" code="TeXTRCPH" description="Releases a compound path."><direct-parameter type="specifier" description="Supported by the following objects: text frame, endnote text frame."></direct-parameter><result type="page item" description="The paths that made up the compound path (as individual objects)."></result></command><command name="remove dictionary path" code="TeXTRdcp" description="Removes the specified user dictionary."><direct-parameter type="language with vendors"></direct-parameter><parameter name="file path" code="path" type="text" description="The path to the dictionary file."></parameter><result type="text" description="The dictionary file."></result></command><command name="remove event listener" code="TeXTeREL" description="Removes the event listener."><direct-parameter type="specifier" description="Supported by the following objects: nested line style, nested grep style, text, character, word, line, text column, paragraph, text style range, insertion point, text frame, story, paragraph style, character style, tab stop, nested style, endnote, endnote range, endnote text frame, language, language with vendors, font, kinsoku table, mojikumi table, hyphenation exception, user dictionary, auto correct table, change, text path, note, footnote, text variable, text variable instance, style export tag map, paragraph style group, character style group, composite font, composite font entry, named grid, indexing sort option, bullet, numbering restart policy, numbering list, object style group, condition, hidden text, condition set."></direct-parameter><parameter name="event type" code="pEvT" type="text" description="The registered event type."></parameter><parameter name="handler" code="pHnd" type="any" description="The registered event handler. Can accept: alias or string or JavaScript Function."></parameter><parameter name="captures" code="pCps" type="boolean" optional="yes" description="This parameter is obsolete. Can accept: boolean (Default: FALSE)."></parameter><result type="boolean" description="Returns true if the handler was previously registered for this event."></result></command><command name="remove exception" code="TeXTrmve" description="Removes the specified words from the hyphenation exceptions list."><direct-parameter type="hyphenation exception"></direct-parameter><parameter name="removed exceptions" code="noth" type="text" description="The list of words to remove."></parameter><parameter name="removed list" code="notl" type="boolean" optional="yes" description="If true, removes the words from the removed exceptions list. If false or unspecified, adds the words to the added exceptions list. Can accept: boolean (Default: FALSE)."></parameter></command><command name="remove override" code="TeXTrmov" description="Removes the override from a previously overridden master page item."><direct-parameter type="specifier" description="Supported by the following objects: text frame, endnote text frame."></direct-parameter></command><command name="remove word" code="TeXTrmvw" description="Removes the specified words from the specified list in the dictionary."><direct-parameter type="user dictionary"></direct-parameter><parameter name="removed words" code="notw" type="text" description="The words to remove."></parameter><parameter name="removed list" code="notl" type="boolean" optional="yes" description="If true, removes the words from the removed words list. If false or unspecified, removes the words from the added words list. Can accept: boolean (Default: FALSE)."></parameter></command><command name="reset overlay defaults" code="TeXTrodf" description="Reset overlay to its default values and/or clear overlay type."><direct-parameter type="specifier" description="Supported by the following objects: text frame, endnote text frame."></direct-parameter><parameter name="overlay type" code="dpol" type="text" description="The overlay type to reset"></parameter><parameter name="clear asset" code="coas" type="boolean" optional="yes" description="The flag to clear overlay asset"></parameter><parameter name="clear overlay" code="cotp" type="boolean" optional="yes" description="The flag to clear overlay"></parameter></command><command name="resize" code="TeXTscal" description="Resize the page item."><direct-parameter type="specifier" description="Supported by the following objects: text frame, endnote text frame."></direct-parameter><parameter name="in" code="in  " type="any" description="The bounding box to resize. Can accept: pasteboard coordinates/parent coordinates/inner coordinates/page coordinates/spread coordinates, outer stroke bounds/geometric path bounds or Ordered list containing coordinate space:pasteboard coordinates/parent coordinates/inner coordinates/page coordinates/spread coordinates, bounds kind:outer stroke bounds/geometric path bounds."></parameter><parameter name="from" code="zpnt" type="any" description="The transform origin. Legal specifications: relative to bounding box: anchor | {anchor | {x,y}, bounds kind [, coordinate space]}; relative to coordinate space: {x,y} | {{x,y}[, coordinate space]}; relative to layout window ruler: {{x,y}, page index | bounds kind}. Can accept: list of 2 fixed, top left anchor/top center anchor/top right anchor/left center anchor/center anchor/right center anchor/bottom left anchor/bottom center anchor/bottom right anchor or list of lists of 2 fixed, pasteboard coordinates/parent coordinates/inner coordinates/page coordinates/spread coordinates, top left anchor/top center anchor/top right anchor/left center anchor/center anchor/right center anchor/bottom left anchor/bottom center anchor/bottom right anchor, outer stroke bounds/geometric path bounds or integers."></parameter><parameter name="by" code="by  " type="rMet" description="How the current dimensions are affected by the given values"></parameter><parameter name="values" code="BoxD" type="any" description="The width and height values. Legal dimensions specifications: {x, y [, coordinate space]}, {x, resize constraint [, coordinate space]}, or {resize constraint, y [, coordinate space]}; where x and y are real numbers and coordinate space is used to determine _only_ the unit of length for x and y; coordinate space is ignored for the 'current dimensions times' resize method). Can accept: list of fixed, keep current value/keep current proportions/tall proportions/wide proportions/inverse proportions or pasteboard coordinates/parent coordinates/inner coordinates/page coordinates/spread coordinates."></parameter><parameter name="resize individually" code="rPer" type="boolean" optional="yes" description="If false and multiple page items are targeted, the new dimensions are attained only by moving the individual items rather than resizing them. Can accept: boolean (Default: TRUE)."></parameter><parameter name="considering ruler units" code="seeR" type="boolean" optional="yes" description="If true then a ruler location is interpreted using ruler units rather than points. The default value is false. This parameter has no effect unless the reference point is specified relative to a page. Can accept: boolean (Default: FALSE)."></parameter></command><command name="resolve" code="TeXTwher" description="Get the coordinates of the given location in the specified coordinate system."><direct-parameter type="specifier" description="Supported by the following objects: text frame, endnote text frame."></direct-parameter><parameter name="location" code="corn" type="any" description="The location requested. Can accept: list of 2 fixed, top left anchor/top center anchor/top right anchor/left center anchor/center anchor/right center anchor/bottom left anchor/bottom center anchor/bottom right anchor or list of lists of 2 fixed, pasteboard coordinates/parent coordinates/inner coordinates/page coordinates/spread coordinates, top left anchor/top center anchor/top right anchor/left center anchor/center anchor/right center anchor/bottom left anchor/bottom center anchor/bottom right anchor, outer stroke bounds/geometric path bounds or integers."></parameter><parameter name="in" code="in  " type="xyxy" description="The coordinate space to use."></parameter><parameter name="considering ruler units" code="seeR" type="boolean" optional="yes" description="If true then a ruler location is interpreted using ruler units rather than points. The default value is false. This parameter has no effect unless the reference point is specified relative to a page. Can accept: boolean (Default: FALSE)."></parameter><result type="any" description="The resolved location for each of the targeted page items. Can return: list of 2 fixed or list of lists of 2 fixed."></result></command><command name="revert" code="TeXTbREV" description="Reverts the document to its state at the last save operation. "><direct-parameter type="story"></direct-parameter><result type="boolean" description="If true, the revert succeeded."></result></command><command name="select" code="TeXTselt" description="Selects the object."><direct-parameter type="specifier" description="Supported by the following objects: text, character, word, line, text column, paragraph, text style range, insertion point, text frame, endnote text frame."></direct-parameter><parameter name="existing selection" code="exts" type="enSl" optional="yes" description="The selection status of the object in relation to previously selected objects. Can accept: add to/remove from/replace with/set key (Default: replace with)."></parameter></command><command name="send backward" code="TeXTsnbw" description="Sends the object back one level in its layer."><direct-parameter type="specifier" description="Supported by the following objects: text frame, endnote text frame."></direct-parameter></command><command name="send to back" code="TeXTsnbk" description="Sends the object to the back of its layer or behind a particular item (must have same parent)."><direct-parameter type="specifier" description="Supported by the following objects: text frame, endnote text frame."></direct-parameter></command><command name="set nth design axis" code="TeXTsndx" description="Set Nth design axis of a variable font."><direct-parameter type="specifier" description="Supported by the following objects: text, character, word, line, text column, paragraph, text style range, insertion point, story, paragraph style, character style."></direct-parameter><parameter name="nth axis index" code="nxsi" type="integer" description="Index of design axis."></parameter><parameter name="nth axis value" code="nxsv" type="real" description="Value of nth design axis."></parameter></command><command name="show text" code="TeXTshtx" description="Jump to the text range."><direct-parameter type="specifier" description="Supported by the following objects: text, character, word, line, text column, paragraph, text style range, insertion point."></direct-parameter></command><command name="store" code="TeXTstor" description="Stores the object in the specified library."><direct-parameter type="specifier" description="Supported by the following objects: text frame, endnote text frame."></direct-parameter><parameter name="using" code="usng" type="library" description="The library in which to store the object."></parameter><parameter name="with properties" code="prdt" type="record" optional="yes" description="Initial values for properties of the new object"></parameter><result type="asset" description="The new library asset(s)."></result></command><command name="story edit" code="TeXTSTed" description="Opens the story in a story editor window."><direct-parameter type="story"></direct-parameter><result type="story window" description="The story editor window."></result></command><command name="subtract path" code="TeXTDFPH" description="Creates a new page item by subtracting the overlapping areas of the object and other objects."><direct-parameter type="specifier" description="Supported by the following objects: text frame, endnote text frame."></direct-parameter><parameter name="with" code="with" type="page item" description="The object(s) to subtract."></parameter><result type="page item" description="The new page item."></result></command><command name="transform" code="TeXTxfrm" description="Transform the page item."><direct-parameter type="specifier" description="Supported by the following objects: text frame, endnote text frame."></direct-parameter><parameter name="in" code="in  " type="xyxy" description="The coordinate space to use"></parameter><parameter name="from" code="zpnt" type="any" description="The temporary origin during the transformation. Can accept: list of 2 fixed, top left anchor/top center anchor/top right anchor/left center anchor/center anchor/right center anchor/bottom left anchor/bottom center anchor/bottom right anchor or list of lists of 2 fixed, pasteboard coordinates/parent coordinates/inner coordinates/page coordinates/spread coordinates, top left anchor/top center anchor/top right anchor/left center anchor/center anchor/right center anchor/bottom left anchor/bottom center anchor/bottom right anchor, outer stroke bounds/geometric path bounds or integers."></parameter><parameter name="with matrix" code="1xfm" type="any" description="Transform matrix. Can accept: list of 6 fixed or transformation matrix."></parameter><parameter name="replacing current" code="mxto" type="any" optional="yes" description="Transform components to consider; providing this optional parameter causes the target's existing transform components to be replaced with new values.  Without this parameter, the given matrix is concatenated onto the target's existing transform combining the effect of the two. Can accept: scale values/shear value/rotation value/translation values, list of scale values/shear value/rotation value/translation values or integer."></parameter><parameter name="considering ruler units" code="seeR" type="boolean" optional="yes" description="If true then a ruler based origin is interpreted using ruler units rather than points. The default value is false. This parameter has no effect unless the reference point is specified relative to a page. Can accept: boolean (Default: FALSE)."></parameter></command><command name="transform again" code="TeXTTrAg" description="Transforms the object using the last transformation performed on any object. Transformations include moving, rotating, shearing, scaling, and flipping. "><direct-parameter type="specifier" description="Supported by the following objects: text frame, endnote text frame."></direct-parameter><result type="text" description="Playback errors."></result></command><command name="transform again individually" code="TeXTTrAI" description="Transforms the object using the last transformation performed on any object. Transformations include moving, rotating, shearing, scaling, and flipping. "><direct-parameter type="specifier" description="Supported by the following objects: text frame, endnote text frame."></direct-parameter><result type="text" description="Playback errors"></result></command><command name="transform sequence again" code="TeXTTrSA" description="Transforms the object using the last sequence of transform operations performed on any single object or performed at the same time on any group of objects. Transformations include moving, rotating, shearing, scaling, and flipping."><direct-parameter type="specifier" description="Supported by the following objects: text frame, endnote text frame."></direct-parameter><result type="text" description="Playback errors"></result></command><command name="transform sequence again individually" code="TeXTTrSI" description="Transforms the object using the last sequence of transformations performed on any single object or performed at the same time on any group of objects. Transformations include moving, rotating, shearing, scaling, and flipping."><direct-parameter type="specifier" description="Supported by the following objects: text frame, endnote text frame."></direct-parameter><result type="text" description="Playback errors"></result></command><command name="transform values of" code="TeXTxfva" description="Get the transformation values of the page item."><direct-parameter type="specifier" description="Supported by the following objects: text frame, endnote text frame."></direct-parameter><parameter name="in" code="in  " type="xyxy" description="The coordinate space to use"></parameter><result type="transformation matrix" description="A list of the transformation matrices"></result></command><class name="auto correct table" code="ACcr" description="An auto-correct table." plural="auto correct tables"><element type="event"></element><element type="event listener"></element><property name="auto correct word pair list" code="acwp" description="An auto-correct word pair, specified as a misspelled word and a corrected word. Can return: list of lists of 2 strings."><type type="any" list="yes"></type></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="index" code="pidx" type="integer" access="r" description="The index of the auto correct table within its containing object."></property><property name="name" code="pnam" type="text" access="r" description="The name of the auto correct table."></property><property name="object reference" code="posp" type="auto correct table" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the auto correct table (a application)."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property></class><class name="bullet" code="bnBF" description="Bullet character."><element type="event"></element><element type="event listener"></element><property name="bullets font" code="blfn" type="any" description="Font of the bullet character. Can return: font, string or auto value."></property><property name="bullets font style" code="blft" type="any" description="Font style of the bullet character. Can return: string, nothing or auto value."></property><property name="character type" code="bnbt" type="enBC" description="The type of bullet character."></property><property name="character value" code="bnbv" type="integer" description="The bullet character as a unicode ID or a glyph ID."></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="object reference" code="posp" type="bullet" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the bullet (a text default, paragraph style, text, insertion point, text style range, paragraph, text column, line, word, character, story, xml story, find text preference, change text preference, find grep preference, change grep preference, find transliterate preference or change transliterate preference). Can return: text default, paragraph style, text, insertion point, text style range, paragraph, text column, line, word, character, story, xml story, find text preference, change text preference, find grep preference, change grep preference, find transliterate preference or change transliterate preference."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property></class><class name="change" code="Chng" description="A tracked change made to a story." plural="changes"><element type="character"></element><element type="event"></element><element type="event listener"></element><element type="insertion point"></element><element type="line"></element><element type="paragraph"></element><element type="text.ctxt"></element><element type="text column"></element><element type="text style range"></element><element type="text variable instance"></element><element type="word"></element><property name="change type" code="dKin" type="dKin" access="r" description="The type of tracked change. Note: Valid only when track changes is true."></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="date" code="sdte" type="date" access="r" description="The date on which the tracked change was made. Note: Valid only when track changes is true."></property><property name="index" code="pidx" type="integer" access="r" description="The index of the change within its containing object."></property><property name="object reference" code="posp" type="change" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the change (a story, xml story or cell). Can return: story, xml story or cell."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="story offset" code="STof" type="insertion point" access="r" description="The location of the first insertion point in the object (relative to the beginning of the story)."></property><property name="user name" code="UsrN" type="text" access="r" description="The user who made the change. Note: Valid only when track changes is true."></property></class><class name="character" code="cha " description="A text character." inherits="text.ctxt" plural="characters"><element type="button"></element><element type="character"></element><element type="check box"></element><element type="combo box"></element><element type="endnote range"></element><element type="endnote text frame"></element><element type="EPSText"></element><element type="event"></element><element type="event listener"></element><element type="footnote"></element><element type="form field"></element><element type="graphic line"></element><element type="group"></element><element type="hidden text"></element><element type="insertion point"></element><element type="line"></element><element type="list box"></element><element type="multi state object"></element><element type="nested grep style"></element><element type="nested line style"></element><element type="nested style"></element><element type="note"></element><element type="oval"></element><element type="page item"></element><element type="paragraph"></element><element type="polygon"></element><element type="preference"></element><element type="radio button"></element><element type="rectangle"></element><element type="signature field"></element><element type="spline item"></element><element type="tab stop"></element><element type="table"></element><element type="text.ctxt"></element><element type="text box"></element><element type="text column"></element><element type="text frame"></element><element type="text style range"></element><element type="text variable instance"></element><element type="word"></element><property name="align to baseline" code="stbl" type="boolean" description="If true, aligns the baseline of the text to the baseline grid."></property><property name="all graphics" code="aGrf" access="r" description="Lists all graphics contained by the character."><type type="graphic" list="yes"></type></property><property name="all page items" code="aPgi" access="r" description="Lists all page items contained by the character."><type type="page item" list="yes"></type></property><property name="allow arbitrary hyphenation" code="jwro" type="boolean" description="If true, words unassociated with a hyphenation dictionary can break to the next line on any character."></property><property name="applied character style" code="crst" type="character style" description="The character style applied to the text. Can also accept: string."></property><property name="applied conditions" code="apCt" description="The applied conditions."><type type="condition" list="yes"></type></property><property name="applied font" code="font" type="any" description="The font applied to the character, specified as either a font object or the name of font family. Can return: font or string."></property><property name="applied language" code="plng" type="specifier" description="The language of the text. Can return: language with vendors or language. Can also accept: string."></property><property name="applied nested styles" code="apss" access="r" description="The applied character styles dictated by nested styles."><type type="character style" list="yes"></type></property><property name="applied numbering list" code="bnnl" type="any" description="The list to be part of. Can return: numbering list or string."></property><property name="applied paragraph style" code="prst" type="paragraph style" description="The paragraph style applied to the text. Can also accept: string."></property><property name="ascent" code="pAsc" access="r" description="The maximum ascent of any character in the text."><type type="number"></type><type type="text"></type></property><property name="associated XML elements" code="Xans" access="r" description="The XML elements associated with the character."><type type="XML item" list="yes"></type></property><property name="auto leading" code="alea" type="real" description="The percent of the type size to use for auto leading. (Range: 0 to 500)."></property><property name="auto tcy" code="jatc" type="integer" description="The number of half-width characters at or below which the characters automatically run horizontally in vertical text."></property><property name="auto tcy include roman" code="jatr" type="boolean" description="If true, auto tcy includes Roman characters."></property><property name="balance ragged lines" code="bala" type="any" description="If true or set to an enumeration value, balances ragged lines. Note: Not valid with a single-line text composer. Can return: boolean or no balancing/vee shape/fully balanced/pyramid shape."></property><property name="baseline" code="pBas" access="r" description="The vertical offset of the text. "><type type="number"></type><type type="text"></type></property><property name="baseline shift" code="bshf" description="The baseline shift applied to the text."><type type="number"></type><type type="text"></type></property><property name="bullet char" code="bnbc" type="bullet" access="r" description="Bullet character."></property><property name="bullets alignment" code="bnba" type="bueA" description="The alignment of the bullet character."></property><property name="bullets and numbering list type" code="bnlt" type="enLT" description="List type for bullets and numbering."></property><property name="bullets character style" code="bnbs" type="any" description="The character style to be used for the text after string. Can return: character style or string."></property><property name="bullets text after" code="bnta" type="text" description="The text after string expression for bullets."></property><property name="bunri kinshi" code="jbki" type="boolean" description="If true, adds the double period (..), ellipse (...), and double hyphen (--) to the selected kinsoku set. Note: Valid only when a kinsoku set is in effect."></property><property name="capitalization" code="capm" type="cape" description="The capitalization scheme."></property><property name="character alignment" code="jcal" type="Jaca" description="The alignment of small characters to the largest character in the line."></property><property name="character direction" code="cdir" type="chdi" description="The direction of the character."></property><property name="character rotation" code="crot" type="real" description="The rotation angle (in degrees) of individual characters. Note: The rotation is counterclockwise."></property><property name="cjk grid tracking" code="jgrt" type="boolean" description="If true, uses grid tracking to track non-Roman characters in CJK grids."></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="composer" code="ptce" type="text" description="The text composer to use to compose the text."></property><property name="contents" code="pcnt" type="any" description="The contents of the text. Can return: string or auto page number/next page number/previous page number/section marker/bullet character/copyright symbol/degree symbol/ellipsis character/forced line break/paragraph symbol/registered trademark/section symbol/trademark symbol/right indent tab/indent here tab/Em dash/En dash/discretionary hyphen/nonbreaking hyphen/end nested style/double left quote/double right quote/single left quote/single right quote/Em space/En space/flush space/hair space/nonbreaking space/thin space/figure space/punctuation space/column break/frame break/page break/odd page break/even page break/left to right embedding/right to left embedding/pop directional formatting/left to right override/right to left override/dotted circle/zero width joiner/footnote symbol/text variable/single straight quote/double straight quote/discretionary line break/zero width nonjoiner/third space/quarter space/sixth space/fixed width nonbreaking space/hebrew maqaf/hebrew geresh/hebrew gershayim/arabic kashida/arabic comma/arabic semicolon/arabic question mark/left to right mark/right to left mark/hebrew sof pasuk."></property><property name="descent" code="pDst" access="r" description="The maximum descent of any character in the text."><type type="number"></type><type type="text"></type></property><property name="design axes" code="ndxs" description="Value of Design Axes"><type type="real" list="yes"></type></property><property name="desired glyph scaling" code="gsde" type="real" description="The desired width (as a percentage) of individual characters. (Range: 50 to 200)"></property><property name="desired letter spacing" code="lsde" type="real" description="The desired letter spacing, specified as a percentge of the built-in space between letters in the font. (Range: -100 to 500)"></property><property name="desired word spacing" code="wsde" type="real" description="The desired word spacing, specified as a percentage of the font word space value. (Range: 0 to 1000)"></property><property name="diacritic position" code="diap" type="dipt" description="Position of diacriticical characters."></property><property name="digits type" code="digi" type="dity" description="The digits type."></property><property name="drop cap characters" code="dcca" type="integer" description="The number of characters to drop cap. Can return: small integer (0 - 150)."></property><property name="drop cap lines" code="dcli" type="integer" description="The number of lines to drop cap. Can return: small integer (0 - 25)."></property><property name="drop cap style" code="dcst" type="character style" description="The character style to apply to the drop cap. Can also accept: string."></property><property name="dropcap detail" code="dcdm" type="integer" description="Details about the drop cap based on the glyph outlines. 1 = left side bearing. 2 = descenders. 0x100,0x200,0x400 are used for Japanese frame grid."></property><property name="end baseline" code="pEBa" access="r" description="Vertical offset of the end of the text."><type type="number"></type><type type="text"></type></property><property name="end horizontal offset" code="pEHo" access="r" description="Horizontal offset of the end of the text."><type type="number"></type><type type="text"></type></property><property name="end join" code="endj" type="ojon" description="The stroke join type applied to the characters of the text."></property><property name="fill color" code="flcl" type="swatch" description="The swatch (color, gradient, tint, or mixed ink) applied to the fill of the character. . Can also accept: string."></property><property name="fill tint" code="filt" type="real" description="The tint (as a percentage) of the fill color of the character. (To specify a tint percentage, use a number in the range of 0 to 100; to use the inherited or overridden value, use -1.)"></property><property name="first line indent" code="infl" description="The amount to indent the first line."><type type="number"></type><type type="text"></type></property><property name="font style" code="ptfs" type="text" description="The name of the font style."></property><property name="glyph form" code="jgfm" type="Jglf" description="The glyph variant to substitute for standard glyphs."></property><property name="gradient fill angle" code="pgfa" type="real" description="The angle of a linear gradient applied to the fill of the text. (Range: -180 to 180)"></property><property name="gradient fill length" code="pgfl" type="real" description="The length (for a linear gradient) or radius (for a radial gradient) applied to the fill of the text."></property><property name="gradient fill start" code="pgst" description="The starting point (in page coordinates) of a gradient applied to the fill of the text, in the format [x, y]."><type type="number" list="yes"></type><type type="text" list="yes"></type></property><property name="gradient stroke angle" code="pgsa" type="real" description="The angle of a linear gradient applied to the stroke of the text. (Range: -180 to 180)"></property><property name="gradient stroke length" code="pgsl" type="real" description="The length (for a linear gradient) or radius (for a radial gradient) applied to the stroke of the text."></property><property name="gradient stroke start" code="pgss" description="The starting point (in page coordinates) of a gradient applied to the stroke of the text, in the format [x, y]."><type type="number" list="yes"></type><type type="text" list="yes"></type></property><property name="grid align first line only" code="jga1" type="boolean" description="If true, aligns only the first line to the frame grid or baseline grid. If false, aligns all lines to the grid."></property><property name="grid alignment" code="jgal" type="Jaga" description="The alignment to the frame grid or baseline grid."></property><property name="grid gyoudori" code="jggy" type="integer" description="The manual gyoudori setting."></property><property name="horizontal offset" code="pHOf" access="r" description="The horizontal offset of the text."><type type="number"></type><type type="text"></type></property><property name="horizontal scale" code="phzs" type="real" description="The horizontal scaling applied to the character."></property><property name="hyphen weight" code="hypw" type="integer" description="The relative desirability of better spacing vs. fewer hyphens. A lower value results in greater use of hyphens. (Range: 0 to 100). Can return: small integer (0 - 10)."></property><property name="hyphenate across columns" code="hycf" type="boolean" description="If true, allows the last word in a text column to be hyphenated."></property><property name="hyphenate after first" code="mibe" type="integer" description="The mininum number of letters at the beginning of a word that can be broken by a hyphen. Can return: small integer (1 - 15)."></property><property name="hyphenate before last" code="miaf" type="integer" description="The minimum number of letters at the end of a word that can be broken by a hyphen. Can return: small integer (1 - 15)."></property><property name="hyphenate capitalized words" code="hypc" type="boolean" description="If true, allows hyphenation of capitalized words."></property><property name="hyphenate ladder limit" code="hypl" type="integer" description="The maximum number of hyphens that can appear on consecutive lines. To specify unlimited consecutive lines, use zero. Can return: small integer (0 - 25)."></property><property name="hyphenate last word" code="hylw" type="boolean" description="If true, allows hyphenation in the last word in a paragraph. Note: Valid only when hyphenation is true."></property><property name="hyphenate words longer than" code="swor" type="integer" description="The minimum number of letters a word must have in order to qualify for hyphenation. Can return: small integer (3 - 25)."></property><property name="hyphenation" code="hyph" type="boolean" description="If true, allows hyphenation."></property><property name="hyphenation zone" code="hyzo" description="The amount of white space allowed at the end of a line of non-justified text before hypenation begins. Note: Valid when composer is single-line composer."><type type="number"></type><type type="text"></type></property><property name="ignore edge alignment" code="igEA" type="boolean" description="If true, ignores optical edge alignment for the paragraph."></property><property name="index" code="pidx" type="integer" access="r" description="The index of the text in the collection or parent object."></property><property name="jidori" code="jjid" type="integer" description="The number of grid squares in which to arrange the text. "></property><property name="justification" code="paln" type="kjst" description="The paragraph alignment."></property><property name="kashidas" code="kash" type="katy" description="Use of Kashidas for justification"></property><property name="keep all lines together" code="kept" type="boolean" description="If true, keeps all lines of the paragraph together. If false, allows paragraphs to break across pages or columns."></property><property name="keep first lines" code="kfnl" type="integer" description="The minimum number of lines to keep together in a paragraph before allowing a page break. Can return: small integer (1 - 50)."></property><property name="keep last lines" code="klnl" type="integer" description="The minimum number of lines to keep together in a paragraph after a page break. Can return: small integer (1 - 50)."></property><property name="keep lines together" code="kepl" type="boolean" description="If true, keeps a specified number of lines together when the paragraph breaks across columns or text frames."></property><property name="keep rule above in frame" code="prak" type="boolean" description="If true, forces the rule above the paragraph to remain in the frame bounds. Note: Valid only when rule above is true."></property><property name="keep with next" code="kwnx" type="integer" description="The minimum number of lines to keep with the next paragraph. Can return: small integer (0 - 5)."></property><property name="keep with previous" code="kwpv" type="boolean" description="If the first line in the paragraph should be kept with the last line of previous paragraph."></property><property name="kenten alignment" code="jkal" type="Jekl" description="The alignment of kenten characters relative to the parent characters. "></property><property name="kenten character set" code="jset" type="Jest" description="The character set used for the custom kenten character. Note: Valid only when kenten kind is custom. "></property><property name="kenten custom character" code="jkcc" type="text" description="The character used for kenten. Note: Valid only when kenten kind is custom."></property><property name="kenten fill color" code="jkfc" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the fill of kenten characters. Can return: swatch or string."></property><property name="kenten font" code="jkfn" type="any" description="The font to use for kenten characters. Can return: font or string."></property><property name="kenten font size" code="jkfz" type="real" description="The size (in points) of kenten characters."></property><property name="kenten font style" code="jkfs" type="any" description="The font style of kenten characters. Can return: string or nothing."></property><property name="kenten kind" code="jktp" type="Jkch" description="The style of kenten characters."></property><property name="kenten overprint fill" code="jkof" type="Jafl" description="The method of overprinting the kenten fill."></property><property name="kenten overprint stroke" code="jkos" type="Jafl" description="The method of overprinting the kenten stroke."></property><property name="kenten placement" code="jkpl" type="real" description="The distance between kenten characters and their parent characters."></property><property name="kenten position" code="jkp2" type="Jkps" description="The kenten position relative to the parent character."></property><property name="kenten stroke color" code="jksc" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the stroke of kenten characters. Can return: swatch or string."></property><property name="kenten stroke tint" code="jkst" type="real" description="The stroke tint (as a percentage) of kenten characters. (Range: 0 to 100)"></property><property name="kenten tint" code="jktn" type="real" description="The fill tint (as a percentage) of kenten characters. (Range: 0 to 100)"></property><property name="kenten weight" code="jkwt" type="real" description="The stroke weight (in points) of kenten characters."></property><property name="kenten X scale" code="jkcm" type="real" description="The horizontal size of kenten characters as a percent of the original size."></property><property name="kenten Y scale" code="jkpt" type="real" description="The vertical size of kenten charachers as a percent of the original size. "></property><property name="kerning method" code="pakm" type="text" description="The type of pair kerning."></property><property name="kerning value" code="pake" type="real" description="The amount of space to add or remove between characters, specified in thousands of an em. "></property><property name="keyboard direction" code="kdir" type="chdi" description="The keyboard direction of the character."></property><property name="kinsoku hang type" code="jkht" type="Jkht" description="The type of hanging punctuation to allow. Note: Valid only when a kinsoku set is in effect."></property><property name="kinsoku set" code="jkin" type="any" description="The kinsoku set that determines legitimate line breaks. Can return: kinsoku table, nothing/hard kinsoku/soft kinsoku/korean kinsoku/simplified chinese kinsoku/traditional chinese kinsoku or string."></property><property name="kinsoku type" code="jkit" type="Jknt" description="The type of kinsoku processing for preventing kinsoku characters from beginning or ending a line. Note: Valid only when a kinsoku set is defined."></property><property name="last line indent" code="inlr" description="The amount to indent the last line in the paragraph."><type type="number"></type><type type="text"></type></property><property name="leading" code="szld" type="any" description="The leading applied to the text. Can return: number or string or auto."></property><property name="leading aki" code="jmbs" type="real" description="The amount of space before each character."></property><property name="leading model" code="Jled" type="JLed" description="The point from which leading is measured from line to line."></property><property name="left indent" code="inbl" description="The width of the left indent."><type type="number"></type><type type="text"></type></property><property name="length" code="leng" type="integer" access="r" description="The number of objects in the collection."></property><property name="ligatures" code="ligt" type="boolean" description="If true, replaces specific character combinations (e.g., fl, fi) with ligature characters."></property><property name="maximum glyph scaling" code="gsma" type="real" description="The maximum width (as a percentage) of individual characters. (Range: 50 to 200)"></property><property name="maximum letter spacing" code="lsma" type="real" description="The maximum letter spacing, specified as a percentge of the built-in space between letters in the font. (Range: -100 to 500) Note: Valid only when text is justified."></property><property name="maximum word spacing" code="wsma" type="real" description="The maximum word spacing, specified as a percentage of the font word space value. Note: Valid only when text is justified. (Range: 0 to 1000)"></property><property name="merge consecutive para borders" code="pbMc" type="boolean" description="If true, consecutive para borders with completely similar properties are merged."></property><property name="minimum glyph scaling" code="gsmi" type="real" description="The minimum width (as a percentage) of individual characters. (Range: 50 to 200)"></property><property name="minimum letter spacing" code="lsmi" type="real" description="The minimum letter spacing, specified as a percentge of the built-in space between letters in the font. (Range: -100 to 500) Note: Valid only when text is justified."></property><property name="minimum word spacing" code="wsmi" type="real" description="The minimum word spacing, specified as a percentage of the font word space value. Note: Valid only when text is justified. (Range: 0 to 1000)"></property><property name="miter limit" code="mitr" type="real" description="The limit of the ratio of stroke width to miter length before a miter (pointed) join becomes a bevel (squared-off) join. Can return: fixed (0 - 1000)."></property><property name="mojikumi" code="jmoj" type="any" description="The mojikumi table. For information, see mojikumi table defaults. Can return: mojikumi table, string or nothing/line end all one half em enum/one em indent line end uke one half em enum/one or one half em indent line end uke one half em enum/one or one half em indent line end all one em enum/one em indent line end all one em enum/one em indent line end all no float enum/one em indent line end uke no float enum/one or one half em indent line end uke no float enum/one em indent line end all one half em enum/line end all one em enum/line end uke no float enum/one or one half em indent line end period one em enum/one em indent line end period one em enum/line end period one em enum/trad chinese default/simp chinese default."></property><property name="no break" code="nobk" type="boolean" description="If true, keeps the text on the same line. "></property><property name="numbering alignment" code="bnna" type="bueA" description="The alignment of the number."></property><property name="numbering apply restart policy" code="bnar" type="boolean" description="If true, apply the numbering restart policy."></property><property name="numbering character style" code="bnnc" type="any" description="The character style to be used for the number string. Can return: character style or string."></property><property name="numbering continue" code="bncp" type="boolean" description="Continue the numbering at this level."></property><property name="numbering expression" code="bnne" type="text" description="The number string expression for numbering."></property><property name="numbering format" code="DHnm" type="any" description="Numbering format options. Can return: upper roman/lower roman/upper letters/lower letters/arabic/kanji/katakana modern/katakana traditional/format none/single leading zeros/arabic alif ba tah/arabic abjad/hebrew biblical/hebrew non standard/double leading zeros/triple leading zeros or string."></property><property name="numbering level" code="bnle" type="integer" description="The level of the paragraph."></property><property name="numbering restart policies" code="bnbr" type="numbering restart policy" access="r" description="Numbering restart policies."></property><property name="numbering start at" code="bnst" type="integer" description="Determines starting number in a numbered list."></property><property name="object reference" code="posp" type="character" access="r" description="An object reference for the object."></property><property name="OpenType features" code="jofl" description="OpenType features. Can return: list of list of 2 strings or integers."><type type="any" list="yes"></type></property><property name="OTF contextual alternate" code="OTca" type="boolean" description="If true, uses contextual alternate forms in OpenType fonts."></property><property name="OTF discretionary ligature" code="OTdl" type="boolean" description="If true, uses discretionary ligatures in OpenType fonts."></property><property name="OTF figure style" code="Ofst" type="OTfs" description="The figure style in OpenType fonts."></property><property name="OTF fraction" code="OTfr" type="boolean" description="If true, uses fractions in OpenType fonts."></property><property name="OTF historical" code="OThi" type="boolean" description="If true, use historical forms in OpenType fonts."></property><property name="OTF HV kana" code="hkna" type="boolean" description="If true, switches hiragana fonts, which have different glyphs for horizontal and vertical. "></property><property name="OTF justification alternate" code="OTja" type="boolean" description="If true, use alternate justification forms in OpenType fonts"></property><property name="OTF locale" code="OTlc" type="boolean" description="If true, uses localized forms in OpenType fonts."></property><property name="OTF mark" code="OTmk" type="boolean" description="If true, uses mark positioning in OpenType fonts."></property><property name="OTF ordinal" code="OTor" type="boolean" description="If true, uses ordinals in OpenType fonts."></property><property name="OTF overlap swash" code="OTol" type="boolean" description="If true, use overlapping swash forms in OpenType fonts"></property><property name="OTF proportional metrics" code="palt" type="boolean" description="If true, kerns according to proportional CJK metrics in OpenType fonts."></property><property name="OTF Roman italics" code="ital" type="boolean" description="If true, applies italics to half-width alphanumerics. "></property><property name="OTF slashed zero" code="OTzr" type="boolean" description="If true, use a slashed zeroes in OpenType fonts."></property><property name="OTF stretched alternate" code="OTsh" type="boolean" description="If true, use stretched alternate forms in OpenType fonts"></property><property name="OTF stylistic alternate" code="OTsy" type="boolean" description="If true, use stylistic alternate forms in OpenType fonts"></property><property name="OTF stylistic sets" code="OTss" type="integer" description="The stylistic sets to use in OpenType fonts."></property><property name="OTF swash" code="OTsw" type="boolean" description="If true, uses swash forms in OpenType fonts."></property><property name="OTF titling" code="OTti" type="boolean" description="If true, uses titling forms in OpenType fonts."></property><property name="overprint fill" code="ovpr" type="boolean" description="If true, the fill color of the characters will overprint."></property><proper