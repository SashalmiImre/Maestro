igits" code="jrtd" type="integer" description="The number of digits included in auto tcy (tate-chuu-yoko) in ruby."></property><property name="ruby auto tcy include roman" code="jrtr" type="boolean" description="If true, includes Roman characters in auto tcy (tate-chuu-yoko) in ruby."></property><property name="ruby fill" code="jrfl" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the fill of ruby characters. Can return: swatch or string."></property><property name="ruby flag" code="jrfg" type="boolean" description="If true, ruby is on. "></property><property name="ruby font" code="jrfn" type="any" description="The font applied to ruby characters. Can return: font or string."></property><property name="ruby font size" code="jrfs" type="real" description="The size (in points) of ruby characters."></property><property name="ruby font style" code="jrft" type="any" description="The font style of ruby characters. Can return: string or nothing."></property><property name="ruby open type pro" code="jpro" type="boolean" description="If true, uses OpenType Pro fonts for ruby."></property><property name="ruby overhang" code="jrov" type="boolean" description="If true, constrains ruby overhang to the specified amount. For information on specifying an amount, see ruby parent overhang amount. "></property><property name="ruby overprint fill" code="jrof" type="Jafl" description="The method of overprinting the ruby fill."></property><property name="ruby overprint stroke" code="jros" type="Jafl" description="The method of overprinting the ruby stroke."></property><property name="ruby parent overhang amount" code="jrva" type="Jruo" description="The amount by which ruby characters can overhang the parent text."></property><property name="ruby parent scaling percent" code="jrsc" type="real" description="The amount (as a percentage) to scale the parent text size to determine the ruby text size."></property><property name="ruby parent spacing" code="jr