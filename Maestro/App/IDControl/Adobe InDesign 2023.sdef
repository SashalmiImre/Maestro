e, the global light angle is used. Can return: boolean or nothing."></property><property name="x offset" code="xpUj" type="any" description="The horizontal offset of the shadow. Can return: number or string (-1000 - 1000 points) or nothing."></property><property name="y offset" code="xpUk" type="any" description="The vertical offset of the shadow. Can return: number or string (-1000 - 1000 points) or nothing."></property></class><class name="find change object option" code="cFCO" description="Find/change object options."><element type="event"></element><element type="event listener"></element><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="include footnotes" code="FIFN" type="boolean" description="If true, includes footnotes in the find/change query."></property><property name="include hidden layers" code="FIHL" type="boolean" description="If true, includes hidden layers in the find/change query."></property><property name="include locked layers for find" code="FILL" type="boolean" description="If true, includes locked layers in the find query."></property><property name="include locked stories for find" code="FILS" type="boolean" description="If true, includes locked stories in the find query."></property><property name="include master pages" code="FIMP" type="boolean" description="If true, includes master pages in the find/change query."></property><property name="object reference" code="posp" type="find change object option" access="r" description="An object reference for the object."></property><property name="object type" code="FOTe" type="FOTy" description="The object type."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the find change object option (a application)."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property></c