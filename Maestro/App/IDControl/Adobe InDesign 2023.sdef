ption="If true, uses mark positioning in OpenType fonts."></property><property name="OTF ordinal" code="OTor" type="boolean" description="If true, uses ordinals in OpenType fonts."></property><property name="OTF overlap swash" code="OTol" type="boolean" description="If true, use overlapping swash forms in OpenType fonts"></property><property name="OTF proportional metrics" code="palt" type="boolean" description="If true, kerns according to proportional CJK metrics in OpenType fonts."></property><property name="OTF Roman italics" code="ital" type="boolean" description="If true, applies italics to half-width alphanumerics. "></property><property name="OTF slashed zero" code="OTzr" type="boolean" description="If true, use a slashed zeroes in OpenType fonts."></property><property name="OTF stretched alternate" code="OTsh" type="boolean" description="If true, use stretched alternate forms in OpenType fonts"></property><property name="OTF stylistic alternate" code="OTsy" type="boolean" description="If true, use stylistic alternate forms in OpenType fonts"></property><property name="OTF stylistic sets" code="OTss" type="integer" description="The stylistic sets to use in OpenType fonts."></property><property name="OTF swash" code="OTsw" type="boolean" description="If true, uses swash forms in OpenType fonts."></property><property name="OTF titling" code="OTti" type="boolean" description="If true, uses titling forms in OpenType fonts."></property><property name="overprint fill" code="ovpr" type="boolean" description="If true, the fill color of the characters will overprint."></property><property name="overprint stroke" code="sovp" type="boolean" description="If true, the stroke of the characters will overprint."></property><property name="paragraph border bottom  right corner option" code="bcO4" type="coPt" description="The shape to apply to the bottom right corner of rectangular shapes."></property><property name="paragraph border bottom left corner option" code="bcO3" type