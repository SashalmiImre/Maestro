perties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="vertical scale" code="pvts" type="real" description="The vertical scaling applied to the layout grid data information."></property></class><class name="linked Page Item option" code="lpio" description="The link options for a linked Page Item."><element type="event"></element><element type="event listener"></element><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="object reference" code="posp" type="linked Page Item option" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the linked Page Item option (a application, document, page item, html item, form field, signature field, text box, radio button, list box, combo box, check box, multi state object, button, media item, sound, movie, EPSText, spline item, polygon, graphic line, rectangle, oval, graphic, SVG, imported page, PICT, WMF, PDF, EPS, image, group, text frame or endnote text frame). Can return: application, document, page item, html item, form field, signature field, text box, radio button, list box, combo box, check box, multi state object, button, media item, sound, movie, EPSText, spline item, polygon, graphic line, rectangle, oval, graphic, SVG, imported page, PICT, WMF, PDF, EPS, image, group, text frame or endnote text frame."></property><property name="preserve appearance" code="lpga" type="boolean" description="If true, appearance edits will be preserved during update."></property><property name="preserve frame content" code="lpoc" type="boolean" description="If true, frame content edits will be preserved during update."></property><property name="preserve interactivity" code="lpia" type="boolean" description="If true, interactivity edits will be preserved during update