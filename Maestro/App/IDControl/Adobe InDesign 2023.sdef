s."></property><property name="ruby stroke" code="jrsk" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the stroke of ruby characters. Can return: swatch or string."></property><property name="ruby stroke tint" code="jrst" type="real" description="The stroke tint (as a percentage) of ruby characters."></property><property name="ruby tint" code="jrti" type="real" description="The tint (as a percentage) of the ruby fill color. (Range: 0 to 100)"></property><property name="ruby type" code="jrtp" type="Jrty" description="The ruby type."></property><property name="ruby weight" code="jrwt" type="real" description="The stroke weight (in points) of ruby characters."></property><property name="ruby X offset" code="jrxo" type="real" description="The amount of horizontal space between ruby and parent characters."></property><property name="ruby X scale" code="jrwd" type="real" description="The horizontal size of ruby characters, specified as a percent of the original size."></property><property name="ruby Y offset" code="jryo" type="real" description="The amount of vertical space between ruby and parent characters."></property><property name="ruby Y scale" code="jrpt" type="real" description="The vertical size of ruby characters, specified as a percent of the original size."></property><property name="rule above" code="prar" type="boolean" description="If true, places a rule above the paragraph."></property><property name="rule above color" code="rlac" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the paragraph rule above. Can return: swatch or string."></property><property name="rule above gap color" code="ragc" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the stroke gap of the paragraph rule above. Note: Valid only when the paragraph rule above type is not solid. Can return: swatch or string."></property><property name="rule above gap overprint" code="rago" type="