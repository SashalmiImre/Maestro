ing."></property></class><class name="JPEG export preference" code="jpPf" description="JPEG export preferences."><element type="event"></element><element type="event listener"></element><property name="anti alias" code="jpAA" type="boolean" description="If true, use anti-aliasing for text and vectors during export."></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="embed color profile" code="jpIP" type="boolean" description="True to embed the color profile, false otherwise."></property><property name="export resolution" code="jpeR" type="real" description="The export	resolution expressed as a real number instead of an integer. (Range: 1.0 to 2400.0). Can return: fixed (1 - 2400)."></property><property name="Exporting Spread" code="jpXS" type="boolean" description="If true, exports each spread as a single JPEG file. If false, exports facing pages as separate files and appends sequential numbers to each file name."></property><property name="jpeg color space" code="jpCS" type="enjC" description="One of RGB, CMYK or Gray"></property><property name="JPEG export range" code="jpRA" type="enRA" description="The page range to export."></property><property name="JPEG Quality" code="jpJQ" type="jpgq" description="The compression quality."></property><property name="JPEG Rendering style" code="jpRS" type="jpge" description="The rendering style."></property><property name="object reference" code="posp" type="JPEG export preference" access="r" description="An object reference for the object."></property><property name="Page String" code="jpPN" type="text" description="The page(s) to export, specified as a page number or an array of page numbers. Note: Valid when JPEG export range is not all."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the JPEG export preference (a application)."></property><property name="properties" code="qpro" type="