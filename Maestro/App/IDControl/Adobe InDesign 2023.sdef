nt" code="Stvp" type="boolean" description="If true, the strikethrough stroke will overprint."></property><property name="strike through tint" code="sttt" type="real" description="The tint (as a percentage) of the strikethrough stroke. (Range: 0 to 100)"></property><property name="strike through type" code="sttp" type="any" description="The stroke type of the strikethrough stroke. Can return: stroke style or string."></property><property name="strike through weight" code="stwt" description="The stroke weight of the strikethrough stroke."><type type="number"></type><type type="text"></type></property><property name="strike thru" code="strk" type="boolean" description="If true, draws a strikethrough line through the text."></property><property name="stroke alignment" code="strA" type="stAl" description="The stroke alignment applied to the text."></property><property name="stroke color" code="lncl" type="swatch" description="The swatch (color, gradient, tint, or mixed ink) applied to the stroke of the text style range. Can also accept: string."></property><property name="stroke tint" code="lint" type="real" description="The tint (as a percentage) of the stroke color of the text style range. (To specify a tint percentage, use a number in the range of 0 to 100; to use the inherited or overridden value, use -1.)"></property><property name="stroke weight" code="lnwt" description="The stroke weight applied to the characters of the text."><type type="number"></type><type type="text"></type></property><property name="style overridden" code="stov" type="boolean" access="r" description="If true, the applied style has been overridden with additional attributes."></property><property name="tab list" code="alts" description="A list of the tab stops in the paragraph. Can return: list of record."><type type="any" list="yes"></type></property><property name="tatechuyoko" code="jtcy" type="boolean" description="If true, makes the character horizontal in vertical text."></property><property name="tatechuyoko X offset" code="jtax" type="real" description="The horizontal offset for horizontal characters in vertical text."></property><property name="tatechuyoko Y offset" code="jtay" type="real" description="The vertical offset for horizontal characters in vertical text."></property><property name="tracking" code="trak" type="real" description="The amount by which to loosen or tighten a block of text, specified in thousands of an em."></property><property name="trailing aki" code="jmas" type="real" description="The amount of space after each character."></property><property name="treat ideographic space as space" code="jisb" type="boolean" description="If true, ideographic spaces will not wrap to the next line like text characters."></property><property name="tsume" code="tsum" type="real" description="The amount of horizontal character compression."></property><property name="underline" code="undr" type="boolean" description="If true, underlines the text."></property><property name="underline color" code="ulco" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the underline stroke. . Can return: swatch or string."></property><property name="underline gap color" code="ulgc" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the gap of the underline stroke. Note: Valid when underline type is not solid. Can return: swatch or string."></property><property name="underline gap overprint" code="upgo" type="boolean" description="If true, the gap color of the underline stroke will overprint."></property><property name="underline gap tint" code="ulgt" type="real" description="The tint (as a percentage) of the gap color of the underline stroke. (Range: 0 to 100) Note: Valid when underline type is not solid."></property><property name="underline offset" code="ulos" description="The amount by which to offset the underline from the text baseline."><type type="number"></type><type type="text"></typ