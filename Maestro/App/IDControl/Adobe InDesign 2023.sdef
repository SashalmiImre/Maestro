erty name="strike through gap color" code="stgc" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the gap of the strikethrough stroke. Can return: swatch or string."></property><property name="strike through gap overprint" code="stgo" type="boolean" description="If true, the gap color of the strikethrough stroke will overprint. Note: Valid when strike through type is not solid."></property><property name="strike through gap tint" code="stgt" type="real" description="The tint (as a percentage) of the strikethrough stroke gap color. (Range: 0 to 100) Note: Valid when strike through type is not solid."></property><property name="strike through offset" code="stos" description="The amount by which to offset the strikethrough stroke from the text baseline."><type type="number"></type><type type="text"></type></property><property name="strike through overprint" code="Stvp" type="boolean" description="If true, the strikethrough stroke will overprint."></property><property name="strike through tint" code="sttt" type="real" description="The tint (as a percentage) of the strikethrough stroke. (Range: 0 to 100)"></property><property name="strike through type" code="sttp" type="any" description="The stroke type of the strikethrough stroke. Can return: stroke style or string."></property><property name="strike through weight" code="stwt" description="The stroke weight of the strikethrough stroke."><type type="number"></type><type type="text"></type></property><property name="strike thru" code="strk" type="boolean" description="If true, draws a strikethrough line through the text."></property><property name="stroke alignment" code="strA" type="stAl" description="The stroke alignment applied to the text."></property><property name="stroke color" code="lncl" type="swatch" description="The swatch (color, gradient, tint, or mixed ink) applied to the stroke of the insertion point. Can also accept: string."></property><property name="stroke tint" code=