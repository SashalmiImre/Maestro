ok" code="from" type="book" optional="yes" description="The book whose documents to include in the TOC."></parameter><parameter name="place point" code="insw" optional="yes" description="The point at which to place the TOC story, specified as page coordinates in the format [x, y]."><type type="number"></type><type type="text"></type></parameter><parameter name="include overset" code="iOvt" type="boolean" optional="yes" description="If true, includes overset text TOC entries in the TOC. Can accept: boolean (Default: FALSE)."></parameter><parameter name="destination layer" code="pdlr" type="layer" optional="yes" description="The layer on which to place the TOC."></parameter><result type="story" description="The table of contents."></result></command><command name="Create vCard QR Code" code="K2  QrVc" description="Create Business Card QR Code on the page item or load on document's placegun"><direct-parameter type="document"></direct-parameter><parameter name="first name" code="QRFN" type="text" optional="yes" description="QR code Business Card First Name"></parameter><parameter name="last name" code="QRLN" type="text" optional="yes" description="QR code Business Card Last Name"></parameter><parameter name="job title" code="QRTl" type="text" optional="yes" description="QR code Business Card Title"></parameter><parameter name="cell phone" code="QRCP" type="text" optional="yes" description="QR code Business Card Cell Phone Number"></parameter><parameter name="phone" code="QRPh" type="text" optional="yes" description="QR code Business Card Phone Number"></parameter><parameter name="email" code="QREm" type="text" optional="yes" description="QR code Business Card Email Address"></parameter><parameter name="organisation" code="QROg" type="text" optional="yes" description="QR code Business Card Organisation"></parameter><parameter name="street Address" code="QRAd" type="text" optional="yes" description="QR code Business Card Street Address"></parameter><parameter name="city" 