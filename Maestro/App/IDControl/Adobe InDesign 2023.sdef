name="paragraph shading top left corner radius" code="scr1" description="The radius in measurement units of the corner effect applied to the top left corner of rectangular shapes and all corners of non-rectangular shapes"><type type="number"></type><type type="text"></type></property><property name="paragraph shading top offset" code="psOt" description="The distance to offset the top edge of the paragraph."><type type="number"></type><type type="text"></type></property><property name="paragraph shading top origin" code="psTo" type="psTe" description="The basis (cap height, ascent or baseline) used to calculate the top origin of the paragraph shading."></property><property name="paragraph shading top right corner option" code="scO2" type="coPt" description="The shape to apply to the top right corner of rectangular shapes"></property><property name="paragraph shading top right corner radius" code="scr2" description="The radius in measurement units of the corner effect applied to the top right corner of rectangular shapes"><type type="number"></type><type type="text"></type></property><property name="paragraph shading width" code="psWi" type="psWe" description="The basis (text width or column width) used to calculate the width of the paragraph shading."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the text (a hidden text, text path, text frame, endnote text frame, text, insertion point, text style range, paragraph, text column, line, word, character, story, xml story, cell, XML element, endnote, footnote, change or note). Can return: hidden text, text path, text frame, endnote text frame, text, insertion point, text style range, paragraph, text column, line, word, character, story, xml story, cell, XML element, endnote, footnote, change or note."></property><property name="parent story" code="strp" type="story" access="r" description="The story that contains the text."></property><property name="parent text frame