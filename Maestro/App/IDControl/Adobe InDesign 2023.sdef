oin in which you can set a radius for a corner option, whereas the rounded or beveled effect of an end join depends on the stroke weight."></property><property name="paragraph shading top left corner radius" code="scr1" description="The radius in measurement units of the corner effect applied to the top left corner of rectangular shapes and all corners of non-rectangular shapes"><type type="number"></type><type type="text"></type></property><property name="paragraph shading top offset" code="psOt" description="The distance to offset the top edge of the paragraph."><type type="number"></type><type type="text"></type></property><property name="paragraph shading top origin" code="psTo" type="psTe" description="The basis (cap height, ascent or baseline) used to calculate the top origin of the paragraph shading."></property><property name="paragraph shading top right corner option" code="scO2" type="coPt" description="The shape to apply to the top right corner of rectangular shapes"></property><property name="paragraph shading top right corner radius" code="scr2" description="The radius in measurement units of the corner effect applied to the top right corner of rectangular shapes"><type type="number"></type><type type="text"></type></property><property name="paragraph shading width" code="psWi" type="psWe" description="The basis (text width or column width) used to calculate the width of the paragraph shading."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the line (a hidden text, text path, text frame, endnote text frame, text, insertion point, text style range, paragraph, text column, line, word, character, story, xml story, cell, XML element, endnote, footnote, change or note). Can return: hidden text, text path, text frame, endnote text frame, text, insertion point, text style range, paragraph, text column, line, word, character, story, xml story, cell, XML element, endnote, footnote, change or note."></property><property name="parent story" code="strp" type="story" access="r" description="The story that contains the text."></property><property name="parent text frames" code="pTxS" access="r" description="An array of the text frames that contain the text. Can return: list of text frames or text paths."><type type="specifier" list="yes"></type></property><property name="point size" code="ptsz" description="The text size."><type type="number"></type><type type="text"></type></property><property name="position" code="posm" type="pose" description="The text position relative to the baseline."></property><property name="positional form" code="OTPf" type="OTpf" description="The OpenType positional form."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="provider hyphenation style" code="phys" type="dphs" description="The hyphenation style chosen for the provider."></property><property name="rensuuji" code="jren" type="boolean" description="If true, disallows line breaks in numbers. If false, lines can break between digits in multi-digit numbers."></property><property name="right indent" code="inbr" description="The width of the right indent."><type type="number"></type><type type="text"></type></property><property name="rotate single byte characters" code="jro1" type="boolean" description="If true, rotates Roman characters in vertical text."></property><property name="ruby alignment" code="jral" type="Jrua" description="The ruby alignment."></property><property name="ruby auto align" code="jraa" type="boolean" description="If true, auto aligns ruby."></property><property name="ruby auto scaling" code="jras" type="boolean" description="If true, automatically scales ruby to the specified percent of parent text size. For information on specifying a percent, see ruby parent scaling percent. "></property><property name="ruby auto tcy auto scale" code="jrts" 