n return: preflight profile or string."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property></class><class name="preflight option" code="PFOp" description="Preflight options."><element type="event"></element><element type="event listener"></element><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="object reference" code="posp" type="preflight option" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the preflight option (a application or document). Can return: application or document."></property><property name="preflight embed working profile" code="pfem" type="boolean" description="If true, embed working profile when creating new document."></property><property name="preflight include nonprinting objects" code="pfNp" type="boolean" description="If true, include objects that do not print when preflighting."></property><property name="preflight include objects on pasteboard" code="pfPB" type="boolean" description="If true, include objects on pasteboard when preflighting."></property><property name="preflight off" code="pfOf" type="boolean" description="If true, preflight is turned off for all documents or for this document."></property><property name="preflight profile policy" code="pfDc" type="pfDE" description="The policy for preflighting applied when opening a document or book, whether to use embedded profile or the another profile when the preflight is turned on."></property><property name="preflight scope" code="pfSc" type="any" description="The pages or documents to preflight, specified either as an enumeration or a string. To specify a range, separate page numbers in the string with a hyphen (-). To specify separate pages, separate page numbers in the string with a comma (,). Can return: preflight all pages/preflight selected documents/preflight all documents or string."></property><property name="preflight which layers" code="pfLy" type="pfLE" description="Which layers to preflight."></property><property name="preflight Working Profile" code="pfWP" type="any" description="The working preflight profile. Can return: preflight profile or string."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property></class><class name="print booklet option" code="CPrB" description="Print booklet options."><element type="event"></element><element type="event listener"></element><property name="auto adjust margins" code="BAAM" type="boolean" description="If true, automatically adjust margins to fit the specified printer's marks and bleed area."></property><property name="bleed between pages" code="BBBP" description="The amount of bleed between pages. Can return: number or string (0 - 144 points)."><type type="number"></type><type type="text"></type></property><property name="booklet type" code="BBTy" type="EnBT" description="The type of booklet."></property><property name="bottom margin" code="dmBM" description="Bottom margin of the printed booklet. Can return: number or string (0 - 288 points)."><type type="number"></type><type type="text"></type></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="creep" code="BCrp" description="The amount of creep (binding adjustment based on paper thickness) to add. Can return: number or string (-144 - 144 points)."><type type="number"></type><type type="text"></type></property><property name="left margin" code="dmLM" description="Left margin of the printed booklet. Can return: number or string (0 - 288 points)."><type type="number"></type><type type="text"></type></property><property name="margins uniform size" code="BChM" type="boolean" description="If true, make all margins equal to the top margin."></property><property name="object reference" code="posp" type="print booklet option" access="r" description="An object reference for the object."></property><property name="page range" code="pcty" type="any" description="The pages to print, specified either as an enumeration or a string. To specify a range, separate page numbers in the string with a hyphen (-). To specify separate pages, separate page numbers in the string with a comma (,). Can return: all pages/selected items or string."></property><property name="parent" code="pare" type="document" access="r" description="The parent of the print booklet option (a document)."></property><property name="print blank printer spreads" code="BPBS" type="boolean" description="If true, print blank spreads."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="right margin" code="dmRM" description="Right margin of the printed booklet. Can return: number or string (0 - 288 points)."><type type="number"></type><type type="text"></type></property><property name="signature size" code="BSgS" type="EnBS" description="The signature size of booklet (for perfect binding)."></property><property name="space between pages" code="BSBP" description="The amount of space between pages. Can return: number or string (0 - 288 points)."><type type="number"></type><type type="text"></type></property><property name="top margin" code="dmTM" description="Top margin of the printed booklet. Can return: number or string (0 - 288 points)."><type type="number"></type><type type="text"></type></property></class><class name="print booklet print preference" code="CPBP" description="Print booklet preferences."><element type="event"></element><element type="event listener"></element><property name="active printer preset" code="Rsty" type="any" description="The current printer preset type. Can return: default/custom or printer preset."></property><property name="all printer marks" code="apm " type="boolean" description="If true, prints all printer marks. If false, prints specified printer marks."></property><property name="bitmap printing" code="bmpr" type="boolean" description="If true, uses bitmap printing."></property><property name="bitmap resolution" code="bmrz" type="integer" description="The resolution for bitmap printing. (Range: 72 to 1200) Note: Valid when bitmap printing is true. Can return: integer (72 - 1200)."></property><property name="black angle" code="RBIA" type="real" description="The angle override for black ink. (Range: 0 to 360)"></property><property name="black frequency" code="RBIF" type="real" description="The frequency override for black ink. (Range: 1 to 500)"></property><property name="bleed bottom" code="RpBb" description="The height of the bleed area at the bottom of the page. Note: Valid only when use document bleed to print is true. Can return: number or string (0 - 432 points)."><type type="number"></type><type type="text"></type></property><property name="bleed chain" code="RpBC" type="boolean" description="If true, forces all bleed area settings to be the same, using the most recent bleed measurement setting. If false, allows bleed top, bleed bottom, bleed inside, and bleed outside to have different measurements. "></property><property name="bleed inside" code="RpBi" description="The width of the bleed area at the inside of the page. Note: Valid only when use document bleed to print is true. Can return: number or string (0 - 432 points)."><type type="number"></type><type type="text"></type></property><property name="bleed marks" code="bldm" type="boolean" description="If true, print bleed marks."></property><property name="bleed outside" code="RpBo" description="The width of the bleed area at the outside of the page. Note: Valid only when use document bleed to print is true. . Can return: number or string (0 - 432 points)."><type type="number"></type><type type="text"></type></property><property name="bleed top" code="RpBt" description="The height of the bleed area at the top of the page. Note: Valid only when use document bleed to print is true. Can return: number or string (0 - 432 points)."><type type="number"></type><type type="text"></type></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="collating" code="lwcl" type="boolean" description="If true, collate printed copies."></property><property name="color bars" code="colb" type="boolean" description="If true, add small squares of color representing the CMYK inks and tints of gray in 10% increments."></property><property name="color output" code="RpCm" type="EnCO" description="The color output mode for composites. Note: Not valid when a device-independent PPD is specified."></property><property name="composite angle" code="RpCA" type="real" description="The screen angle to use when printing composites. (Range: 0 to 360) Note: Valid only for PostScript or PDF files that use custom screening."></property><property name="composite frequency" code="RpCF" type="real" description="The screen frequency to use when printing composites. (Range: 1 to 500) Note: Valid only for PostScript or PDF files that use custom screening."></property><property name="copies" code="lwcp" type="integer" description="The number of copies to print. Note: Not valid when printer is PostScript File."></property><property name="CRD" code="RpCr" type="any" description="The color-rendering dictionary (CRD), specified as a CRD name or an enumeration value. Note: Valid only when use color management is true. Can return: default/use document/working or string."></property><property name="crop marks" code="crpm" type="boolean" description="Prints crop marks that define where the page should be trimmed."></property><property name="cyan angle" code="RCIA" type="real" description="The angle override for cyan ink. (Range: 0 to 360)"></property><property name="cyan frequency" code="RCIF" type="real" description="The frequency override for cyan ink. (Range: 1 to 500)"></property><property name="data format" code="RpDF" type="EnDF" description="The format in which to send image data to the printer."></property><property name="download PPD fonts" code="RpPF" type="boolean" description="If true, downloads all fonts listed in the selected PPD. Valid only when font downloading is complete or subset."></property><property name="flattener preset name" code="RpFS" type="text" description="The name of the transparency flattener preset."></property><property name="flip" code="RpFp" type="EnFp" description="The direction in which to flip the printed image."></property><property name="font downloading" code="fndl" type="EnFD" description="Controls how fonts are downloaded to the printer."></property><property name="ignore spread overrides" code="igSO" type="boolean" description="If true, ignores flattener spread overrides."></property><property name="intent" code="RCin" type="RIri" description="The rendering intent. Note: Valid only when use color management is true."></property><property name="magenta angle" code="RMIA" type="real" description="The angle override for magenta ink. (Range: 0 to 360)"></property><property name="magenta frequency" code="RMIF" type="real" description="The frequency override for magenta ink. (Range: 1 to 500)"></property><property name="mark line weight" code="RpMw" type="EnMW" description="The stroke weight (in points) for printer marks."></property><property name="mark offset" code="Rpmo" description="The distance to offset the page marks from the edge of the page."><type type="number"></type><type type="text"></type></property><property name="mark type" code="RpMt" type="any" description="The type of printer marks, either an enum value or the name of a custom marks file. Can return: default/J mark with circle/J mark without circle or string."></property><property name="negative" code="RpNe" type="boolean" description="If true, prints the document as a negative."></property><property name="object reference" code="posp" type="print booklet print preference" access="r" description="An object reference for the object."></property><property name="omit bitmaps" code="omtb" type="boolean" description="If true, replaces bitmap images with OPI links."></property><property name="omit EPS" code="omte" type="boolean" description="If true, replaces EPS images with OPI links."></property><property name="omit PDF" code="omtp" type="boolean" description="If true, replaces PDF images with OPI links."></property><property name="OPI image replacement" code="odir" type="boolean" description="If true, prints graphics that are either OPI comments stored in imported EPS files or linked using OPI comments. For information on linking files using OPI comments, see omit EPS, omit PDF, or omit bitmaps."></property><property name="page information marks" code="pifo" type="boolean" description="If true, prints the filename, page number, current date and time, and color separation name."></property><property name="page position" code="RpCt" type="EnPP" description="The position of the page on the printing medium. Note: Valid only when tile is false."></property><property name="paper gap" code="Rpgp" description="The space between document pages on the printing medium."><type type="number"></type><type type="text"></type></property><property name="paper height" code="Rpht" type="any" description="The paper height. Note: Valid only when paper size is custom or scale mode is scale width height. Can return: auto or number or string."></property><property name="paper offset" code="Rpof" description="The amount of space to offset the page from the left edge of the imageable area."><type type="number"></type><type type="text"></type></property><property name="paper size" code="Rpsz" type="any" description="The paper size, specified as either a string or an enumeration. For information on paper size names, see paper size list. Can return: defined by driver/custom or string."></property><property name="paper size list" code="Rpss" access="r" description="A list of the available paper sizes."><type type="text" list="yes"></type></property><property name="paper transverse" code="RpTv" type="boolean" description="If true, uses transverse orientation."></property><property name="paper width" code="Rpwd" type="any" description="The paper width. Note: Valid only when paper size is custom or scale mode is scale width height. Can return: auto or number or string."></property><property name="parent" code="pare" type="document" access="r" description="The parent of the print booklet print preference (a document)."></property><property name="PDF passthrough" code="RpPt" type="boolean" access="r" description="If true, doing pdf passthrough."></property><property name="PostScript level" code="RpPL" type="EnPL" description="The PostScript level of the printer."></property><property name="PPD" code="ppd " type="any" description="The PPD, specified as a PPD name or an enumeration. Can return: device independent or string."></property><property name="PPD list" code="Rpds" access="r" description="Available PPDs."><type type="text" list="yes"></type></property><property name="preserve color numbers" code="RpCn" type="boolean" description="If true, preserves uncalibrated color numbers."></property><property name="print black" code="RPBI" type="boolean" description="If true, prints the black ink. Note: Valid only when trapping is off."></property><property name="print blank pages" code="Rblk" type="boolean" description="If true, prints blank pages. Note: Valid only when trapping is off. "></property><property name="print cyan" code="RPCI" type="boolean" description="If true, prints the cyan ink. Note: Valid only when trapping is off. "></property><property name="print file" code="RpFn" description="The PostScript file to print to. Note: Valid only when the current printer is defined as postscript file."><type type="file"></type><type type="text"></type></property><property name="print guides grids" code="Rpgg" type="boolean" description="If true, prints visible guides and baseline grids. Note: Valid only when trapping is off."></property><property name="print layers" code="RpLR" type="EnLR" description="The layers to print."></property><property name="print magenta" code="RPMI" type="boolean" description="If true, prints the magenta ink. Note: Valid only when trapping is off."></property><property name="print nonprinting" code="Rpnp" type="boolean" description="If true, prints non-printing objects. Note: Valid only when trapping is off."></property><property name="print page orientation" code="RpOr" type="EnPO" description="The orientation of the printed page."></property><property name="print yellow" code="RPYI" type="boolean" description="If true, prints the yellow ink. Note: Valid only when trapping is off."></property><property name="printer" code="Rprt" type="any" description="The current printer. Can return: postscript file or string."></property><property name="printer list" code="Rprs" access="r" description="Available printers."><type type="text" list="yes"></type></property><property name="profile" code="RpPr" type="any" description="The color profile. Can return: PostScript CMS/use document/working/No CMS or string."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="registration marks" code="regm" type="boolean" description="If true, prints small targets outside the page area for aligning color separations."></property><property name="reverse order" code="Rrvr" type="boolean" description="If true, prints pages in reverse order."></property><property name="scale height" code="shtp" type="real" description="The amount (as a percentage) that the page height is scaled during printing. (Range: 0 to 1000) Note: Valid only when scale mode is scale width height."></property><property name="scale mode" code="RScm" type="EnSM" description="The policy for scaling the page. Note: Valid only when printing from Layout view."></property><property name="scale proportional" code="RpSP" type="boolean" description="If true, constrains the proportions of the scaling; uses the most recent value for either scale width or scale height to define both values. Note: Valid only when scale mode is scale width height."></property><property name="scale width" code="swdp" type="real" description="The amount (as a percentage)  that the page width is scaled during printing. (Range: 0 to 1000) Note: Valid only when scale mode is scale width height."></property><property name="screening" code="RpSc" type="any" description="The ink screening settings for composite gray output in PostScript or PDF format. . Can return: default/custom or string."></property><property name="screening list" code="RpSL" access="r" description="Lists the ink screenings available in the PPD. Note: Valid only when color output is separations or in rip separations."><type type="text" list="yes"></type></property><property name="send image data" code="simd" type="EnID" description="The image data sent to the printer or file."></property><property name="simulate overprint" code="RpSO" type="boolean" description="If true, simulates the effects of overprinting spot inks with different neutral density values by converting spot colors to process colors for printing. Note: Not valid when the color output mode is defined to leave color profiles unchanged."></property><property name="source space" code="RCSP" type="EnSS" description="The source of the color management system. Note: Valid only when use color management is true."></property><property name="text as black" code="RpTB" type="boolean" description="If true, prints all text as black unless text has the color None or Paper or a color value that equals white. If false, prints colored text, such as blue hyperlinks, in halftone patterns. Note: Valid only when trapping is off."></property><property name="trapping" code="trpe" type="EnTp" description="The type of trapping."></property><property name="use document bleed to print" code="RpDB" type="boolean" description="If true, uses the bleed area set for the document."></property><property name="yellow angle" code="RYIA" type="real" description="The angle override for yellow ink. (Range: 0 to 360)"></property><property name="yellow frequency" code="RYIF" type="real" description="The frequency override for yellow ink. (Range: 1 to 500)"></property></class><class name="print preference" code="prnp" description="Print preferences."><element type="event"></element><element type="event listener"></element><property name="active printer preset" code="Rsty" type="any" description="The current printer preset type. Can return: default/custom or printer preset."></property><property name="all printer marks" code="apm " type="boolean" description="If true, prints all printer marks. If false, prints specified printer marks."></property><property name="bitmap printing" code="bmpr" type="boolean" description="If true, uses bitmap printing."></property><property name="bitmap resolution" code="bmrz" type="integer" description="The resolution for bitmap printing. (Range: 72 to 1200) Note: Valid when bitmap printing is true. Can return: integer (72 - 1200)."></property><property name="black angle" code="RBIA" type="real" description="The angle override for black ink. (Range: 0 to 360)"></property><property name="black frequency" code="RBIF" type="real" description="The frequency override for black ink. (Range: 1 to 500)"></property><property name="bleed bottom" code="RpBb" description="The height of the bleed area at the bottom of the page. Note: Valid only when use document bleed to print is true. Can return: number or string (0 - 432 points)."><type type="number"></type><type type="text"></type></property><property name="bleed chain" code="RpBC" type="boolean" description="If true, forces all bleed area settings to be the same, using the most recent bleed measurement setting. If false, allows bleed top, bleed bottom, bleed inside, and bleed outside to have different measurements. "></property><property name="bleed inside" code="RpBi" description="The width of the bleed area at the inside of the page. Note: Valid only when use document bleed to print is true. Can return: number or string (0 - 432 points)."><type type="number"></type><type type="text"></type></property><property name="bleed marks" code="bldm" type="boolean" description="If true, print bleed marks."></property><property name="bleed outside" code="RpBo" description="The width of the bleed area at the outside of the page. Note: Valid only when use document bleed to print is true. . Can return: number or string (0 - 432 points)."><type type="number"></type><type type="text"></type></property><property name="bleed top" code="RpBt" description="The height of the bleed area at the top of the page. Note: Valid only when use document bleed to print is true. Can return: number or string (0 - 432 points)."><type type="number"></type><type type="text"></type></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="collating" code="lwcl" type="boolean" description="If true, collate printed copies."></property><property name="color bars" code="colb" type="boolean" description="If true, add small squares of color representing the CMYK inks and tints of gray in 10% increments."></property><property name="color output" code="RpCm" type="EnCO" description="The color output mode for composites. Note: Not valid when a device-independent PPD is specified."></property><property name="composite angle" code="RpCA" type="real" description="The screen angle to use when printing composites. (Range: 0 to 360) Note: Valid only for PostScript or PDF files that use custom screening."></property><property name="composite frequency" code="RpCF" type="real" description="The screen frequency to use when printing composites. (Range: 1 to 500) Note: Valid only for PostScript or PDF files that use custom screening."></property><property name="copies" code="lwcp" type="integer" description="The number of copies to print. Note: Not valid when printer is PostScript File."></property><property name="CRD" code="RpCr" type="any" description="The color-rendering dictionary (CRD), specified as a CRD name or an enumeration value. Note: Valid only when use color management is true. Can return: default/use document/working or string."></property><property name="crop marks" code="crpm" type="boolean" description="Prints crop marks that define where the page should be trimmed."></property><property name="cyan angle" code="RCIA" type="real" description="The angle override for cyan ink. (Range: 0 to 360)"></property><property name="cyan frequency" code="RCIF" type="real" description="The frequency override for cyan ink. (Range: 1 to 500)"></property><property name="data format" code="RpDF" type="EnDF" description="The format in which to send image data to the printer."></property><property name="download PPD fonts" code="RpPF" type="boolean" description="If true, downloads all fonts listed in the selected PPD. Valid only when font downloading is complete or subset."></property><property name="flattener preset name" code="RpFS" type="text" description="The name of the transparency flattener preset."></property><property name="flip" code="RpFp" type="EnFp" description="The direction in which to flip the printed image."></property><property name="font downloading" code="fndl" type="EnFD" description="Controls how fonts are downloaded to the printer."></property><property name="ignore spread overrides" code="igSO" type="boolean" description="If true, ignores flattener spread overrides."></property><property name="include slug to print" code="RpIS" type="boolean" description="If true, includes the slug area in the printed document."></property><property name="intent" code="RCin" type="RIri" description="The rendering intent. Note: Valid only when use color management is true."></property><property name="magenta angle" code="RMIA" type="real" description="The angle override for magenta ink. (Range: 0 to 360)"></property><property name="magenta frequency" code="RMIF" type="real" description="The frequency override for magenta ink. (Range: 1 to 500)"></property><property name="mark line weight" code="RpMw" type="EnMW" description="The stroke weight (in points) for printer marks."></property><property name="mark offset" code="Rpmo" description="The distance to offset the page marks from the edge of the page."><type type="number"></type><type type="text"></type></property><property name="mark type" code="RpMt" type="any" description="The type of printer marks, either an enum value or the name of a custom marks file. Can return: default/J mark with circle/J mark without circle or string."></property><property name="negative" code="RpNe" type="boolean" description="If true, prints the document as a negative."></property><property name="object reference" code="posp" type="print preference" access="r" description="An object reference for the object."></property><property name="omit bitmaps" code="omtb" type="boolean" description="If true, replaces bitmap images with OPI links."></property><property name="omit EPS" code="omte" type="boolean" description="If true, replaces EPS images with OPI links."></property><property name="omit PDF" code="omtp" type="boolean" description="If true, replaces PDF images with OPI links."></property><property name="OPI image replacement" code="odir" type="boolean" description="If true, prints graphics that are either OPI comments stored in imported EPS files or linked using OPI comments. For information on linking files using OPI comments, see omit EPS, omit PDF, or omit bitmaps."></property><property name="page information marks" code="pifo" type="boolean" description="If true, prints the filename, page number, current date and time, and color separation name."></property><property name="page position" code="RpCt" type="EnPP" description="The position of the page on the printing medium. Note: Valid only when tile is false."></property><property name="page range" code="pcty" type="any" description="The pages to print, specified either as an enumeration or a string. To specify a range, separate page numbers in the string with a hyphen (-). To specify separate pages, separate page numbers in the string with a comma (,). Can return: all pages/selected items or string."></property><property name="paper gap" code="Rpgp" description="The space between document pages on the printing medium."><type type="number"></type><type type="text"></type></property><property name="paper height" code="Rpht" type="any" description="The paper height. Note: Valid only when paper size is custom or scale mode is scale width height. Can return: auto or number or string."></property><property name="paper offset" code="Rpof" description="The amount of space to offset the page from the left edge of the imageable area."><type type="number"></type><type type="text"></type></property><property name="paper size" code="Rpsz" type="any" description="The paper size, specified as either a string or an enumeration. For information on paper size names, see paper size list. Can return: defined by driver/custom or string."></property><property name="paper size list" code="Rpss" access="r" description="A list of the available paper sizes."><type type="text" list="yes"></type></property><property name="paper transverse" code="RpTv" type="boolean" description="If true, uses transverse orientation."></property><property name="paper width" code="Rpwd" type="any" description="The paper width. Note: Valid only when paper size is custom or scale mode is scale width height. Can return: auto or number or string."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the print preference (a book or document). Can return: book or document."></property><property name="PDF passthrough" code="RpPt" type="boolean" access="r" description="If true, doing pdf passthrough."></property><property name="PostScript level" code="RpPL" type="EnPL" description="The PostScript level of the printer."></property><property name="PPD" code="ppd " type="any" description="The PPD, specified as a PPD name or an enumeration. Can return: device independent or string."></property><property name="PPD list" code="Rpds" access="r" description="Available PPDs."><type type="text" list="yes"></type></property><property name="preserve color numbers" code="RpCn" type="boolean" description="If true, preserves uncalibrated color numbers."></property><property name="print black" code="RPBI" type="boolean" description="If true, prints the black ink. Note: Valid only when trapping is off."></property><property name="print blank pages" code="Rblk" type="boolean" description="If true, prints blank pages. Note: Valid only when trapping is off. "></property><property name="print cyan" code="RPCI" type="boolean" description="If true, prints the cyan ink. Note: Valid only when trapping is off. "></property><property name="print file" code="RpFn" description="The PostScript file to print to. Note: Valid only when the current printer is defined as postscript file."><type type="file"></type><type type="text"></type></property><property name="print guides grids" code="Rpgg" type="boolean" description="If true, prints visible guides and baseline grids. Note: Valid only when trapping is off."></property><property name="print layers" code="RpLR" type="EnLR" description="The layers to print."></property><property name="print magenta" code="RPMI" type="boolean" description="If true, prints the magenta ink. Note: Valid only when trapping is off."></property><property name="print master pages" code="Rpmp" type="boolean" description="If true, prints master pages."></property><property name="print nonprinting" code="Rpnp" type="boolean" description="If true, prints non-printing objects. Note: Valid only when trapping is off."></property><property name="print page orientation" code="RpOr" type="EnPO" description="The orientation of the printed page."></property><property name="print spreads" code="Rspd" type="boolean" description="If true, prints each spread with all spread pages on a single sheet. If false, prints spread pages as separate pages."></property><property name="print yellow" code="RPYI" type="boolean" description="If true, prints the yellow ink. Note: Valid only when trapping is off."></property><property name="printer" code="Rprt" type="any" description="The current printer. Can return: postscript file or string."></property><property name="printer list" code="Rprs" access="r" description="Available printers."><type type="text" list="yes"></type></property><property name="profile" code="RpPr" type="any" description="The color profile. Can return: PostScript CMS/use document/working/No CMS or string."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="registration marks" code="regm" type="boolean" description="If true, prints small targets outside the page area for aligning color separations."></property><property name="reverse order" code="Rrvr" type="boolean" description="If true, prints pages in reverse order."></property><property name="scale height" code="shtp" type="real" description="The amount (as a percentage) that the page height is scaled during printing. (Range: 0 to 1000) Note: Valid only when scale mode is scale width height."></property><property name="scale mode" cod