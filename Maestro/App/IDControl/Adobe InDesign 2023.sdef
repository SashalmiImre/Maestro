s" description="Do not show progress bar during printing."></enumerator><enumerator name="suppress print warnings" code="spwr" description="Do not show warning dialog during printing."></enumerator><enumerator name="suppress print dialog" code="spdg" description="Do not show print dialog. "></enumerator><enumerator name="suppress file save dialog" code="sfad" description="Do not show file save dialog during printing. "></enumerator></enumeration><enumeration name="vdsp" code="vdsp"><enumerator name="high quality" code="PHir" description="Slower performance; displays high-resolution graphics and high-quality transparencies and turns on anti-aliasing."></enumerator><enumerator name="typical" code="Ptyp" description="Moderate performance speed; displays proxy graphics and low-quality transparencies and turns on anti-aliasing."></enumerator><enumerator name="optimized" code="Popt" description="Best performance; grays out graphics and turns off transparency and anti-aliasing."></enumerator></enumeration><enumeration name="eAnc" code="eAnc"><enumerator name="top left anchor" code="ANtl" description="The top left corner."></enumerator><enumerator name="top center anchor" code="ANtc" description="The center point on the top of the bounding box."></enumerator><enumerator name="top right anchor" code="ANtr" description="The top right corner."></enumerator><enumerator name="left center anchor" code="ANlc" description="The center point on the left side of the bounding box."></enumerator><enumerator name="center anchor" code="ANct" description="The center point in the bounding box."></enumerator><enumerator name="right center anchor" code="ANrc" description="The center point on the right side of the bounding box."></enumerator><enumerator name="bottom left anchor" code="ANbl" description="The bottom left corner."></enumerator><enumerator name="bottom center anchor" code="ANbc" description="The center point on the bottom of the bounding box."></enumerator><enumerator name="bottom right anchor" code="ANbr" description="The bottom right corner."></enumerator></enumeration><enumeration name="scmo" code="scmo"><enumerator name="preview off" code="smpo" description="Normal view; displays guides and frame edges."></enumerator><enumerator name="preview to page" code="smpp" description="Preview mode; displays the document as it will be printed (hides guides and frame edges)."></enumerator><enumerator name="preview to bleed" code="smpb" description="Preview mode including the bleed area."></enumerator><enumerator name="preview to slug" code="smps" description="Preview mode including the slug area."></enumerator><enumerator name="presentation preview" code="smpn" description="Preview mode with editing turned off. Mouse clicks and arrow keys will move to previous or next spread."></enumerator></enumeration><enumeration name="PTpt" code="PTpt"><enumerator name="proof off" code="PTof" description="Turns off soft proof display. "></enumerator><enumerator name="document CMYK" code="PTdc" description="Creates a soft proof of colors using the document's CMYK profile."></enumerator><enumerator name="working CMYK" code="PTwc" description="Creates a soft proof of colors using the current CMYK working space. "></enumerator><enumerator name="custom" code="Cstm" description="Allows creation of a custom proofing setup for a specific output condition. "></enumerator></enumeration><enumeration name="elnt" code="elnt"><enumerator name="never interact" code="eNvr" description="The script does not display any dialogs or alerts."></enumerator><enumerator name="interact with all" code="eInA" description="The script displays all dialogs and alerts."></enumerator><enumerator name="interact with alerts" code="eInB" description="Displays alerts but not dialogs."></enumerator></enumeration><enumeration name="enEP" code="enEP"><enumerator name="not dispatching" code="enND" description="Not yet propagating."></enumerator><enumerator name="at target" code="enAT" description="The at-target phase of propagation."></enumerator><enumerator name="bubbling phase" code="enBu" description="The bubbling phase of propagation."></enumerator><enumerator name="done" code="enDD" description="The propagation is complete."></enumerator></enumeration><enumeration name="vcVS" code="vcVS"><enumerator name="version unknown" code="vcVU" description="The version is not known."></enumerator><enumerator name="project file newer" code="vcVP" description="The project has a newer file."></enumerator><enumerator name="local project match" code="vcVM" description="The version is identical to the project."></enumerator><enumerator name="local newer" code="vcVL" description="The version has modifications that make it newer than the project."></enumerator><enumerator name="version conflict" code="vcVC" description="The version contains local edits but the project file is newer."></enumerator><enumerator name="no resource" code="vcVN" description="No resource and no local file."></enumerator></enumeration><enumeration name="vcES" code="vcES"><enumerator name="editing unknown" code="vcEU" description="The editing status is not known."></enumerator><enumerator name="editing nowhere" code="vcEN" description="The file is not currently in use and is not locked."></enumerator><enumerator name="editing remotely" code="vcER" description="Lock held but not usable."></enumerator><enumerator name="editing locally" code="vcEL" description="The file has been modified locally and not locked."></enumerator><enumerator name="editing locally locked" code="vcEK" description="The file has been locked locally and may be modified."></enumerator><enumerator name="editing conflict" code="vcEC" description="The file was modified locally or remotely while it was locked and therefore two versions exist."></enumerator></enumeration><enumeration name="CPcp" code="CPcp"><enumerator name="color policy off" code="CPof" description="Turns off color management for documents whose profiles do not match the working space. For imported colors, numeric values override color appearance."></enumerator><enumerator name="preserve embedded profiles" code="CPpp" description="Preserves embedded color profiles in newly opened documents."></enumerator><enumerator name="convert to working space" code="CPws" description="Converts newly opened documents to the current working space. For imported colors, color appearance overrides numeric values."></enumerator><enumerator name="combination of preserve and safe cmyk" code="CPpd" description="Preserves raw color numbers and ignores embedded color profiles."></enumerator></enumeration><enumeration name="RIri" code="RIri"><enumerator name="use color settings" code="RIcs" description="Uses the current color settings."></enumerator><enumerator name="perceptual" code="RIpc" description="Preserves the visual relationship between colors at the expense of actual color values; most suitable for photographic images with high percentages of out-of-gamut colors."></enumerator><enumerator name="saturation" code="RIsa" description="Produces vivid colors at the expense of color accuracy; most suitable for business graphics such as graphs or charts."></enumerator><enumerator name="relative colorimetric" code="RIrc" description="Compares the extreme highlight of the source color space to that of the desination color space and shifts all colors accordingly; out-of-gamut colors are shifted to the closest reproducible color in the destination color space. "></enumerator><enumerator name="absolute colorimetric" code="RIac" description="Maintains color accuracy at the expense of preserving relationships between colors; most suitable for previewing how paper color affects printed colors. "></enumerator></enumeration><enumeration name="enTA" code="enTA"><enumerator name="task information" code="eIMs" description="Information message"></enumerator><enumerator name="task warning" code="eWMs" description="Warning message"></enumerator><enumerator name="task er