numerator></enumeration><enumeration name="mvop" code="mvop"><enumerator name="play" code="play" description="Starts playback."></enumerator><enumerator name="stop" code="stop" description="Stops playback."></enumerator><enumerator name="pause" code="paus" description="Pauses playback."></enumerator><enumerator name="resume" code="resu" description="Resumes playback."></enumerator><enumerator name="stop all" code="stpa" description="Stops all playback (SWF only)."></enumerator></enumeration><enumeration name="Smpt" code="Smpt"><enumerator name="none" code="none" description="No sound poster."></enumerator><enumerator name="standard" code="xpFb" description="Generic sound poster."></enumerator><enumerator name="proxy image" code="Mpxy" description="Proxy image sound poster."></enumerator></enumeration><enumeration name="otop" code="otop"><enumerator name="play" code="play" description="Starts playback."></enumerator><enumerator name="play from navigation point" code="plnv" description="Starts playback from the specified navigation point."></enumerator><enumerator name="stop" code="stop" description="Stops playback."></enumerator><enumerator name="pause" code="paus" description="Pauses playback."></enumerator><enumerator name="resume" code="resu" description="Resumes playback."></enumerator><enumerator name="stop all" code="stpa" description="Stops all playback (SWF only)."></enumerator></enumeration><enumeration name="Mmpt" code="Mmpt"><enumerator name="none" code="none" description="None."></enumerator><enumerator name="standard" code="xpFb" description="Uses the generic movie poster image file."></enumerator><enumerator name="from movie" code="Mfmf" description="Uses an image from the movie file."></enumerator><enumerator name="proxy image" code="Mpxy" description="(Read-only) Indicates whether the movie poster is not the standard, generic image."></enumerator></enumeration><enumeration name="Mfws" code="Mfws"><enumerator name="one fifth" code="Mfif" description="Makes the floating window one fifth the length and height of the movie's original display size."></enumerator><enumerator name="one fourth" code="Mfor" description="Makes the floating window one fourth the length and height of the movie's original display size."></enumerator><enumerator name="one half" code="Mhal" description="Makes the floating window one half the length and height of the movie's original display size."></enumerator><enumerator name="full" code="Mful" description="Makes the floating window the movie's original display size."></enumerator><enumerator name="double" code="Mtox" description="Makes the floating window twice the length and height of the movie's original display size."></enumerator><enumerator name="triple" code="Mtrx" description="Makes the floating window triple the length and height of the movie's original display size."></enumerator><enumerator name="quadruple" code="Mqux" description="Makes the floating window quadruple the length and height of the movie's original display size."></enumerator><enumerator name="max" code="Mmax" description="The floating window fills the entire screen."></enumerator></enumeration><enumeration name="Mfwp" code="Mfwp"><enumerator name="upper left" code="cntN" description="Positions the window in the upper left corner of the screen."></enumerator><enumerator name="upper middle" code="Mumd" description="Positions the window at the top of the screen midway between the left and right edges."></enumerator><enumerator name="upper right" code="Murt" description="Positions the window in the upper right corner of the screen."></enumerator><enumerator name="center left" code="Mclf" description="Positions the window on the left side of the screen midway between the top and bottom."></enumerator><enumerator name="center" code="Mcen" description="Positions the window in the center of the screen."></enumerator><enumerator name="center right" code="Mcrt" description="Positions the window on the right side of the screen midway between the top and bottom."></enumerator><enumerator name="lower left" code="Mllf" description="Positions the window in the lower left corner of the screen."></enumerator><enumerator name="lower middle" code="Mlmd" description="Positions the window at the bottom of the screen midway between the left and right edges."></enumerator><enumerator name="lower right" code="Mlrt" description="Positions the window in the lower right corner of the screen."></enumerator></enumeration><enumeration name="zmop" code="zmop"><enumerator name="inherit zoom" code="HDSz" description="Inherits the zoom setting from the previously displayed page."></enumerator><enumerator name="fit window" code="HDSw" description="Fits the page in the display window."></enumerator><enumerator name="fit width" code="HDSW" description="Fits the page to the width of the window; may obscure the lower portion of the page."></enumerator><enumerator name="fit visible" code="HDSV" description="Fits the text area of the page to the window width; obscures page margins and may obscure the lower portion of the page."></enumerator><enumerator name="actual size" code="zasz" description="Displays the page at 100% magnification."></enumerator></enumeration><enumeration name="Escj" code="Escj"><enumerator name="none" code="none" description="No adjustment."></enumerator><enumerator name="dashes" code="EDsh" description="Changes the length of dashes so that dashes always occur at path ends and corners; maintains set gap length. Note: Can cause dashes to be different lengths on shapes whose sides are of different lengths, such as rectangles."></enumerator><enumerator name="gaps" code="Egps" description="Changes the length of gaps so that dashes or dots always occur at ends and corners; maintains dash length or dot diameter. Note: Can cause gaps to be different lengths on shapes whose sides are of different lengths, such as rectangles. "></enumerator><enumerator name="dashes and gaps" code="DsGp" description="Adjusts both dashes and gaps to cover corners and end points. Note: Causes dash and gap sizes to be consistent on all sides of the shape. "></enumerator></enumeration><enumeration name="stAm" code="stAm"><enumerator name="center alignment" code="stAC" description="The stroke straddles the path."></enumerator><enumerator name="inside alignment" code="stAI" description="The stroke is inside the path. "></enumerator><enumerator name="outside alignment" code="stAO" description="The stroke is outside the path, like a picture frame."></enumerator></enumeration><enumeration name="dsps" code="dsps"><enumerator name="high quality" code="PHir" description="Slower performance; displays high-resolution graphics and high-quality transparencies and turns on anti-aliasing."></enumerator><enumerator name="typical" code="Ptyp" description="Moderate performance speed; displays proxy graphics and low-quality transparencies and turns on anti-aliasing."></enumerator><enumerator name="optimized" code="Popt" description="Best performance; grays out graphics and turns off transparency and anti-aliasing."></enumerator><enumerator name="default" code="Dflt" description="Uses the container object's default display performance preferences setting. For information, see default display settings."></enumerator></enumeration><enumeration name="ahed" code="ahed"><enumerator name="none" code="none" description="None."></enumerator><enumerator name="simple arrow head" code="simp" description="An arrow head formed by two slanting lines whose intersection forms a 45-degree angle and whose stroke weight is the same as the path's stroke."></enumerator><enumerator name="simple wide arrow head" code="swah" description="An arrow head formed by two slanting lines whose intersection forms a 90-degree angle and whose stroke weight is the same as the path's stroke."></enumerator><enumerator name="triangle arrow head" code="trin" description="A solid triangle arrow head whose point describes a 45-degree angle."></enumerator><enumerator name="triangle wide arrow head" code="twah" description="A solid triangle arrow head whose point describes a 90-degree angle."></enumerator><enumerator name="barbed arrow head" code="barb" description="A solid arrow head whose pierced end bows sharply toward the point and whose point describes a 45-degree angle."></enumerator><enumerator name="curved arrow head" code="cvah" description="A solid arrow head whose pierced end concaves toward the point and whose point describes a 45-degree angle."></enumerator><enumerator name="circle arrow head" code="crah" description="A hollow circle whose outline is the same weight as the stroke. The circle's diameter is 5 times the stroke width."></enumerator><enumerator name="circle solid arrow head" code="csah" description="A solid circle whose diameter is 5 times the stroke width."></enumerator><enumerator name="square arrow head" code="sqah" description="A hollow square set perpendicular to the path, whose outline is the same weight as the stroke. The length of one side of the square is 5 times the stroke width."></enumerator><enumerator name="square solid arrow head" code="ssah" description="A solid square set perpendicular to the end of the path. The length of one side of the square is 5 times the stroke width."></enumerator><enumerator name="bar arrow head" code="brah" description="A vertical bar bisected by the stroke, which meets the stroke at a right angle and is the same weight as the stroke. The bar's length is 4.5 times the stroke width."></enumerator></enumeration><enumeration name="LPdc" code="LPdc"><enumerator name="fixed dimension" code="DCfi" description="The dimension remains fixed relative to the parent."></enumerator><enumerator name="flexible dimension" code="DCfl" description="The dimension can vary relative to the parent."></enumerator></enumeration><enumeration name="ejon" code="ejon"><enumerator name="miter end join" code="mjon" description="Miter end join."></enumerator><enumerator name="round end join" code="rjon" description="Rounded end join."></enumerator><enumerator name="bevel end join" code="bjon" description="Beveled end join."></enumerator></enumeration><enumeration name="ecap" code="ecap"><enumerator name="butt end cap" code="bcap" description="A squared end that stops at the path's endpoint."></enumerator><enumerator name="round end cap" code="rcap" description="A semicircular end that extends beyond the endpoint by half the stroke-width."></enumerator><enumerator name="projecting end cap" code="pjcp" description="A squared end that extends beyond the endpoint by half the stroke-width."></enumerator></enumeration><enumeration name="coPt" code="coPt"><enumerator name="none" code="none" description="No corner option."></enumerator><enumerator name="rounded corner" code="cerd" description="Rounded corner option."></enumerator><enumerator name="inverse rounded corner" code="cenv" description="Inverted rounded corner option."></enumerator><enumerator name="inset corner" code="cens" description="Inset corner option."></enumerator><enumerator name="bevel corner" code="cebv" description="Beveled corner option."></enumerator><enumerator name="fancy corner" code="cefn" description="Fancy corner option."></enumerator></enumeration><enumeration name="eaha" code="eaha"><enumerator name="inside path" code="ahai" description="The arrowhead is inside the path, path geometry changes to accomodate arrow heads."></enumerator><enumerator name="outside path" code="ahao" description="The arrowhead is outside the path i.e. path geometry remains same."></enumerator></enumeration><enumeration name="anop" code="anop"><enumerator name="play" code="play" description="Starts playback."></enumerator><enumerator name="stop" code="stop" description="Stops playback."></enumerator><enumerator name="pause" code="paus" description="Pauses playback."></enumerator><enumerator name="resume" code="resu" description="Resumes playback."></enumerator><enumerator name="reverse playback" code="reve" description="Reverses playback."></enumerator><enumerator name="stop all" code="stpa" description="Stops all playback."></enumerator></enumeration><enumeration name="bhev" code="bhev"><enumerator name="mouse up" code="muev" description="Triggers the behavior when the mouse is released after a click."></enumerator><enumerator name="mouse down" code="mdev" description="Triggers the behavior when the mouse button is clicked (without being released). "></enumerator><enumerator name="mouse enter" code="meev" description="Triggers the behavior when the mouse pointer enters the area defined by the bounding box of the object."></enumerator><enumerator name="mouse exit" code="mxev" description="Triggers the behavior when the mouse pointer exits the area defined by the bounding box of the object."></enumerator><enumerator name="on focus" code="ofev" description="Triggers the behavior when the object receives focus, either through a mouse action or by pressing the Tab key."></enumerator><enumerator name="on blur" code="obev" description="Triggers the behavior when the focus moves to a different interactive object."></enumerator></enumeration><enumeration name="mxco" code="mxco"><enumerator name="scale values" code="grow" description="Scale values"></enumerator><enumerator name="shear value" code="slnt" description="Shear value"></enumerator><enumerator name="rotation value" code="spin" description="Rotation value"></enumerator><enumerator name="translation values" code="slip" description="Translation values"></enumerator></enumeration><enumeration name="enSl" code="enSl"><enumerator name="add to" code="add2" description="Adds the object to the existing selection; if no object was previously selected, makes the object the only selected object."></enumerator><enumerator name="remove from" code="remF" description="Deselects the object."></enumerator><enumerator name="replace with" code="repW" description="Selects the object and deselects any previously selected objects."></enumerator><enumerator name="set key" code="setk" description="Sets the key object. At least 2 objects must be selected, and the key object specified must be one of them."></enumerator></enumeration><enumeration name="rKVP" code="rKVP"><enumerator name="keep current value" code="KepV" description="Keep current value"></enumerator><enumerator name="keep current proportions" code="KepP" description="Keep current proportions"></enumerator><enumerator name="tall proportions" code="TalP" description="Tall proportions"></enumerator><enumerator name="wide proportions" code="WidP" description="Wide proportions"></enumerator><enumerator name="inverse proportions" code="InvP" description="Inverse proportions"></enumerator></enumeration><enumeration name="rMet" code="rMet"><enumerator name="adding current dimensions to" code="HowP" description="Add additional width and height to current values"></enumerator><enumerator name="multiplying current dimensions by" code="HowM" description="Multiply current width and height by the given factors"></enumerator><enumerator name="replacing current dimensions with" code="HowE" description="Change width and height overriding current values"></enumerator><enumerator name="reshaping area to ratio" code="HowA" description="Change width to height ratio keeping the current area"></enumerator><enumerator name="reshaping border to ratio" code="HowS" description="Change width to height ratio keeping the current perimeter"></enumerator></enumeration><enumeration name="edge" code="edge"><enumerator name="outer stroke bounds" code="ink1" description="Outer stroke bounds"></enumerator><enumerator name="geometric path bounds" code="ink0" description="Geometric path bounds"></enumerator></enumeration><enumeration name="xyxy" code="xyxy"><enumerator name="pasteboard coordinates" code="xypb" description="Pasteboard coordinates"></enumerator><enumerator name="parent coordinates" code="xypa" description="Parent coordinates"></enumerator><enumerator name="inner coordinates" code="xyin" description="Inner coordinates"></enumerator><enumerator name="page coordinates" code="xypg" description="Page coordinates."></enumerator><enumerator name="spread coordinates" code="xysp" description="Spread coordinates."></enumerator></enumeration><enumeration name="eAnc" code="eAnc"><enumerator name="top left anchor" code="ANtl" description="The top left corner."></enumerator><enumerator name="top center anchor" code="ANtc" description="The center point on the top of the bounding box."></enumerator><enumerator name="top right anchor" code="ANtr" description="The top right corner."></enumerator><enumerator name="left center anchor" code="ANlc" description="The center point on the left side of the bounding box."></enumerator><enumerator name="center anchor" code="ANct" description="The center point in the bounding box."></enumerator><enumerator name="right center anchor" code="ANrc" description="The center point on the right side of the bounding box."></enumerator><enumerator name="bottom left anchor" code="ANbl" description="The bottom left corner."></enumerator><enumerator name="bottom center anchor" code="ANbc" description="The center point on the bottom of the bounding box."></enumerator><enumerator name="bottom right anchor" code="ANbr" description="The bottom right corner."></enumerator></enumeration><enumeration name="EnFp" code="EnFp"><enumerator name="none" code="none" description="The printed image is not flipped."></enumerator><enumerator name="horizontal" code="horz" description="Flips the printed image horizontally."></enumerator><enumerator name="vertical" code="vert" description="Flips the printed image vertically."></enumerator><enumerator name="horizontal and vertical" code="HzVl" description="Flips the printed image horizontally and vertically (same as rotate 180)."></enumerator><enumerator name="both" code="both" description="Horizontal and vertical flip (same as rotate 180)"></enumerator></enumeration><enumeration name="fito" code="fito"><enumerator name="content to frame" code="ctof" description="Resizes content to fit the frame. Note: Content that is a different size than the frame appears stretched or squeezed."></enumerator><enumerator name="center content" code="cenc" description="Centers content in the frame; preserves the frame size as well as content size and proportions. Note: If the content is larger than the frame, content around the edges is obscured."></enumerator><enumerator name="proportionally" code="conp" description="Resizes content to fit the frame while preserving content proportions. If the content and frame have different proportions, some empty space appears in the frame."></enumerator><enumerator name="content aware fit" code="cafi" description="Selects best crop region of the content for the frame based on Adobe Sensei. Note: Preserves frame size but might scale the content size."></enumerator><enumerator name="frame to content" code="ftoc" description="Resizes the frame so it fits the content."></enumerator><enumerator name="fill proportionally" code="filp" description="Resizes content to fill the frame while perserving the proportions of the content. If the content and frame have different proportions, some of the content is obscured by the bounding box of the frame."></enumerator><enumerator name="apply frame fitting options" code="affo" description="Applies the current frame fitting options to the frame and content. Before using this, do confirm that the expected Frame Fitting Options are applied on the frame. For example, the act of placing an image in a frame set to 'Fit Content Proportionally' can change the crop settings in the Frame Fitting Options, which would then get applied for any subsequent image placement when this API is called."></enumerator></enumeration><enumeration name="CSOP" code="CSOP"><enumerator name="convert to rectangle" code="CSRE" description="Converts the object to a rectangle."></enumerator><enumerator name="convert to rounded rectangle" code="CSRR" description="Converts the object to a rectangle with rounded corners."></enumerator><enumerator name="convert to beveled rectangle" code="CSBR" description="Converts the object to a rectangle with beveled corners."></enumerator><enumerator name="convert to inverse rounded rectangle" code="CSIR" description="Converts the object to a rectangle with inverse rounded corners."></enumerator><enumerator name="convert to oval" code="CSOV" description="Converts the object to an ellipse."></enumerator><enumerator name="convert to triangle" code="CSTR" description="Converts the object to a triangle."></enumerator><enumerator name="convert to polygon" code="CSPO" description="Converts the object to a polygon."></enumerator><enumerator name="convert to line" code="CSLI" description="Converts the object to a line that connects the upper left and lower right corners of the object's bounding box."></enumerator><enumerator name="convert to straight line" code="CSSL" description="Converts the object to straight line. If the object is a square, circle, or its bounding box is wider than it is tall, the line is horizontal and connects the center points on the vertical sides of the bounding box. If the object's bounding box is taller than it is wide, the line connects the center points of the horizontal sides of the bounding box."></enumerator><enumerator name="convert to open path" code="CSOp" description="Converts the object to an open path."></enumerator><enumerator name="convert to closed path" code="CSCp" description="Converts the object to a closed path."></enumerator></enumeration><enumeration name="eXft" code="eXft"><enumerator name="tagged text" code="Tgtx" description="Exports to a tagged text file with a TXT extension. "></enumerator><enumerator name="PDF type" code="t_PD" description="Exports to PDF format."></enumerator><enumerator name="EPS type" code="t_EP" description="Exports to EPS format."></enumerator><enumerator name="RTF" code="RTF " description="Exports to rich text format (RTF). "></enumerator><enumerator name="text type" code="t_te" description="Exports to text (TXT) format."></enumerator><enumerator name="XML" code="XML " description="Exports the document's tagged content to XML."></enumerator><enumerator name="JPG" code="JPG " description="Exports to JPEG format."></enumerator><enumerator name="HTML" code="HTML" description="Exports to XHTML format."></enumerator><enumerator name="EPUB" code="epub" description="Exports to EPub format."></enumerator><enumerator name="fixed layout EPUB" code="epfx" description="Exports to fixed layout EPub format."></enumerator><enumerator name="HTMLFXL" code="HTfx" description="Exports to XHTML FXL format."></enumerator><enumerator name="InDesign snippet" code="snpt" description="Exports to InDesign snippet (IDMS) format."></enumerator><enumerator name="InDesign markup" code="idml" description="Exports to InDesign markup (IDML) format."></enumerator><enumerator name="InCopy markup" code="icml" description="Exports to InCopy markup (ICML) format."></enumerator><enumerator name="PNG format" code="ePNG" description="Exports to PNG format."></enumerator><enumerator name="interactive PDF" code="t_iP" description="Exports to Interactive PDF format."></enumerator></enumeration></suite><suite name="layout suite" code="K2PI" description="Scripting support for layout operations."><command name="add document content" code="K2PIePaR" description="Populates the article with all page items in the document."><direct-parameter type="article"></direct-parameter></command><command name="add event listener" code="K2PIeAEL" description="Adds an event listener."><direct-parameter type="specifier" description="Supported by the following objects: layer, spread, page, master spread, PDF attribute, page item, oval, rectangle, graphic line, polygon, group, image, EPS, PDF, WMF, PICT, graphic, transformation matrix, frame fitting option, guide, text wrap preference, contour option, section, path, path point, spline item, EPSText, imported page, SVG, media item, snippet, transform attribute option, Motion Preset, article, article member, article child, html item."></direct-parameter><parameter name="event type" code="pEvT" type="text" description="The event type."></parameter><parameter name="handler" code="pHnd" type="any" description="The event handler. Can accept: alias or string or JavaScript Function."></parameter><parameter name="captures" code="pCps" type="boolean" optional="yes" description="This parameter is obsolete. Can accept: boolean (Default: FALSE)."></parameter><result type="event listener" description="The new event listener."></result></command><command name="add path" code="K2PIUNPH" description="Creates a new page item by combining the object with other objects. Deletes the objects if they do not intersect."><direct-parameter type="specifier" description="Supported by the following objects: oval, rectangle, graphic line, polygon, spline item."></direct-parameter><parameter name="with" code="with" type="page item" description="The object(s) to add."></parameter><result type="page item" description="The new page item."></result></command><command name="adjust layout" code="K2PIeADL" description="Adjust the existing layout according to new page size, bleed and margin values. The first parameter is a plain object with key value pairs for properties affected. Permissible keys are width, height, bleedInside, bleedTop, bleedOutside, bleedBottom, leftMargin, topMargin, rightMargin, bottomMargin. The values can be specified as decimal numbers in units of Pt or as a string having a measurement value such as '1 in'. Not all properties need to be specified, only the values that need updation. Notice that when dealing with individual pages rather than the whole document, bleed changes has no effect. E.g. - app.activeDocument.adjustLayout({width:'600px', leftMargin: '1in'}), app.activeDocument.adjustLayout({rightMargin:'1in'}, app.activeDocument.spreads[0].pages), app.activeDocument.spreads[0].pages[0].adjustLayout({width:'400px', leftMargin: '10px'})"><direct-parameter type="page"></direct-parameter><parameter name="adopt to" code="PadT" type="record" description="Change values - see functin definition for details"></parameter><parameter name="affected pages" code="PpfT" type="page" optional="yes" description="The collection of Page objects to affect (optional). Has no effect if function is called from Page"></parameter></command><command name="apply object style" code="K2PIAOsy" description="Applies the specified object style."><direct-parameter type="specifier" description="Supported by the following objects: page item, oval, rectangle, graphic line, polygon, group, image, EPS, PDF, WMF, PICT, graphic, spline item, EPSText, imported page, SVG, media item, html item."></direct-parameter><parameter name="using" code="usng" type="object style" description="The object style to apply."></parameter><parameter name="clearing overrides" code="clov" type="boolean" optional="yes" description="If true, clears the object's existing attributes before applying the style. Can accept: boolean (Default: TRUE)."></parameter><parameter name="clearing overrides through root object style" code="cotr" type="boolean" optional="yes" description="If true, clears attributes and formatting applied to the object that are not defined in the object style. Can accept: boolean (Default: FALSE)."></parameter></command><command name="asynchronous export file" code="K2PIexAs" description="asynchronously exports the object(s) to a file."><direct-parameter type="specifier" description="Supported by the following objects: page item, oval, rectangle, graphic line, polygon, group, image, EPS, PDF, WMF, PICT, graphic, spline item, EPSText, imported page, SVG, media item, html item."></direct-parameter><parameter name="format" code="exft" type="any" description="The export format, specified as an enumeration value or as an extension that appears in the Save as type or Format menu in the Export dialog. Can accept: tagged text/PDF type/EPS type/RTF/text type/XML/JPG/HTML/EPUB/fixed layout EPUB/HTMLFXL/InDesign snippet/InDesign markup/InCopy markup/PNG format/interactive PDF or string."></parameter><parameter name="to" code="kfil" description="The path to the export file."><type type="file"></type><type type="text"></type></parameter><parameter name="showing options" code="imot" type="boolean" optional="yes" description="If true, displays the export options dialog. Can accept: boolean (Default: FALSE)."></parameter><parameter name="using" code="usng" type="PDF export preset" optional="yes" description="The export style."></parameter><parameter name="version comments" code="vcmt" type="text" optional="yes" description="The comment for this version."></parameter><parameter name="force save" code="vclb" type="boolean" optional="yes" description="If true, forcibly saves a version. Can accept: boolean (Default: FALSE)."></parameter><result type="background task" description="object representing the asynchronous export"></result></command><command name="auto tag" code="K2PIXste" description="Tag the object or the parent story using default tags defined in XML preference."><direct-parameter type="specifier" description="Supported by the following objects: page item, oval, rectangle, graphic line, polygon, group, image, EPS, PDF, WMF, PICT, graphic, spline item, EPSText, imported page, SVG, media item, html item."></direct-parameter></command><command name="bring forward" code="K2PIbrfr" description="Brings the object forward one level in its layer."><direct-parameter type="specifier" description="Supported by the following objects: oval, rectangle, graphic line, polygon, group, spline item, EPSText."></direct-parameter></command><command name="bring to front" code="K2PIbtfr" description="Brings the object to the front of its layer or in front of a particular item."><direct-parameter type="specifier" description="Supported by the following objects: oval, rectangle, graphic line, polygon, group, spline item, EPSText."></direct-parameter></command><command name="catenate matrix" code="K2PIxfmu" description="Multiply the transformation matrix by another."><direct-parameter type="transformation matrix"></direct-parameter><parameter name="with matrix" code="xfmm" type="transformation matrix" description="The right hand matrix factor"></parameter><result type="transformation matrix" description="The product transformation matrix"></result></command><command name="change coordinates" code="K2PIptop" description="Multiply the point by the matrix."><direct-parameter type="transformation matrix"></direct-parameter><parameter name="point" code="ptpt" type="real" description="The point to transform"></parameter><result type="real" description="The transformed point"></result></command><command name="change object" code="K2PIFCOt" description="Finds objects that match the find what value and replace the objects with the change to value."><direct-parameter type="specifier" description="Supported by the following objects: page item, oval, rectangle, graphic line, polygon, group, image, EPS, PDF, WMF, PICT, graphic, spline item, EPSText, imported page, SVG, media item, html item."></direct-parameter><parameter name="reverse order" code="Rrvr" type="boolean" optional="yes" description="If true, returns the results in reverse order."></parameter><result type="page item" description="The replaced object(s)."></result></command><command name="check in" code="K2PIbSUB" description="Checks in the story or stories."><direct-parameter type="specifier" description="Supported by the following objects: oval, rectangle, graphic line, polygon, spline item."></direct-parameter><parameter name="version comments" code="vcmt" type="text" optional="yes" description="The comment for this version."></parameter><parameter name="force save" code="vclb" type="boolean" optional="yes" description="If true, forcibly saves a version. Can accept: boolean (Default: FALSE)."></parameter><result type="boolean" description="True if the check in succeeded."></result></command><command name="check out" code="K2PIbEDT" description="Checks out the story."><direct-parameter type="specifier" description="Supported by the following objects: oval, rectangle, graphic line, polygon, spline item."></direct-parameter><result type="boolean" description="If true, the check out succeeded."></result></command><command name="clear frame fitting options" code="K2PIcfit" description="Removes the frame fittings options and resets it to the initial state."><direct-parameter type="specifier" description="Supported by the following objects: oval, rectangle, polygon."></direct-parameter></command><command name="clear object style overrides" code="K2PIosco" description="Clear overrides for object style"><direct-parameter type="specifier" description="Supported by the following objects: page item, oval, rectangle, graphic line, polygon, group, image, EPS, PDF, WMF, PICT, graphic, spline item, EPSText, imported page, SVG, media item, html item."></direct-parameter></command><command name="clear transformations" code="K2PIcxfm" description="Clears transformations from the object. Transformations include rotation, scaling, flipping, fitting, and shearing."><direct-parameter type="specifier" description="Supported by the following objects: page item, oval, rectangle, graphic line, polygon, group, image, EPS, PDF, WMF, PICT, graphic, spline item, EPSText, imported page, SVG, media item, html item."></direct-parameter></command><command name="content place" code="K2PIcopl" description="Duplicate an object and place it into the target."><direct-parameter type="specifier" description="Supported by the following objects: spread, page, master spread, page item, oval, rectangle, graphic line, polygon, group, image, EPS, PDF, WMF, PICT, graphic, spline item, EPSText, imported page, SVG, media item, html item."></direct-parameter><parameter name="page items" code="pits" type="page item" description="One or more page items to place or load"></parameter><parameter name="link page items" code="pLOO" type="boolean" optional="yes" description="Whether to link pageItems in content placer (if true it will override link stories value). Can accept: boolean (Default: FALSE)."></parameter><parameter name="link stories" code="pLSO" type="boolean" optional="yes" description="Whether to link stories in content placer (only applicable for single story, pageItem links will also be created in case of more than one item). Can accept: boolean (Default: FALSE)."></parameter><parameter name="map styles" code="pMSO" type="boolean" optional="yes" description="Whether to map styles in content placer. Can accept: boolean (Default: FALSE)."></parameter><parameter name="on" code="insh" type="specifier" optional="yes" description="Where to place the story. Can accept: spread, page or master spread."></parameter><parameter name="place point" code="insw" optional="yes" description="The point at which to place (only applicable if you are telling a page or spread to place)"><type type="number"></type><type type="text"></type></parameter><parameter name="destination layer" code="pdlr" type="layer" optional="yes" description="The layer on which to place (only applicable if you are telling a page or spread to place)"></parameter><parameter name="showing options" code="imot" type="boolean" optional="yes" description="Whether to display the link options dialog. Can accept: boolean (Default: FALSE)."></parameter><result type="specifier" description="The placed content. Can return: list of page items, graphics, stories or texts."></result></command><command name="convert shape" code="K2PICOSH" description="Converts the object to a different shape."><direct-parameter type="specifier" description="Supported by the following objects: page item, oval, rectangle, graphic line, polygon, group, image, EPS, PDF, WMF, PICT, graphic, spline item, EPSText, imported page, SVG, media item, html item."></direct-parameter><parameter name="given" code="givn" type="CSOP" description="The object's new shape."></parameter><parameter name="number of sides" code="nsid" type="integer" optional="yes" description="The number of sides for the resulting polygon. (Range: 3 to 100). Can accept: integer (3 - 100)."></parameter><parameter name="inset percentage" code="istp" type="integer" optional="yes" description="The star inset percentage for the resulting polygon. (Range: 0.0 to 100.0) . Can accept: integer (0 - 100)."></parameter><parameter name="corner radius" code="pcrd" optional="yes" description="The corner radius of the resulting rectangle. Can accept: number or string (0 - 800 points)."><type type="number"></type><type type="text"></type></parameter></command><command name="Create Email QR Code" code="K2PIQrem" description="Create Email QR Code on the page item or document"><direct-parameter type="specifier" description="Supported by the following objects: page item, oval, rectangle, graphic line, polygon, group, image, EPS, PDF, WMF, PICT, graphic, spline item, EPSText, imported page, SVG, media item, html item."></direct-parameter><parameter name="email address" code="QETo" type="text" optional="yes" description="QR code Email Address"></parameter><parameter name="subject" code="QRSu" type="text" optional="yes" description="QR code Email Subject"></parameter><parameter name="body" code="GNbo" type="text" optional="yes" description="QR code Email Body Message"></parameter><parameter name="qr code swatch" code="QRsw" type="any" optional="yes" description="Swatch to be applied on generated QR Code Graphic . Can accept: swatch or string."></parameter><parameter name="with properties" code="prdt" type="text" optional="yes" description="Initial values for properties of the new object. Above parameters can also be passed as properties"></parameter></command><command name="create guides" code="K2PIcrgd" description="Creates multiple guides on all pages of the spread."><direct-parameter type="specifier" description="Supported by the following objects: spread, master spread."></direct-parameter><parameter name="number of rows" code="nrws" type="integer" optional="yes" description="The number of rows to create on each page. Can accept: integer (0 - 40) (Default: 0)."></parameter><parameter name="number of columns" code="ncls" type="integer" optional="yes" description="The number of columns to create on each page. . Can accept: integer (0 - 40) (Default: 0)."></parameter><parameter name="row gutter" code="rowg" optional="yes" description="The height of the gutter between rows. Can accept: number or string (0 - 1440 points) (Default: 0.0 points)."><type type="number"></type><type type="text"></type></parameter><parameter name="column gutter" code="cclg" optional="yes" description="The width of the gutter between columns. Can accept: number or string (0 - 1440 points) (Default: 0.0 points)."><type type="number"></type><type type="text"></type></parameter><parameter name="guide color" code="gcol" type="any" optional="yes" description="The color to make the guides, specified either as an array of three doubles, each in the range 0 to 255 and representing R, G, and B values, or as a UI color. Can accept: list of 3 fixed (0 - 255) or light blue/red/green/blue/yellow/magenta/cyan/gray/black/orange/dark green/teal/tan/brown/violet/gold/dark blue/pink/lavender/brick red/olive green/peach/burgundy/grass green/ochre/purple/light gray/charcoal/grid blue/grid orange/fiesta/light olive/lipstick/cute teal/sulphur/grid green/white (Default: cyan)."></parameter><parameter name="fit margins" code="fmar" type="boolean" optional="yes" description="If true, the row height and column width are calculated based on the space within the page margins. If false, row height and column width are calculated based on the full page. Can accept: boolean (Default: FALSE)."></parameter><parameter name="remove existing" code="rmex" type="boolean" optional="yes" description="If true, removes existing guides when creating new ones. Can accept: boolean (Default: FALSE)."></parameter><parameter name="layer" code="layr" type="layer" optional="yes" description="The layer on which to create the guides."></parameter></command><command name="Create Hyperlink QR Code" code="K2PIQurl" description="Create Hyperlink QR Code on the page item or document"><direct-parameter type="specifier" description="Supported by the following objects: page item, oval, rectangle, graphic line, polygon, group, image, EPS, PDF, WMF, PICT, graphic, spline item, EPSText, imported page, SVG, media item, html item."></direct-parameter><parameter name="url link" code="QrUr" type="text" optional="yes" description="QR code Hyperlink URL "></parameter><parameter name="qr code swatch" code="QRsw" type="any" optional="yes" description="Swatch to be applied on generated QR Code Graphic . Can accept: swatch or string."></parameter><parameter name="with properties" code="prdt" type="text" optional="yes" description="Initial values for properties of the new object. Above parameters can also be passed as properties"></parameter></command><command name="Create Plain Text QR Code" code="K2PIQrPt" description="Create Plain Text QR Code on the page item"><direct-parameter type="specifier" description="Supported by the following objects: page item, oval, rectangle, graphic line, polygon, group, image, EPS, PDF, WMF, PICT, graphic, spline item, EPSText, imported page, SVG, media item, html item."></direct-parameter><parameter name="plain text" code="TYPt" type="text" optional="yes" description="QR code Plain Text "></parameter><parameter name="qr code swatch" code="QRsw" type="any" optional="yes" description="Swatch to be applied on generated QR Code Graphic . Can accept: swatch or string."></parameter><parameter name="with properties" code="prdt" type="text" optional="yes" description="Initial values for properties of the new object. Above parameters can also be passed as properties"></parameter></command><command name="Create Text Msg QR Code" code="K2PIQrSm" description="Create Text Msg QR Code on the page item or document"><direct-parameter type="specifier" description="Supported by the following objects: page item, oval, rectangle, graphic line, polygon, group, image, EPS, PDF, WMF, PICT, graphic, spline item, EPSText, imported page, SVG, media item, html item."></direct-parameter><parameter name="cell number" code="QPhN" type="text" optional="yes" description="QR code Text Phone Number"></parameter><parameter name="text message" code="QRtM" type="text" optional="yes" description="QR code Text Message"></parameter><parameter name="qr code swatch" code="QRsw" type="any" optional="yes" description="Swatch to be applied on generated QR Code Graphic . Can accept: swatch or string."></parameter><parameter name="with properties" code="prdt" type="text" optional="yes" description="Initial values for properties of the new object. Above parameters can also be passed as properties"></parameter></command><command name="Create vCard QR Code" code="K2PIQrVc" description="Create Business Card QR Code on the page item or load on document's placegun"><direct-parameter type="specifier" description="Supported by the following objects: page item, oval, rectangle, graphic line, polygon, group, image, EPS, PDF, WMF, PICT, graphic, spline item, EPSText, imported page, SVG, media item, html item."></direct-parameter><parameter name="first name" code="QRFN" type="text" optional="yes" description="QR code Business Card First Name"></parameter><parameter name="last name" code="QRLN" type="text" optional="yes" description="QR code Business Card Last Name"></parameter><parameter name="job title" code="QRTl" type="text" optional="yes" description="QR code Business Card Title"></parameter><parameter name="cell phone" code="QRCP" type="text" optional="yes" description="QR code Business Card Cell Phone Number"></parameter><parameter name="phone" code="QRPh" type="text" optional="yes" description="QR code Business Card Phone Number"></parameter><parameter name="email" code="QREm" type="text" optional="yes" description="QR code Business Card Email Address"></parameter><parameter name="organisation" code="QROg" type="text" optional="yes" description="QR code Business Card Organisation"></parameter><parameter name="street Address" code="QRAd" type="text" optional="yes" description="QR code Business Card Street Address"></parameter><parameter name="city" code="QRCi" type="text" optional="yes" description="QR code Business Card City"></parameter><parameter name="adr state" code="QRSt" type="text" optional="yes" description="QR code Business Card State"></parameter><parameter name="country" code="QRCn" type="text" optional="yes" description="QR code Business Card Country"></parameter><parameter name="postal code" code="QRPC" type="text" optional="yes" description="QR code Business Card Postal Code"></parameter><parameter name="website" code="QRUr" type="text" optional="yes" description="QR code Business Card URL"></parameter><parameter name="qr code swatch" code="QRsw" type="any" optional="yes" description="Swatch to be applied on generated QR Code Graphic . Can accept: swatch or string."></parameter><parameter name="with properties" code="prdt" type="text" optional="yes" description="Initial values for properties of the new object. Above parameters can also be passed as properties"></parameter></command><command name="delete all layout snapshots" code="K2PILSda" description="Delete all layout snapshots for this object."><direct-parameter type="page"></direct-parameter></command><command name="delete layout snapshot" code="K2PILSde" description="Delete the snapshot of the layout for the current object size and shape."><direct-parameter type="page"></direct-parameter></command><command name="detach" code="K2PIdtch" description="Detaches an overridden master page item from the master page."><direct-parameter type="specifier" description="Supported by the following objects: spread, page, master spread, page item, oval, rectangle, graphic line, polygon, group, image, EPS, PDF, WMF, PICT, graphic, guide, spline item, EPSText, imported page, SVG, media item, html item."></direct-parameter></command><command name="exclude overlap path" code="K2PIXOPH" description="Creates a new page item by excluding the overlapping areas of the object and other objects."><direct-parameter type="specifier" description="Supported by the following objects: oval, rectangle, graphic line, polygon, spline item."></direct-parameter><parameter name="with" code="with" type="page item" description="The object(s) to exclude."></parameter><result type="page item" description="The new page item."></result></command><command name="export" code="K2PIexpt" description="Exports the object(s) to a file."><direct-parameter type="specifier" description="Supported by the following objects: page item, oval, rectangle, graphic line, polygon, group, image, EPS, PDF, WMF, PICT, graphic, spline item, EPSText, imported page, SVG, media item, html item."></direct-parameter><parameter name="format" code="exft" type="any" description="The export format, specified as an enumeration value or as an extension that appears in the Save as type or Format menu in the Export dialog. Can accept: tagged text/PDF type/EPS type/RTF/text type/XML/JPG/HTML/EPUB/fixed layout EPUB/HTMLFXL/InDesign snippet/InDesign markup/InCopy markup/PNG format/interactive PDF or string."></parameter><parameter name="to" code="kfil" description="The path to the export file."><type type="file"></type><type type="text"></type></parameter><parameter name="showing options" code="imot" type="boolean" optional="yes" description="If true, displays the export options dialog. Can accept: boolean (Default: FALSE)."></parameter><parameter name="using" code="usng" type="PDF export preset" optional="yes" description="The export style."></parameter><parameter name="version comments" code="vcmt" type="text" optional="yes" description="The comment for this version."></parameter><parameter name="force save" code="vclb" type="boolean" optional="yes" description="If true, forcibly saves a version. Can accept: boolean (Default: FALSE)."></parameter></command><command name="export for web" code="K2PIexpw" description="Exports the object for the web."><direct-parameter type="specifier" description="Supported by the following objects: image, EPS, PDF, WMF, PICT, graphic, imported page, SVG."></direct-parameter><parameter name="to" code="kfil" description="The full path name of the exported file."><type type="file"></type><type type="text"></type></parameter><result type="text" description="The file names of the exported object in the following order: copied formatted image, copied optimized image, copied original image."></result></command><command name="extract labels" code="K2PIexLs" description="Gets the label value associated with the specified key. If key string is null, then a list of key-value pairs associated with the item is returned."><direct-parameter type="specifier" description="Supported by the following objects: page item, oval, rectangle, graphic line, polygon, group, image, EPS, PDF, WMF, PICT, graphic, spline item, EPSText, imported page, SVG, media item, html item."></direct-parameter><parameter name="key" code="with" type="text" optional="yes" description="The key."></parameter><result type="any" description="The label. Can return: string or list of lists of 2 strings."></result></command><command name="find object" code="K2PIFOjt" description="Finds objects that match the find what value."><direct-parameter type="specifier" description="Supported by the following objects: page item, oval, rectangle, graphic line, polygon, group, image, EPS, PDF, WMF, PICT, graphic, spline item, EPSText, imported page, SVG, media item, html item."></direct-parameter><parameter name="reverse order" code="Rrvr" type="boolean" optional="yes" description="If true, returns the results in reverse order."></parameter><result type="page item" description="The found object(s)."></result></command><command name="fit" code="K2PIfitc" description="Applies the specified fit option to content in a frame."><direct-parameter type="specifier" description="Supported by the following objects: page item, oval, rectangle, graphic line, polygon, group, image, EPS, PDF, WMF, PICT, graphic, spline item, EPSText, imported page, SVG, media item, html item."></direct-parameter><parameter name="given" code="givn" type="fito" description="The fit option to use."></parameter></command><command name="flip item" code="K2PIflip" description="Flips the object."><direct-parameter type="specifier" description="Supported by the following objects: page item, oval, rectangle, graphic line, polygon, group, image, EPS, PDF, WMF, PICT, graphic, spline item, EPSText, imported page, SVG, media item, html item."></direct-parameter><parameter name="given" code="givn" type="EnFp" description="The axis around which to flip the object."></parameter><parameter name="around" code="arnd" type="any" optional="yes" description="The point around which to flip the object. Can accept: list of 2 numbers or strings or top left anchor/top center anchor/top right anchor/left center anchor/center anchor/right center anchor/bottom left anchor/bottom center anchor/bottom right anchor."></parameter></command><command name="intersect path" code="K2PIISPH" description="Creates a new page item by intersecting the object with other objects. Returns an error if the objects do not intersect."><direct-parameter type="specifier" description="Supported by the following objects: oval, rectangle, graphic line, polygon, spline item."></direct-parameter><parameter name="with" code="with" type="page item" description="The object(s) with which to intersect. "></parameter><result type="page item" description="The new page item."></result></command><command name="invert matrix" code="K2PImInv" description="Invert the transformation matrix."><direct-parameter type="transformation matrix"></direct-parameter><result type="transformation matrix" description="The inverse of the transformation matrix"></result></command><command name="join" code="K2PIjoin" description="Join this path point to another path point. The two points must be end points and their paths combined into a single path on a single page item."><direct-parameter type="path point"></direct-parameter><parameter name="given" code="givn" type="jono" optional="yes" description="The join option to use."></parameter></command><command name="make compound path" code="K2PIMCPH" description="Creates a compound path by combining the path(s) of the object with the paths of other objects."><direct-parameter type="specifier" description="Supported by the following objects: oval, rectangle, graphic line, polygon, spline item."></direct-parameter><parameter name="with" code="with" type="page item" description="The other objects whose paths to include in the new compound path."></parameter><result type="page item" description="The new compound path."></result></command><command name="markup" code="K2PIXmku" description="Associates the page item with the specified XML element while preserving existing content."><direct-parameter type="specifier" description="Supported by the following objects: page item, oval, rectangle, graphic line, polygon, group, image, EPS, PDF, WMF, PICT, graphic, spline item, EPSText, imported page, SVG, media item, html item."></direct-parameter><parameter name="using" code="usng" type="XML element" description="The XML element."></parameter></command><command name="merge" code="K2PImerg" description="Merges the layer with other layer(s)."><direct-parameter type="layer"></direct-parameter><parameter name="with" code="with" type="layer" description="The layer(s) with which to merge."></parameter><result type="layer" description="The merged layer."></result></command><command name="minus back" code="K2PIRDPH" description="Creates a new page item by reverse subtracting the overlapping areas of the object and other objects."><direct-parameter type="specifier" description="Supported by the following objects: oval, rectangle, graphic line, polygon, spline item."></direct-parameter><parameter name="with" code="with" type="page item" description="The object(s) to reverse subtract."></parameter><result type="page item" description="The new page item."></result></command><command name="override" code="K2PIovrr" description="Overrides a master page item and places the item on the document page as a new object."><direct-parameter type="specifier" description="Supported by the following objects: page item, oval, rectangle, graphic line, polygon, group, image, EPS, PDF, WMF, PICT, graphic, guide, spline item, EPSText, imported page, SVG, media item, html item."></direct-parameter><parameter name="destination page" code="dPge" type="page" description="The document page that contains the master page item to override."></parameter><result type="specifier" description="The new object. Can return: page item, guide, graphic, movie or sound."></result></command><command name="place" code="K2PIplac" description="Places the file."><direct-parameter description="The file to place. Supported by the following objects: spread, page, master spread, page item, oval, rectangle, graphic line, polygon, image, EPS, PDF, WMF, PICT, graphic, spline item, EPSText, imported page, SVG, media item, html item."><type type="file"></type><type type="text"></type></direct-parameter><parameter name="on" code="insh" type="specifier" optional="yes" description="Where to place the file. Can accept: spread, page, master spread, page item or graphic."></parameter><parameter name="place point" code="insw" optional="yes" description="The point at which to place (only applicable if you are telling a page or spread to place)"><type type="number"></type><type type="text"></type></parameter><parameter name="destination layer" code="pdlr" type="layer" optional="yes" description="The layer on which to place (only applicable if you are telling a page or spread to place)"></parameter><parameter name="showing options" code="imot" type="boolean" optional="yes" description="Whether to display the import options dialog. Can accept: boolean (Default: FALSE)."></parameter><parameter name="autoflowing" code="aflw" type="boolean" optional="yes" description="Whether to autoflow placed text. Can accept: boolean (Default: FALSE)."></parameter><parameter name="with properties" code="prdt" type="record" optional="yes" description="Initial values for properties of the placed object(s)"></parameter><result type="specifier" description="The placed file. Can return: list of page items, graphics, movies, sounds, stories or texts."></result></command><command name="place and link" code="K2PIplli" description="Deprecated: Use contentPlace method. Original Description: Create a linked story and place it into the target."><direct-parameter type="specifier" description="Supported by the following objects: spread, page, master spread."></direct-parameter><parameter name="parent story" code="strp" type="story" description="The story to place and link from."></parameter><parameter name="on" code="insh" type="specifier" optional="yes" description="Where to place the story. Can accept: spread, page or master spread."></parameter><parameter name="place point" code="insw" optional="yes" description="The point at which to place (only applicable if you are telling a page or spread to place)"><type type="number"></type><type type="text"></type></parameter><parameter name="destination layer" code="pdlr" type="layer" optional="yes" description="The layer on which to place (only applicable if you are telling a page or spread to place)"></parameter><parameter name="showing options" code="imot" type="boolean" optional="yes" description="Whether to display the link options dialog. Can accept: boolean (Default: FALSE)."></parameter><result type="story" description="The placed story"></result></command><command name="place XML" code="K2PIXplc" description="Places the XML element onto a page. If the place point is above an existing page item, place the XML element into the page item."><direct-parameter type="specifier" description="Supported by the following objects: spread, page, page item, oval, rectangle, graphic line, polygon, group, image, EPS, PDF, WMF, PICT, graphic, spline item, EPSText, imported page, SVG, media item, html item."></direct-parameter><parameter name="using" code="usng" type="XML element" description="The XML element to place."></parameter><parameter name="place point" code="insw" description="The point at which to place the object, specified in the format [x, y]."><type type="number"></type><type type="text"></type></parameter><parameter name="autoflowing" code="aflw" type="boolean" optional="yes" description="If true, autoflows placed text. Can accept: boolean (Default: FALSE)."></parameter><result type="page item" description="The new page item"></result></command><command name="redefine scaling" code="K2PIpshs" description="Apply an item's scaling to its content if possible."><direct-parameter type="specifier" description="Supported by the following objects: page item, oval, rectangle, graphic line, polygon, group, image, EPS, PDF, WMF, PICT, graphic, spline item, EPSText, imported page, SVG, media item, html item."></direct-parameter><parameter name="to" code="to  " type="real" optional="yes" description="The scale factors to be left on the item.  The default is {1.0, 1.0}."></parameter></command><command name="reframe" code="K2PItlbr" description="Move the bounding box of the page item"><direct-parameter type="specifier" description="Supported by the following objects: page, page item, oval, rectangle, graphic line, polygon, group, image, EPS, PDF, WMF, PICT, graphic, spline item, EPSText, imported page, SVG, media item, html item."></direct-parameter><parameter name="in" code="in  " type="any" description="The bounding box to resize. Can accept: pasteboard coordinates/parent coordinates/inner coordinates/page coordinates/spread coordinates or Ordered list containing coordinate space:pasteboard coordinates/parent coordinates/inner coordinates/page coordinates/spread coordinates, bounds kind:outer stroke bounds/geometric path bounds."></parameter><parameter name="opposing corners" code="BoxC" type="real" description="Opposing corners of new bounding box in the given coordinate space"></parameter></command><command name="release compound path" code="K2PIRCPH" description="Releases a compound path."><direct-parameter type="specifier" description="Supported by the following objects: oval, rectangle, graphic line, polygon, spline item."></direct-parameter><result type="page item" description="The paths that made up the compound path (as individual objects)."></result></command><command name="remove event listener" code="K2PIeREL" description="Removes the event listener."><direct-parameter type="specifier" description="Supported by the following objects: layer, spread, page, master spread, PDF attribute, page item, oval, rectangle, graphic line, polygon, group, image, EPS, PDF, WMF, PICT, graphic, transformation matrix, frame fitting option, guide, text wrap preference, contour option, section, path, path point, spline item, EPSText, imported page, SVG, media item, snippet, transform attribute option, Motion Preset, article, article member, article child, html item."></direct-parameter><parameter name="event type" code="pEvT" type="text" description="The registered event type."></parameter><parameter name="handler" code="pHnd" type="any" description="The registered event handler. Can accept: alias or string or JavaScript Function."></parameter><parameter name="captures" code="pCps" type="boolean" optional="yes" description="This parameter is obsolete. Can accept: boolean (Default: FALSE)."></parameter><result type="boolean" description="Returns true if the handler was previously registered for this event."></result></command><command name="remove override" code="K2PIrmov" description="Removes the override from a previously overridden master page item."><direct-parameter type="specifier" description="Supported by the following objects: spread, page, master spread, page item, oval, rectangle, graphic line, polygon, group, image, EPS, PDF, WMF, PICT, graphic, guide, spline item, EPSText, imported page, SVG, media item, html item."></direct-parameter></command><command name="reset overlay defaults" code="K2PIrodf" description="Reset overlay to its default values and/or clear overlay type."><direct-parameter type="specifier" description="Supported by the following objects: page item, oval, rectangle, graphic line, polygon, group, image, EPS, PDF, WMF, PICT, graphic, spline item, EPSText, imported page, SVG, media item, html item."></direct-parameter><parameter name="overlay type" code="dpol" type="text" description="The overlay type to reset"></parameter><parameter name="clear asset" code="coas" type="boolean" optional="yes" description="The flag to clear overlay asset"></parameter><parameter name="clear overlay" code="cotp" type="boolean" optional="yes" description="The flag to clear overlay"></parameter></command><command name="resize" code="K2PIscal" description="Resize the page item."><direct-parameter type="specifier" description="Supported by the following objects: page, page item, oval, rectangle, graphic line, polygon, group, image, EPS, PDF, WMF, PICT, graphic, spline item, EPSText, imported page, SVG, media item, html item."></direct-parameter><parameter name="in" code="in  " type="any" description="The bounding box to resize. Can accept: pasteboard coordinates/parent coordinates/inner coordinates/page coordinates/spread coordinates, outer stroke bounds/geometric path bounds or Ordered list containing coordinate space:pasteboard coordinates/parent coordinates/inner coordinates/page coordinates/spread coordinates, bounds kind:outer stroke bounds/geometric path bounds."></parameter><parameter name="from" code="zpnt" type="any" description="The transform origin. Legal specifications: relative to bounding box: anchor | {anchor | {x,y}, bounds kind [, coordinate space]}; relative to coordinate space: {x,y} | {{x,y}[, coordinate space]}; relative to layout window ruler: {{x,y}, page index | bounds kind}. Can accept: list of 2 fixed, top left anchor/top center anchor/top right anchor/left center anchor/center anchor/right center anchor/bottom left anchor/bottom center anchor/bottom right anchor or list of lists of 2 fixed, pasteboard coordinates/parent coordinates/inner coordinates/page coordinates/spread coordinates, top left anchor/top center anchor/top right anchor/left center anchor/center anchor/right center anchor/bottom left anchor/bottom center anchor/bottom right anchor, outer stroke bounds/geometric path bounds or integers."></parameter><parameter name="by" code="by  " type="rMet" description="How the current dimensions are affected by the given values"></parameter><parameter name="values" code="BoxD" type="any" description="The width and height values. Legal dimensions specifications: {x, y [, coordinate space]}, {x, resize constraint [, coordinate space]}, or {resize constraint, y [, coordinate space]}; where x and y are real numbers and coordinate space is used to determine _only_ the unit of length for x and y; coordinate space is ignored for the 'current dimensions times' resize method). Can accept: list of fixed, keep current value/keep current proportions/tall proportions/wide proportions/inverse proportions or pasteboard coordinates/parent coordinates/inner coordinates/page coordinates/spread coordinates."></parameter><parameter name="resize individually" code="rPer" type="boolean" optional="yes" description="If false and multiple page items are targeted, the new dimensions are attained only by moving the individual items rather than resizing them. Can accept: boolean (Default: TRUE)."></parameter><parameter name="considering ruler units" code="seeR" type="boolean" optional="yes" description="If true then a ruler location is interpreted using ruler units rather than points. The default value is false. This parameter has no effect unless the reference point is specified relative to a page. Can accept: boolean (Default: FALSE)."></parameter></command><command name="resolve" code="K2PIwher" description="Get the coordinates of the given location in the specified coordinate system."><direct-parameter type="specifier" description="Supported by the following objects: spread, page, master spread, page item, oval, rectangle, graphic line, polygon, group, image, EPS, PDF, WMF, PICT, graphic, guide, spline item, EPSText, imported page, SVG, media item, html item."></direct-parameter><parameter name="location" code="corn" type="any" description="The location requested. Can accept: list of 2 fixed, top left anchor/top center anchor/top right anchor/left center anchor/center anchor/right center anchor/bottom left anchor/bottom center anchor/bottom right anchor or list of lists of 2 fixed, pasteboard coordinates/parent coordinates/inner coordinates/page coordinates/spread coordinates, top left anchor/top center anchor/top right anchor/left center anchor/center anchor/right center anchor/bottom left anchor/bottom center anchor/bottom right anchor, outer stroke bounds/geometric path bounds or integers."></parameter><parameter name="in" code="in  " type="xyxy" description="The coordinate space to use."></parameter><parameter name="considering ruler units" code="seeR" type="boolean" optional="yes" description="If true then a ruler location is interpreted using ruler units rather than points. The default value is false. This parameter has no effect unless the reference point is specified relative to a page. Can accept: boolean (Default: FALSE)."></parameter><result type="any" description="The resolved location for each of the targeted page items. Can return: list of 2 fixed or list of lists of 2 fixed."></result></command><command name="reverse path" code="K2PIrevP" description="Reverses the path."><direct-parameter type="path"></direct-parameter></command><command name="revert" code="K2PIbREV" description="Reverts the document to its state at the last save operation. "><direct-parameter type="specifier" description="Supported by the following objects: oval, rectangle, graphic line, polygon, spline item."></direct-parameter><result type="boolean" description="If true, the revert succeeded."></result></command><command name="rotate matrix" code="K2PIxfro" description="Rotate the transformation matrix."><direct-parameter type="transformation matrix"></direct-parameter><parameter name="by angle" code="xfra" type="real" optional="yes" description="The counterclockwise rotation angle"></parameter><parameter name="by cosine" code="xfrc" type="real" optional="yes" description="The cosine of the desired rotation"></parameter><parameter name="by sine" code="xfrs" type="real" optional="yes" description="The sine of the desired rotation"></parameter><result type="transformation matrix" description="The rotated transformation matrix"></result></command><command name="save a copy" code="K2PIsavc" description="Save a copy of this motion preset to a InDesign motion preset file."><direct-parameter type="Motion Preset"></direct-parameter><parameter name="to" code="kfil" description="The Flash motion preset file to export to."><type type="file"></type><type type="text"></type></parameter></command><command name="scale matrix" code="K2PIxfsc" description="Scale the transformation matrix."><direct-parameter type="transformation matrix"></direct-parameter><parameter name="horizontally by" code="xfsx" type="real" optional="yes" description="The horizontal scale factor"></parameter><parameter name="vertically by" code="xfsy" type="real" optional="yes" description="The vertical scale factor"></parameter><result type="transformation matrix" description="The scaled transformation matrix"></result></command><command name="select" code="K2PIselt" description="Selects the object."><direct-parameter type="specifier" description="Supported by the following objects: spread, page, master spread, page item, oval, rectangle, graphic line, polygon, group, image, EPS, PDF, WMF, PICT, graphic, guide, spline item, EPSText, imported page, SVG, media item, html item."></direct-parameter><parameter name="existing selection" code="exts" type="enSl" optional="yes" description="The selection status of the object in relation to previously selected objects. Can accept: add to/remove from/replace with/set key (Default: replace with)."></parameter></command><command name="send backward" code="K2PIsnbw" description="Sends the object back one level in its layer."><direct-parameter type="specifier" description="Supported by the following objects: oval, rectangle, graphic line, polygon, group, spline item, EPSText."></direct-parameter></command><command name="send to back" code="K2PIsnbk" description="Sends the object to the back of its layer or behind a particular item (must have same parent)."><direct-parameter type="specifier" description="Supported by the following objects: oval, rectangle, graphic line, polygon, group, spline item, EPSText."></direct-parameter></command><command name="set content" code="K2PIXsec" description="Replaces the content of XML element with content imported from a file."><direct-parameter type="specifier" description="Supported by the following objects: spread, page."></direct-parameter><parameter name="using" code="usng" type="text" description="The file path to the import file."></parameter><parameter name="relative base path" code="XRel" type="text" optional="yes" description="Base path used to resolve relative paths."></parameter><result type="page item" description="The new page item"></result></command><command name="shear matrix" code="K2PIxfsk" description="Shear the transformation matrix."><direct-parameter type="transformation matrix"></direct-parameter><parameter name="by angle" code="xfka" type="real" optional="yes" description="The horizontal shear angle"></parameter><parameter name="by slope" code="xfkm" type="real" optional="yes" description="The horizontal shear slope"></parameter><result type="transformation matrix" description="The sheared transformation matrix"></result></command><command name="snapshot current layout" code="K2PILSnw" description="Create a snapshot of the layout for the current object size and shape."><direct-parameter type="page"></direct-parameter></command><command name="store" code="K2PIstor" description="Stores the object in the specified library."><direct-parameter type="specifier" description="Supported by the following objects: page item, oval, rectangle, graphic line, polygon, group, image, EPS, PDF, WMF, PICT, graphic, spline item, EPSText, imported page, SVG, media item, html item."></direct-parameter><parameter name="using" code="usng" type="library" description="The library in which to store the object."></parameter><parameter name="with properties" code="prdt" type="record" optional="yes" description="Initial values for properties of the new object"></parameter><result type="asset" description="The new library asset(s)."></result></command><command name="subtract path" code="K2PIDFPH" description="Creates a new page item by subtracting the overlapping areas of the object and other objects."><direct-parameter type="specifier" description="Supported by the following objects: oval, rectangle, graphic line, polygon, spline item."></direct-parameter><parameter name="with" code="with" type="page item" description="The object(s) to subtract."></parameter><result type="page item" description="The new page item."></result></command><command name="transform" code="K2PIxfrm" description="Transform the page item."><direct-parameter type="specifier" description="Supported by the following objects: spread, page, master spread, page item, oval, rectangle, graphic line, polygon, group, image, EPS, PDF, WMF, PICT, graphic, spline item, EPSText, imported page, SVG, media item, html item."></direct-parameter><parameter name="in" code="in  " type="xyxy" description="The coordinate space to use"></parameter><parameter name="from" code="zpnt" type="any" description="The temporary origin during the transformation. Can accept: list of 2 fixed, top left anchor/top center anchor/top right anchor/left center anchor/center anchor/right center anchor/bottom left anchor/bottom center anchor/bottom right anchor or list of lists of 2 fixed, pasteboard coordinates/parent coordinates/inner coordinates/page coordinates/spread coordinates, top left anchor/top center anchor/top right anchor/left center anchor/center anchor/right center anchor/bottom left anchor/bottom center anchor/bottom right anchor, outer stroke bounds/geometric path bounds or integers."></parameter><parameter name="with matrix" code="1xfm" type="any" description="Transform matrix. Can accept: list of 6 fixed or transformation matrix."></parameter><parameter name="replacing current" code="mxto" type="any" optional="yes" description="Transform components to consider; providing this optional parameter causes the target's existing transform components to be replaced with new values.  Without this parameter, the given matrix is concatenated onto the target's existing transform combining the effect of the two. Can accept: scale values/shear value/rotation value/translation values, list of scale values/shear value/rotation value/translation values or integer."></parameter><parameter name="considering ruler units" code="seeR" type="boolean" optional="yes" description="If true then a ruler based origin is interpreted using ruler units rather than points. The default value is false. This parameter has no effect unless the reference point is specified relative to a page. Can accept: boolean (Default: FALSE)."></parameter></command><command name="transform again" code="K2PITrAg" description="Transforms the object using the last transformation performed on any object. Transformations include moving, rotating, shearing, scaling, and flipping. "><direct-parameter type="specifier" description="Supported by the following objects: page item, oval, rectangle, graphic line, polygon, group, image, EPS, PDF, WMF, PICT, graphic, spline item, EPSText, imported page, SVG, media item, html item."></direct-parameter><result type="text" description="Playback errors."></result></command><command name="transform again individually" code="K2PITrAI" description="Transforms the object using the last transformation performed on any object. Transformations include moving, rotating, shearing, scaling, and flipping. "><direct-parameter type="specifier" description="Supported by the following objects: page item, oval, rectangle, graphic line, polygon, group, image, EPS, PDF, WMF, PICT, graphic, spline item, EPSText, imported page, SVG, media item, html item."></direct-parameter><result type="text" description="Playback errors"></result></command><command name="transform sequence again" code="K2PITrSA" description="Transforms the object using the last sequence of transform operations performed on any single object or performed at the same time on any group of objects. Transformations include moving, rotating, shearing, scaling, and flipping."><direct-parameter type="specifier" description="Supported by the following objects: page item, oval, rectangle, graphic line, polygon, group, image, EPS, PDF, WMF, PICT, graphic, spline item, EPSText, imported page, SVG, media item, html item."></direct-parameter><result type="text" description="Playback errors"></result></command><command name="transform sequence again individually" code="K2PITrSI" description="Transforms the object using the last sequence of transformations performed on any single object or performed at the same time on any group of objects. Transformations include moving, rotating, shearing, scaling, and flipping."><direct-parameter type="specifier" description="Supported by the following objects: page item, oval, rectangle, graphic line, polygon, group, image, EPS, PDF, WMF, PICT, graphic, spline item, EPSText, imported page, SVG, media item, html item."></direct-parameter><result type="text" description="Playback errors"></result></command><command name="transform values of" code="K2PIxfva" description="Get the transformation values of the page item."><direct-parameter type="specifier" description="Supported by the following objects: spread, page, master spread, page item, oval, rectangle, graphic line, polygon, group, image, EPS, PDF, WMF, PICT, graphic, guide, spline item, EPSText, imported page, SVG, media item, html item."></direct-parameter><parameter name="in" code="in  " type="xyxy" description="The coordinate space to use"></parameter><result type="transformation matrix" description="A list of the transformation matrices"></result></command><command name="translate matrix" code="K2PIxftr" description="Translate the transformation matrix."><direct-parameter type="transformation matrix"></direct-parameter><parameter name="horizontally by" code="xftx" type="real" optional="yes" description="The horizontal translation distance"></parameter><parameter name="vertically by" code="xfty" type="real" optional="yes" description="The vertical translation distance"></parameter><result type="transformation matrix" description="The translated transformation matrix"></result></command><command name="ungroup" code="K2PIugrp" description="Ungroups the group."><direct-parameter type="group"></direct-parameter></command><class name="article" code="cArt" description="An article" plural="articles"><element type="article member"></element><element type="event"></element><element type="event listener"></element><property