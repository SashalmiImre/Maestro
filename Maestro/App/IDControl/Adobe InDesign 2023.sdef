"></parameter></command><command name="delete unused tags" code="K2  Xdut" description="Deletes unused XML markup tags."><direct-parameter type="specifier" description="Supported by the following objects: application, document."></direct-parameter></command><command name="distribute" code="K2  dsBT" description="Distribute page items."><direct-parameter type="document"></direct-parameter><parameter name="align distribute items" code="adIT" type="page item" description="The page items to align or distribute"></parameter><parameter name="distribute option" code="dBOs" type="dOEn" description="The type of distribution to apply."></parameter><parameter name="align distribute bounds" code="aDsT" type="aDeT" optional="yes" description="The bounds within which to align or distribute the page items."></parameter><parameter name="use distribute measurement" code="uALv" type="boolean" optional="yes" description="If true, distribute space between page items. When this property is true, the bounds setting is ignored."></parameter><parameter name="absolute distribute measurement" code="aDSv" optional="yes" description="The distance to use when distributing page items. Required when 'align distribute bounds' specifies 'key object'."><type type="number"></type><type type="text"></type></parameter></command><command name="do script" code="K2  dosc" description="Executes the script in the specified language as a single transaction."><direct-parameter type="any" description="The script to execute. "></direct-parameter><parameter name="language" code="doLg" type="ScLg" optional="yes" description="The language of the script to execute. If not specified, uses the language used to call this method. Can accept: unknown/javascript/uxpscript/applescript language (Default: unknown)."></parameter><parameter name="with arguments" code="wArg" type="any" optional="yes" description="An array of arguments passed to the script."></parameter><parameter name="undo mode" code="pSUM" type="eSUM" optional="yes" description="How to undo this script. Can accept: script request/entire script/auto undo/fast entire script (Default: script request)."></parameter><parameter name="undo name" code="unnm" type="text" optional="yes" description="The name of the undo step for entire script undo mode. Can accept: string (Default: &quot;Script&quot;)."></parameter><result type="any" description="The return value of the script."></result></command><command name="dump between memory marks" code="K2  SDBm" description="Dumps memory allocations from all marks in the specified range."><parameter name="from" code="from" type="integer" description="The first mark in the range."></parameter><parameter name="to" code="to  " type="integer" description="The last mark in the range."></parameter></command><command name="dump from memory mark" code="K2  SDFm" description="Dumps memory allocations from the specified mark."><parameter name="from" code="from" type="integer" description="The mark from which to dump memory."></parameter></command><command name="embed" code="K2  emPF" description="Embed this profile to the document."><direct-parameter type="document"></direct-parameter><parameter name="using" code="usng" type="any" description="The preflight profile to embed. Can accept: string or preflight profile."></parameter><result type="preflight profile" description="The preflight profile that is embedded."></result></command><command name="export" code="K2  expt" description="Exports the object(s) to a file."><direct-parameter type="document"></direct-parameter><parameter name="format" code="exft" type="any" description="The export format, specified as an enumeration value or as an extension that appears in the Save as type or Format menu in the Export dialog. Can accept: tagged text/PDF type/EPS type/RTF/text type/XML/JPG/HTML/EPUB/fixed layout EPUB/HTMLFXL/InDesign snippet/InDesign markup/InCopy markup/PNG format/interactive PDF or string."></parameter><parameter name="to" code="kfil" description="The path to the export file."><type type="file"></type><type type="text"></type></parameter><parameter name="showing options" code="imot" type="boolean" optional="yes" description="If true, displays the export options dialog. Can accept: boolean (Default: FALSE)."></parameter><parameter name="using" code="usng" type="PDF export preset" optional="yes" description="The export style."></parameter><parameter name="version comments" code="vcmt" type="text" optional="yes" description="The comment for this version."></parameter><parameter name="force save" code="vclb" type="boolean" optional="yes" description="If true, forcibly saves a version. Can accept: boolean (Default: FALSE)."></parameter></command><command name="export article folio" code="K2  emn2" description="Export the specified documents to an article folio.

Note: This method behaves identically to @method(exportMiniFolio), but differs in its return value. @method(exportMiniFolio) returns an array of warning strings whereas this method returns an XML structure."><parameter name="destination" code="hlds" description="The location to write the file."><type type="file"></type><type type="text"></type></parameter><parameter name="portrait document" code="mipd" type="document" description="The InDesign document for the stack's portrait orientation."></parameter><parameter name="landscape document" code="mild" type="document" description="The InDesign document for the stack's landscape orientation."></parameter><parameter name="folio metadata" code="ismd" type="any" optional="yes" description="Optional meta data for the mini folio. Can accept: Ordered list containing key:string, value:string."></parameter><parameter name="mini folio params" code="miPm" type="any" optional="yes" description="Options for exporting a mini folio. Can accept: Ordered list containing data field:string, data value:anything."></parameter><result type="text" description="The results of the export as an XML string.

The structure is currently defined as:

&lt;results&gt;
&lt;warnings&gt;
&lt;warning [attrs]&gt;
&lt;/warnings&gt;
&lt;/results&gt;

Note: If no warnings are encountered during the export, the warnings tag will be omitted.

Attributes for &lt;warning&gt; tag:
|| Name || Type || Required? || Description ||
| code | uint | yes | The error code associated with the warning. |
| translatedDesc | string | no | A string description of the warning, translated to current locale. |
| cause | uint | no | The error code that ultimately caused the warning, if different from code. |
| data | string | no | An untranslated string that gives further information about what failed, to be relative to the returned error. E.g., if a font can't be subset (code == kDigPub_FontSubsettingErr), this would be the name of the font. |

Note: the code attribute is the only required item. Callers must handle cases where other pieces of information are missing.
"></result></command><command name="export dps article" code="K2  emn3" description="Export the specified document to a DPS article.
Note: This method behaves similarly to @method(exportMiniFolio), but differs in its parameters. "><parameter name="destination" code="hlds" description="The location to write the file."><type type="file"></type><type type="text"></type></parameter><parameter name="document" code="DGdc" type="document" description="The source InDesign document."></parameter><parameter name="dps article params" code="juAP" type="any" description="Options for exporting a DPS article. Can accept: Ordered list containing data field:string, data value:anything."></parameter><result type="text" description="The list of warning information."></result></command><command name="export folio to directory" code="K2  eitd" description="Export the selected documents to a directory."><parameter name="destination" code="hlds" description="The directory to write the folio."><type type="file"></type><type type="text"></type></parameter><parameter name="mini folio list" code="mfLS" type="any" description="The mini folio(es) to add to the folio. Can accept: alias or string or list of aliases or strings."></parameter><parameter name="folio metadata" code="ismd" type="any" description="Meta data for the folio. Can accept: Ordered list containing key:string, value:string."></parameter><parameter name="export folio params" code="exfP" type="any" optional="yes" description="Additional options for export folios. Can accept: Ordered list containing data field:string, data value:anything."></parameter></command><command name="export folio to directory package" code="K2  eidp" description="Export the selected documents to a compressed folio file that contains non-compressed mini folios."><parameter name="destination" code="hlds" description="The location to write the package."><type type="file"></type><type type="text"></type></parameter><parameter name="mini folio list" code="mfLS" type="any" description="The mini folio(es) to add to the folio. Can accept: alias or string or list of aliases or strings."></parameter><parameter name="folio metadata" code="ismd" type="any" description="Meta data for the folio. Can accept: Ordered list containing key:string, value:string."></parameter><parameter name="export folio params" code="exfP" type="any" optional="yes" description="Additional options for export folios. Can accept: Ordered list containing data field:string, data value:anything."></parameter></command><command name="export folio to package" code="K2  eitp" description="Export the selected documents to a compressed folio file that contains compressed mini folios."><parameter name="destination" code="hlds" description="The location to write the package."><type type="file"></type><type type="text"></type></parameter><parameter name="mini folio list" code="mfLS" type="any" description="The mini folio(es) to add to the folio. Can accept: alias or string or list of aliases or strings."></parameter><parameter name="folio metadata" code="ismd" type="any" description="Meta data for the folio. Can accept: Ordered list containing key:string, value:string."></parameter><parameter name="export folio params" code="exfP" type="any" optional="yes" description="Additional options for export folios. Can accept: Ordered list containing data field:string, data value:anything."></parameter></command><command name="export mini folio" code="K2  emni" description="Export the specified documents to a mini-folio."><parameter name="destination" code="hlds" description="The location to write the file."><type type="file"></type><type type="text"></type></parameter><parameter name="portrait document" code="mipd" type="document" description="The InDesign document for the stack's portrait orientation."></parameter><parameter name="landscape document" code="mild" type="document" description="The InDesign document for the stack's landscape orientation."></parameter><parameter name="folio metadata" code="ismd" type="any" optional="yes" description="Optional meta data for the mini folio. Can accept: Ordere