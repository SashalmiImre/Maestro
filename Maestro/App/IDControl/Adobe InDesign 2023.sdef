 object reference for the object."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the tagged text export preference (a application)."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="tag form" code="TTtf" type="ttfe" description="The form for tags in the exported text."></property></class><class name="tagged text import preference" code="TTII" description="Tagged text import preferences."><element type="event"></element><element type="event listener"></element><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="object reference" code="posp" type="tagged text import preference" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the tagged text import preference (a application)."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="remove text formatting" code="TTrf" type="boolean" description="If true, removes text formatting."></property><property name="style conflict" code="TTtd" type="tttd" description="The policy for resolving conflicts when style names in the imported tagged text file match style names the current publication."></property><property name="use typographers quotes" code="TTtq" type="boolean" description="If true, convert straight quotes and apostrophes in the imported text to typographic quotation marks and apostrophes."></property></class><class name="text default" code="cTdf" description="Text defaults."><element type="event"></element><element type="event listener"></element><element type="nested grep style"></element><element type="nested line style"></element><element type="nested style"></element><element type="preference"></element><element type="tab stop"></element><property name="align to baseline" code="stbl" type="boolean" description="If true, aligns the baseline of the text to the baseline grid."></property><property name="allow arbitrary hyphenation" code="jwro" type="boolean" description="If true, words unassociated with a hyphenation dictionary can break to the next line on any character."></property><property name="applied character style" code="crst" type="character style" description="The character style applied to the text. Can also accept: string."></property><property name="applied font" code="font" type="any" description="The font applied to the text default, specified as either a font object or the name of font family. Can return: font or string."></property><property name="applied language" code="plng" type="specifier" description="The language of the text. Can return: language with vendors or language. Can also accept: string."></property><property name="applied named grid" code="Jang" type="named grid" description="The named grid in use."></property><property name="applied numbering list" code="bnnl" type="any" description="The list to be part of. Can return: numbering list or string."></property><property name="applied paragraph style" code="prst" type="paragraph style" description="The paragraph style applied to the text. Can also accept: string."></property><property name="auto leading" code="alea" type="real" description="The percent of the type size to use for auto leading. (Range: 0 to 500)."></property><property name="auto tcy" code="jatc" type="integer" description="The number of half-width characters at or below which the characters automatically run horizontally in vertical text."></property><property name="auto tcy include roman" code="jatr" type="boolean" description="If true, auto tcy includes Roman characters."></property><property name="balance ragged lines" code="bala" type="any" description="If true or set to an enumeration value, balances ragged lines. Note: Not valid with a single-line text composer. Can return: boolean or no balancing/vee shape/fully balanced/pyramid shape."></property><property name="baseline shift" code="bshf" description="The baseline shift applied to the text."><type type="number"></type><type type="text"></type></property><property name="bullet char" code="bnbc" type="bullet" access="r" description="Bullet character."></property><property name="bullets alignment" code="bnba" type="bueA" description="The alignment of the bullet character."></property><property name="bullets and numbering list type" code="bnlt" type="enLT" description="List type for bullets and numbering."></property><property name="bullets character style" code="bnbs" type="any" description="The character style to be used for the text after string. Can return: character style or string."></property><property name="bullets text after" code="bnta" type="text" description="The text after string expression for bullets."></property><property name="bunri kinshi" code="jbki" type="boolean" description="If true, adds the double period (..), ellipse (...), and double hyphen (--) to the selected kinsoku set. Note: Valid only when a kinsoku set is in effect."></property><property name="capitalization" code="capm" type="cape" description="The capitalization scheme."></property><property name="character alignment" code="jcal" type="Jaca" description="The alignment of small characters to the largest character in the line."></property><property name="character direction" code="cdir" type="chdi" description="The direction of the character."></property><property name="character rotation" code="crot" type="real" description="The rotation angle (in degrees) of individual characters. Note: The rotation is counterclockwise."></property><property name="cjk grid tracking" code="jgrt" type="boolean" description="If true, uses grid tracking to track non-Roman characters in CJK grids."></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="composer" code="ptce" type="text" description="The text composer to use to compose the text."></property><property name="design axes" code="ndxs" description="Value of Design Axes"><type type="real" list="yes"></type></property><property name="desired glyph scaling" code="gsde" type="real" description="The desired width (as a percentage) of individual characters. (Range: 50 to 200)"></property><property name="desired letter spacing" code="lsde" type="real" description="The desired letter spacing, specified as a percentge of the built-in space between letters in the font. (Range: -100 to 500)"></property><property name="desired word spacing" code="wsde" type="real" description="The desired word spacing, specified as a percentage of the font word space value. (Range: 0 to 1000)"></property><property name="diacritic position" code="diap" type="dipt" description="Position of diacriticical characters."></property><property name="digits type" code="digi" type="dity" description="The digits type."></property><property name="drop cap characters" code="dcca" type="integer" description="The number of characters to drop cap. Can return: small integer (0 - 150)."></property><property name="drop cap lines" code="dcli" type="integer" description="The number of lines to drop cap. Can return: small integer (0 - 25)."></property><property name="drop cap style" code="dcst" type="character style" description="The character style to apply to the drop cap. Can also accept: string."></property><property name="dropcap detail" code="dcdm" type="integer" description="Details about the drop cap based on the glyph outlines. 1 = left side bearing. 2 = descenders. 0x100,0x200,0x400 are used for Japanese frame grid."></property><property name="end join" code="endj" type="ojon" description="The stroke join type applied to the characters of the text."></property><property name="fill color" code="flcl" type="swatch" description="The swatch (color, gradient, tint, or mixed ink) applied to the fill of the text default. . Can also accept: string."></property><property name="fill tint" code="filt" type="real" description="The tint (as a percentage) of the fill color of the text default. (To specify a tint percentage, use a number in the range of 0 to 100; to use the inherited or overridden value, use -1.)"></property><property name="first line indent" code="infl" description="The amount to indent the first line."><type type="number"></type><type type="text"></type></property><property name="font style" code="ptfs" type="text" description="The name of the font style."></property><property name="glyph form" code="jgfm" type="Jglf" description="The glyph variant to substitute for standard glyphs."></property><property name="gradient fill angle" code="pgfa" type="real" description="The angle of a linear gradient applied to the fill of the text. (Range: -180 to 180)"></property><property name="gradient fill length" code="pgfl" type="real" description="The length (for a linear gradient) or radius (for a radial gradient) applied to the fill of the text."></property><property name="gradient fill start" code="pgst" description="The starting point (in page coordinates) of a gradient applied to the fill of the text, in the format [x, y]."><type type="number" list="yes"></type><type type="text" list="yes"></type></property><property name="gradient stroke angle" code="pgsa" type="real" description="The angle of a linear gradient applied to the stroke of the text. (Range: -180 to 180)"></property><property name="gradient stroke length" code="pgsl" type="real" description="The length (for a linear gradient) or radius (for a radial gradient) applied to the stroke of the text."></property><property name="gradient stroke start" code="pgss" description="The starting point (in page coordinates) of a gradient applied to the stroke of the text, in the format [x, y]."><type type="number" list="yes"></type><type type="text" list="yes"></type></property><property name="grid align first line only" code="jga1" type="boolean" description="If true, aligns only the first line to the frame grid or baseline grid. If false, aligns all lines to the grid."></property><property name="grid alignment" code="jgal" type="Jaga" description="The alignment to the frame grid or baseline grid."></property><property name="grid gyoudori" code="jggy" type="integer" description="The manual gyoudori setting."></property><property name="horizontal scale" code="phzs" type="real" description="The horizontal scaling applied to the text default."></property><property name="hyphen weight" code="hypw" type="integer" description="The relative desirability of better spacing vs. fewer hyphens. A lower value results in greater use of hyphens. (Range: 0 to 100). Can return: small integer (0 - 10)."></property><property name="hyphenate across columns" code="hycf" type="boolean" description="If true, allows the last word in a text column to be hyphenated."></property><property name="hyphenate after first" code="mibe" type="integer" description="The mininum number of letters at the beginning of a word that can be broken by a hyphen. Can return: small integer (1 - 15)."></property><property name="hyphenate before last" code="miaf" type="integer" description="The minimum number of letters at the end of a word that can be broken by a hyphen. Can return: small integer (1 - 15)."></property><property name="hyphenate capitalized words" code="hypc" type="boolean" description="If true, allows hyphenation of capitalized words."></property><property name="hyphenate ladder limit" code="hypl" type="integer" description="The maximum number of hyphens that can appear on consecutive lines. To specify unlimited consecutive lines, use zero. Can return: small integer (0 - 25)."></property><property name="hyphenate last word" code="hylw" type="boolean" description="If true, allows hyphenation in the last word in a paragraph. Note: Valid only when hyphenation is true."></property><property name="hyphenate words longer than" code="swor" type="integer" description="The minimum number of letters a word must have in order to qualify for hyphenation. Can return: small integer (3 - 25)."></property><property name="hyphenation" code="hyph" type="boolean" description="If true, allows hyphenation."></property><property name="hyphenation zone" code="hyzo" description="The amount of white space allowed at the end of a line of non-justified text before hypenation begins. Note: Valid when composer is single-line composer."><type type="number"></type><type type="text"></type></property><property name="ignore edge alignment" code="igEA" type="boolean" description="If true, ignores optical edge alignment for the paragraph."></property><property name="jidori" code="jjid" type="integer" description="The number of grid squares in which to arrange the text. "></property><property name="justification" code="paln" type="kjst" description="The paragraph alignment."></property><property name="kashidas" code="kash" type="katy" description="Use of Kashidas for justification"></property><property name="keep all lines together" code="kept" type="boolean" description="If true, keeps all lines of the paragraph together. If false, allows paragraphs to break across pages or columns."></property><property name="keep first lines" code="kfnl" type="integer" description="The minimum number of lines to keep together in a paragraph before allowing a page break. Can return: small integer (1 - 50)."></property><property name="keep last lines" code="klnl" type="integer" description="The minimum number of lines to keep together in a paragraph after a page break. Can return: small integer (1 - 50)."></property><property name="keep lines together" code="kepl" type="boolean" description="If true, keeps a specified number of lines together when the paragraph breaks across columns or text frames."></property><property name="keep rule above in frame" code="prak" type="boolean" description="If true, forces the rule above the paragraph to remain in the frame bounds. Note: Valid only when rule above is true."></property><property name="keep with next" code="kwnx" type="integer" description="The minimum number of lines to keep with the next paragraph. Can return: small integer (0 - 5)."></property><property name="keep with previous" code="kwpv" type="boolean" description="If the first line in the paragraph should be kept with the last line of previous paragraph."></property><property name="kenten alignment" code="jkal" type="Jekl" description="The alignment of kenten characters relative to the parent characters. "></property><property name="kenten character set" code="jset" type="Jest" description="The character set used for the custom kenten character. Note: Valid only when kenten kind is custom. "></property><property name="kenten custom character" code="jkcc" type="text" description="The character used for kenten. Note: Valid only when kenten kind is custom."></property><property name="kenten fill color" code="jkfc" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the fill of kenten characters. Can return: swatch or string."></property><property name="kenten font" code="jkfn" type="any" description="The font to use for kenten characters. Can return: font or string."></property><property name="kenten font size" code="jkfz" type="real" description="The size (in points) of kenten characters."></property><property name="kenten font style" code="jkfs" type="any" description="The font style of kenten characters. Can return: string or nothing."></property><property name="kenten kind" code="jktp" type="Jkch" description="The style of kenten characters."></property><property name="kenten overprint fill" code="jkof" type="Jafl" description="The method of overprinting the kenten fill."></property><property name="kenten overprint stroke" code="jkos" type="Jafl" description="The method of overprinting the kenten stroke."></property><property name="kenten placement" code="jkpl" type="real" description="The distance between kenten characters and their parent characters."></property><property name="kenten position" code="jkp2" type="Jkps" description="The kenten position relative to the parent character."></property><property name="kenten stroke color" code="jksc" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the stroke of kenten characters. Can return: swatch or string."></property><property name="kenten stroke tint" code="jkst" type="real" description="The stroke tint (as a percentage) of kenten characters. (Range: 0 to 100)"></property><property name="kenten tint" code="jktn" type="real" description="The fill tint (as a percentage) of kenten characters. (Range: 0 to 100)"></property><property name="kenten weight" code="jkwt" type="real" description="The stroke weight (in points) of kenten characters."></property><property name="kenten X scale" code="jkcm" type="real" description="The horizontal size of kenten characters as a percent of the original size."></property><property name="kenten Y scale" code="jkpt" type="real" description="The vertical size of kenten charachers as a percent of the original size. "></property><property name="kerning method" code="pakm" type="text" description="The type of pair kerning."></property><property name="keyboard direction" code="kdir" type="chdi" description="The keyboard direction of the character."></property><property name="kinsoku hang type" code="jkht" type="Jkht" description="The type of hanging punctuation to allow. Note: Valid only when a kinsoku set is in effect."></property><property name="kinsoku set" code="jkin" type="any" description="The kinsoku set that determines legitimate line breaks. Can return: kinsoku table, nothing/hard kinsoku/soft kinsoku/korean kinsoku/simplified chinese kinsoku/traditional chinese kinsoku or string."></property><property name="kinsoku type" code="jkit" type="Jknt" description="The type of kinsoku processing for preventing kinsoku characters from beginning or ending a line. Note: Valid only when a kinsoku set is defined."></property><property name="last line indent" code="inlr" description="The amount to indent the last line in the paragraph."><type type="number"></type><type type="text"></type></property><property name="leading" code="szld" type="any" description="The leading applied to the text. Can return: number or string or auto."></property><property name="leading aki" code="jmbs" type="real" description="The amount of space before each character."></property><property name="leading model" code="Jled" type="JLed" description="The point from which leading is measured from line to line."></property><property name="left indent" code="inbl" description="The width of the left indent."><type type="number"></type><type type="text"></type></property><property name="ligatures" code="ligt" type="boolean" description="If true, replaces specific character combinations (e.g., fl, fi) with ligature characters."></property><property name="maximum glyph scaling" code="gsma" type="real" description="The maximum width (as a percentage) of individual characters. (Range: 50 to 200)"></property><property name="maximum letter spacing" code="lsma" type="real" description="The maximum letter spacing, specified as a percentge of the built-in space between letters in the font. (Range: -100 to 500) Note: Valid only when text is justified."></property><property name="maximum word spacing" code="wsma" type="real" description="The maximum word spacing, specified as a percentage of the font word space value. Note: Valid only when text is justified. (Range: 0 to 1000)"></property><property name="merge consecutive para borders" code="pbMc" type="boolean" description="If true, consecutive para borders with completely similar properties are merged."></property><property name="minimum glyph scaling" code="gsmi" type="real" description="The minimum width (as a percentage) of individual characters. (Range: 50 to 200)"></property><property name="minimum letter spacing" code="lsmi" type="real" description="The minimum letter spacing, specified as a percentge of the built-in space between letters in the font. (Range: -100 to 500) Note: Valid only when text is justified."></property><property name="minimum word spacing" code="wsmi" type="real" description="The minimum word spacing, specified as a percentage of the font word space value. Note: Valid only when text is justified. (Range: 0 to 1000)"></property><property name="miter limit" code="mitr" type="real" description="The limit of the ratio of stroke width to miter length before a miter (pointed) join becomes a bevel (squared-off) join. Can return: fixed (0 - 1000)."></property><property name="mojikumi" code="jmoj" type="any" description="The mojikumi table. For information, see mojikumi table defaults. Can return: mojikumi table, string or nothing/line end all one half em enum/one em indent line end uke one half em enum/one or one half em indent line end uke one half em enum/one or one half em indent line end all one em enum/one em indent line end all one em enum/one em indent line end all no float enum/one em indent line end uke no float enum/one or one half em indent line end uke no float enum/one em indent line end all one half em enum/line end all one em enum/line end uke no float enum/one or one half em indent line end period one em enum/one em indent line end period one em enum/line end period one em enum/trad chinese default/simp chinese default."></property><property name="no break" code="nobk" type="boolean" description="If true, keeps the text on the same line. "></property><property name="numbering alignment" code="bnna" type="bueA" description="The alignment of the number."></property><property name="numbering apply restart policy" code="bnar" type="boolean" description="If true, apply the numbering restart policy."></property><property name="numbering character style" code="bnnc" type="any" description="The character style to be used for the number string. Can return: character style or string."></property><property name="numbering continue" code="bncp" type="boolean" description="Continue the numbering at this level."></property><property name="numbering expression" code="bnne" type="text" description="The number string expression for numbering."></property><property name="numbering format" code="DHnm" type="any" description="Numbering format options. Can return: upper roman/lower roman/upper letters/lower letters/arabic/kanji/katakana modern/katakana traditional/format none/single leading zeros/arabic alif ba tah/arabic abjad/hebrew biblical/hebrew non standard/double leading zeros/triple leading zeros or string."></property><property name="numbering level" code="bnle" type="integer" description="The level of the paragraph."></property><property name="numbering restart policies" code="bnbr" type="numbering restart policy" access="r" description="Numbering restart policies."></property><property name="numbering start at" code="bnst" type="integer" description="Determines starting number in a numbered list."></property><property name="object reference" code="posp" type="text default" access="r" description="An object reference for the object."></property><property name="OTF contextual alternate" code="OTca" type="boolean" description="If true, uses contextual alternate forms in OpenType fonts."></property><property name="OTF discretionary ligature" code="OTdl" type="boolean" description="If true, uses discretionary ligatures in OpenType fonts."></property><property name="OTF figure style" code="Ofst" type="OTfs" description="The figure style in OpenType fonts."></property><property name="OTF fraction" code="OTfr" type="boolean" description="If true, uses fractions in OpenType fonts."></property><property name="OTF historical" code="OThi" type="boolean" description="If true, use historical forms in OpenType fonts."></property><property name="OTF HV kana" code="hkna" type="boolean" description="If true, switches hiragana fonts, which have different glyphs for horizontal and vertical. "></property><property name="OTF justification alternate" code="OTja" type="boolean" description="If true, use alternate justification forms in OpenType fonts"></property><property name="OTF locale" code="OTlc" type="boolean" description="If true, uses localized forms in OpenType fonts."></property><property name="OTF mark" code="OTmk" type="boolean" description="If true, uses mark positioning in OpenType fonts."></property><property name="OTF ordinal" code="OTor" type="boolean" description="If true, uses ordinals in OpenType fonts."></property><property name="OTF overlap swash" code="OTol" type="boolean" description="If true, use overlapping swash forms in OpenType fonts"></property><property name="OTF proportional metrics" code="palt" type="boolean" description="If true, kerns according to proportional CJK metrics in OpenType fonts."></property><property name="OTF Roman italics" code="ital" type="boolean" description="If true, applies italics to half-width alphanumerics. "></property><property name="OTF slashed zero" code="OTzr" type="boolean" description="If true, use a slashed zeroes in OpenType fonts."></property><property name="OTF stretched alternate" code="OTsh" type="boolean" description="If true, use stretched alternate forms in OpenType fonts"></property><property name="OTF stylistic alternate" code="OTsy" type="boolean" description="If true, use stylistic alternate forms in OpenType fonts"></property><property name="OTF stylistic sets" code="OTss" type="integer" description="The stylistic sets to use in OpenType fonts."></property><property name="OTF swash" code="OTsw" type="boolean" description="If true, uses swash forms in OpenType fonts."></property><property name="OTF titling" code="OTti" type="boolean" description="If true, uses titling forms in OpenType fonts."></property><property name="overprint fill" code="ovpr" type="boolean" description="If true, the fill color of the characters will overprint."></property><property name="overprint stroke" code="sovp" type="boolean" description="If true, the stroke of the characters will overprint."></property><property name="paragraph border bottom  right corner option" code="bcO4" type="coPt" description="The shape to apply to the bottom right corner of rectangular shapes."></property><property name="paragraph border bottom left corner option" code="bcO3" type="coPt" description="The shape to apply to the bottom left corner of rectangular shapes."></property><property name="paragraph border bottom left corner radius" code="bcr3" description="The radius in measurement units of the corner effect applied to the bottom left corner of rectangular shapes"><type type="number"></type><type type="text"></type></property><property name="paragraph border bottom line weight" code="psWB" description="The bottom line weight of the border of paragraph."><type type="number"></type><type type="text"></type></property><property name="paragraph border bottom offset" code="pbOb" description="The distance to offset the bottom edge of the paragraph border."><type type="number"></type><type type="text"></type></property><property name="paragraph border bottom origin" code="pbBo" type="pbBe" description="The basis (descent or baseline) used to calculate the bottom origin of the paragraph border."></property><property name="paragraph border bottom right corner radius" code="bcr4" description="The radius in measurement units of the corner effect applied to the bottom right corner of rectangular shapes"><type type="number"></type><type type="text"></type></property><property name="paragraph border color" code="psSc" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the paragraph stroke. C