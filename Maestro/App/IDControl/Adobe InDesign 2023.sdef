rty name="anchor yoffset" code="AOyo" description="The vertical (y) offset of the anchored object. Corresponds to the space after property for above line positioning."><type type="number"></type><type type="text"></type></property><property name="anchored position" code="AOpt" type="mAOP" description="The position of the anchored object relative to the anchor."></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="horizontal alignment" code="AOHa" type="mAOH" description="When anchored position is above line, the position of the anchored object is relative to the text area. When anchored position is custom, the horizontal alignment of the anchored object is set by the horizontal reference point. Note: Not valid when anchored position is inline."></property><property name="horizontal reference point" code="AHrl" type="mAVr" description="The horizontal reference point on the page. Valid only when anchored position is custom."></property><property name="lock position" code="AOlp" type="boolean" description="If true, prevents manual positioning of the anchored object."></property><property name="object reference" code="posp" type="anchored object setting" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the anchored object setting (a object style, spline item, polygon, graphic line, rectangle, oval, group, text frame, endnote text frame, button, form field, signature field, text box, radio button, list box, combo box, check box, multi state object, application, document or EPSText). Can return: object style, spline item, polygon, graphic line, rectangle, oval, group, text frame, endnote text frame, button, form field, signature field, text box, radio button, list box, combo box, check box, multi state object, application, document or EPSText."></property><property name="pin position" code="AOpp" type="boolean" description="If true, pins the position of the anchored object within the text frame top and bottom."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="spine relative" code="AOsr" type="boolean" description="If true, the position of the anchored object is relative to the binding spine of the page or spread."></property><property name="vertical alignment" code="AOVa" type="mAVA" description="The vertical alignment of the anchored object reference point with the vertical reference point on the page. Notes: Valid only when anchored position is custom."></property><property name="vertical reference point" code="AOVr" type="mAVR" description="The vertical reference point on the page. Valid when anchored position is custom."></property></class><class name="animation setting" code="cAmS" description="Animation settings."><element type="event"></element><element type="event listener"></element><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="design option" code="AmAO" type="AOEm" description="The animation design option."></property><property name="duration" code="AmDn" type="real" description="The duration in second for this animation. Can return: fixed (0.125 - 60)."></property><property name="ease type" code="AmEz" type="EsEm" description="The ease type."></property><property name="has custom settings" code="AmCm" type="boolean" access="r" description="Determines if this animated object has custom settings."></property><property name="hidden after" code="AmHa" type="boolean" description="Determines if this object is hidden after its animation is played in an exported SWF file."></property><property name="initially hidden" code="Minh" type="boolean" description="Determines if this object is initially hidden when displayed in an exported SWF file."></property><property name="motion path" code="AmPh" description="The list of motion path points and key frames for this animation. Can return: Ordered list containing key frame:integer, path point:Ordered list containing anchor:list of 2 fixed, left direction:list of 2 fixed, right direction:list of 2 fixed."><type type="any" list="yes"></type></property><property name="motion path points" code="AmPp" type="any" description="The list of motion path points for this animation. Can return: Ordered list containing path point array:list of Ordered list containing anchor:list of 2 fixed, left direction:list of 2 fixed, right direction:list of 2 fixed, path open:boolean."></property><property name="object reference" code="posp" type="animation setting" access="r" description="An object reference for the object."></property><property name="opacity array" code="AmOp" description="The list of opacity key frames for this animation. Can return: Ordered list containing key frame:integer, value:fixed."><type type="any" list="yes"></type></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the animation setting (a page item, html item, form field, signature field, text box, radio button, list box, combo box, check box, multi state object, button, media item, sound, movie, EPSText, spline item, polygon, graphic line, rectangle, oval, graphic, SVG, imported page, PICT, WMF, PDF, EPS, image, group, text frame or endnote text frame). Can return: page item, html item, form field, signature field, text box, radio button, list box, combo box, check box, multi state object, button, media item, sound, movie, EPSText, spline item, polygon, graphic line, rectangle, oval, graphic, SVG, imported page, PICT, WMF, PDF, EPS, image, group, text frame or endnote text frame."></property><property name="plays" code="AmPl" type="integer" description="The number of times this animation plays. Can return: integer (1 - 100)."></property><property name="plays loop" code="AmPL" type="boolean" description="Set to true if animation play loops."></property><property name="preset" code="Amps" type="any" description="The base animation preset applied. Can return: Motion Preset, string or nothing."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="rotation array" code="AmRt" description="The list of rotation key frames for this animation. Can return: Ordered list containing key frame:integer, value:fixed."><type type="any" list="yes"></type></property><property name="scale x array" code="AmSx" description="The list of scale x key frames for this animation. Can return: Ordered list containing key frame:integer, value:fixed."><type type="any" list="yes"></type></property><property name="scale y array" code="AmSy" description="The list of scale y key frames for this animation. Can return: Ordered list containing key frame:integer, value:fixed."><type type="any" list="yes"></type></property><property name="transform offsets" code="AmTx" description="The tranform offset percentage from the target object bounding box's left-top corner."><type type="real" list="yes"></type></property></class><class name="auto correct preference" code="acrp" description="Auto-correct preferences."><element type="event"></element><element type="event listener"></element><property name="auto correct" code="pacr" type="boolean" description="If true, automatically corrects misspelled words listed in the auto-correct table. "></property><property name="auto correct capitalization errors" code="acce" type="boolean" description="If true, automatically corrects capitalization errors listed in the auto-correct table."></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="object reference" code="posp" type="auto correct preference" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the auto correct preference (a application)."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property></class><class name="baseline frame grid option" code="BfGo" description="Baseline frame grid options."><element type="event"></element><element type="event listener"></element><property name="baseline frame grid color" code="BFcl" type="any" description="The grid line color, specified either as an array of three doubles, each in the range 0 to 255 and representing R, G, and B values, or as a UI color. Can return: list of 3 fixed (0 - 255) or light blue/red/green/blue/yellow/magenta/cyan/gray/black/orange/dark green/teal/tan/brown/violet/gold/dark blue/pink/lavender/brick red/olive green/peach/burgundy/grass green/ochre/purple/light gray/charcoal/grid blue/grid orange/fiesta/light olive/lipstick/cute teal/sulphur/grid green/white."></property><property name="baseline frame grid increment" code="BFic" description="The distance between grid lines. Can return: number or string (1 - 8640 points)."><type type="number"></type><type type="text"></type></property><property name="baseline frame grid relative option" code="BFro" type="ENro" description="The location (top of page, top margin, top of frame, or frame inset) on which to base the custom baseline grid."></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="object reference" code="posp" type="baseline frame grid option" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the baseline frame grid option (a object style, application, document, text frame or endnote text frame). Can return: object style, application, document, text frame or endnote text frame."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="starting offset for baseline frame grid" code="BFso" description="The amount to offset the baseline grid. Can return: number or string (0 - 8640 points)."><type type="number"></type><type type="text"></type></property><property name="use custom baseline frame grid" code="BFuc" type="boolean" description="If true, uses a custom baseline frame grid."></property></class><class name="bevel and emboss setting" code="xpQk" description="Bevel and emboss effect settings."><element type="event"></element><element type="event listener"></element><property name="altitude" code="xpUf" type="real" description="The altitude of the light source. (Range: 0 to 90). Can return: fixed (0 - 100)."></property><property name="angle" code="inAn" type="real" description="The angle of the light source. (Range: -180 to 180). Can return: fixed (-180 - 180)."></property><property name="applied" code="xpUn" type="boolean" description="If true, the bevel or emboss effect is applied."></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="depth" code="xpUc" type="real" description="The depth of the bevel or emboss (as a percentage). (Range: 0 to 1000). Can return: fixed (0 - 1000)."></property><property name="direction" code="xpUd" type="enX4" description="The direction of the bevel or emboss."></property><property name="highlight blend mode" code="xpUh" type="enXM" description="The blending mode for the highlight portion of the effect."></property><property name="highlight color" code="e0E4" type="swatch" description="The color applied to the highlight portion of the effect, specified as a swatch (color, gradient, tint, or mixed ink), a color library color, a hex value, or as an array of color values. The color mode dictates the array values: for RGB, specify three values, each in the range 0 to 255, in the format [R,G,B]; for CMYK, specify four values, each as a percentage and each in the range 0 to 100, in the format [C,M,Y,K]; for LAB, specify three values in the format [L,A,B], with L in the range 0 to 100 and A and B in the range -128 to 127; for HSB, specify three colors in the format [H,S,B], with H in the range 0 to 360 and S and B as percentages in the range 0 to 100."></property><property name="highlight opacity" code="e0E3" type="real" description="The opacity of the highlight portion of the effect (as a percentage). (Range: 0 to 100). Can return: fixed (0 - 100)."></property><property name="object reference" code="posp" type="bevel and emboss setting" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the bevel and emboss setting (a transparency setting, stroke transparency setting, fill transparency setting or content transparency setting). Can return: transparency setting, stroke transparency setting, fill transparency setting or content transparency setting."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="shadow blend mode" code="xpSb" type="enXM" description="The blending mode for the shadow portion of the effect."></property><property name="shadow color" code="xpSc" type="swatch" description="The color applied to the shadow portion of the effect, specified as a swatch (color, gradient, tint, or mixed ink), a color library color, a hex value, or as an array of color values. The color mode dictates the array values: for RGB, specify three values, each in the range 0 to 255, in the format [R,G,B]; for CMYK, specify four values, each as a percentage and each in the range 0 to 100, in the format [C,M,Y,K]; for LAB, specify three values in the format [L,A,B], with L in the range 0 to 100 and A and B in the range -128 to 127; for HSB, specify three colors in the format [H,S,B], with H in the range 0 to 360 and S and B as percentages in the range 0 to 100."></property><property name="shadow opacity" code="xpSo" type="real" description="The opacity of the shadow portion of the effect (as a percentage). (Range: 0 to 100). Can return: fixed (0 - 100)."></property><property name="size" code="dsiz" description="The size of the bevel or emboss. Can return: number or string (0 - 144 points)."><type type="number"></type><type type="text"></type></property><property name="soften" code="xpUe" description="The amount (in pixels) of softening. Can return: number or string (0 - 144 points)."><type type="number"></type><type type="text"></type></property><property name="style" code="xpUb" type="enX2" description="The style of bevel or emboss."></property><property name="technique" code="xpUo" type="enX3" description="The edging technique of the bevel or emboss."></property><property name="use global light" code="xpUs" type="boolean" description="If true, the global light source is used."></property></class><class name="blending setting" code="xpQe" description="Basic object blending settings."><element type="event"></element><element type="event listener"></element><property name="blend mode" code="xpBm" type="enXM" description="The blending mode for controlling how the base color interacts with the color of the blending setting."></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="isolate blending" code="xpBi" type="boolean" description="If true, blending is applied only to the group. If false, blending includes all objects beneath the group."></property><property name="knockout group" code="xpBk" type="boolean" description="If true, the blending setting is a knockout group."></property><property name="object reference" code="posp" type="blending setting" access="r" description="An object reference for the object."></property><property name="opacity" code="xpBo" type="real" description="The fill opacity of the blending setting (as a percentage). (Range: 0 to 100). Can return: fixed (0 - 100)."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the blending setting (a transparency setting, stroke transparency setting, fill transparency setting or content transparency setting). Can return: transparency setting, stroke transparency setting, fill transparency setting or content transparency setting."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property></class><class name="button preference" code="btnp" description="Button preferences."><element type="event"></element><element type="event listener"></element><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="name" code="pnam" type="text" description="The name of the button preference."></property><property name="object reference" code="posp" type="button preference" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the button preference (a application or document). Can return: application or document."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property></class><class name="caption metadata variable preference" code="TVPm" description="The preferences for a caption metadata variable."><element type="event"></element><element type="event listener"></element><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="metadata provider name" code="TVmp" type="text" description="Name of the metadata provider."></property><property name="object reference" code="posp" type="caption metadata variable preference" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="text variable" access="r" description="The parent of the caption metadata variable preference (a text variable)."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="text after" code="TVta" type="text" description="The text that follows the value of the variable. (Limit: 128 characters)"></property><property name="text before" code="TVtb" type="text" description="The text that precedes the value of the variable. (Limit: 128 characters)"></property></class><class name="cell style mapping" code="acsm" description="A cell style mapping." plural="cell style mappings"><element type="event"></element><element type="event listener"></element><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="destination style name" code="dsnm" type="text" description="The destination style name property."></property><property name="index" code="pidx" type="integer" access="r" description="The index of the cell style mapping within its containing object."></property><property name="mapping rule type" code="rutp" type="mrty" description="The type of the mapping rule."></property><property name="object reference" code="posp" type="cell style mapping" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the cell style mapping (a application, document, story or xml story). Can return: application, document, story or xml story."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="source style name" code="sosn" type="text" description="The source style name property."></property></class><class name="change color preference" code="cCCP" description="Change color preferences."><element type="event"></element><element type="event listener"></element><property name="change to" code="Chgo" type="any" description="The replacement color. Can return: swatch or nothing."></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="object reference" code="posp" type="change color preference" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the change color preference (a application)."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="tint" code="tint" type="any" description="The replacement tint. Can return: fixed (0 - 100) or nothing."></property></class><class name="change glyph preference" code="cCPP" description="Change glyph preferences."><element type="event"></element><element type="event listener"></element><property name="applied font" code="font" type="any" description="The font applied to the change glyph preference, specified as either a font object or the name of font family. Can return: font, string or nothing."></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="design axes" code="ndxs" type="any" description="Value of Design Axes. Can return: list of fixed or nothing."></property><property name="font style" code="ptfs" type="any" description="The name of the font style. Can return: string or nothing."></property><property name="glyph ID" code="Fgid" type="any" description="The GID/CID of the glyph. Can return: integer or nothing."></property><property name="object reference" code="posp" type="change glyph preference" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the change glyph preference (a application)."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property></class><class name="change grep preference" code="cCGP" description="Change grep preferences."><element type="event"></element><element type="event listener"></element><element type="preference"></element><property name="allow arbitrary hyphenation" code="jwro" type="any" description="If true, words unassociated with a hyphenation dictionary can break to the next line on any character. Can return: boolean or nothing."></property><property name="applied character style" code="crst" type="any" description="The character style to search for or change to. Can return: string or nothing. Can also accept: character style."></property><property name="applied conditions" code="apCt" type="any" description="The conditions to search for or change to. Specify the &quot;nothing&quot; enum for &quot;Any&quot; or an empty list for &quot;[Unconditional]&quot;. Can return: list of strings or nothing. Can also accept: list of conditions."></property><property name="applied font" code="font" type="any" description="The font applied to the change grep preference, specified as either a font object or the name of font family. Can return: font, string or nothing."></property><property name="applied language" code="plng" type="any" description="The language to search for or change to. Can return: string or nothing. Can also accept: language or language with vendors."></property><property name="applied numbering list" code="bnnl" type="any" description="The list to be part of. Can return: numbering list, string or nothing."></property><property name="applied paragraph style" code="prst" type="any" description="The paragraph style to search for or change to. Can return: string or nothing. Can also accept: paragraph style."></property><property name="auto leading" code="alea" type="any" description="The percent of the type size to use for auto leading. (Range: 0 to 500). Can return: fixed or nothing."></property><property name="auto tcy" code="jatc" type="any" description="The number of half-width characters at or below which the characters automatically run horizontally in vertical text. Can return: small integer or nothing."></property><property name="auto tcy include roman" code="jatr" type="any" description="If true, auto tcy includes Roman characters. Can return: boolean or nothing."></property><property name="balance ragged lines" code="bala" type="any" description="If true or set to an enumeration value, balances ragged lines. Note: Not valid with a single-line text composer. Can return: boolean, no balancing/vee shape/fully balanced/pyramid shape or nothing."></property><property name="baseline shift" code="bshf" type="any" description="The baseline shift applied to the text. Can return: number or string or nothing."></property><property name="bullet char" code="bnbc" type="any" access="r" description="Bullet character. Can return: bullet or nothing."></property><property name="bullets and numbering list type" code="bnlt" type="any" description="List type for bullets and numbering. Can return: no list/bullet list/numbered list or nothing."></property><property name="bullets character style" code="bnbs" type="any" description="The character style to be used for the text after string. Can return: character style, string or nothing."></property><property name="bullets text after" code="bnta" type="any" description="The text after string expression for bullets. Can return: string or nothing."></property><property name="bunri kinshi" code="jbki" type="any" description="If true, adds the double period (..), ellipse (...), and double hyphen (--) to the selected kinsoku set. Note: Valid only when a kinsoku set is in effect. Can return: boolean or nothing."></property><property name="capitalization" code="capm" type="any" description="The capitalization scheme. Can return: normal/small caps/all caps/cap to small cap or nothing."></property><property name="change conditions mode" code="CHcm" type="any" description="The change conditions mode, change either replaces applied conditions or adds to applied conditions. Can return: replace with/add to or nothing."></property><property name="change to" code="Chgo" type="any" description="The replacement change grep preference. Can return: string or nothing."></property><property name="character alignment" code="jcal" type="any" description="The alignment of small characters to the largest character in the line. Can return: align baseline/align em top/align em center/align em bottom/align ICF top/align ICF bottom or nothing."></property><property name="character direction" code="cdir" type="any" description="The direction of the character. Can return: default direction/left to right direction/right to left direction or nothing."></property><property name="character rotation" code="crot" type="any" description="The rotation angle (in degrees) of individual characters. Note: The rotation is counterclockwise. Can return: fixed or nothing."></property><property name="cjk grid tracking" code="jgrt" type="any" description="If true, uses grid tracking to track non-Roman characters in CJK grids. Can return: boolean or nothing."></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="composer" code="ptce" type="any" description="The text composer to use to compose the text. Can return: string or nothing."></property><property name="design axes" code="ndxs" type="any" description="Value of Design Axes. Can return: list of fixed or nothing."></property><property name="diacritic position" code="diap" type="any" description="Position of diacriticical characters. Can return: default position/loose position/medium position/tight position/opentype position/opentype position from baseline or nothing."></property><property name="digits type" code="digi" type="any" description="The digits type. Can return: default digits/arabic digits/hindi digits/farsi digits/Native digits/full farsi digits/thai digits/lao digits/devanagari digits/bengali digits/gurmukhi digits/gujarati digits/oriya digits/tamil digits/telugu digits/kannada digits/malayalam digits/tibetan digits/khmer digits/burmese digits or nothing."></property><property name="drop cap characters" code="dcca" type="any" description="The number of characters to drop cap. Can return: small integer (0 - 150) or nothing."></property><property name="drop cap lines" code="dcli" type="any" description="The number of lines to drop cap. Can return: small integer (0 - 25) or nothing."></property><property name="dropcap detail" code="dcdm" type="any" description="Details about the drop cap based on the glyph outlines. 1 = left side bearing. 2 = descenders. 0x100,0x200,0x400 are used for Japanese frame grid. Can return: integer or nothing."></property><property name="end join" code="endj" type="any" description="The stroke join type applied to the characters of the text. Can return: miter end join/round end join/bevel end join or nothing."></property><property name="fill color" code="flcl" type="any" description="The swatch (color, gradient, tint, or mixed ink), applied as a fill color, to search for or change to. Can return: string or nothing. Can also accept: swatch."></property><property name="fill tint" code="filt" type="any" description="The tint (as a percentage) of the fill color of the change grep preference. (To specify a tint percentage, use a number in the range of 0 to 100; to use the inherited or overridden value, use -1.). Can return: fixed or nothing."></property><property name="first line indent" code="infl" type="any" description="The amount to indent the first line. Can return: number or string or nothing."></property><property name="font style" code="ptfs" type="any" description="The name of the font style. Can return: string or nothing."></property><property name="glyph form" code="jgfm" type="any" description="The glyph variant to substitute for standard glyphs. Can return: none/traditional form/expert form/JIS78 form/JIS83 form/monospaced half width form/third width form/quarter width form/NLC form/proportional width form/full width form/JIS04 form/JIS90 form or nothing."></property><property name="gradient fill angle" code="pgfa" type="any" description="The angle of a linear gradient applied to the fill of the text. (Range: -180 to 180). Can return: fixed or nothing."></property><property name="gradient fill length" code="pgfl" type="any" description="The length (for a linear gradient) or radius (for a radial gradient) applied to the fill of the text. Can return: fixed or nothing."></property><property name="gradient fill start" code="pgst" type="any" description="The starting point (in page coordinates) of a gradient applied to the fill of the text, in the format [x, y]. Can return: list of 2 numbers or strings or nothing."></property><property name="gradient stroke angle" code="pgsa" type="any" description="The angle of a linear gradient applied to the stroke of the text. (Range: -180 to 180). Can return: fixed or nothing."></property><property name="gradient stroke length" code="pgsl" type="any" description="The length (for a linear gradient) or radius (for a radial gradient) applied to the stroke of the text. Can return: fixed or nothing."></property><property name="gradient stroke start" code="pgss" type="any" description="The starting point (in page coordinates) of a gradient applied to the stroke of the text, in the format [x, y]. Can return: list of 2 numbers or strings or nothing."></property><property name="grid alignment" code="jgal" type="any" description="The alignment to the frame grid or baseline grid. Can return: none/align baseline/align em top/align em center/align em bottom/align ICF top/align ICF bottom or nothing."></property><property name="grid gyoudori" code="jggy" type="any" description="The manual gyoudori setting. Can return: small integer or nothing."></property><property name="horizontal scale" code="phzs" type="any" description="The horizontal scaling applied to the change grep preference. Can return: fixed or nothing."></property><property name="hyphenate across columns" code="hycf" type="any" description="If true, allows the last word in a text column to be hyphenated. Can return: boolean or nothing."></property><property name="hyphenate last word" code="hylw" type="any" description="If true, allows hyphenation in the last word in a paragraph. Note: Valid only when hyphenation is true. Can return: boolean or nothing."></property><property name="ignore edge alignment" code="igEA" type="any" description="If true, ignores optical edge alignment for the paragraph. Can return: boolean or nothing."></property><property name="jidori" code="jjid" type="any" description="The number of grid squares in which to arrange the text. . Can return: small integer or nothing."></property><property name="justification" code="paln" type="any" description="The paragraph alignment. Can return: left align/center align/right align/left justified/right justified/center justified/fully justified/to binding side/away from binding side or nothing."></property><property name="kashidas" code="kash" type="any" description="Use of Kashidas for justification. Can return: default kashidas/kashidas off or nothing."></property><property name="keep all lines together" code="kept" type="any" description="If true, keeps all lines of the paragraph together. If false, allows paragraphs to break across pages or columns. Can return: boolean or nothing."></property><property name="keep first lines" code="kfnl" type="any" description="The minimum number of lines to keep together in a paragraph before allowing a page break. Can return: small integer (1 - 50) or nothing."></property><property name="keep last lines" code="klnl" type="any" description="The minimum number of lines to keep together in a paragraph after a page break. Can return: small integer (1 - 50) or nothing."></property><property name="keep lines together" code="kepl" type="any" description="If true, keeps a specified number of lines together when the paragraph breaks across columns or text frames. Can return: boolean or nothing."></property><property name="keep rule above in frame" code="prak" type="any" description="If true, forces the rule above the paragraph to remain in the frame bounds. Note: Valid only when rule above is true. Can return: boolean or nothing."></property><property name="keep with next" code="kwnx" type="any" description="The minimum number of lines to keep with the next paragraph. Can return: small integer (0 - 5) or nothing."></property><property name="keep with previous" code="kwpv" type="any" description="If the first line in the paragraph should be kept with the last line of previous paragraph. Can return: boolean or nothing."></property><property name="kenten alignment" code="jkal" type="any" description="The alignment of kenten characters relative to the parent characters. . Can return: align kenten left/align kenten center or nothing."></property><property name="kenten character set" code="jset" type="any" description="The character set used for the custom kenten character. Note: Valid only when kenten kind is custom. . Can return: character input/shift JIS/JIS/kuten/unicode or nothing."></property><property name="kenten custom character" code="jkcc" type="any" description="The character used for kenten. Note: Valid only when kenten kind is custom. Can return: string or nothing."></property><property name="kenten fill color" code="jkfc" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the fill of kenten characters. Can return: swatch, string or nothing."></property><property name="kenten font" code="jkfn" type="any" description="The font to use for kenten characters. Can return: font, string or nothing."></property><property name="kenten font size" code="jkfz" type="any" description="The size (in points) of kenten characters. Can return: fixed or nothing."></property><property name="kenten font style" code="jkfs" type="any" description="The font style of kenten characters. Can return: string or nothing."></property><property name="kenten kind" code="jktp" type="any" description="The style of kenten characters. Can return: none/kenten sesame dot/kenten white sesame dot/kenten black circle/kenten white circle/kenten black triangle/kenten white triangle/kenten bullseye/kenten fisheye/kenten small black circle/kenten small white circle/custom or nothing."></property><property name="kenten overprint fill" code="jkof" type="any" description="The method of overprinting the kenten fill. Can return: auto/overprint on/overprint off or nothing."></property><property name="kenten overprint stroke" code="jkos" type="any" description="The method of overprinting the kenten stroke. Can return: auto/overprint on/overprint off or nothing."></property><property name="kenten placement" code="jkpl" type="any" description="The distance between kenten characters and their parent characters. Can return: fixed or nothing."></property><property name="kenten position" code="jkp2" type="any" description="The kenten position relative to the parent character. Can return: above right/below left or nothing."></property><property name="kenten stroke color" code="jksc" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the stroke of kenten characters. Can return: swatch, string or nothing."></property><property name="kenten stroke tint" code="jkst" type="any" description="The stroke tint (as a percentage) of kenten characters. (Range: 0 to 100). Can return: fixed or nothing."></property><property name="kenten tint" code="jktn" type="any" description="The fill tint (as a percentage) of kenten characters. (Range: 0 to 100). Can return: fixed or nothing."></property><property name="kenten weight" code="jkwt" type="any" description="The stroke weight (in points) of kenten characters. Can return: fixed or nothing."></property><property name="kenten X scale" code="jkcm" type="any" description="The horizontal size of kenten characters as a percent of the original size. Can return: fixed or nothing."></property><property name="kenten Y scale" code="jkpt" type="any" description="The vertical size of kenten charachers as a percent of the original size. . Can return: fixed or nothing."></property><property name="kerning method" code="pakm" type="any" description="The type of pair kerning. Can return: string or nothing."></property><property name="kerning value" code="pake" type="any" description="The amount of space to add or remove between characters, specified in thousands of an em. . Can return: fixed or nothing."></property><property name="keyboard direction" code="kdir" type="any" description="The keyboard direction of the character. Can return: default direction/left to right direction/right to left direction or nothing."></property><property name="kinsoku hang type" code="jkht" type="any" description="The type of hanging punctuation to allow. Note: Valid only when a kinsoku set is in effect. Can return: none/kinsoku hang regular/kinsoku hang force or nothing."></property><property name="kinsoku set" code="jkin" type="any" description="The kinsoku set that determines legitimate line breaks. Can return: kinsoku table, nothing/hard kinsoku/soft kinsoku/korean kinsoku/simplified chinese kinsoku/traditional chinese kinsoku, string or nothing."></property><property name="kinsoku type" code="jkit" type="any" description="The type of kinsoku processing for preventing kinsoku characters from beginning or ending a line. Note: Valid only when a kinsoku set is defined. Can return: kinsoku push in first/kinsoku push out first/kinsoku push out only/kinsoku prioritize adjustment amount or nothing."></property><property name="last line indent" code="inlr" type="any" description="The amount to indent the last line in the paragraph. Can return: number or string or nothing."></property><property name="leading" code="szld" type="any" description="The leading applied to the text. Can return: number or string, auto or nothing."></property><property name="leading aki" code="jmbs" type="any" description="The amount of space before each character. Can return: fixed or nothing."></property><property name="leading model" code="Jled" type="any" description="The point from which leading is measured from line to line. Can return: leading model roman/leading model aki below/leading model aki above/leading model center/leading model center down or nothing."></property><property name="left indent" code="inbl" type="any" description="The width of the left indent. Can return: number or string or nothing."></property><property name="ligatures" code="ligt" type="any" description="If true, replaces specific character combinations (e.g., fl, fi) with ligature characters. Can return: boolean or nothing."></property><property name="markup tag" code="XMLt" type="any" description="The XML tag applied to the element. Can return: string or nothing. Can also accept: XML tag."></property><property name="miter limit" code="mitr" type="any" description="The limit of the ratio of stroke width to miter length before a miter (pointed) join becomes a bevel (squared-off) join. Can return: fixed (0 - 1000) or nothing."></property><property name="mojikumi" code="jmoj" type="any" description="The mojikumi table. For information, see mojikumi table defaults. Can return: mojikumi table, string, nothing/line end all one half em enum/one em indent line end uke one half em enum/one or one half em indent line end uke one half em enum/one or one half em indent line end all one em enum/one em indent line end all one em enum/one em indent line end all no float enum/one em indent line end uke no float enum/one or one half em indent line end uke no float enum/one em indent line end all one half em enum/line end all one em enum/line end uke no float enum/one or one half em indent line end period one em enum/one em indent line end period one em enum/line end period one em enum/trad chinese default/simp chinese default or nothing."></property><property name="no break" code="nobk" type="any" description="If true, keeps the text on the same line. . Can return: boolean or nothing."></property><property name="numbering apply restart policy" code="bnar" type="any" description="If true, apply the numbering restart policy. Can return: boolean or nothing."></property><property name="numbering character style" code="bnnc" type="any" description="The character style to be used for the number string. Can return: character style, string or nothing."></property><property name="numbering continue" code="bncp" type="any" description="Continue the numbering at this level. Can return: boolean or nothing."></property><property name="numbering expression" code="bnne" type="any" description="The number string expression for numbering. Can return: string or nothing."></property><property name="numbering format" code="DHnm" type="any" description="Numbering format options. Can return: upper roman/lower roman/upper letters/lower letters/arabic/kanji/katakana modern/katakana traditional/format none/single leading zeros/arabic alif ba tah/arabic abjad/hebrew biblical/hebrew non standard/double leading zeros/triple leading zeros, string or nothing."></property><property name="numbering level" code="bnle" type="any" description="The level of the paragraph. Can return: integer or nothing."></property><property name="numbering restart policies" code="bnbr" type="any" access="r" description="Numbering restart policies. Can return: numbering restart policy or nothing."></property><property name="numbering start at" code="bnst" type="any" description="Determines starting number in a numbered list. Can return: integer or nothing."></property><property name="object reference" code="posp" type="change grep preference" access="r" description="An object reference for the object."></property><property name="OTF contextual alternate" code="OTca" type="any" description="If true, uses contextual alternate forms in OpenType fonts. Can return: boolean or nothing."></property><property name="OTF discretionary ligature" code="OTdl" type="any" description="If true, uses discretionary ligatures in OpenType fonts. Can return: boolean or nothing."></property><property name="OTF figure style" code="Ofst" type="any" description="The figure style in OpenType fonts. Can return: tabular lining/proportional oldstyle/proportional lining/tabular oldstyle/default or nothing."></property><property name="OTF fraction" code="OTfr" type="any" description="If true, uses fractions in OpenType fonts. Can return: boolean or nothing."></property><property name="OTF historical" code="OThi" type="any" description="If true, use historical forms in OpenType fonts. Can return: boolean or nothing."></property><property name="OTF HV kana" code="hkna" type="any" description="If true, switches hiragana fonts, which have different glyphs for horizontal and vertical. . Can return: boolean or nothing."></property><property name="OTF justification alternate" code="OTja" type="any" description="If true, use alternate justification forms in OpenType fonts. Can return: boolean or nothing."></property><property name="OTF locale" code="OTlc" type="any" description="If true, uses localized forms in OpenType fonts. Can return: boolean or nothing."></property><property name="OTF mark" code="OTmk" type="any" description="If true, uses mark positioning in OpenType fonts. Can return: boolean or nothing."></property><property name="OTF ordinal" code="OTor" type="any" description="If true, uses ordinals in OpenType fonts. Can return: boolean or nothing."></property><property name="OTF overlap swash" code="OTol" type="any" description="If true, use overlapping swash forms in OpenType fonts. Can return: boolean or nothing."></property><property name="OTF proportional metrics" code="palt" type="any" description="If true, kerns according to proportional CJK metrics in OpenType fonts. Can return: boolean or nothing."></property><property name="OTF Roman italics" code="ital" type="any" description="If true, applies italics to half-width alphanumerics. . Can return: boolean or nothing."></property><property name="OTF slashed zero" code="OTzr" type="any" description="If true, use a slashed zeroes in OpenType fonts. Can return: boolean or nothing."></property><property name="OTF stretched alternate" code="OTsh" type="any" description="If true, use stretched alternate forms in OpenType fonts. Can return: boolean or nothing."></property><property name="OTF stylistic alternate" code="OTsy" type="any" description="If true, use stylistic alternate forms in OpenType fonts. Can return: boolean or nothing."></property><property name="OTF stylistic sets" code="OTss" type="any" description="The stylistic sets to use in OpenType fonts. Can return: integer or nothing."></property><property name="OTF swash" code="OTsw" type="any" description="If true, uses swash forms in OpenType fonts. Can return: boolean or nothing."></property><property name="OTF titling" code="OTti" type="any" description="If true, uses titling forms in OpenType fonts. Can return: boolean or nothing."></property><property name="overprint fill" code="ovpr" type="any" description="If true, the fill color of the characters will overprint. Can return: boolean or nothing."></property><property name="overprint stroke" code="sovp" type="any" description="If true, the stroke of the characters will overprint. Can return: boolean or nothing."></property><property name="paragraph direction" code="pdir" type="any" description="Paragraph direction. Can return: left to right direction/right to left direction or nothing."></property><property name="paragraph gyoudori" code="jpgd" type="any" description="If true, the gyoudori mode applies to the entire paragraph. If false, the gyoudori mode applies to each line in the paragraph. Can return: boolean or nothing."></property><property name="paragraph justification" code="pjus" type="any" description="Paragraph justification. Can return: default justification/arabic justification/naskh justification/naskh tatweel justification/naskh kashida justification/naskh tatweel justification frac/naskh kashida justification frac or nothing."></property><property name="paragraph kashida width" code="pkas" type="any" description="Paragraph kashida width. 0 is none, 1 is short, 2 is medium, 3 is long. Can return: fixed or nothing."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the change grep preference (a application)."></property><property name="point size" code="ptsz" type="any" description="The text size. Can return: number or string or nothing."></property><property name="position" code="posm" type="any" description="The text position relative to the baseline. Can return: normal/superscript/subscript/OT superscript/OT subscript/OT numerator/OT denominator or nothing."></property><property name="positional form" code="OTPf" type="any" description="The OpenType positional form. Can return: none/calculate/initial/medial/final/isolated or nothing."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="rensuuji" code="jren" type="any" description="If true, disallows line breaks in numbers. If false, lines can break between digits in multi-digit numbers. Can return: boolean or nothing."></property><property name="right indent" code="inbr" type="any" description="The width of the right indent. Can return: number or string or nothing."></property><property name="rotate single byte characters" code="jro1" type="any" description="If true, rotates Roman characters in vertical text. Can return: boolean or nothing."></property><property name="ruby alignment" code="jral" type="any" description="The ruby alignment. Can return: ruby left/ruby center/ruby right/ruby full justify/ruby JIS/ruby equal aki/ruby 1 aki or nothing."></property><property name="ruby auto align" code="jraa" type="any" description="If true, auto aligns ruby. Can return: boolean or nothing."></property><property name="ruby auto scaling" code="jras" type="any" description="If true, automatically scales ruby to the specified percent of parent text size. For information on specifying a percent, see ruby parent scaling percent. . Can return: boolean or nothing."></property><property name="ruby auto tcy auto scale" code="jrts" type="any" description="If true, automatically scales glyphs in auto tcy (tate-chuu-yoko) in ruby to fit one em. Can return: boolean or nothing."></property><property name="ruby auto tcy digits" code="jrtd" type="any" description="The number of digits included in auto tcy (tate-chuu-yoko) in ruby. Can return: small integer or nothing."></property><property name="ruby auto tcy include roman" code="jrtr" type="any" description="If true, includes Roman characters in auto tcy (tate-chuu-yoko) in ruby. Can return: boolean or nothing."></property><property name="ruby fill" code="jrfl" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the fill of ruby characters. Can return: swatch, string or nothing."></property><property name="ruby font" code="jrfn" type="any" description="The font applied to ruby characters. Can return: font, string or nothing."></property><property name="ruby font size" code="jrfs" type="any" description="The size (in points) of ruby characters. Can return: fixed or nothing."></property><property name="ruby font style" code="jrft" type="any" description="The font style of ruby characters. Can return: string or nothing."></property><property name="ruby open type pro" code="jpro" type="any" description="If true, uses OpenType Pro fonts for ruby. Can return: boolean or nothing."></property><property name="ruby overhang" code="jrov" type="any" description="If true, constrains ruby overhang to the specified amount. For information on specifying an amount, see ruby parent overhang amount. . Can return: boolean or nothing."></property><property name="ruby overprint fill" code="jrof" type="any" description="The method of overprinting the ruby fill. Can return: auto/overprint on/overprint off or nothing."></property><property name="ruby overprint stroke" code="jros" type="any" description="The method of overprinting the ruby stroke. Can return: auto/overprint on/overprint off or nothing."></property><property name="ruby parent overhang amount" code="jrva" type="any" description="The amount by which ruby characters can overhang the parent text. Can return: none/ruby overhang one ruby/ruby overhang half ruby/ruby overhang one char/ruby overhang half char/ruby overhang no limit or nothing."></property><property name="ruby parent scaling percent" code="jrsc" type="any" description="The amount (as a percentage) to scale the parent text size to determine the ruby text size. Can return: fixed or nothing."></property><property name="ruby parent spacing" code="jrsp" type="any" description="The ruby spacing relative to the parent text. . Can return: ruby parent no adjustment/ruby parent both sides/ruby parent 121 aki/ruby parent equal aki/ruby parent full justify or nothing."></property><property name="ruby position" code="jrpz" type="any" description="The position of ruby characters relative to the parent text. Can return: above right/below left or nothing."></property><property name="ruby stroke" code="jrsk" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the stroke of ruby characters. Can return: swatch, string or nothing."></property><property name="ruby stroke tint" code="jrst" type="any" description="The stroke tint (as a percentage) of ruby characters. Can return: fixed or nothing."></property><property name="ruby tint" code="jrti" type="any" description="The tint (as a percentage) of the ruby fill color. (Range: 0 to 100). Can return: fixed or nothing."></property><property name="ruby type" code="jrtp" type="any" description="The ruby type. Can return: group ruby/per character ruby or nothing."></property><property name="ruby weight" code="jrwt" type="any" description="The stroke weight (in points) of ruby characters. Can return: fixed or nothing."></property><property name="ruby X offset" code="jrxo" type="any" description="The amount of horizontal space between ruby and parent characters. Can return: fixed or nothing."></property><property name="ruby X scale" code="jrwd" type="any" description="The horizontal size of ruby characters, specified as a percent of the original size. Can return: fixed or nothing."></property><property name="ruby Y offset" code="jryo" type="any" description="The amount of vertical space between ruby and parent characters. Can return: fixed or nothing."></property><property name="ruby Y scale" code="jrpt" type="any" description="The vertical size of ruby characters, specified as a percent of the original size. Can return: fixed or nothing."></property><property name="same para style spacing" code="spsp" type="any" description="The space between paragraphs using same style. Can return: number or string, SetIgnore or nothing."></property><property name="scale affects line height" code="jslh" type="any" description="If true, the line changes size when characters are scaled. . Can return: boolean or nothing."></property><property name="shatai adjust rotation" code="jshr" type="any" description="If true, applies shatai rotation. Can return: boolean or nothing."></property><property name="shatai adjust tsume" code="jsht" type="any" description="If true, adjusts shatai tsume. Can return: boolean or nothing."></property><property name="shatai degree angle" code="jsha" type="any" description="The shatai lens angle (in degrees). Can return: fixed or nothing."></property><property name="shatai magnification" code="jshp" type="any" description="The amount (as a percentage) of shatai obliquing to apply. Can return: fixed or nothing."></property><property name="single word justification" code="pals" type="any" description="The alignment to use for lines that contain a single word. Can return: left align/center align/right align/fully justified or nothing."></property><property name="skew" code="pskw" type="any" description="The skew angle of the change grep preference. Can return: fixed or nothing."></property><property name="space after" code="spaf" type="any" description="The height of the paragraph space below. Can return: number or string or nothing."></property><property name="space before" code="spbe" type="any" description="The height of the paragraph space above. Can return: number or string or nothing."></property><property name="span column min space after" code="scma" type="any" description="The minimum space after a span or a split column. Can return: number or string or nothing."></property><property name="span column min space before" code="scmb" type="any" description="The minimum space before a span or a split column. Can return: number or string or nothing."></property><property name="span column type" code="scte" type="any" description="Whether a paragraph should be a single column, span columns or split columns. Can return: single column/span columns/split columns or nothing."></property><property name="span split column count" code="scct" type="any" description="The number of columns a paragraph spans or the number of split columns. Can return: small integer (1 - 40), all or nothing."></property><property name="split column inside gutter" code="scig" type="any" description="The inside gutter if the paragraph splits columns. Can return: number or string or nothing."></property><property name="split column outside gutter" code="scog" type="any" description="The outside gutter if the paragraph splits columns. Can return: number or string or nothing."></property><property name="start paragraph" code="pbbp" type="any" description="The location at which to start the paragraph. Can return: anywhere/next column/next frame/next page/next odd page/next even page or nothing."></property><property name="strike through color" code="stco" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the strikethrough stroke. Can return: swatch, string or nothing."></property><property name="strike through gap color" code="stgc" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the gap of the strikethrough stroke. Can return: swatch, string or nothing."></property><property name="strike through gap overprint" code="stgo" type="any" description="If true, the gap color of the strikethrough stroke will overprint. Note: Valid when strike through type is not solid. Can return: boolean or nothing."></property><property name="strike through gap tint" code="stgt" type="any" description="The tint (as a percentage) of the strikethrough stroke gap color. (Range: 0 to 100) Note: Valid when strike through type is not solid. Can return: fixed or nothing."></property><property name="strike through offset" code="stos" type="any" description="The amount by which to offset the strikethrough stroke from the text baseline. Can return: number or string or nothing."></property><property name="strike through overprint" code="Stvp" type="any" description="If true, the strikethrough stroke will overprint. Can return: boolean or nothing."></property><property name="strike through tint" code="sttt" type="any" description="The tint (as a percentage) of the strikethrough stroke. (Range: 0 to 100). Can return: fixed or nothing."></property><property name="strike through type" code="sttp" type="any" description="The stroke type of the strikethrough stroke. Can return: stroke style, string or nothing."></property><property name="strike through weight" code="stwt" type="any" description="The stroke weight of the strikethrough stroke. Can return: number or string or nothing."></property><property name="strike thru" code="strk" type="any" description="If true, draws a strikethrough line through the text. Can return: boolean or nothing."></property><property name="stroke alignment" code="strA" type="any" description="The stroke alignment applied to the text. Can return: center alignment/outside alignment or nothing."></property><property name="stroke color" code="lncl" type="any" description="The swatch (color, gradient, tint, or mixed ink), applied as a stroke color, to search for or change to. Can return: string or nothing. Can also accept: swatch."></property><property name="stroke tint" code="lint" type="any" description="The tint (as a percentage) of the stroke color of the change grep preference. (To specify a tint percentage, use a number in the range of 0 to 100; to use the inherited or overridden value, use -1.). Can return: fixed or nothing."></property><property name="stroke weight" code="lnwt" type="any" description="The stroke weight applied to the characters of the text. Can return: number or string or nothing."></property><property name="tatechuyoko" code="jtcy" type="any" description="If true, makes the character horizontal in vertical text. Can return: boolean or nothing."></property><property name="tatechuyoko X offset" code="jtax" type="any" description="The horizontal offset for horizontal characters in vertical text. Can return: fixed or nothing."></property><property name="tatechuyoko Y offset" code="jtay" type="any" description="The vertical offset for horizontal characters in vertical text. Can return: fixed or nothing."></property><property name="tracking" code="trak" type="any" description="The amount by which to loosen or tighten a block of text, specified in thousands of an em. Can return: fixed or nothing."></property><property name="trailing aki" code="jmas" type="any" description="The amount of space after each character. Can return: fixed or nothing."></property><property name="treat ideographic space as space" code="jisb" type="any" description="If true, ideographic spaces will not wrap to the next line like text characters. Can return: boolean or nothing."></property><property name="tsume" code="tsum" type="any" description="The amount of horizontal character compression. Can return: fixed or nothing."></property><property name="underline" code="undr" type="any" description="If true, underlines the text. Can return: boolean or nothing."></property><property name="underline color" code="ulco" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the underline stroke. . Can return: swatch, string or nothing."></property><property name="underline gap color" code="ulgc" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the gap of the underline stroke. Note: Valid when underline type is not solid. Can return: swatch, string or nothing."></property><property name="underline gap overprint" code="upgo" type="any" description="If true, the gap color of the underline stroke will overprint. Can return: boolean or nothing."></property><property name="underline gap tint" code="ulgt" type="any" description="The tint (as a percentage) of the gap color of the underline stroke. (Range: 0 to 100) Note: Valid when underline type is not solid. Can return: fixed or nothing."></property><property name="underline offset" code="ulos" type="any" description="The amount by which to offset the underline from the text baseline. Can return: number or string or nothing."></property><property name="underline overprint" code="ulop" type="any" description="If true, the underline stroke color will overprint. Can return: boolean or nothing."></property><property name="underline tint" code="ultt" type="any" description="The underline stroke tint (as a percentage). (Range: 0 to 100). Can return: fixed or nothing."></property><property name="underline type" code="ultp" type="any" description="The stroke type of the underline stroke. Can return: stroke style, string or nothing."></property><property name="underline weight" code="ulwt" type="any" description="The stroke weight of the underline stroke. Can return: number or string or nothing."></property><property name="vertical scale" code="pvts" type="any" description="The vertical scaling applied to the change grep preference. Can return: fixed or nothing."></property><property name="warichu" code="jwar" type="any" description="If true, turns on warichu. Can return: boolean or nothing."></property><property name="warichu alignment" code="jwal" type="any" description="The warichu alignment. Can return: auto/left align/center align/right align/fully justified/left justified/center justified/right justified or nothing."></property><property name="warichu chars after break" code="jmab" type="any" description="The minimum number of characters allowed after a line break. . Can return: small integer or nothing."></property><property name="warichu chars before break" code="jmbb" type="any" description="The minimum number of characters allowed before a line break. Can return: small integer or nothing."></property><property name="warichu line spacing" code="jwls" type="any" description="The gap between lines of warichu characters. Can return: fixed or nothing."></property><property name="warichu lines" code="jwli" type="any" description="The number of lines of warichu within a single normal line. Can return: small integer or nothing."></property><property name="warichu size" code="jwas" type="any" description="The amount (as a percentage) to scale parent text size to determine warichu size. Can return: fixed or nothing."></property><property name="x offset diacritic" code="diax" type="any" description="The x (horizontal) offset for diacritic adjustment. Can return: fixed or nothing."></property><property name="y offset diacritic" code="diay" type="any" description="The y (vertical) offset for diacritic adjustment. Can return: fixed or nothing."></property></class><class name="change object preference" code="cCOP" description="Change object preferences."><element type="event"></element><element type="event listener"></element><element type="preference"></element><property name="actual metadata property" code="acMp" type="any" description="The metadata property to use as source of actual text. Can return: Ordered list containing namespace prefix:string, property path:string or nothing."></property><property name="actual text source type" code="acSP" type="any" description="The source type of actual text. Can return: source custom/source XMP title/source XMP description/source XMP headline/source XMP other/source XML structure/source XMP Alt Text/source XMP Extended Description or nothing."></property><property name="alt metadata property" code="alMp" type="any" description="The metadata property to use as source of alternate text. Can return: Ordered list containing namespace prefix:string, property path:string or nothing."></property><property name="alt text source type" code="alSP" type="any" description="The source type of alternate text. Can return: source custom/source XMP title/source XMP description/source XMP headline/source XMP other/source XML structure/source XMP Alt Text/source XMP Extended Description or nothing."></property><property name="anchor point" code="AOwp" type="any" description="The point in the anchored object to position. Can return: top left anchor/top center anchor/top right anchor/left center anchor/center anchor/right center anchor/bottom left anchor/bottom center anchor/bottom right anchor or nothing."></property><property name="anchor space above" code="AOya" type="any" description="The space above an above-line anchored object. Can return: number or string or nothing."></property><property name="anchor xoffset" code="AOxo" type="any" description="The horizontal (x) offset of the anchored object. Can return: number or string or nothing."></property><property name="anchor yoffset" code="AOyo" type="any" description="The vertical (y) offset of the anchored object. Corresponds to the space after property for above line positioning. Can return: number or string or nothing."></property><property name="anchored position" code="AOpt" type="any" description="The position of the anchored object relative to the anchor. Can return: inline position/above line/anchored or nothing."></property><property name="applied object styles" code="fcos" type="any" description="The applied object style(s). Can return: string or nothing. Can also accept: object style."></property><property name="apply tag type" code="Aptt" type="any" description="The tag type of page item. Can return: tag from structure/tag artifact/tag based on object or nothing."></property><property name="apply to master page only" code="ptwm" type="any" description="If true, text wraps on the master spread apply to that spread only, and not to any pages the master spread has been applied to. Can return: boolean or nothing."></property><property name="arrow head alignment" code="awha" type="any" description="The arrowhead alignment applied to the change object preference. Can return: inside path/outside path or nothing."></property><property name="auto sizing reference point" code="asrp" type="any" description="The reference point for auto sizing of text frame. Reference point is automatically adjusted to the suitable value depending on the auto-sizing type value. As an example, top left reference point becomes top center for height only dimension. Can return: top left point/top center point/top right point/left center point/center point/right center point/bottom left point/bottom center point/bottom right point or nothing."></property><property name="auto sizing type" code="asdi" type="any" description="Auto-sizing type of text frame. Based on type, reference value is automatically adjusted. For example, for height only type, top-left reference point becomes top-center. Recommended to change auto-sizing type, after setting other auto-sizing attributes. Can return: off/height only/width only/height and width/height and width proportionally or nothing."></property><property name="baseline frame grid color" code="BFcl" type="any" description="The grid line color, specified either as an array of three doubles, each in the range 0 to 255 and representing R, G, and B values, or as a UI color. Can return: list of 3 fixed (0 - 255) or light blue/red/green/blue/yellow/magenta/cyan/gray/black/orange/dark green/teal/tan/brown/violet/gold/dark blue/pink/lavender/brick red/olive green/peach/burgundy/grass green/ochre/purple/light gray/charcoal/grid blue/grid orange/fiesta/light olive/lipstick/cute teal/sulphur/grid green/white or nothing."></property><property name="baseline frame grid increment" code="BFic" type="any" description="The distance between grid lines. Can return: number or string (1 - 8640 points) or nothing."></property><property name="baseline frame grid relative option" code="BFro" type="any" description="The location (top of page, top margin, top of frame, or frame inset) on which to base the custom baseline grid. Can return: top of page/top of margin/top of frame/top of inset or nothing."></property><property name="bottom  right corner option" code="pcO4" type="any" description="The shape to apply to the bottom right corner of rectangular shapes. Can return: none/rounded corner/inverse rounded corner/inset corner/bevel corner/fancy corner or nothing."></property><property name="bottom crop" code="fcrb" type="any" description="The amount in measurement units to crop the bottom edge of a graphic. Can return: number or string or nothing."></property><property name="bottom left corner option" code="pcO3" type="any" description="The shape to apply to the bottom left corner of rectangular shapes. Can return: none/rounded corner/inverse rounded corner/inset corner/bevel corner/fancy corner or nothing."></property><property name="bottom left corner radius" code="pcr3" type="any" description="The radius in measurement units of the corner effect applied to the bottom left corner of rectangular shapes. Can return: number or string or nothing."></property><property name="bottom right corner radius" code="pcr4" type="any" description="The radius in measurement units of the corner effect applied to the bottom right corner of rectangular shapes. Can return: number or string or nothing."></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="content transparency settings" code="xpSC" type="any" access="r" description="Transparency settings for the content of the change object preference. Can return: find change content transparency setting or nothing."></property><property name="contour type" code="pcot" type="any" description="The contour type. Can return: bounding box/photoshop path/detect edges/alpha channel/graphic frame/same as clipping/select subject or nothing."></property><property name="custom actual text" code="acCt" type="any" description="The custom actual text entered by the user. Can return: string or nothing."></property><property name="custom alt text" code="alCt" type="any" description="The custom alternate text entered by the user. Can return: string or nothing."></property><property name="end cap" code="endc" type="any" description="The end shape of an open path. Can return: butt end cap/round end cap/projecting end cap or nothing."></property><property name="end join" code="endj" type="any" description="The corner join applied to the change object preference. Can return: miter end join/round end join/bevel end join or nothing."></property><property name="fill color" code="flcl" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the fill of the change object preference. . Can return: swatch or nothing. Can also accept: string."></property><property name="fill tint" code="filt" type="any" description="The percent of tint to use in the change object preference's fill color. (To specify a tint percent, use a number in the range of 0 to 100; to use the inherited or overridden value, use -1.). Can return: fixed or nothing."></property><property name="fill transparency settings" code="xpSF" type="any" access="r" description="Transparency settings for the fill applied to the change object preference. Can return: find change fill transparency setting or nothing."></property><property name="first baseline offset" code="Fbof" type="any" description="The distance between the baseline of the text and the top inset of the text frame or cell. Can return: ascent offset/cap height/leading offset/embox height/x height/fixed height or nothing."></property><property name="fitting alignment" code="faln" type="any" description="The point with which to align the image empty when fitting in a frame. For information, see frame fitting options. Can return: top left anchor/top center anchor/top right anchor/left center anchor/center anchor/right center anchor/bottom left anchor/bottom center anchor/bottom right anchor or nothing."></property><property name="fitting on empty frame" code="ffit" type="any" description="The frame fitting option to apply to placed or pasted content if the frame is empty. Can be applied to a frame, object style, or document or to the application. Can return: none/content to frame/proportionally/fill proportionally or nothing."></property><property name="footnotes enable overrides" code="TFEO" type="any" description="If true, enable overrides to document footnote options. Can return: boolean or nothing."></property><property name="footnotes minimum spacing" code="TFMS" type="any" description="Minimum Spacing Before First Footnote. Can return: number or string (0 - 8640 points) or nothing."></property><property name="footnotes space between" code="TFSB" type="any" description="Space between footnotes. Can return: number or string (0 - 8640 points) or nothing."></property><property name="footnotes span across columns" code="TFSF" type="any" description="If true, enable straddling footnotes. Can return: boolean or nothing."></property><property name="gap color" code="gapC" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the gap of a dashed, dotted, or striped stroke. For information, see stroke type. Can return: swatch or nothing."></property><property name="gap tint" code="gapT" type="any" description="The tint as a percentage of the gap color. (To specify a tint percent, use a number in the range of 0 to 100; to use the inherited or overridden value, use -1.). Can return: fixed or nothing."></property><property name="GIF options interlaced" code="Xegi" type="any" description="If true, generates interlaced GIFs. Note: Not valid  when image conversion is JPEG. Can return: boolean or nothing."></property><property name="GIF options palette" code="Xegp" type="any" description="The color palette for GIF conversion. Note: Not valid when image conversion is JPEG. . Can return: adaptive palette/macintosh palette/web palette/windows palette or nothing."></property><property name="gradient fill angle" code="pgfa" type="any" description="The angle of a linear gradient applied to the fill of the change object preference. (Range: -180 to 180). Can return: fixed or nothing."></property><property name="gradient stroke angle" code="pgsa" type="any" description="The angle of a linear gradient applied to the stroke of the change object preference. (Range: -180 to 180). Can return: fixed or nothing."></property><property name="horizontal reference point" code="AHrl" type="any" description="The horizontal reference point on the page. Valid only when anchored position is custom. Can return: column edge/text frame/page margins/page edge/anchor location or nothing."></property><property name="ignore wrap" code="iwrp" type="any" description="If true, ignores text wrap settings for drawn or placed objects in the text frame. . Can return: boolean or nothing."></property><property name="image alignment" code="ImAl" type="any" description="Alignment applied to images. Can return: align left/align center/align right or nothing."></property><property name="image conversion type" code="ICvt" type="any" description="Allows user to select the image format for conversion. Can return: JPEG/GIF/PNG or nothing."></property><property name="image export resolution" code="ImRs" type="any" description="The export resolution. Can return: ppi 72/ppi 96/ppi 150/ppi 300 or nothing."></property><property name="image page break" code="ImPk" type="any" description="Image page break settings to be used with objects. Can return: page break before/page break after/page break before and after or nothing."></property><property name="image space after" code="ImSA" type="any" description="Space After applied to images. Can return: fixed (0 - 8640) or nothing."></property><property name="image space before" code="ImSB" type="any" description="Space Before applied to images. Can return: fixed (0 - 8640) or nothing."></property><property name="include inside edges" code="iied" type="any" description="If true, creates interior clipping paths within the surrounding clipping path. Note: Valid only when clipping type is alpha channel or detect edges. . Can return: boolean or nothing."></property><property name="inset spacing" code="inst" type="any" description="The amount to offset text from the edges of the text frame, specified either as a single value applied uniformly to all sides of the text frame or as an array of 4 values in the format [top inset, left inset, bottom inset, right inset]. Can return: number or string (0 - 8640 points), list of 4 numbers or strings (0 - 8640 points) or nothing."></property><property name="inverse" code="ptwv" type="any" description="If true, inverts the text wrap. Can return: boolean or nothing."></property><property name="JPEG options format" code="Xejf" type="any" description="The formatting method for converted JPEG images. Note: Not valid  when image conversion is GIF. Can return: baseline encoding/progressive encoding or nothing."></property><property name="JPEG options quality" code="Xejq" type="any" description="The quality of converted JPEG images. Note: Not valid when image conversion is GIF. . Can return: low/medium/high/maximum or nothing."></property><property name="left arrow head scale" code="lahs" type="any" description="The scaling applied to the arrowhead at the start of the path. (Range: 1 to 1000). Can return: fixed or nothing."></property><property name="left crop" code="fcrl" type="any" description="The amount in measurement units to crop the left edge of a graphic. Can return: number or string or nothing."></property><property name="left line end" code="llen" type="any" description="The arrowhead applied to the start of the path. . Can return: none/simple arrow head/simple wide arrow head/triangle arrow head/triangle wide arrow head/barbed arrow head/curved arrow head/circle arrow head/circle solid arrow head/square arrow head/square solid arrow head/bar arrow head or nothing."></property><property name="lock position" code="AOlp" type="any" description="If true, prevents manual positioning of the anchored object. Can return: boolean or nothing."></property><property name="minimum first baseline offset" code="Fboa" type="any" description="The minimum distance between the baseline of the text and the top inset of the text frame or cell. Can return: number or string (0 - 8640 points) or nothing."></property><property name="minimum height for auto sizing" code="asmh" type="any" description="The minimum height for auto-sizing of the text frame. Can return: number or string or nothing."></property><property name="minimum width for auto sizing" code="asmw" type="any" description="The minimum width for auto-sizing of the text frame. Can return: number or string or nothing."></property><property name="miter limit" code="mitr" type="any" description="The limit of the ratio of stroke width to miter length before a miter (pointed) join becomes a bevel (squared-off) join. Can return: fixed (1 - 500) or nothing."></property><property name="nonprinting" code="nopr" type="any" description="If true, the change object preference does not print. Can return: boolean or nothing."></property><property name="object reference" code="posp" type="change object preference" access="r" description="An object reference for the object."></property><property name="optical margin alignment" code="omAL" type="any" description="If true, adjust the position of characters at the edges of the frame to provide a better appearance. Can return: boolean or nothing."></property><property name="optical margin size" code="omBZ" type="any" description="The point size used as the basis for calculating optical margin alignment. (Range: 0.1 to 1296). Can return: number or string (0.1 - 1296 points) or nothing."></property><property name="overprint fill" code="ovpr" type="any" description="If true, the change object preference's fill color overprints any underlying objects. If false, the fill color knocks out the underlying colors. Can return: boolean or nothing."></property><property name="overprint gap" code="gapO" type="any" description="If true, the gap color overprints any underlying colors. If false, the gap color knocks out the underlying colors. Can return: boolean or nothing."></property><property name="overprint stroke" code="sovp" type="any" description="If true, the change object preference's stroke color overprints any underlying objects. If false, the stroke color knocks out the  underlying colors. Can return: boolean or nothing."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the change object preference (a application)."></property><property name="pin position" code="AOpp" type="any" description="If true, pins the position of the anchored object within the text frame top and bottom. Can return: boolean or nothing."></property><property name="position reference point" code="AOPr" type="any" description="The point in the referenced object relative to which to position the anchored object. Notes: Valid only when anchored position is custom. Can return: top left anchor/top center anchor/top right anchor/left center anchor/center anchor/right center anchor/bottom left anchor/bottom center anchor/bottom right anchor or nothing."></property><property name="preserve appearance from layout" code="PoLa" type="any" description="Preserve Appearance from Layout. Can return: preserve appearance default/preserve appearance use existing image/preserve appearance rasterize container/preserve appearance rasterize content or nothing."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="right arrow head scale" code="rahs" type="any" description="The scaling applied to the arrowhead at the end of the path. (Range: 1 to 1000). Can return: fixed or nothing."></property><property name="right crop" code="fcrr" type="any" description="The amount in measurement units to crop the right edge of a graphic. Can return: number or string or nothing."></property><property name="right line end" code="rlen" type="any" description="The arrowhead applied to the end of the path. Can return: none/simple arrow head/simple wide arrow head/triangle arrow head/triangle wide arrow head/barbed arrow head/curved arrow head/circle arrow head/circle solid arrow head/square arrow head/square solid arrow head/bar arrow head or nothing."></property><property name="spine relative" code="AOsr" type="any" description="If true, the position of the anchored object is relative to the binding spine of the page or spread. Can return: boolean or nothing."></property><property name="starting offset for baseline frame grid" code="BFso" type="any" description="The amount to offset the baseline grid. Can return: number or string (0 - 8640 points) or nothing."></property><property name="story direction" code="sdir" type="any" description="The direction of the story. Can return: left to right direction/right to left direction/unknown direction or nothing."></property><property name="stroke alignment" code="strA" type="any" description="The stroke alignment applied to the change object preference. Can return: center alignment/inside alignment/outside alignment or nothing."></property><property name="stroke color" code="lncl" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the stroke of the change object preference. Can return: swatch or nothing. Can also accept: string."></property><property name="stroke corner adjustment" code="Scaj" type="any" description="The corner adjustment applied to the change object preference. Can return: none/dashes/gaps/dashes and gaps or nothing."></property><property name="stroke dash and gap" code="Sdag" type="any" description="The dash and gap measurements that define the pattern of a custom dashed line. Define up to six values (in points) in the format [dash1, gap1, dash2, gap2, dash3, gap3]. Can return: list of numbers or strings or nothing."></property><property name="stroke tint" code="lint" type="any" description="The percent of tint to use in object's stroke color. (To specify a tint percent, use a number in the range of 0 to 100; to use the inherited or overridden value, use -1.). Can return: fixed or nothing."></property><property name="stroke transparency settings" code="xpSS" type="any" access="r" description="Transparency settings for the stroke. Can return: find change stroke transparency setting or nothing."></property><property name="stroke type" code="stty" type="any" description="The name of the stroke style to apply. Can return: stroke style or nothing. Can also accept: string."></property><property name="stroke weight" code="lnwt" type="any" description="The weight (in points) to apply to the change object preference's stroke. Can return: number or string or nothing."></property><property name="text column count" code="ccnt" type="any" description="The number of columns in the text frame. Note: Depending on the value of use fixed column width, the number of columns can change automatically when the text frame size changes. Can return: integer (1 - 40) or nothing."></property><property name="text column fixed width" code="clwd" type="any" description="The column width of the columns in the text frame. Can return: number or string (0 - 8640 points) or nothing."></property><property name="text column gutter" code="clgt" type="any" description="The space between columns in the text frame. Can return: number or string (0 - 8640 points) or nothing."></property><property name="text wrap mode" code="txwm" type="any" description="The text wrap mode. . Can return: none/jump object text wrap/next column text wrap/bounding box text wrap/contour or nothing."></property><property name="text wrap offset" code="ptwi" type="any" description="The minimum space between text and the edges of the wrapped object. Specify four values in the format [top, left, bottom, right]. . Can return: Ordered list containing top:number or string, left:number or string, bottom:number or string, right:number or string or nothing."></property><property name="text wrap side" code="ptws" type="any" description="Text wrap side options. Can return: both sides/left side/right side/side towards spine/side away from spine/largest area or nothing."></property><property name="top crop" code="fcrt" type="any" description="The amount in measurement units to crop the top edge of a graphic. Can return: number or string or nothing."></property><property name="top left corner option" code="pcO1" type="any" description="The shape to be applied to the top left corner of rectangular shapes and all corners of non-rectangular shapes.Note: corner option differs from end join in which you can set a radius for a corner option, whereas the rounded or beveled effect of an end join depends on the stroke weight. Can return: none/rounded corner/inverse rounded corner/inset corner/bevel corner/fancy corner or nothing."></property><property name="top left corner radius" code="pcr1" type="any" description="The radius in measurement units of the corner effect applied to the top left corner of rectangular shapes and all corners of non-rectangular shapes. Can return: number or string or nothing."></property><property name="top right corner option" code="pcO2" type="any" description="The shape to apply to the top right corner of rectangular shapes. Can return: none/rounded corner/inverse rounded corner/inset corner/bevel corner/fancy corner or nothing."></property><property name="top right corner radius" code="pcr2" type="any" description="The radius in measurement units of the corner effect applied to the top right corner of rectangular shapes. Can return: number or string or nothing."></property><property name="transparency settings" code="xpSP" type="any" access="r" description="Transparency settings. Can return: find change transparency setting or nothing."></property><property name="use custom baseline frame grid" code="BFuc" type="any" description="If true, uses a custom baseline frame grid. Can return: boolean or nothing."></property><property name="use fixed column width" code="ufcw" type="any" description="If true, maintains column width when the text frame is resized. If false, causes columns to resize when the text frame is resized. Note: When true, resizing the frame can change the number of columns in the frame. Can return: boolean or nothing."></property><property name="use image page break" code="Uipb" type="any" description="If true, image page break settings will be used in objects. Can return: boolean or nothing."></property><property name="use minimum height for auto sizing" code="ashm" type="any" description="If true, minimum height value is used during the auto-sizing of text frame. . Can return: boolean or nothing."></property><property name="use minimum width for auto sizing" code="ashw" type="any" description="If true, minimum width value is used during the auto-sizing of text frame. . Can return: boolean or nothing."></property><property name="use no line breaks for auto sizing" code="asnl" type="any" description="If true, line-breaks are not introduced after auto sizing. . Can return: boolean or nothing."></property><property name="user modified wrap" code="ptwu" type="any" access="r" description="If true, the text wrap path has been explicitly modified by the user. Can return: boolean or nothing."></property><property name="vertical justification" code="VJal" type="any" description="The vertical alignment of the text content. . Can return: top align/center align/bottom align/justify align or nothing."></property><property name="vertical reference point" code="AOVr" type="any" description="The vertical reference point on the page. Valid when anchored position is custom. Can return: column edge/text frame/page margins/page edge/line baseline/line xheight/line ascent/capheight/top of leading/embox top/embox middle/embox bottom or nothing."></property><property name="vertical threshold" code="VJmi" type="any" description="The maximum amount of vertical space between two paragraphs. Note: Valid only when vertical justification is justified; the specified amount is applied in addition to the space before or space after values defined for the paragraph. Can return: number or string (0 - 8640 points) or nothing."></property></class><class name="change text preference" code="cCTP" description="Change text preferences."><element type="event"></element><element type="event listener"></element><element type="preference"></element><property name="allow arbitrary hyphenation" code="jwro" type="any" description="If true, words unassociated with a hyphenation dictionary can break to the next line on any character. Can return: boolean or nothing."></property><property name="applied character style" code="crst" type="any" description="The character style to search for or change to. Can return: string or nothing. Can also accept: character style."></property><property name="applied conditions" code="apCt" type="any" description="The conditions to search for or change to. Specify the &quot;nothing&quot; enum for &quot;Any&quot; or an empty list for &quot;[Unconditional]&quot;. Can return: list of strings or nothing. Can also accept: list of conditions."></property><property name="applied font" code="font" type="any" description="The font applied to the change text preference, specified as either a font object or the name of font family. Can return: font, string or nothing."></property><property name="applied language" code="plng" type="any" description="The language to search for or change to. Can return: string or nothing. Can also accept: language or language with vendors."></property><property name="applied numbering list" code="bnnl" type="any" description="The list to be part of. Can return: numbering list, string or nothing."></property><property name="applied paragraph style" code="prst" type="any" description="The paragraph style to search for or change to. Can return: string or nothing. Can also accept: paragraph style."></property><property name="auto leading" code="alea" type="any" description="The percent of the type size to use for auto leading. (Range: 0 to 500). Can return: fixed or nothing."></property><property name="auto tcy" code="jatc" type="any" description="The number of half-width characters at or below which the characters automatically run horizontally in vertical text. Can return: small integer or nothing."></property><property name="auto tcy include roman" code="jatr" type="any" description="If true, auto tcy includes Roman characters. Can return: boolean or nothing."></property><property name="balance ragged lines" code="bala" type="any" description="If true or set to an enumeration value, balances ragged lines. Note: Not valid with a single-line text composer. Can return: boolean, no balancing/vee shape/fully balanced/pyramid shape or nothing."></property><property name="baseline shift" code="bshf" type="any" description="The baseline shift applied to the text. Can return: number or string or nothing."></property><property name="bullet char" code="bnbc" type="any" access="r" description="Bullet character. Can return: bullet or nothing."></property><property name="bullets and numbering list type" code="bnlt" type="any" description="List type for bullets and numbering. Can return: no list/bullet list/numbered list or nothing."></property><property name="bullets character style" code="bnbs" type="any" description="The character style to be used for the text after string. Can return: character style, string or nothing."></property><property name="bullets text after" code="bnta" type="any" description="The text after string expression for bullets. Can return: string or nothing."></property><property name="bunri kinshi" code="jbki" type="any" description="If true, adds the double period (..), ellipse (...), and double hyphen (--) to the selected kinsoku set. Note: Valid only when a kinsoku set is in effect. Can return: boolean or nothing."></property><property name="capitalization" code="capm" type="any" description="The capitalization scheme. Can return: normal/small caps/all caps/cap to small cap or nothing."></property><property name="change conditions mode" code="CHcm" type="any" description="The change conditions mode, change either replaces applied conditions or adds to applied conditions. Can return: replace with/add to or nothing."></property><property name="change to" code="Chgo" type="any" description="The replacement change text preference. Can return: string or nothing."></property><property name="character alignment" code="jcal" type="any" description="The alignment of small characters to the largest character in the line. Can return: align baseline/align em top/align em center/align em bottom/align ICF top/align ICF bottom or nothing."></property><property name="character direction" code="cdir" type="any" description="The direction of the character. Can return: default direction/left to right direction/right to left direction or nothing."></property><property name="character rotation" code="crot" type="any" description="The rotation angle (in degrees) of individual characters. Note: The rotation is counterclockwise. Can return: fixed or nothing."></property><property name="cjk grid tracking" code="jgrt" type="any" description="If true, uses grid tracking to track non-Roman characters in CJK grids. Can return: boolean or nothing."></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="composer" code="ptce" type="any" description="The text composer to use to compose the text. Can return: string or nothing."></property><property name="design axes" code="ndxs" type="any" description="Value of Design Axes. Can return: list of fixed or nothing."></property><property name="diacritic position" code="diap" type="any" description="Position of diacriticical characters. Can return: default position/loose position/medium position/tight position/opentype position/opentype position from baseline or nothing."></property><property name="digits type" code="digi" type="any" description="The digits type. Can return: default digits/arabic digits/hindi digits/farsi digits/Native digits/full farsi digits/thai digits/lao digits/devanagari digits/bengali digits/gurmukhi digits/gujarati digits/oriya digits/tamil digits/telugu digits/kannada digits/malayalam digits/tibetan digits/khmer digits/burmese digits or nothing."></property><property name="drop cap characters" code="dcca" type="any" description="The number of characters to drop cap. Can return: small integer (0 - 150) or nothing."></property><property name="drop cap lines" code="dcli" type="any" description="The number of lines to drop cap. Can return: small integer (0 - 25) or nothing."></property><property name="dropcap detail" code="dcdm" type="any" description="Details about the drop cap based on the glyph outlines. 1 = left side bearing. 2 = descenders. 0x100,0x200,0x400 are used for Japanese frame grid. Can return: integer or nothing."></property><property name="end join" code="endj" type="any" description="The stroke join type applied to the characters of the text. Can return: miter end join/round end join/bevel end join or nothing."></property><property name="fill color" code="flcl" type="any" description="The swatch (color, gradient, tint, or mixed ink), applied as a fill color, to search for or change to. Can return: string or nothing. Can also accept: swatch."></property><property name="fill tint" code="filt" type="any" description="The tint (as a percentage) of the fill color of the change text preference. (To specify a tint percentage, use a number in the range of 0 to 100; to use the inherited or overridden value, use -1.). Can return: fixed or nothing."></property><property name="first line indent" code="infl" type="any" description="The amount to indent the first line. Can return: number or string or nothing."></property><property name="font style" code="ptfs" type="any" description="The name of the font style. Can return: string or nothing."></property><property name="glyph form" code="jgfm" type="any" description="The glyph variant to substitute for standard glyphs. Can return: none/traditional form/expert form/JIS78 form/JIS83 form/monospaced half width form/third width form/quarter width form/NLC form/proportional width form/full width form/JIS04 form/JIS90 form or nothing."></property><property name="gradient fill angle" code="pgfa" type="any" description="The angle of a linear gradient applied to the fill of the text. (Range: -180 to 180). Can return: fixed or nothing."></property><property name="gradient fill length" code="pgfl" type="any" description="The length (for a linear gradient) or radius (for a radial gradient) applied to the fill of the text. Can return: fixed or nothing."></property><property name="gradient fill start" code="pgst" type="any" description="The starting point (in page coordinates) of a gradient applied to the fill of the text, in the format [x, y]. Can return: list of 2 numbers or strings or nothing."></property><property name="gradient stroke angle" code="pgsa" type="any" description="The angle of a linear gradient applied to the stroke of the text. (Range: -180 to 180). Can return: fixed or nothing."></property><property name="gradient stroke length" code="pgsl" type="any" description="The length (for a linear gradient) or radius (for a radial gradient) applied to the stroke of the text. Can return: fixed or nothing."></property><property name="gradient stroke start" code="pgss" type="any" description="The starting point (in page coordinates) of a gradient applied to the stroke of the text, in the format [x, y]. Can return: list of 2 numbers or strings or nothing."></property><property name="grid alignment" code="jgal" type="any" description="The alignment to the frame grid or baseline grid. Can return: none/align baseline/align em top/align em center/align em bottom/align ICF top/align ICF bottom or nothing."></property><property name="grid gyoudori" code="jggy" type="any" description="The manual gyoudori setting. Can return: small integer or nothing."></property><property name="horizontal scale" code="phzs" type="any" description="The horizontal scaling applied to the change text preference. Can return: fixed or nothing."></property><property name="hyphenate across columns" code="hycf" type="any" description="If true, allows the last word in a text column to be hyphenated. Can return: boolean or nothing."></property><property name="hyphenate last word" code="hylw" type="any" description="If true, allows hyphenation in the last word in a paragraph. Note: Valid only when hyphenation is true. Can return: boolean or nothing."></property><property name="ignore edge alignment" code="igEA" type="any" description="If true, ignores optical edge alignment for the paragraph. Can return: boolean or nothing."></property><property name="jidori" code="jjid" type="any" description="The number of grid squares in which to arrange the text. . Can return: small integer or nothing."></property><property name="justification" code="paln" type="any" description="The paragraph alignment. Can return: left align/center align/right align/left justified/right justified/center justified/fully justified/to binding side/away from binding side or nothing."></property><property name="kashidas" code="kash" type="any" description="Use of Kashidas for justification. Can return: default kashidas/kashidas off or nothing."></property><property name="keep all lines together" code="kept" type="any" description="If true, keeps all lines of the paragraph together. If false, allows paragraphs to break across pages or columns. Can return: boolean or nothing."></property><property name="keep first lines" code="kfnl" type="any" description="The minimum number of lines to keep together in a paragraph before allowing a page break. Can return: small integer (1 - 50) or nothing."></property><property name="keep last lines" code="klnl" type="any" description="The minimum number of lines to keep together in a paragraph after a page break. Can return: small integer (1 - 50) or nothing."></property><property name="keep lines together" code="kepl" type="any" description="If true, keeps a specified number of lines together when the paragraph breaks across columns or text frames. Can return: boolean or nothing."></property><property name="keep rule above in frame" code="prak" type="any" description="If true, forces the rule above the paragraph to remain in the frame bounds. Note: Valid only when rule above is true. Can return: boolean or nothing."></property><property name="keep with next" code="kwnx" type="any" description="The minimum number of lines to keep with the next paragraph. Can return: small integer (0 - 5) or nothing."></property><property name="keep with previous" code="kwpv" type="any" description="If the first line in the paragraph should be kept with the last line of previous paragraph. Can return: boolean or nothing."></property><property name="kenten alignment" code="jkal" type="any" description="The alignment of kenten characters relative to the parent characters. . Can return: align kenten left/align kenten center or nothing."></property><property name="kenten character set" code="jset" type="any" description="The character set used for the custom kenten character. Note: Valid only when kenten kind is custom. . Can return: character input/shift JIS/JIS/kuten/unicode or nothing."></property><property name="kenten custom character" code="jkcc" type="any" description="The character used for kenten. Note: Valid only when kenten kind is custom. Can return: string or nothing."></property><property name="kenten fill color" code="jkfc" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the fill of kenten characters. Can return: swatch, string or nothing."></property><property name="kenten font" code="jkfn" type="any" description="The font to use for kenten characters. Can return: font, string or nothing."></property><property name="kenten font size" code="jkfz" type="any" description="The size (in points) of kenten characters. Can return: fixed or nothing."></property><property name="kenten font style" code="jkfs" type="any" description="The font style of kenten characters. Can return: string or nothing."></property><property name="kenten kind" code="jktp" type="any" description="The style of kenten characters. Can return: none/kenten sesame dot/kenten white sesame dot/kenten black circle/kenten white circle/kenten black triangle/kenten white triangle/kenten bullseye/kenten fisheye/kenten small black circle/kenten small white circle/custom or nothing."></property><property name="kenten overprint fill" code="jkof" type="any" description="The method of overprinting the kenten fill. Can return: auto/overprint on/overprint off or nothing."></property><property name="kenten overprint stroke" code="jkos" type="any" description="The method of overprinting the kenten stroke. Can return: auto/overprint on/overprint off or nothing."></property><property name="kenten placement" code="jkpl" type="any" description="The distance between kenten characters and their parent characters. Can return: fixed or nothing."></property><property name="kenten position" code="jkp2" type="any" description="The kenten position relative to the parent character. Can return: above right/below left or nothing."></property><property name="kenten stroke color" code="jksc" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the stroke of kenten characters. Can return: swatch, string or nothing."></property><property name="kenten stroke tint" code="jkst" type="any" description="The stroke tint (as a percentage) of kenten characters. (Range: 0 to 100). Can return: fixed or nothing."></property><property name="kenten tint" code="jktn" type="any" description="The fill tint (as a percentage) of kenten characters. (Range: 0 to 100). Can return: fixed or nothing."></property><property name="kenten weight" code="jkwt" type="any" description="The stroke weight (in points) of kenten characters. Can return: fixed or nothing."></property><property name="kenten X scale" code="jkcm" type="any" description="The horizontal size of kenten characters as a percent of the original size. Can return: fixed or nothing."></property><property name="kenten Y scale" code="jkpt" type="any" description="The vertical size of kenten charachers as a percent of the original size. . Can return: fixed or nothing."></property><property name="kerning method" code="pakm" type="any" description="The type of pair kerning. Can return: string or nothing."></property><property name="kerning value" code="pake" type="any" description="The amount of space to add or remove between characters, specified in thousands of an em. . Can return: fixed or nothing."></property><property name="keyboard direction" code="kdir" type="any" description="The keyboard direction of the character. Can return: default direction/left to right direction/right to left direction or nothing."></property><property name="kinsoku hang type" code="jkht" type="any" description="The type of hanging punctuation to allow. Note: Valid only when a kinsoku set is in effect. Can return: none/kinsoku hang regular/kinsoku hang force or nothing."></property><property name="kinsoku set" code="jkin" type="any" description="The kinsoku set that determines legitimate line breaks. Can return: kinsoku table, nothing/hard kinsoku/soft kinsoku/korean kinsoku/simplified chinese kinsoku/traditional chinese kinsoku, string or nothing."></property><property name="kinsoku type" code="jkit" type="any" description="The type of kinsoku processing for preventing kinsoku characters from beginning or ending a line. Note: Valid only when a kinsoku set is defined. Can return: kinsoku push in first/kinsoku push out first/kinsoku push out only/kinsoku prioritize adjustment amount or nothing."></property><property name="last line indent" code="inlr" type="any" description="The amount to indent the last line in the paragraph. Can return: number or string or nothing."></property><property name="leading" code="szld" type="any" description="The leading applied to the text. Can return: number or string, auto or nothing."></property><property name="leading aki" code="jmbs" type="any" description="The amount of space before each character. Can return: fixed or nothing."></property><property name="leading model" code="Jled" type="any" description="The point from which leading is measured from line to line. Can return: leading model roman/leading model aki below/leading model aki above/leading model center/leading model center down or nothing."></property><property name="left indent" code="inbl" type="any" description="The width of the left indent. Can return: number or string or nothing."></property><property name="ligatures" code="ligt" type="any" description="If true, replaces specific character combinations (e.g., fl, fi) with ligature characters. Can return: boolean or nothing."></property><property name="markup tag" code="XMLt" type="any" description="The XML tag applied to the element. Can return: string or nothing. Can also accept: XML tag."></property><property name="miter limit" code="mitr" type="any" description="The limit of the ratio of stroke width to miter length before a miter (pointed) join becomes a bevel (squared-off) join. Can return: fixed (0 - 1000) or nothing."></property><property name="mojikumi" code="jmoj" type="any" description="The mojikumi table. For information, see mojikumi table defaults. Can return: mojikumi table, string, nothing/line end all one half em enum/one em indent line end uke one half em enum/one or one half em indent line end uke one half em enum/one or one half em indent line end all one em enum/one em indent line end all one em enum/one em indent line end all no float enum/one em indent line end uke no float enum/one or one half em indent line end uke no float enum/one em indent line end all one half em enum/line end all one em enum/line end uke no float enum/one or one half em indent line end period one em enum/one em indent line end period one em enum/line end period one em enum/trad chinese default/simp chinese default or nothing."></property><property name="no break" code="nobk" type="any" description="If true, keeps the text on the same line. . Can return: boolean or nothing."></property><property name="numbering apply restart policy" code="bnar" type="any" description="If true, apply the numbering restart policy. Can return: boolean or nothing."></property><property name="numbering character style" code="bnnc" type="any" description="The character style to be used for the number string. Can return: character style, string or nothing."></property><property name="numbering continue" code="bncp" type="any" description="Continue the numbering at this level. Can return: boolean or nothing."></property><property name="numbering expression" code="bnne" type="any" description="The number string expression for numbering. Can return: string or nothing."></property><property name="numbering format" code="DHnm" type="any" description="Numbering format options. Can return: upper roman/lower roman/upper letters/lower letters/arabic/kanji/katakana modern/katakana traditional/format none/single leading zeros/arabic alif ba tah/arabic abjad/hebrew biblical/hebrew non standard/double leading zeros/triple leading zeros, string or nothing."></property><property name="numbering level" code="bnle" type="any" description="The level of the paragraph. Can return: integer or nothing."></property><property name="numbering restart policies" code="bnbr" type="any" access="r" description="Numbering restart policies. Can return: numbering restart policy or nothing."></property><property name="numbering start at" code="bnst" type="any" description="Determines starting number in a numbered list. Can return: integer or nothing."></property><property name="object reference" code="posp" type="change text preference" access="r" description="An object reference for the object."></property><property name="OTF contextual alternate" code="OTca" type="any" description="If true, uses contextual alternate forms in OpenType fonts. Can return: boolean or nothing."></property><property name="OTF discretionary ligature" code="OTdl" type="any" description="If true, uses discretionary ligatures in OpenType fonts. Can return: boolean or nothing."></property><property name="OTF figure style" code="Ofst" type="any" description="The figure style in OpenType fonts. Can return: tabular lining/proportional oldstyle/proportional lining/tabular oldstyle/default or nothing."></property><property name="OTF fraction" code="OTfr" type="any" description="If true, uses fractions in OpenType fonts. Can return: boolean or nothing."></property><property name="OTF historical" code="OThi" type="any" description="If true, use historical forms in OpenType fonts. Can return: boolean or nothing."></property><property name="OTF HV kana" code="hkna" type="any" description="If true, switches hiragana fonts, which have different glyphs for horizontal and vertical. . Can return: boolean or nothing."></property><property name="OTF justification alternate" code="OTja" type="any" description="If true, use alternate justification forms in OpenType fonts. Can return: boolean or nothing."></property><property name="OTF locale" code="OTlc" type="any" description="If true, uses localized forms in OpenType fonts. Can return: boolean or nothing."></property><property name="OTF mark" code="OTmk" type="any" description="If true, uses mark positioning in OpenType fonts. Can return: boolean or nothing."></property><property name="OTF ordinal" code="OTor" type="any" description="If true, uses ordinals in OpenType fonts. Can return: boolean or nothing."></