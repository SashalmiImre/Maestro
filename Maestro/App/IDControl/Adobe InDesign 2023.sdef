ar shapes.Note: corner option differs from end join in which you can set a radius for a corner option, whereas the rounded or beveled effect of an end join depends on the stroke weight."></property><property name="top left corner radius" code="pcr1" description="The radius in measurement units of the corner effect applied to the top left corner of rectangular shapes and all corners of non-rectangular shapes"><type type="number"></type><type type="text"></type></property><property name="top right corner option" code="pcO2" type="coPt" description="The shape to apply to the top right corner of rectangular shapes"></property><property name="top right corner radius" code="pcr2" description="The radius in measurement units of the corner effect applied to the top right corner of rectangular shapes"><type type="number"></type><type type="text"></type></property><property name="transform attribute options" code="plOp" type="transform attribute option" description="The layout attribute options to apply to any page item."></property><property name="transparency settings" code="xpSP" type="transparency setting" access="r" description="Transparency settings."></property></class><class name="object style export tag map" code="oset" description="A mapping object that maps an object export type to an export tag." plural="object style export tag maps"><element type="event"></element><element type="event listener"></element><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="export attributes" code="exta" type="text" description="The attributes to map."></property><property name="export class" code="extc" type="text" description="The class to map."></property><property name="export tag" code="extt" type="text" description="The tag to map."></property><property name="export type" code="exty" type="text" access="r" description="The type of export."></property><property name="index" code="pidx" type="integer" access="r" description="The index of the object style export tag map within its containing object."></property><property name="object reference" code="posp" type="object style export tag map" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="object style" access="r" description="The parent of the object style export tag map (a object style)."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property></class><enumeration name="stAm" code="stAm"><enumerator name="center alignment" code="stAC" description="The stroke straddles the path."></enumerator><enumerator name="inside alignment" code="stAI" description="The stroke is inside the path. "></enumerator><enumerator name="outside alignment" code="stAO" description="The stroke is outside the path, like a picture frame."></enumerator></enumeration><enumeration name="ahed" code="ahed"><enumerator name="none" code="none" description="None."></enumerator><enumerator name="simple arrow head" code="simp" description="An arrow head formed by two slanting lines whose intersection forms a 45-degree angle and whose stroke weight is the same as the path's stroke."></enumerator><enumerator name="simple wide arrow head" code="swah" description="An arrow head formed by two slanting lines whose intersection forms a 90-degree angle and whose stroke weight is the same as the path's stroke."></enumerator><enumerator name="triangle arrow head" code="trin" description="A solid triangle arrow head whose point describes a 45-degree angle."></enumerator><enumerator name="triangle wide arrow head" code="twah" description="A solid triangle arrow head whose point describes a 90-degree angle."></enumerator><enumerator name="barbed arrow head" code="barb" description="A solid arrow head whose pierced end bows sharply toward the point and whose point describes a 45-degree angle."></enumerator><enumerator name="curved arrow head" code="cvah" description="A solid arrow head whose pierced end concaves toward the point and whose point describes a 45-degree angle."></enumerator><enumerator name="circle arrow head" code="crah" description="A hollow circle whose outline is the same weight as the stroke. The circle's diameter is 5 times the stroke width."></enumerator><enumerator name="circle solid arrow head" code="csah" description="A solid circle whose diameter is 5 times the stroke width."></enumerator><enumerator name="square arrow head" code="sqah" description="A hollow square set perpendicular to the path, whose outline is the same weight as the stroke. The length of one side of the square is 5 times the stroke width."></enumerator><enumerator name="square solid arrow head" code="ssah" description="A solid square set perpendicular to the end of the path. The length of one side of the square is 5 times the stroke width."></enumerator><enumerator name="bar arrow head" code="brah" description="A vertical bar bisected by the stroke, which meets the stroke at a right angle and is the same weight as the stroke. The bar's length is 4.5 times the stroke width."></enumerator></enumeration><enumeration name="ejon" code="ejon"><enumerator name="miter end join" code="mjon" description="Miter end join."></enumerator><enumerator name="round end join" code="rjon" description="Rounded end join."></enumerator><enumerator name="bevel end join" code="bjon" description="Beveled end join."></enumerator></enumeration><enumeration name="ecap" code="ecap"><enumerator name="butt end cap" code="bcap" description="A squared end that stops at the path's endpoint."></enumerator><enumerator name="round end cap" code="rcap" description="A semicircular end that extends beyond the endpoint by half the stroke-width."></enumerator><enumerator name="projecting end cap" code="pjcp" description="A squared end that extends beyond the endpoint by half the stroke-width."></enumerator></enumeration><enumeration name="coPt" code="coPt"><enumerator name="none" code="none" description="No corner option."></enumerator><enumerator name="rounded corner" code="cerd" description="Rounded corner option."></enumerator><enumerator name="inverse rounded corner" code="cenv" description="Inverted rounded corner option."></enumerator><enumerator name="inset corner" code="cens" description="Inset corner option."></enumerator><enumerator name="bevel corner" code="cebv" description="Beveled corner option."></enumerator><enumerator name="fancy corner" code="cefn" description="Fancy corner option."></enumerator></enumeration><enumeration name="eaha" code="eaha"><enumerator name="inside path" code="ahai" description="The arrowhead is inside the path, path geometry changes to accomodate arrow heads."></enumerator><enumerator name="outside path" code="ahao" description="The arrowhead is outside the path i.e. path geometry remains same."></enumerator></enumeration><enumeration name="ePaB" code="ePaB"><enumerator name="x attribute" code="eXAo" description="X attribute of position."></enumerator><enumerator name="y attribute" code="eYAo" description="Y attribute of position."></enumerator><enumerator name="both x y attribute" code="eBxY" description="Both X and Y of position."></enumerator></enumeration><enumeration name="dMAb" code="dMAb"><enumerator name="width attribute" code="eWdO" description="Width attribute of dimension."></enumerator><enumerator name="height attribute" code="eHtO" description="Height attribute of dimension."></enumerator><enumerator name="both height width attribute" code="eWhb" description="Both height and width of dimension."></enumerator></enumeration></suite><suite name="PDF comment suite" code="IMCs" description="Scripting support for importing comments from PDF"><command name="add event listener" code="IMCseAEL" description="Adds an event listener."><direct-parameter type="specifier" description="Supported by the following objects: PDF comment, 