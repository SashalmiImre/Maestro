ption="The name of the book content."></property><property name="object reference" code="posp" type="book content" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="book" access="r" description="The parent of the book content (a book)."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="size" code="dsiz" type="integer" access="r" description="The size of the book content file."></property><property name="status" code="stts" type="BoCS" access="r" description="The status of the book content object file."></property></class><enumeration name="BoCS" code="BoCS"><enumerator name="normal" code="norm" description="The book content object is not open and is unchanged."></enumerator><enumerator name="missing document" code="DocM" description="The book content object is missing because it has been moved, renamed, or deleted."></enumerator><enumerator name="document out of date" code="DocD" description="The book content object has been modified after repagination."></enumerator><enumerator name="document in use" code="DocI" description="The book content object is being used by someone else and is therefore locked."></enumerator><enumerator name="document is open" code="DocO" description="The book content object is open."></enumerator></enumeration><enumeration name="smse" code="smse"><enumerator name="match style path" code="smfp" description="Match the full path of style while finding styles in target."></enumerator><enumerator name="match style name" code="smsn" description="Match only the style name while finding styles in target."></enumerator></enumeration><enumeration name="Brpo" code="Brpo"><enumerator name="next page" code="pbrk" description="Continues page numbers sequentially from the previous book content object."></enumerator><enumerator name="next odd page" code="Opbk" descrip