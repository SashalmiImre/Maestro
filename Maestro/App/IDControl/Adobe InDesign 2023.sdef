 statement. "></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="current visibility" code="crvi" type="boolean" description="If true, the layer is visible in the document."></property><property name="export state" code="esta" type="boolean" access="r" description="If true, the export state is on."></property><property name="FX layer" code="fxlr" type="boolean" access="r" description="If true, layer effects have been applied to the layer. Note: Must occur in the script before overriding the visibility state of the layer with a current visibility statement."></property><property name="has export state" code="hest" type="boolean" access="r" description="If true, the layer has an export state."></property><property name="has print state" code="hpri" type="boolean" access="r" description="If true, the layer has a print state."></property><property name="has view state" code="hvws" type="boolean" access="r" description="If true, the layer has a view state."></property><property name="id" code="ID  " type="integer" access="r" description="The unique ID of the graphic layer."></property><property name="index" code="pidx" type="integer" access="r" description="The index of the graphic layer within its containing object."></property><property name="locked" code="plck" type="boolean" access="r" description="If true, the graphic layer is locked."></property><property name="name" code="pnam" type="text" access="r" description="The name of the graphic layer."></property><property name="object reference" code="posp" type="graphic layer" access="r" description="An object reference for the object."></property><property name="original visibility" code="orvi" type="boolean" access="r" description="Returns the visibility setting set for the layer before the graphic file was imported. Note: Must occur in the script before overriding the visibility state with a current visibility statement.  "></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the graphic layer (a graphic layer option or graphic layer). Can return: graphic layer option or graphic layer."></property><property name="print state" code="pris" type="boolean" access="r" description="If true, the print state is on."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="section divider layer" code="secd" type="boolean" access="r" description="If true, the layer is a section divider layer."></property><property name="separator layer" code="sepl" type="boolean" access="r" description="If true, the layer is a separator layer."></property><property name="view state" code="vwst" type="boolean" access="r" description="If true, the view state is on."></property></class><class name="graphic layer option" code="glop" description="Graphic layer option."><element type="event"></element><element type="event listener"></element><element type="graphic layer"></element><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="object reference" code="posp" type="graphic layer option" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the graphic layer option (a image, PDF or imported page). Can return: image, PDF or imported page."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="update link option" code="gulo" type="uplo" description="Options for updating a graphic link after the visibility settings for the graphic layer have been modified in a different application."></property></class><class name="grid data information" code="Jgda" description="