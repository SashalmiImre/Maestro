sde" type="real" description="The desired width (as a percentage) of individual characters. (Range: 50 to 200)"></property><property name="desired letter spacing" code="lsde" type="real" description="The desired letter spacing, specified as a percentge of the built-in space between letters in the font. (Range: -100 to 500)"></property><property name="desired word spacing" code="wsde" type="real" description="The desired word spacing, specified as a percentage of the font word space value. (Range: 0 to 1000)"></property><property name="diacritic position" code="diap" type="dipt" description="Position of diacriticical characters."></property><property name="digits type" code="digi" type="dity" description="The digits type."></property><property name="drop cap characters" code="dcca" type="integer" description="The number of characters to drop cap. Can return: small integer (0 - 150)."></property><property name="drop cap lines" code="dcli" type="integer" description="The number of lines to drop cap. Can return: small integer (0 - 25)."></property><property name="drop cap style" code="dcst" type="character style" description="The character style to apply to the drop cap. Can also accept: string."></property><property name="dropcap detail" code="dcdm" type="integer" description="Details about the drop cap based on the glyph outlines. 1 = left side bearing. 2 = descenders. 0x100,0x200,0x400 are used for Japanese frame grid."></property><property name="end join" code="endj" type="ojon" description="The stroke join type applied to the characters of the text."></property><property name="fill color" code="flcl" type="swatch" description="The swatch (color, gradient, tint, or mixed ink) applied to the fill of the xml story. . Can also accept: string."></property><property name="fill tint" code="filt" type="real" description="The tint (as a percentage) of the fill color of the xml story. (To specify a tint percentage, use a number in the range of 0 to 100; to use the inherited or overridden value, use -1.)"></property><property name="first line indent" code="infl" description="The amount to indent the first line."><type type="number"></type><type type="text"></type></property><property name="font style" code="ptfs" type="text" description="The name of the font style."></property><property name="glyph form" code="jgfm" type="Jglf" description="The glyph variant to substitute for standard glyphs."></property><property name="gradient fill angle" code="pgfa" type="real" description="The angle of a linear gradient applied to the fill of the text. (Range: -180 to 180)"></property><property name="gradient fill length" code="pgfl" type="real" description="The length (for a linear gradient) or radius (for a radial gradient) applied to the fill of the text."></property><property name="gradient fill start" code="pgst" description="The starting point (in page coordinates) of a gradient applied to the fill of the text, in the format [x, y]."><type type="number" list="yes"></type><type type="text" list="yes"></type></property><property name="gradient stroke angle" code="pgsa" type="real" description="The angle of a linear gradient applied to the stroke of the text. (Range: -180 to 180)"></property><property name="gradient stroke length" code="pgsl" type="real" description="The length (for a linear gradient) or radius (for a radial gradient) applied to the stroke of the text."></property><property name="gradient stroke start" code="pgss" description="The starting point (in page coordinates) of a gradient applied to the stroke of the text, in the format [x, y]."><type type="number" list="yes"></type><type type="text" list="yes"></type></property><property name="grid align first line only" code="jga1" type="boolean" description="If true, aligns only the first line to the frame grid or baseline grid. If false, aligns all lines to the grid."></property><property name="grid alignment" code="jgal" type="Jaga" description="The alignment to the frame grid or baseline grid."></property><property name="grid data" code="Jgrd" type="grid data information" access="r" description="Default grid properties. Note: Applies to named, layout, and frame (story) grids."></property><property name="grid gyoudori" code="jggy" type="integer" description="The manual gyoudori setting."></property><property name="horizontal scale" code="phzs" type="real" description="The horizontal scaling applied to the xml story."></property><property name="hyphen weight" code="hypw" type="integer" description="The relative desirability of better spacing vs. fewer hyphens. A lower value results in greater use of hyphens. (Range: 0 to 100). Can return: small integer (0 - 10)."></property><property name="hyphenate across columns" code="hycf" type="boolean" description="If true, allows the last word in a text column to be hyphenated."></property><property name="hyphenate after first" code="mibe" type="integer" description="The mininum number of letters at the beginning of a word that can be broken by a hyphen. Can return: small integer (1 - 15)."></property><property name="hyphenate before last" code="miaf" type="integer" description="The minimum number of letters at the end of a word that can be broken by a hyphen. Can return: small integer (1 - 15)."></property><property name="hyphenate capitalized words" code="hypc" type="boolean" description="If true, allows hyphenation of capitalized words."></property><property name="hyphenate ladder limit" code="hypl" type="integer" description="The maximum number of hyphens that can appear on consecutive lines. To specify unlimited consecutive lines, use zero. Can return: small integer (0 - 25)."></property><property name="hyphenate last word" code="hylw" type="boolean" description="If true, allows hyphenation in the last word in a paragraph. Note: Valid only when hyphenation is true."></property><property name="hyphenate words longer than" code="swor" type="integer" description="The minimum number of letters a word must have in order to qualify for hyphenation. Can return: small integer (3 - 25)."></property><property name="hyphenation" code="hyph" type="boolean" description="If true, allows hyphenation."></property><property name="hyphenation zone" code="hyzo" description="The amount of white space allowed at the end of a line of non-justified text before hypenation begins. Note: Valid when composer is single-line composer."><type type="number"></type><type type="text"></type></property><property name="id" code="ID  " type="integer" access="r" description="The unique ID of the xml story."></property><property name="ignore edge alignment" code="igEA" type="boolean" description="If true, ignores optical edge alignment for the paragraph."></property><property name="InCopy export options" code="ipEo" type="InCopy export option" access="r" description="Export options for InCopy INCX document format."></property><property name="index" code="pidx" type="integer" access="r" description="The index of the xml story within its containing object."></property><property name="is endnote story" code="iens" type="boolean" access="r" description="returns true if it's an endnote story otherwise returns false."></property><property name="item link" code="plnk" type="link" access="r" description="The source file of the link."></property><property name="jidori" code="jjid" type="integer" description="The number of grid squares in which to arrange the text. "></property><property name="justification" code="paln" type="kjst" description="The paragraph alignment."></property><property name="kashidas" code="kash" type="katy" description="Use of Kashidas for justification"></property><property name="keep all lines together" code="kept" type="boolean" description="If true, keeps all lines of the paragraph together. If false, allows paragraphs to break across pages or columns."></property><property name="keep first lines" code="kfnl" type="integer" description="The minimum number of lines to keep together in a paragraph before allowing a page break. Can return: small integer (1 - 50)."></property><property name="keep last lines" code="klnl" type="integer" description="The minimum number of lines to keep together in a paragraph after a page break. Can return: small integer (1 - 50)."></property><property name="keep lines together" code="kepl" type="boolean" description="If true, keeps a specified number of lines together when the paragraph breaks across columns or text frames."></property><property name="keep rule above in frame" code="prak" type="boolean" description="If true, forces the rule above the paragraph to remain in the frame bounds. Note: Valid only when rule above is true."></property><property name="keep with next" code="kwnx" type="integer" description="The minimum number of lines to keep with the next paragraph. Can return: small integer (0 - 5)."></property><property name="keep with previous" code="kwpv" type="boolean" description="If the first line in the paragraph should be kept with the last line of previous paragraph."></property><property name="kenten alignment" code="jkal" type="Jekl" description="The alignment of kenten characters relative to the parent characters. "></property><property name="kenten character set" code="jset" type="Jest" description="The character set used for the custom kenten character. Note: Valid only when kenten kind is custom. "></property><property name="kenten custom character" code="jkcc" type="text" description="The character used for kenten. Note: Valid only when kenten kind is custom."></property><property name="kenten fill color" code="jkfc" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the fill of kenten characters. Can return: swatch or string."></property><property name="kenten font" code="jkfn" type="any" description="The font to use for kenten characters. Can return: font or string."></property><property name="kenten font size" code="jkfz" type="real" description="The size (in points) of kenten characters."></property><property name="kenten font style" code="jkfs" type="any" description="The font style of kenten characters. Can return: string or nothing."></property><property name="kenten kind" code="jktp" type="Jkch" description="The style of kenten characters."></property><property name="kenten overprint fill" code="jkof" type="Jafl" description="The method of overprinting the kenten fill."></property><property name="kenten overprint stroke" code="jkos" type="Jafl" description="The method of overprinting the kenten stroke."></property><property name="kenten placement" code="jkpl" type="real" description="The distance between kenten characters and their parent characters."></property><property name="kenten position" code="jkp2" type="Jkps" description="The kenten position relative to the parent character."></property><property name="kenten stroke color" code="jksc" type="any" description="The swatch (color, gradient, tint, or mixed ink) applied to the stroke of kenten characters. Can return: swatch or string."></property><property name="kenten stroke tint" code="jkst" type="real" description="The stroke tint (as a percentage) of kenten characters. (Range: 0 to 100)"></property><property name="kenten tint" code="jktn" type="real" description="The fill tint (as a percentage) of kenten characters. (Range: 0 to 100)"></property><property name="kenten weight" code="jkwt" type="real" description="The stroke weight (in points) of kenten characters."></property><property name="kenten X scale" code="jkcm" type="real" description="The horizontal size of kenten characters as a percent of the original size."></property><property name="kenten Y scale" code="jkpt" type="real" description="The vertical size of kenten charachers as a percent of the original size. "></property><property name="kerning method" code="pakm" type="text" description="The type of pair kerning."></property><property name="keyboard direction" code="kdir" type="chdi" description="The keyboard direction of the character."></property><property name="kinsoku hang type" code="jkht" type="Jkht" description="The type of hanging punctuation to allow. Note: Valid only when a kinsoku set is in effect."></property><property name="kinsoku set" code="jkin" type="any" description="The kinsoku set that determines legitimate line breaks. Can return: kinsoku table, nothing/hard kinsoku/soft kinsoku/korean kinsoku/simplified chinese kinsoku/traditional chinese kinsoku or string."></property><property name="kinsoku type" code="jkit" type="Jknt" description="The type of kinsoku processing for preventing kinsoku characters from beginning or ending a line. Note: Valid only when a kinsoku set is defined."></property><property name="label" code="ptag" type="text" description="A property that can be set to any string."></property><property name="last line indent" code="inlr" description="The amount to indent the last line in the paragraph."><type type="number"></type><type type="text"></type></property><property name="leading" code="szld" type="any" description="The leading applied to the text. Can return: number or string or auto."></property><property name="leading aki" code="jmbs" type="real" description="The amount of space before each character."></property><property name="leading model" code="Jled" type="JLed" description="The point from which leading is measured from line to line."></property><property name="left indent" code="inbl" description="The width of the left indent."><type type="number"></type><type type="text"></type></property><property name="length" code="leng" type="integer" access="r" description="The number of objects in the collection."></property><property name="ligatures" code="ligt" type="boolean" description="If true, replaces specific character combinations (e.g., fl, fi) with ligature characters."></property><property name="linked story options" code="lspp" type="linked story option" access="r" description="Linked story options"><