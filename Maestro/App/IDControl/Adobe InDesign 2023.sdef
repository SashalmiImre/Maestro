roke type of the underline stroke. Can return: stroke style or string."></property><property name="underline weight" code="ulwt" description="The stroke weight of the underline stroke."><type type="number"></type><type type="text"></type></property><property name="vertical scale" code="pvts" type="real" description="The vertical scaling applied to the text default."></property><property name="warichu" code="jwar" type="boolean" description="If true, turns on warichu."></property><property name="warichu alignment" code="jwal" type="Jwca" description="The warichu alignment."></property><property name="warichu chars after break" code="jmab" type="integer" description="The minimum number of characters allowed after a line break. "></property><property name="warichu chars before break" code="jmbb" type="integer" description="The minimum number of characters allowed before a line break."></property><property name="warichu line spacing" code="jwls" type="real" description="The gap between lines of warichu characters."></property><property name="warichu lines" code="jwli" type="integer" description="The number of lines of warichu within a single normal line."></property><property name="warichu size" code="jwas" type="real" description="The amount (as a percentage) to scale parent text size to determine warichu size."></property><property name="x offset diacritic" code="diax" type="real" description="The x (horizontal) offset for diacritic adjustment."></property><property name="y offset diacritic" code="diay" type="real" description="The y (vertical) offset for diacritic adjustment."></property></class><class name="text editing preference" code="txep" description="Text editing preferences."><element type="event"></element><element type="event listener"></element><property name="allow drag and drop text in story" code="dnds" type="boolean" description="If true, allows text to be dragged and dropped in the story editor or galley view."></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="drag and drop text in layout" code="dndl" type="boolean" description="If true, allows text to be dragged and dropped on a layout page."></property><property name="object reference" code="posp" type="text editing preference" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the text editing preference (a application)."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="single click converts frames to text frames" code="tClk" type="boolean" description="If true, a single click (with the Type tool) converts non-text frames to text frames."></property><property name="smart cut and paste" code="smrt" type="boolean" description="If true, automatically adjusts spacing among words and between words and punctuation marks when cutting and pasting text."></property><property name="triple click selects line" code="tclk" type="boolean" description="If true, a triple click selects a line of text. If false, a triple click selects a paragraph."></property></class><class name="text export preference" code="TXEI" description="Text export preferences."><element type="event"></element><element type="event listener"></element><property name="character set" code="Tchs" type="ecse" description="The character set."></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="object reference" code="posp" type="text export preference" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the text export preference (a application)."></property><property name="platform" code="Tplf" type="apfe" description="The platform on which the text file will be used."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property></class><class name="text frame preference" code="TFPf" description="Text frame preferences."><element type="event"></element><element type="event listener"></element><property name="auto sizing reference point" code="asrp" type="eASR" description="The reference point for auto sizing of text frame. Reference point is automatically adjusted to the suitable value depending on the auto-sizing type value. As an example, top left reference point becomes top center for height only dimension"></property><property name="auto sizing type" code="asdi" type="eASD" description="Auto-sizing type of text frame. Based on type, reference value is automatically adjusted. For example, for height only type, top-left reference point becomes top-center. Recommended to change auto-sizing type, after setting other auto-sizing attributes"></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="column rule bottom inset" code="VRBi" type="real" description="Text Frame Column Rule Bottom Inset. Can return: fixed (-10000 - 10000)."></property><property name="column rule inset chain override" code="VRIc" type="boolean" description="If true, enable inset chain override."></property><property name="column rule offset" code="VROf" type="real" description="Text Frame Column Rule Offset. Can return: fixed (-10000 - 10000)."></property><property name="column rule overprint override" code="VROo" type="boolean" description="If true, enable overprint override."></property><property name="column rule override" code="VREo" type="boolean" description="If true, enable overrides to text frame vertical column rule options."></property><property name="column rule stroke color" code="VRSc" type="swatch" description="Text Frame Column Rule Stroke Color"></property><property name="column rule stroke tint" code="VRSt" type="real" description="Text Frame Column Rule Stroke Tint. Can return: fixed (0 - 100)."></property><property name="column rule stroke type" code="VRTy" type="stroke style" description="Text Frame Column Rule Stroke Type"></property><property name="column rule stroke width" code="VRWi" type="real" description="Text Frame Column Rule Width. Can return: fixed (0 - 10000)."></property><property name="column rule top inset" code="VRTi" type="real" description="Text Frame Column Rule top inset. Can return: fixed (-10000 - 10000)."></property><property name="first baseline offset" code="Fbof" type="eFBO" description="The distance between the baseline of the text and the top inset of the text frame or cell."></property><property name="footnotes enable overrides" code="TFEO" type="boolean" description="If true, enable overrides to document footnote options."></property><property name="footnotes minimum spacing" code="TFMS" description="Minimum Spacing Before First Footnote. Can return: number or string (0 - 8640 points)."><type type="number"></type><type type="text"></type></property><property name="footnotes space between" code="TFSB" description="Space between footnotes. Can return: number or string (0 - 8640 points)."><type type="number"></type><type type="text"></type></property><property name="footnotes span across columns" code="TFSF" type="boolean" description="If true, enable straddling footnotes."></property><property name="ignore wrap" code="iwrp" type="boolean" description="If true, ignores text wrap settings for drawn or placed objects in the text frame. "></property><property name="inset spacing" code="inst" type="any" description="The amount to offset text from the edges of the text frame, specified either as a single value applied uniformly to all sides of the text frame or as an array of 4 values in the format [top inset, left inset, bottom inset, right inset]. Can return: number or string (0 - 8640 points) or list of 4 numbers or strings (0 - 8640 points)."></property><property name="minimum first baseline offset" code="Fboa" description="The minimum distance between the baseline of the text and the top inset of the text frame or cell. Can return: number or string (0 - 8640 points)."><type type="number"></type><type type="text"></type></property><property name="minimum height for auto sizing" code="asmh" description="The minimum height for auto-sizing of the text frame."><type type="number"></type><type type="text"></type></property><property name="minimum width for auto sizing" code="asmw" description="The minimum width for auto-sizing of the text frame."><type type="number"></type><type type="text"></type></property><property name="object reference" code="posp" type="text frame preference" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the text frame preference (a object style, application, document, text frame or endnote text frame). Can return: object style, application, document, text frame or endnote text frame."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="text column count" code="ccnt" type="integer" description="The number of columns in the text frame. Note: Depending on the value of use fixed column width, the number of columns can change automatically when the text frame size changes. Can return: integer (1 - 40)."></property><property name="text column fixed width" code="clwd" description="The column width of the columns in the text frame. Can return: number or string (0 - 8640 points)."><type type="number"></type><type type="text"></type></property><property name="text column gutter" code="clgt" description="The space between columns in the text frame. Can return: number or string (0 - 8640 points)."><type type="number"></type><type type="text"></type></property><property name="text column max width" code="tcmx" description="The maximum column width of the columns in the text frame. Use 0 to indicate no upper limit. Can return: number or string (0 - 8640 points)."><type type="number"></type><type type="text"></type></property><property name="use fixed column width" code="ufcw" type="boolean" description="If true, maintains column width when the text frame is resized. If false, causes columns to resize when the text frame is resized. Note: When true, resizing the frame can change the number of columns in the frame."></property><property name="use flexible column width" code="urcw" type="boolean" description="If true, maintains column width between a min and max range when the text frame is resized. If false, causes columns to resize when the text frame is resized. Note: When true, resizing the frame can change the number of columns in the frame."></property><property name="use minimum height for auto sizing" code="ashm" type="boolean" description="If true, minimum height value is used during the auto-sizing of text frame. "></property><property name="use minimum width for auto sizing" code="ashw" type="boolean" description="If true, minimum width value is used during the auto-sizing of text frame. "></property><property name="use no line breaks for auto sizing" code="asnl" type="boolean" description="If true, line-breaks are not introduced after auto sizing. "></property><property name="vertical balance columns" code="VJbl" type="boolean" description="Vertically justify balanced across all columns."></property><property name="vertical justification" code="VJal" type="eVJA" description="The vertical alignment of the text content. "></property><property name="vertical threshold" code="VJmi" description="The maximum amount of vertical space between two paragraphs. Note: Valid only when vertical justification is justified; the specified amount is applied in addition to the space before or space after values defined for the paragraph. Can return: number or string (0 - 8640 points)."><type type="number"></type><type type="text"></type></property></class><class name="text import preference" code="TXTI" description="Text import preferences."><element type="event"></element><element type="event listener"></element><property name="character set" code="Tchs" type="acse" description="The computer language character set used to create the text file."></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="convert spaces into tabs" code="Ts2t" type="boolean" description="If true, converts the specified number of spaces into a tab. For information on specifying the number of spaces, see spaces into tabs count."></property><property name="dictionary" code="Tdic" type="text" description="The dictionary to use for the imported text."></property><property name="object reference" code="posp" type="text import preference" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the text import preference (a application)."></property><property name="platform" code="Tplf" type="apfe" description="The platform used to create the imported text file."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="spaces into tabs count" code="Tmsp" type="integer" description="The number of spaces to convert to a tab. Note: Valid when convert spaces into tabs is true."></property><property name="strip returns between lines" code="TCRl" type="boolean" description="If true, the import filter removes extra carriage returns at the ends of lines."></property><property name="strip returns between paragraphs" code="TCRp" type="boolean" description="If true, the import filter removes extra carriage returns between paragraphs."></property><property name="use typographers quotes" code="TTtq" type="boolean" description="If true, convert straight quotes and apostrophes in the imported text to typographic quotation marks and apostrophes."></property></class><class name="text preference" code="txtp" description="Text preferences."><element type="event"></element><element type="event listener"></element><property name="abut text to text wrap" code="awrp" type="boolean" description="If true, moves wrapped text to the next available leading increment below the text wrap objects (skip by leading)."></property><property name="add pages" code="apin" type="Enpi" description="Specifies where to insert new pages in response to overset text."></property><property name="baseline shift key increment" code="bkbd" description="The amount that the baseline shift increases each time the user presses the option/alt-shift-up arrow keys or decreases each time the user presses the option/alt-shift-down arrow keys. (Range: .001 to 100). Can return: number or string (0.001 - 200 points)."><type type="number"></type><type type="text"></type></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="delete empty pages" code="ddel" type="boolean" description="Enable auto-deletion of pages containing empty threaded text frames."></property><property name="enable style preview mode" code="sspm" type="boolean" description="If true, highlights character and paragraph styles with colored backgrounds."></property><property name="highlight custom spacing" code="shcs" type="boolean" description="If true, highlights custom kerned or tracked characters."></property><property name="highlight hj violations" code="shhj" type="boolean" description="If true, highlights hyphenation and justification rule violations in the text."></property><property name="highlight keeps" code="shkp" type="boolean" description="If true, highlights paragraphs that violate keep options."></property><property name="highlight kinsoku" code="shkk" type="boolean" description="If true, uses on-screen highlighting to identify kinsoku."></property><property name="highlight substituted fonts" code="hlmf" type="boolean" description="If true, highlights missing fonts."></property><property name="highlight substituted glyphs" code="shsb" type="boolean" description="If true, highlights substituted glyphs."></property><property name="Honour Text Indents with Text Wrap" code="mitw" type="boolean" description="If true, modifies indentation for Bulleted Paragraph and Bullets around a Text Wrap object."></property><property name="justify text wraps" code="jwrp" type="boolean" description="If true, justifies text around text wrap objects."></property><property name="kerning key increment" code="kkbd" type="real" description="The amount the kerning value per 1000 ems increases each time the user presses of the option/alt-right arrow keys or decreases each time the user presses the option/alt-left arrow keys. (Range: 1 to 100). Can return: fixed (1 - 100)."></property><property name="leading key increment" code="lkbd" description="The amount that leading increases each time the user presses the option/alt-up arrow keys or decreases each time the user presses the option/alt-down arrow keys. (Range: .001 to 100). Can return: number or string (0.001 - 200 points)."><type type="number"></type><type type="text"></type></property><property name="limit to master text frames" code="aprm" type="boolean" description="Restrict the adding of pages during smart text reflow to overridden master text frames."></property><property name="link text files when importing" code="gplt" type="boolean" description="If true, links placed text files and spreadsheet files. If false, embeds the files. "></property><property name="object reference" code="posp" type="text preference" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the text preference (a application or document). Can return: application or document."></property><property name="preserve facing page spreads" code="afrv" type="boolean" description="Preserve left-hand and right-and pages when facing pages are enabled during smart text reflow."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="quote characters rotated in vertical" code="Jquo" type="boolean" description="If true, Japanese composer treats quotes as half width and rotates them in vertical."></property><property name="shape indic and latin with harbuzz" code="silh" type="boolean" description="If this bool is set to true, shaping of Indic &amp; Latin characters will be done through Harfbuzz Shaping engine, instead of Lipika."></property><property name="show invisibles" code="sinv" type="boolean" description="If true, shows hidden characters."></property><property name="small cap" code="Smcp" type="real" description="The size of text formatted as small caps, specified as a percentage of the font size. (Range: 1 to 200). Can return: fixed (1 - 200)."></property><property name="smart text reflow" code="dflw" type="boolean" description="If true, enable automatic adding and deleting of pages in response to text reflow."></property><property name="smart text reflow sync" code="essf" type="boolean" description="If this is True, and if Smart text reflow is also enabled, then this will synchronously add/delete pages after text reflowing "></property><property name="subscript position" code="subp" type="real" description="The position of subscript characters, specified as a percentage of the regular leading. (Range: -500 to 500). Can return: fixed (-500 - 500)."></property><property name="subscript size" code="subs" type="real" description="The size of subscript characters, specified as a percentage of the font size. (Range: 0 to 200). Can return: fixed (1 - 200)."></property><property name="superscript position" code="supp" type="real" description="The position of superscript characters, specified as a percentage of the regular leading. (Range: -500 to 500). Can return: fixed (-500 - 500)."></property><property name="superscript size" code="sups" type="real" description="The size of superscript characters, specified as a percentage of the font size. (Range: 0 to 200). Can return: fixed (1 - 200)."></property><property name="typographers quotes" code="typq" type="boolean" description="If true, converts straight quotes to typographic quotes."></property><property name="use cid mojikumi" code="Jcid" type="boolean" description="If true, uses the glyph CID to get the mojikumi class of the character. "></property><property name="use new vertical scaling" code="Jnvs" type="boolean" description="If true, reverses X and Y scaling on Roman characters in vertical text."></property><property name="use optical size" code="mmos" type="boolean" description="If true, automatically selects the correct optical size."></property><property name="use paragraph leading" code="pled" type="boolean" description="If true, applies the leading changes made to a text range to the entire paragraph. If false, applies leading changes only to the text range."></property><property name="z order text wrap" code="zwrp" type="boolean" description="If true, text wrap does not affect text on layers above the layer that contains the text wrap object. If false, text wrap affects text on all visible layers."></property></class><class name="tool box" code="ctbx" description="Tool box tools"><element type="event"></element><element type="event listener"></element><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><prop