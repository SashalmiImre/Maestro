t, use a number in the range of 0 to 100; to use the inherited or overridden value, use -1.)"></property><property name="geometric bounds" code="gbnd" description="The bounds of the WMF excluding the stroke width, in the format [y1, x1, y2, x2], which give the coordinates of the top-left and bottom-right corners of the bounding box."><type type="number"></type><type type="text"></type></property><property name="gradient fill angle" code="pgfa" type="real" description="The angle of a linear gradient applied to the fill of the WMF. (Range: -180 to 180)"></property><property name="gradient fill length" code="pgfl" description="The length (for a linear gradient) or radius (for a radial gradient) applied to the fill of the WMF."><type type="number"></type><type type="text"></type></property><property name="gradient fill start" code="pgst" description="The starting point (in page coordinates) of a gradient applied to the fill of the WMF, in the format [x, y]."><type type="number" list="yes"></type><type type="text" list="yes"></type></property><property name="gradient stroke angle" code="pgsa" type="real" description="The angle of a linear gradient applied to the stroke of the WMF. (Range: -180 to 180)"></property><property name="gradient stroke length" code="pgsl" description="The length (for a linear gradient) or radius (for a radial gradient) applied to the stroke of the WMF."><type type="number"></type><type type="text"></type></property><property name="gradient stroke start" code="pgss" description="The starting point (in page coordinates) of a gradient applied to the stroke of the WMF, in the format [x, y]."><type type="number" list="yes"></type><type type="text" list="yes"></type></property><property name="horizontal layout constraints" code="HoCo" description="The left margin, width, and right margin constraints this item is subject to when using the object-based layout rule."><type type="LPdc" list="yes"></type></property><property name="horizontal scale" code="p