><property name="line end all one em" code="jm10" type="boolean" description="If true, uses full-width spacing for all characters. "></property><property name="line end all one half em" code="jm01" type="boolean" description="If true, uses half-width spacing for all characters. "></property><property name="line end period one em" code="jm14" type="boolean" description="If true, uses full-width spacing for punctuation and for the last character in the line. "></property><property name="line end uke no float" code="jm11" type="boolean" description="If true, uses line end uke no float."></property><property name="object reference" code="posp" type="mojikumi ui preference" access="r" description="An object reference for the object."></property><property name="one em indent line end all no float" code="jm06" type="boolean" description="If true, indents lines one full space and uses no float for all characters."></property><property name="one em indent line end all one em" code="jm05" type="boolean" description="If true, indents lines one full space and uses full-width spacing for all characters."></property><property name="one em indent line end all one half em" code="jm09" type="boolean" description="If true, indents lines one full space and uses half-width spacing for all characters."></property><property name="one em indent line end period one em" code="jm13" type="boolean" description="If true, indents lines one space and uses full-width spacing for punctuation and for the last character in the line. "></property><property name="one em indent line end uke no float" code="jm07" type="boolean" description="If true, indents lines one full space and uses line end uke no float."></property><property name="one em indent line end uke one half em" code="jm02" type="boolean" description="If true, indents lines one space and uses line end uke one half space."></property><property name="one or one half em indent line end all one em" code="jm04" type="boolean" description="If true, Uses full-witdh spacing for all characters except the last character in the line, which uses either full- or half-width spacing. "></property><property name="one or one half em indent line end period one em" code="jm12" type="boolean" description="If true, indents lines one or one-half space and uses full-width spacing for punctuation and for the last character in the line. "></property><property name="one or one half em indent line end uke no float" code="jm08" type="boolean" description="If true, indents lines one half space or one full space and uses line end uke no float."></property><property name="one or one half em indent line end uke one half em" code="jm03" type="boolean" description="If true, indents lines one full or half space and uses line end uke one half space."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the mojikumi ui preference (a document or application). Can return: document or application."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property></class><class name="note preference" code="Ntep" description="Note preferences."><element type="event"></element><element type="event listener"></element><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="find and replace note contents" code="FRNt" type="boolean" description="If true, includes inline notes content when using Find/Change commands (in Galley and Story views only)."></property><property name="note background color" code="NBGC" type="eNBG" description="The background color for notes."></property><property name="note color" code="ntCl" type="any" description="The note color, specified either as an array of three doubles, each in the range 0 to 255 and representing R, G, and B values, or as an InCopy UI color. Can return: list of 3 fixed (0 - 255) or can