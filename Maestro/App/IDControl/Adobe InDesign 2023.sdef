ich grayscale compression is applied. (Range: 1 to 10 times the value specified for grayscale bitmap sampling DPI.)"></property><property name="threshold to compress monochrome" code="CmMA" type="integer" description="The minimum dpi at which monochrome compression is applied. (Range: 1 to 10 times the value specified for monochrome bitmap sampling DPI.)"></property><property name="use document bleed with PDF" code="UDoB" type="boolean" description="If true, uses the document's bleed settings in the PDF document."></property></class><class name="PDF place preference" code="PDFi" description="PDF place preferences."><element type="event"></element><element type="event listener"></element><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="object reference" code="posp" type="PDF place preference" access="r" description="An object reference for the object."></property><property name="open document password" code="DFop" type="text" description="The password to enter when opening the PDF document. Valid only when use security is true. Note: A script can set but not get this value."></property><property name="page number" code="Pgnb" type="integer" description="The page number of the PDF document page to place."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the PDF place preference (a application)."></property><property name="PDF crop" code="DFcr" type="nFcp" description="The type of cropping to apply."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="transparent background" code="TBkg" type="boolean" description="If true, the background of the PDF is transparent."></property></class><class name="PNG export preference" code="pnPf" description="PNG export preferences."><element type="event"></element><element type="event listener"></element><property name="anti alias" code="jpAA" type="boolean" description="If true, use anti-aliasing for text and vectors during export."></property><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="export resolution" code="jpeR" type="real" description="The export resolution expressed as a real number instead of an integer. (Range: 1.0 to 2400.0). Can return: fixed (1 - 2400)."></property><property name="Exporting Spread" code="jpXS" type="boolean" description="If true, exports each spread as a single PNG file. If false, exports facing pages as separate files and appends sequential numbers to each file name."></property><property name="object reference" code="posp" type="PNG export preference" access="r" description="An object reference for the object."></property><property name="Page String" code="jpPN" type="text" description="The page(s) to export, specified as a page number or an array of page numbers. Note: Valid when PNG export range is not all."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the PNG export preference (a application)."></property><property name="PNG color space" code="pnCS" type="epCS" description="RGB or Gray"></property><property name="PNG export range" code="pnRA" type="epRA" description="The page range to export."></property><property name="PNG Quality" code="pnPQ" type="epPQ" description="The compression quality."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="simulate overprint" code="RpSO" type="boolean" description="If true, simulates the effects of overprinting spot and process colors in the same way they would occur when printing."></property><property name="transparent background" code="TBkg" type="boolean" description="If true, use a transparent background for the exported PNG."></property><property name="use document bleeds" code="jpBl" type="boolean" description="If true, uses the document's bleed settings in the exported PNG."></property></class><class name="polygon preference" code="plyp" description="Default settings to use when creating a polygon."><element type="event"></element><element type="event listener"></element><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="inset percentage" code="istp" type="integer" description="The star inset percentage for the sides of a polygon. (Range: 0 to 100). Can return: integer (0 - 100)."></property><property name="number of sides" code="nsid" type="integer" description="The number of sides for a polygon. (Range: 3 to 100). Can return: integer (3 - 100)."></property><property name="object reference" code="posp" type="polygon preference" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the polygon preference (a application)."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property></class><class name="preference" code="PObj" description="A preferences object." plural="preferences"><element type="event"></element><element type="event listener"></element><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="object reference" code="posp" type="preference" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="specifier" access="r" description="The parent of the preference (a application, document, image, EPS, WMF, PICT, PDF, book, object style, polygon, graphic line, rectangle, oval, spline item, group, endnote text frame, text frame, xml story, story, button,