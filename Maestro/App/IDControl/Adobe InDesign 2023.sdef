 wrap or contour, specify a single value. For bounding box text wrap, specify 4 values in the format in the format [top, left, bottom, right]. . Can return: number or string, list of numbers or strings or nothing."></property><property name="text wrap side" code="ptws" type="txws" description="Text wrap side options."></property><property name="user modified wrap" code="ptwu" type="boolean" access="r" description="If true, the text wrap path has been explicitly modified by the user."></property></class><class name="transform attribute option" code="LlOp" description="Options for applying layout attributes to any page item."><element type="event"></element><element type="event listener"></element><property name="class" code="pcls" type="type" access="r" description="The class descriptor type."></property><property name="object reference" code="posp" type="transform attribute option" access="r" description="An object reference for the object."></property><property name="parent" code="pare" type="object style" access="r" description="The parent of the transform attribute option (a object style)."></property><property name="properties" code="qpro" type="record" description="A property that allows setting of several properties at the same time."></property><property name="transform attr height" code="pTaH" description="The height of the object, defined by the object style. Can return: number or string (1 - 1440 points)."><type type="number"></type><type type="text"></type></property><property name="transform attr left reference" code="tLRp" type="TprP" description="The reference point to be used while setting the X attribute of object style."></property><property name="transform attr ref anchor point" code="tARa" type="eAnc" description="Option to specify the achor point to be used by the style for anchoring the object while applying the position."></property><property name="transform attr top reference" code="tTrP" type="TprP" description="The reference point to be used